# TappsMCP dev repo — operator-wide secrets + local overrides.
export TAPPS_MCP_MEMORY_BRAIN_HTTP_URL=http://localhost:8080

if [ -f "${HOME}/.tapps-operator.env" ]; then
  set -a
  # shellcheck disable=SC1091
  source "${HOME}/.tapps-operator.env"
  set +a
fi

if [ -f .env ]; then
  set -a
  # shellcheck disable=SC1091
  source .env
  set +a
fi
