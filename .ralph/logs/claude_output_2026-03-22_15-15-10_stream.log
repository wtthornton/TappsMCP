{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015AhHZi6y1Pckh6LWwb6ESb","type":"tool_result","content":"     1→\"\"\"In-memory cache backed by SQLite for the shared memory subsystem.\n     2→\n     3→Provides fast reads from an in-memory dict with write-through to SQLite.\n     4→RAG safety checks on save prevent prompt injection in stored content.\n     5→Auto-consolidation triggers on save when enabled (Epic 58).\n     6→\"\"\"\n     7→\n     8→from __future__ import annotations\n     9→\n    10→import sqlite3\n    11→import threading\n    12→from dataclasses import dataclass\n    13→from typing import TYPE_CHECKING, Any\n    14→\n    15→import structlog\n    16→\n    17→from tapps_brain.models import (\n    18→    MemoryEntry,\n    19→    MemoryScope,\n    20→    MemorySnapshot,\n    21→    MemorySource,\n    22→    MemoryTier,\n    23→    _utc_now_iso,\n    24→)\n    25→from tapps_brain.persistence import MemoryPersistence\n    26→\n    27→if TYPE_CHECKING:\n    28→    from pathlib import Path\n    29→\n    30→    from tapps_brain.embeddings import EmbeddingProvider\n    31→    from tapps_brain.hive import HiveStore\n    32→\n    33→from tapps_brain.metrics import MetricsCollector, MetricsSnapshot, MetricsTimer, StoreHealthReport\n    34→from tapps_brain.relations import RelationEntry, extract_relations\n    35→from tapps_brain.safety import check_content_safety\n    36→\n    37→logger = structlog.get_logger(__name__)\n    38→\n    39→# Maximum number of memories per project.\n    40→_MAX_ENTRIES = 500\n    41→\n    42→# Valid Hive propagation scope values.\n    43→VALID_AGENT_SCOPES: tuple[str, ...] = (\"private\", \"domain\", \"hive\")\n    44→\n    45→# RAG safety match count threshold for blocking content.\n    46→# (moved up for visibility, original kept below for compat)\n    47→\n    48→\n    49→def _validate_write_rules(\n    50→    key: str,\n    51→    value: str,\n    52→    write_rules: Any,  # noqa: ANN401\n    53→) -> str