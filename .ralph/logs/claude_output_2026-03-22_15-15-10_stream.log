{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VmYCduLRQTcYSMYtmWsRr2","type":"tool_result","content":"     1→\"\"\"HMAC-SHA256 integrity hashing for memory entries.\n     2→\n     3→Provides tamper detection for stored memory content. A per-installation\n     4→HMAC key is stored at ``~/.tapps-brain/integrity.key`` and used to sign\n     5→canonical entry data on save. Verification compares the stored hash\n     6→against a freshly computed one.\n     7→\"\"\"\n     8→\n     9→from __future__ import annotations\n    10→\n    11→import hashlib\n    12→import hmac\n    13→import secrets\n    14→from pathlib import Path\n    15→\n    16→import structlog\n    17→\n    18→logger = structlog.get_logger(__name__)\n    19→\n    20→# Default location for the HMAC signing key.\n    21→_DEFAULT_KEY_DIR = Path.home() / \".tapps-brain\"\n    22→_DEFAULT_KEY_PATH = _DEFAULT_KEY_DIR / \"integrity.key\"\n    23→\n    24→# Key length in bytes (256-bit).\n    25→_KEY_LENGTH = 32\n    26→\n    27→\n    28→def _ensure_key(key_path: Path | None = None) -> bytes:\n    29→    \"\"\"Load or generate the HMAC signing key.\n    30→\n    31→    If the key file does not exist, a cryptographically random 32-byte key\n    32→    is generated and persisted. The directory is created with restricted\n    33→    permissions where possible.\n    34→\n    35→    Args:\n    36→        key_path: Override path for the key file. Defaults to\n    37→            ``~/.tapps-brain/integrity.key``.\n    38→\n    39→    Returns:\n    40→        The raw HMAC key bytes.\n    41→    \"\"\"\n    42→    path = key_path or _DEFAULT_KEY_PATH\n    43→\n    44→    if path.exists():\n    45→        raw = path.read_bytes()\n    46→        if len(raw) >= _KEY_LENGTH:\n    47→            return raw[:_KEY_LENGTH]\n    48→        # Key file is too short - regenerate\n    49→        logger.warning(\"integrity_key_too_short\", path=str(path), length=len(raw))\n    50→\n    51→    # Generate a new key\n    52→    path.parent.mkdir(parents=True, exist_ok=True)\n    53→    key = secrets.token_bytes(_KEY_LENGTH)\n    54→    path.write_bytes(key)\n    55→    logger.info(\"integrity_key_generated\", path=str(path))\n    56→    return key\n    57→\n    58→\n    59→# Module-level cache so we only read the key file once per process.\n    60→_cached_key: bytes | None = None\n    61→\n    62→\n    63→def get_signing_key(key_path: Path | None = None) -> bytes:\n    64→    \"\"\"Return the HMAC signing key, loading or generating as needed.\n    65→\n    66→    The key is cached in-process after the first call.\n    67→\n    68→    Args:\n    69→        key_path: Override path for the key file.\n    70→\n    71→    Returns:\n    72→        The raw HMAC key bytes.\n    73→    \"\"\"\n    74→    global _cached_key  # noqa: PLW0603\n    75→    if _cached_key is None:\n    76→        _cached_key = _ensure_key(key_path)\n    77→    return _cached_key\n    78→\n    79→\n    80→def reset_key_cache() -> None:\n    81→    \"\"\"Clear the cached signing key (useful for testing).\"\"\"\n    82→    global _cached_key  # noqa: PLW0603\n    83→    _cached_key = None\n    84→\n    85→\n    86→def compute_integrity_hash(\n    87→    key: str,\n    88→    value: str,\n    89→    tier: str,\n    90→    source: str,\n    91→    *,\n    92→    signing_key: bytes | None = None,\n    93→) -> str:\n    94→    \"\"\"Compute HMAC-SHA256 over the canonical entry fields.\n    95→\n    96→    The canonical form is ``key|value|tier|source`` encoded as UTF-8.\n    97→    The pipe separator is chosen because keys are validated slugs that\n    98→    cannot contain pipes.\n    99→\n   100→    Args:\n   101→        key: Memory entry key.\n   102→        value: Memory entry value.\n   103→        tier: Memory tier string.\n   104→        source: Memory source string.\n   105→        signing_key: Override HMAC key bytes. If ``None``, uses the\n   106→            default key from ``get_signing_key()``.\n   107→\n   108→    Returns:\n   109→        Hex-encoded HMAC-SHA256 digest.\n   110→    \"\"\"\n   111→    hmac_key = signing_key or get_signing_key()\n   112→    canonical = f\"{key}|{value}|{tier}|{source}\".encode(\"utf-8\")\n   113→    return hmac.new(hmac_key, canonical, hashlib.sha256).hexdigest()\n   114→\n   115→\n   116→def verify_integrity_hash(\n   117→    key: str,\n   118→    value: str,\n   119→    tier: str,\n   120→    source: str,\n   121→    stored_hash: str,\n   122→    *,\n   123→    signing_key: bytes | None = None,\n   124→) -> bool:\n   125→    \"\"\"Verify an entry's integrity hash using constant-time comparison.\n   126→\n   127→    Args:\n   128→        key: Memory entry key.\n   129→        value: Memory entry value.\n   130→        tier: Memory tier string.\n   131→        source: Memory source string.\n   132→        stored_hash: The hex-encoded hash to verify against.\n   133→        signing_key: Override HMAC key bytes.\n   134→\n   135→    Returns:\n   136→        ``True`` if the hash matches, ``False`` if tampered or missing.\n   137→    \"\"\"\n   138→    expected = compute_integrity_hash(\n   139→        key, value, tier, source, signing_key=signing_key\n   140→    )\n   141→    return hmac.compare_digest(expected, stored_hash)\n   142→"}]},"parent_tool_use_id":null,"session_id":"9c6cb207-da68-4164-9f58-f8072bc99cd2","uuid":"ce35dc16-9266-4e07-a084-becc2cc7a192","timestamp":"2026-03-22T22:15:27.705Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\cursor\\tapps-brain\\src\\tapps_brain\\integrity.py","content":"\"\"\"HMAC-SHA256 integrity hashing for memory entries.\n\nProvides tamper detection for stored memory content. A per-installation\nHMAC key is stored at ``~/.tapps-brain/integrity.key`` and used to sign\ncanonical entry data on save. Verification compares the stored hash\nagainst a freshly computed one.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport hashlib\nimport hmac\nimport secrets\nfrom pathlib import Path\n\nimport structlog\n\nlogger = structlog.get_logger(__name__)\n\n# Default location for the HMAC signing key.\n_DEFAULT_KEY_DIR = Path.home() / \".tapps-brain\"\n_DEFAULT_KEY_PATH = _DEFAULT_KEY_DIR / \"integrity.key\"\n\n# Key length in bytes (256-bit).\n_KEY_LENGTH = 32\n\n\ndef _ensure_key(key_path: Path | None = None) -> bytes:\n    \"\"\"Load or generate the HMAC signing key.\n\n    If the key file does not exist, a cryptographically random 32-byte key\n    is generated and persisted. The directory is created with restricted\n    permissions where possible.\n\n    Args:\n        key_path: Override path for the key file. Defaults to\n            ``~/.tapps-brain/integrity.key``.\n\n    Returns:\n        The raw HMAC key bytes.\n    \"\"\"\n    path = key_path or _DEFAULT_KEY_PATH\n\n    if path.exists():\n        raw = path.read_bytes()\n        if len(raw) >= _KEY_LENGTH:\n            return raw[:_KEY_LENGTH]\n        # Key file is too short - regenerate\n        logger.warning(\"integrity_key_too_short\", path=str(path), length=len(raw))\n\n    # Generate a new key\n    path.parent.mkdir(parents=True, exist_ok=True)\n    key = secrets.token_bytes(_KEY_LENGTH)\n    path.write_bytes(key)\n    logger.info(\"integrity_key_generated\", path=str(path))\n    return key\n\n\n# Module-level cache so we only read the key file once per process.\n_cached_key: bytes | None = None\n\n\ndef get_signing_key(key_path: Path | None = None) -> bytes:\n    \"\"\"Return the HMAC signing key, loading or generating as needed.\n\n    The key is cached in-process after the first call.\n\n    Args:\n        key_path: Override path for the key file.\n\n    Returns:\n        The raw HMAC key bytes.\n    \"\"\"\n    global _cached_key  # noqa: PLW0603\n    if _cached_key is None:\n        _cached_key = _ensure_key(key_path)\n    return _cached_key\n\n\ndef reset_key_cache() -> None:\n    \"\"\"Clear the cached signing key (useful for testing).\"\"\"\n    global _cached_key  # noqa: PLW0603\n    _cached_key = None\n\n\ndef compute_integrity_hash(\n    key: str,\n    value: str,\n    tier: str,\n    source: str,\n    *,\n    signing_key: bytes | None = None,\n) -> str:\n    \"\"\"Compute HMAC-SHA256 over the canonical entry fields.\n\n    The canonical form is ``key|value|tier|source`` encoded as UTF-8.\n    The pipe separator is chosen because keys are validated slugs that\n    cannot contain pipes.\n\n    Args:\n        key: Memory entry key.\n        value: Memory entry value.\n        tier: Memory tier string.\n        source: Memory source string.\n        signing_key: Override HMAC key bytes. If ``None``, uses the\n            default key from ``get_signing_key()``.\n\n    Returns:\n        Hex-encoded HMAC-SHA256 digest.\n    \"\"\"\n    hmac_key = signing_key or get_signing_key()\n    canonical = f\"{key}|{value}|{tier}|{source}\".encode(\"utf-8\")\n    return hmac.new(hmac_key, canonical, hashlib.sha256).hexdigest()\n\n\ndef verify_integrity_hash(\n    key: str,\n    value: str,\n    tier: str,\n    source: str,\n    stored_hash: str,\n    *,\n    signing_key: bytes | None = None,\n) -> bool:\n    \"\"\"Verify an entry's integrity hash using constant-time comparison.\n\n    Args:\n        key: Memory entry key.\n        value: Memory entry value.\n        tier: Memory tier string.\n        source: Memory source string.\n        stored_hash: The hex-encoded hash to verify against.\n        signing_key: Override HMAC key bytes.\n\n    Returns:\n        ``True`` if the hash matches, ``False`` if tampered or missing.\n    \"\"\"\n    expected = compute_integrity_hash(\n        key, value, tier, source, signing_key=signing_key\n    )\n    return hmac.compare_digest(expected, stored_hash)\n","numLines":142,"startLine":1,"totalLines":142}}}
