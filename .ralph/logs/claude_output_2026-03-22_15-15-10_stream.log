sert result[\"tampered\"] == 1","+        detail = result[\"tampered_details\"][0]","+        assert detail[\"key\"] == \"hash-detail\"","+        assert detail[\"stored_hash\"] == original_hash","+        assert detail[\"expected_hash\"] != original_hash"]}],"originalFile":"\"\"\"Unit tests for MemoryStore.verify_integrity() (H4b).\"\"\"\n\nfrom __future__ import annotations\n\nfrom typing import TYPE_CHECKING\n\nimport pytest\n\nfrom tapps_brain.integrity import compute_integrity_hash, reset_key_cache\nfrom tapps_brain.models import MemoryEntry, MemorySource, MemoryTier\nfrom tapps_brain.store import MemoryStore\n\nif TYPE_CHECKING:\n    from pathlib import Path\n\n\n@pytest.fixture(autouse=True)\ndef _reset_integrity_key() -> None:\n    \"\"\"Reset the cached signing key between tests.\"\"\"\n    reset_key_cache()\n\n\n@pytest.fixture()\ndef store(tmp_path: Path) -> MemoryStore:\n    \"\"\"Create a MemoryStore backed by a temp directory.\"\"\"\n    return MemoryStore(tmp_path)\n\n\n@pytest.fixture()\ndef entry_a() -> MemoryEntry:\n    return MemoryEntry(\n        key=\"entry-a\",\n        value=\"Architecture uses event sourcing\",\n        tier=MemoryTier.architectural,\n        source=MemorySource.human,\n    )\n\n\n@pytest.fixture()\ndef entry_b() -> MemoryEntry:\n    return MemoryEntry(\n        key=\"entry-b\",\n        value=\"Use pytest for all tests\",\n        tier=MemoryTier.pattern,\n        source=MemorySource.agent,\n    )\n\n\nclass TestVerifyIntegrity:\n    \"\"\"Tests for MemoryStore.verify_integrity().\"\"\"\n\n    def test_empty_store_returns_zeroes(self, store: MemoryStore) -> None:\n        result = store.verify_integrity()\n        assert result[\"total\"] == 0\n        assert result[\"valid\"] == 0\n        assert result[\"tampered_count\"] == 0\n        assert result[\"missing_hash_count\"] == 0\n        assert result[\"tampered\"] == []\n        assert result[\"missing_hash\"] == []\n\n    def test_valid_entries_pass(\n        self, store: MemoryStore, entry_a: MemoryEntry, entry_b: MemoryEntry\n    ) -> None:\n        store.save(entry_a.key, entry_a.value, tier=entry_a.tier.value, source=entry_a.source.value)\n        store.save(entry_b.key, entry_b.value, tier=entry_b.tier.value, source=entry_b.source.value)\n        result = store.verify_integrity()\n        assert result[\"total\"] == 2\n        assert result[\"valid\"] == 2\n        assert result[\"tampered_count\"] == 0\n        assert result[\"missing_hash_count\"] == 0\n\n    def test_tampered_value_detected(self, store: MemoryStore, entry_a: MemoryEntry) -> None:\n        store.save(entry_a.key, entry_a.value, tier=entry_a.tier.value, source=entry_a.source.value)\n\n        # Tamper with the value directly in the in-memory cache\n        with store._lock:\n            cached = store._entries[entry_a.key]\n            # Create a modified copy with different value but same hash\n            tampered = cached.model_copy(update={\"value\": \"TAMPERED VALUE\"})\n            store._entries[entry_a.key] = tampered\n\n        result = store.verify_integrity()\n        assert result[\"tampered_count\"] == 1\n        assert result[\"tampered\"][0][\"key\"] == entry_a.key\n        assert result[\"valid\"] == 0\n\n    def test_missing_hash_reported(self, store: MemoryStore) -> None:\n        # Insert an entry without an integrity hash (simulating pre-v8 data)\n        entry = MemoryEntry(\n            key=\"legacy-entry\",\n            value=\"Old entry without hash\",\n            tier=MemoryTier.context,\n            source=MemorySource.agent,\n            integrity_hash=None,\n        )\n        with store._lock:\n            store._entries[entry.key] = entry\n\n        result = store.verify_integrity()\n        assert result[\"total\"] == 1\n        assert result[\"missing_hash_count\"] == 1\n        assert \"legacy-entry\" in result[\"missing_hash\"]\n        assert result[\"valid\"] == 0\n        assert result[\"tampered_count\"] == 0\n\n    def test_mixed_valid_tampered_missing(self, store: MemoryStore) -> None:\n        # Valid entry\n        store.save(\"valid-key\", \"Valid value\", tier=\"pattern\", source=\"agent\")\n\n        # Entry with missing hash\n        no_hash = MemoryEntry(\n            key=\"no-hash-key\",\n            value=\"Missing hash\",\n            tier=MemoryTier.context,\n            source=MemorySource.agent,\n            integrity_hash=None,\n        )\n        with store._lock:\n            store._entries[no_hash.key] = no_hash\n\n        # Tampered entry\n        store.save(\"tamper-key\", \"Original value\", tier=\"pattern\", source=\"agent\")\n        with store._lock:\n            cached = store._entries[\"tamper-key\"]\n            tampered = cached.model_copy(update={\"value\": \"CHANGED\"})\n            store._entries[\"tamper-key\"] = tampered\n\n        result = store.verify_integrity()\n        assert result[\"total\"] == 3\n        assert result[\"valid\"] == 1\n        assert result[\"tampered_count\"] == 1\n        assert result[\"missing_hash_count\"] == 1\n\n    def test_tampered_tier_detected(self, store: MemoryStore) -> None:\n        store.save(\"tier-test\", \"Some value\", tier=\"pattern\", source=\"agent\")\n        with store._lock:\n            cached = store._entries[\"tier-test\"]\n            tampered = cached.model_copy(update={\"tier\": MemoryTier.architectural})\n            store._entries[\"tier-test\"] = tampered\n\n        result = store.verify_integrity()\n        assert result[\"tampered_count\"] == 1\n        assert result[\"tampered\"][0][\"key\"] == \"tier-test\"\n\n    def test_tampered_source_detected(self, store: MemoryStore) -> None:\n        store.save(\"source-test\", \"Some value\", tier=\"pattern\", source=\"agent\")\n        with store._lock:\n            cached = store._entries[\"source-test\"]\n            tampered = cached.model_copy(update={\"source\": MemorySource.human})\n            store._entries[\"source-test\"] = tampered\n\n        result = store.verify_integrity()\n        assert result[\"tampered_count\"] == 1\n\n    def test_tampered_key_detected(self, store: MemoryStore) -> None:\n        store.save(\"original-key\", \"Some value\", tier=\"pattern\", source=\"agent\")\n        with store._lock:\n            cached = store._entries[\"original-key\"]\n            # Copy the entry with a new key but keep the old hash\n            forged = cached.model_copy(update={\"key\": \"forged-key\"})\n            store._entries[\"forged-key\"] = forged\n            del store._entries[\"original-key\"]\n\n        result = store.verify_integrity()\n        assert result[\"tampered_count\"] == 1\n        assert result[\"tampered\"][0][\"key\"] == \"forged-key\"\n"}}
