{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GrbKtdga5Zk41CLhjMkY6z","type":"tool_result","content":"     1→\"\"\"Unit tests for memory persistence layer (Epic 23, Story 2).\"\"\"\n     2→\n     3→from __future__ import annotations\n     4→\n     5→import json\n     6→import sqlite3\n     7→from datetime import UTC, datetime\n     8→from typing import TYPE_CHECKING\n     9→\n    10→import pytest\n    11→\n    12→from tapps_brain.models import (\n    13→    MemoryEntry,\n    14→    MemoryScope,\n    15→    MemorySource,\n    16→    MemoryTier,\n    17→)\n    18→from tapps_brain.persistence import MemoryPersistence\n    19→\n    20→if TYPE_CHECKING:\n    21→    from pathlib import Path\n    22→\n    23→\n    24→@pytest.fixture()\n    25→def persistence(tmp_path: Path) -> MemoryPersistence:\n    26→    \"\"\"Create a MemoryPersistence instance backed by a temp directory.\"\"\"\n    27→    return MemoryPersistence(tmp_path)\n    28→\n    29→\n    30→@pytest.fixture()\n    31→def sample_entry() -> MemoryEntry:\n    32→    \"\"\"Create a sample MemoryEntry for testing.\"\"\"\n    33→    return MemoryEntry(\n    34→        key=\"test-key\",\n    35→        value=\"Test value for persistence\",\n    36→        tier=MemoryTier.pattern,\n    37→        source=MemorySource.agent,\n    38→        tags=[\"python\", \"testing\"],\n    39→    )\n    40→\n    41→\n    42→class TestMemoryPersistence:\n    43→    \"\"\"Tests for MemoryPersistence.\"\"\"\n    44→\n    45→    def test_save_and_get_roundtrip(\n    46→        self, persistence: MemoryPersistence, sample_entry: MemoryEntry\n    47→    ) -> None:\n    48→        persistence.save(sample_entry)\n    49→        loaded = persistence.get(\"test-key\")\n    50→        assert loaded is not None"}]},"parent_tool_use_id":null,"session_id":"9c6cb207-da68-4164-9f58-f8072bc99cd2","uuid":"d51f00a6-07a2-48c9-ab6c-f83da6bd5a80","timestamp":"2026-03-22T22:17:00.342Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\cursor\\tapps-brain\\tests\\unit\\test_memory_persistence.py","content":"\"\"\"Unit tests for memory persistence layer (Epic 23, Story 2).\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport sqlite3\nfrom datetime import UTC, datetime\nfrom typing import TYPE_CHECKING\n\nimport pytest\n\nfrom tapps_brain.models import (\n    MemoryEntry,\n    MemoryScope,\n    MemorySource,\n    MemoryTier,\n)\nfrom tapps_brain.persistence import MemoryPersistence\n\nif TYPE_CHECKING:\n    from pathlib import Path\n\n\n@pytest.fixture()\ndef persistence(tmp_path: Path) -> MemoryPersistence:\n    \"\"\"Create a MemoryPersistence instance backed by a temp directory.\"\"\"\n    return MemoryPersistence(tmp_path)\n\n\n@pytest.fixture()\ndef sample_entry() -> MemoryEntry:\n    \"\"\"Create a sample MemoryEntry for testing.\"\"\"\n    return MemoryEntry(\n        key=\"test-key\",\n        value=\"Test value for persistence\",\n        tier=MemoryTier.pattern,\n        source=MemorySource.agent,\n        tags=[\"python\", \"testing\"],\n    )\n\n\nclass TestMemoryPersistence:\n    \"\"\"Tests for MemoryPersistence.\"\"\"\n\n    def test_save_and_get_roundtrip(\n        self, persistence: MemoryPersistence, sample_entry: MemoryEntry\n    ) -> None:\n        persistence.save(sample_entry)\n        loaded = persistence.get(\"test-key\")\n        assert loaded is not None","numLines":50,"startLine":1,"totalLines":965}}}
