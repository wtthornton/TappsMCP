{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J55L2UaAjvoiAqfsdxVT4H","type":"tool_result","content":"  1575→def _handle_verify_integrity(store: MemoryStore, _p: _Params) -> dict[str, Any]:\n  1576→    \"\"\"Handle the verify_integrity action -- check memory entries for tampering.\n  1577→\n  1578→    Computes SHA-256 hashes of stored entries and compares against stored\n  1579→    hashes when available.  Falls back to a basic consistency check (entry\n  1580→    round-trip) when the tapps-brain version does not expose\n  1581→    ``verify_integrity()``.\n  1582→    \"\"\"\n  1583→    import hashlib\n  1584→\n  1585→    entries = store.list_all()\n  1586→    total = len(entries)\n  1587→    tampered: list[str] = []\n  1588→    verified = 0\n  1589→\n  1590→    for entry in entries:\n  1591→        # Basic integrity: verify value round-trips through the store\n  1592→        fetched = store.get(entry.key)\n  1593→        if fetched is None:\n  1594→            tampered.append(entry.key)\n  1595→            continue\n  1596→\n  1597→        # Compare content hash\n  1598→        expected = hashlib.sha256(\n  1599→            f\"{entry.key}|{entry.value}|{entry.tier}\".encode()\n  1600→        ).hexdigest()[:16]\n  1601→        actual = hashlib.sha256(\n  1602→            f\"{fetched.key}|{fetched.value}|{fetched.tier}\".encode()\n  1603→        ).hexdigest()[:16]\n  1604→\n  1605→        if expected == actual:\n  1606→            verified += 1\n  1607→        else:\n  1608→            tampered.append(entry.key)\n  1609→\n  1610→    return {\n  1611→        \"action\": \"verify_integrity\",\n  1612→        \"total_entries\": total,\n  1613→        \"verified\": verified,\n  1614→        \"tampered\": len(tampered),\n  1615→        \"tampered_keys\": tampered[:20],  # Cap to avoid huge responses\n  1616→        \"store_metadata\": _store_metadata(store),\n  1617→    }\n  1618→\n  1619→\n  1620→# ---------------------------------------------------------------------------\n  1621→# Epic M2: Profile & lifecycle management handlers\n  1622→# ---------------------------------------------------------------------------\n  1623→\n  1624→\n  1625→def _handle_profile_info(store: MemoryStore, _p: _Params) -> dict[str, Any]:\n  1626→    \"\"\"Handle the profile_info action -- show active profile details.\"\"\"\n  1627→    profile = getattr(store, \"profile\", None)\n  1628→    if profile is None:\n  1629→        return {\n  1630→            \"action\": \"profile_info\",\n  1631→            \"active_profile\": \"repo-brain\",\n  1632→            \"source\": \"default\",\n  1633→            \"layers\": [],\n  1634→            \"scoring_weights\": {},\n  1635→            \"promotion_enabled\": False,\n  1636→        }\n  1637→\n  1638→    layers = []\n  1639→    promotion_enabled = False\n  1640→    for layer in profile.layers:\n  1641→        layer_info: dict[str, Any] = {\n  1642→            \"name\": layer.name,\n  1643→            \"description\": getattr(layer, \"description\", \"\"),\n  1644→            \"half_life_days\": layer.half_life_days,"}]},"parent_tool_use_id":null,"session_id":"9c6cb207-da68-4164-9f58-f8072bc99cd2","uuid":"1a1ee996-2b94-40b5-b822-a1716cb0e8b1","timestamp":"2026-03-22T22:19:13.511Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\cursor\\TappMCP\\packages\\tapps-mcp\\src\\tapps_mcp\\server_memory_tools.py","content":"def _handle_verify_integrity(store: MemoryStore, _p: _Params) -> dict[str, Any]:\n    \"\"\"Handle the verify_integrity action -- check memory entries for tampering.\n\n    Computes SHA-256 hashes of stored entries and compares against stored\n    hashes when available.  Falls back to a basic consistency check (entry\n    round-trip) when the tapps-brain version does not expose\n    ``verify_integrity()``.\n    \"\"\"\n    import hashlib\n\n    entries = store.list_all()\n    total = len(entries)\n    tampered: list[str] = []\n    verified = 0\n\n    for entry in entries:\n        # Basic integrity: verify value round-trips through the store\n        fetched = store.get(entry.key)\n        if fetched is None:\n            tampered.append(entry.key)\n            continue\n\n        # Compare content hash\n        expected = hashlib.sha256(\n            f\"{entry.key}|{entry.value}|{entry.tier}\".encode()\n        ).hexdigest()[:16]\n        actual = hashlib.sha256(\n            f\"{fetched.key}|{fetched.value}|{fetched.tier}\".encode()\n        ).hexdigest()[:16]\n\n        if expected == actual:\n            verified += 1\n        else:\n            tampered.append(entry.key)\n\n    return {\n        \"action\": \"verify_integrity\",\n        \"total_entries\": total,\n        \"verified\": verified,\n        \"tampered\": len(tampered),\n        \"tampered_keys\": tampered[:20],  # Cap to avoid huge responses\n        \"store_metadata\": _store_metadata(store),\n    }\n\n\n# ---------------------------------------------------------------------------\n# Epic M2: Profile & lifecycle management handlers\n# ---------------------------------------------------------------------------\n\n\ndef _handle_profile_info(store: MemoryStore, _p: _Params) -> dict[str, Any]:\n    \"\"\"Handle the profile_info action -- show active profile details.\"\"\"\n    profile = getattr(store, \"profile\", None)\n    if profile is None:\n        return {\n            \"action\": \"profile_info\",\n            \"active_profile\": \"repo-brain\",\n            \"source\": \"default\",\n            \"layers\": [],\n            \"scoring_weights\": {},\n            \"promotion_enabled\": False,\n        }\n\n    layers = []\n    promotion_enabled = False\n    for layer in profile.layers:\n        layer_info: dict[str, Any] = {\n            \"name\": layer.name,\n            \"description\": getattr(layer, \"description\", \"\"),\n            \"half_life_days\": layer.half_life_days,","numLines":70,"startLine":1575,"totalLines":2128}}}
