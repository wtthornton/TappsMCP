{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RHHi1RLT8rj3CSeUR8x7oD","type":"tool_result","content":"     1→\"\"\"SQLite-backed persistence layer for the shared memory subsystem.\n     2→\n     3→Uses WAL journal mode for concurrent reads during writes, FTS5 for\n     4→full-text search, and schema versioning with forward migrations.\n     5→A JSONL audit log is maintained for debugging/compliance (append-only).\n     6→\"\"\"\n     7→\n     8→from __future__ import annotations\n     9→\n    10→import json\n    11→import logging\n    12→import sqlite3\n    13→import threading\n    14→from datetime import UTC, datetime\n    15→from typing import TYPE_CHECKING, Any\n    16→\n    17→import structlog\n    18→\n    19→if TYPE_CHECKING:\n    20→    from pathlib import Path\n    21→\n    22→    from tapps_brain.relations import RelationEntry\n    23→\n    24→from tapps_brain.models import MemoryEntry\n    25→\n    26→logger = structlog.get_logger(__name__)\n    27→\n    28→# Current schema version - bump when adding migrations.\n    29→_SCHEMA_VERSION = 8\n    30→\n    31→# Previous schema versions for migration checks.\n    32→_SCHEMA_V2 = 2\n    33→_SCHEMA_V3 = 3\n    34→_SCHEMA_V4 = 4\n    35→_SCHEMA_V5 = 5\n    36→_SCHEMA_V6 = 6\n    37→_SCHEMA_V7 = 7\n    38→_SCHEMA_V8 = 8\n    39→\n    40→# Maximum JSONL audit log lines before truncation.\n    41→_MAX_AUDIT_LINES = 10_000\n    42→\n    43→\n    44→class MemoryPersistence:\n    45→    \"\"\"SQLite-backed persistence for memory entries.\n    46→\n    47→    Storage directory: ``{project_root}/{store_dir}/memory/``\n    48→\n    49→    Default store_dir is ``.tapps-brain`` for standalone use.\n    50→    TappsMCP passes ``.tapps-mcp`` for backward compatibility.\n    51→\n    52→    Files:\n    53→    - ``memory.db`` -- SQLite database (WAL mode, FTS5)\n    54→    - ``memory_log.jsonl`` -- append-only audit log\n    55→    \"\"\"\n    56→\n    57→    def __init__(self, project_root: Path, *, store_dir: str = \".tapps-brain\") -> None:\n    58→        self._store_dir = project_root / store_dir / \"memory\"\n    59→        self._store_dir.mkdir(parents=True, exist_ok=True)\n    60→        self._db_path = self._store_dir / \"memory.db\"\n    61→        self._audit_path = self._store_dir / \"memory_log.jsonl\"\n    62→        self._lock = threading.Lock()\n    63→\n    64→        try:\n    65→            self._conn = self._connect()\n    66→            self._ensure_schema()\n    67→        except sqlite3.DatabaseError as exc:\n    68→            _msg = f\"Database corrupt: {self._db_path}. Back up and delete to recover.\"\n    69→            # Emit via stdlib logging so pytest caplog can capture it in tests\n    70→            logging.getLogger(__name__).error(\"database_corrupt: %s\", _msg, exc_info=exc)\n    71→            logger.error(\n    72→                \"database_corrupt\",\n    73→                path=str(self._db_path),\n    74→                message=_msg,\n    75→            )\n    76→            raise\n    77→\n    78→    # ------------------------------------------------------------------\n    79→    # Connection and schema\n    80→    # ------------------------------------------------------------------\n    81→\n    82→    def _connect(self) -> sqlite3.Connection:\n    83→        \"\"\"Open a SQLite connection with recommended pragmas.\"\"\"\n    84→        conn = sqlite3.connect(\n    85→            str(self._db_path),\n    86→            check_same_thread=False,\n    87→        )\n    88→        conn.row_factory = sqlite3.Row\n    89→        conn.execute(\"PRAGMA journal_mode=WAL\")\n    90→        conn.execute(\"PRAGMA busy_timeout=5000\")\n    91→        conn.execute(\"PRAGMA foreign_keys=ON\")\n    92→        return conn\n    93→\n    94→    def _ensure_schema(self) -> None:\n    95→        \"\"\"Create tables if absent and apply forward migrations.\"\"\"\n    96→        with self._lock:\n    97→            cur = self._conn.cursor()\n    98→\n    99→            # Schema version table\n   100→            cur.execute(\n   101→                \"CREATE TABLE IF NOT EXISTS schema_version \"\n   102→                \"(version INTEGER NOT NULL, migrated_at TEXT NOT NULL)\"\n   103→            )\n   104→\n   105→            # Check current version\n   106→            row = cur.execute(\"SELECT MAX(version) FROM schema_version\").fetchone()\n   107→            current_version: int = row[0] if row[0] is not None else 0\n   108→\n   109→            if current_version < 1:\n   110→                self._create_v1_schema(cur)\n   111→\n   112→            if current_version < _SCHEMA_V2:\n   113→                self._migrate_v1_to_v2(cur)\n   114→            if current_version < _SCHEMA_V3:\n   115→                self._migrate_v2_to_v3(cur)\n   116→            if current_version < _SCHEMA_V4:\n   117→                self._migrate_v3_to_v4(cur)\n   118→            if current_version < _SCHEMA_V5:\n   119→                self._migrate_v4_to_v5(cur)\n   120→            if current_version < _SCHEMA_V6:\n   121→                self._migrate_v5_to_v6(cur)\n   122→            if current_version < _SCHEMA_V7:\n   123→                self._migrate_v6_to_v7(cur)\n   124→            if current_version < _SCHEMA_V8:\n   125→                self._migrate_v7_to_v8(cur)\n   126→\n   127→            self._conn.commit()\n   128→\n   129→    def _create_v1_schema(self, cur: sqlite3.Cursor) -> None:\n   130→        \"\"\"Create the initial v1 schema.\"\"\"\n   131→        # Main memories table\n   132→        cur.execute(\"\"\"\n   133→            CREATE TABLE IF NOT EXISTS memories (\n   134→                key TEXT NOT NULL,\n   135→                value TEXT NOT NULL,\n   136→                tier TEXT NOT NULL DEFAULT 'pattern',\n   137→                confidence REAL NOT NULL DEFAULT 0.6,\n   138→                source TEXT NOT NULL DEFAULT 'agent',\n   139→                source_agent TEXT NOT NULL DEFAULT 'unknown',\n   140→                scope TEXT NOT NULL DEFAULT 'project',\n   141→                tags TEXT NOT NULL DEFAULT '[]',\n   142→                created_at TEXT NOT NULL,\n   143→                updated_at TEXT NOT NULL,\n   144→                last_accessed TEXT NOT NULL,\n   145→                access_count INTEGER NOT NULL DEFAULT 0,\n   146→                branch TEXT,\n   147→                last_reinforced TEXT,\n   148→                reinforce_count INTEGER NOT NULL DEFAULT 0,\n   149→                contradicted INTEGER NOT NULL DEFAULT 0,\n   150→                contradiction_reason TEXT,\n   151→                seeded_from TEXT,\n   152→                PRIMARY KEY (key)\n   153→            )\n   154→        \"\"\")\n   155→\n   156→        # Indexes for common queries\n   157→        cur.execute(\"CREATE INDEX IF NOT EXISTS idx_memories_tier ON memories(tier)\")\n   158→        cur.execute(\"CREATE INDEX IF NOT EXISTS idx_memories_scope ON memories(scope)\")\n   159→        cur.execute(\"CREATE INDEX IF NOT EXISTS idx_memories_confidence ON memories(confidence)\")\n   160→\n   161→        # FTS5 full-text search index\n   162→        cur.execute(\"\"\"\n   163→            CREATE VIRTUAL TABLE IF NOT EXISTS memories_fts\n   164→            USING fts5(key, value, tags, content=memories, content_rowid=rowid)\n   165→        \"\"\")\n   166→\n   167→        # Triggers to keep FTS in sync\n   168→        cur.execute(\"\"\"\n   169→            CREATE TRIGGER IF NOT EXISTS memories_ai AFTER INSERT ON memories BEGIN\n   170→                INSERT INTO memories_fts(rowid, key, value, tags)\n   171→                VALUES (new.rowid, new.key, new.value, new.tags);\n   172→            END\n   173→        \"\"\")\n   174→        cur.execute(\"\"\"\n   175→            CREATE TRIGGER IF NOT EXISTS memories_ad AFTER DELETE ON memories BEGIN\n   176→                INSERT INTO memories_fts(memories_fts, rowid, key, value, tags)\n   177→                VALUES ('delete', old.rowid, old.key, old.value, old.tags);\n   178→            END\n   179→        \"\"\")\n   180→        cur.execute(\"\"\"\n   181→            CREATE TRIGGER IF NOT EXISTS memories_au AFTER UPDATE ON memories BEGIN\n   182→                INSERT INTO memories_fts(memories_fts, rowid, key, value, tags)\n   183→                VALUES ('delete', old.rowid, old.key, old.value, old.tags);\n   184→                INSERT INTO memories_fts(rowid, key, value, tags)\n   185→                VALUES (new.rowid, new.key, new.value, new.tags);\n   186→            END\n   187→        \"\"\")\n   188→\n   189→        # Reserved for Epic 24 GC\n   190→        cur.execute(\"\"\"\n   191→            CREATE TABLE IF NOT EXISTS archived_memories (\n   192→                key TEXT NOT NULL,\n   193→                value TEXT NOT NULL,\n   194→                tier TEXT NOT NULL,\n   195→                confidence REAL NOT NULL,\n   196→                source TEXT NOT NULL,\n   197→                source_agent TEXT NOT NULL,\n   198→                scope TEXT NOT NULL,\n   199→                tags TEXT NOT NULL DEFAULT '[]',\n   200→                created_at TEXT NOT NULL,\n   201→                updated_at TEXT NOT NULL,\n   202→                last_accessed TEXT NOT NULL,\n   203→                access_count INTEGER NOT NULL DEFAULT 0,\n   204→                branch TEXT,\n   205→                last_reinforced TEXT,\n   206→                reinforce_count INTEGER NOT NULL DEFAULT 0,\n   207→                contradicted INTEGER NOT NULL DEFAULT 0,\n   208→                contradiction_reason TEXT,\n   209→                seeded_from TEXT,\n   210→                archived_at TEXT NOT NULL\n   211→            )\n   212→        \"\"\")\n   213→\n   214→        # Record schema version\n   215→        cur.execute(\n   216→            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n   217→            (1, datetime.now(tz=UTC).isoformat()),\n   218→        )\n   219→\n   220→    def _migrate_v1_to_v2(self, cur: sqlite3.Cursor) -> None:\n   221→        \"\"\"Add optional embedding column for semantic search (Epic 65.7).\n   222→\n   223→        Stores JSON array of floats. Existing rows get NULL.\n   224→        \"\"\"\n   225→        try:\n   226→            cur.execute(\"ALTER TABLE memories ADD COLUMN embedding TEXT\")\n   227→        except sqlite3.OperationalError as e:\n   228→            if \"duplicate column name\" in str(e).lower():\n   229→                pass  # Column already exists\n   230→            else:\n   231→                raise\n   232→\n   233→        cur.execute(\n   234→            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n   235→            (2, datetime.now(tz=UTC).isoformat()),\n   236→        )\n   237→\n   238→    def _migrate_v2_to_v3(self, cur: sqlite3.Cursor) -> None:\n   239→        \"\"\"Add session_index table for searchable session chunks (Epic 65.10).\"\"\"\n   240→        cur.execute(\"\"\"\n   241→            CREATE TABLE IF NOT EXISTS session_index (\n   242→                session_id TEXT NOT NULL,\n   243→                chunk_index INTEGER NOT NULL,\n   244→                content TEXT NOT NULL,\n   245→                created_at TEXT NOT NULL,\n   246→                PRIMARY KEY (session_id, chunk_index)\n   247→            )\n   248→        \"\"\")\n   249→        cur.execute(\n   250→            \"CREATE INDEX IF NOT EXISTS idx_session_index_session ON session_index(session_id)\"\n   251→        )\n   252→        cur.execute(\"\"\"\n   253→            CREATE VIRTUAL TABLE IF NOT EXISTS session_index_fts\n   254→            USING fts5(session_id, content, content=session_index, content_rowid=rowid)\n   255→        \"\"\")\n   256→        cur.execute(\"\"\"\n   257→            CREATE TRIGGER IF NOT EXISTS session_index_ai AFTER INSERT ON session_index BEGIN\n   258→                INSERT INTO session_index_fts(rowid, session_id, content)\n   259→                VALUES (new.rowid, new.session_id, new.content);\n   260→            END\n   261→        \"\"\")\n   262→        cur.execute(\"\"\"\n   263→            CREATE TRIGGER IF NOT EXISTS session_index_ad AFTER DELETE ON session_index BEGIN\n   264→                INSERT INTO session_index_fts(session_index_fts, rowid, session_id, content)\n   265→                VALUES ('delete', old.rowid, old.session_id, old.content);\n   266→            END\n   267→        \"\"\")\n   268→        cur.execute(\"\"\"\n   269→            CREATE TRIGGER IF NOT EXISTS session_index_au AFTER UPDATE ON session_index BEGIN\n   270→                INSERT INTO session_index_fts(session_index_fts, rowid, session_id, content)\n   271→                VALUES ('delete', old.rowid, old.session_id, old.content);\n   272→                INSERT INTO session_index_fts(rowid, session_id, content)\n   273→                VALUES (new.rowid, new.session_id, new.content);\n   274→            END\n   275→        \"\"\")\n   276→        cur.execute(\n   277→            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n   278→            (3, datetime.now(tz=UTC).isoformat()),\n   279→        )\n   280→\n   281→    def _migrate_v3_to_v4(self, cur: sqlite3.Cursor) -> None:\n   282→        \"\"\"Add relations table for entity/relationship extraction (Epic 65.12).\"\"\"\n   283→        cur.execute(\"\"\"\n   284→            CREATE TABLE IF NOT EXISTS relations (\n   285→                subject TEXT NOT NULL,\n   286→                predicate TEXT NOT NULL,\n   287→                object_entity TEXT NOT NULL,\n   288→                source_entry_keys TEXT NOT NULL DEFAULT '[]',\n   289→                confidence REAL NOT NULL DEFAULT 0.8,\n   290→                created_at TEXT NOT NULL,\n   291→                PRIMARY KEY (subject, predicate, object_entity)\n   292→            )\n   293→        \"\"\")\n   294→        cur.execute(\"CREATE INDEX IF NOT EXISTS idx_relations_subject ON relations(subject)\")\n   295→        cur.execute(\"CREATE INDEX IF NOT EXISTS idx_relations_object ON relations(object_entity)\")\n   296→        cur.execute(\n   297→            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n   298→            (4, datetime.now(tz=UTC).isoformat()),\n   299→        )\n   300→\n   301→    def _migrate_v4_to_v5(self, cur: sqlite3.Cursor) -> None:\n   302→        \"\"\"Add bi-temporal columns for validity windows (EPIC-004).\n   303→\n   304→        Adds ``valid_at``, ``invalid_at``, ``superseded_by`` to memories\n   305→        and creates an index for temporal queries.\n   306→        \"\"\"\n   307→        for col in (\"valid_at\", \"invalid_at\", \"superseded_by\"):\n   308→            try:\n   309→                cur.execute(f\"ALTER TABLE memories ADD COLUMN {col} TEXT\")\n   310→            except sqlite3.OperationalError as e:\n   311→                if \"duplicate column name\" not in str(e).lower():\n   312→                    raise\n   313→\n   314→        cur.execute(\n   315→            \"CREATE INDEX IF NOT EXISTS idx_memories_temporal ON memories(valid_at, invalid_at)\"\n   316→        )\n   317→\n   318→        cur.execute(\n   319→            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n   320→            (5, datetime.now(tz=UTC).isoformat()),\n   321→        )\n   322→\n   323→    def _migrate_v5_to_v6(self, cur: sqlite3.Cursor) -> None:\n   324→        \"\"\"Schema v6 — observability hooks / version bump (EPIC-007).\n   325→\n   326→        No SQLite shape changes; bumps version so tooling can detect v6 stores.\n   327→        \"\"\"\n   328→        cur.execute(\n   329→            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n   330→            (6, datetime.now(tz=UTC).isoformat()),\n   331→        )\n   332→\n   333→    def _migrate_v6_to_v7(self, cur: sqlite3.Cursor) -> None:\n   334→        \"\"\"Add agent_scope column for Hive propagation (EPIC-011).\n   335→\n   336→        Adds ``agent_scope TEXT DEFAULT 'private'`` to memories table.\n   337→        Existing entries default to ``'private'`` (no Hive propagation).\n   338→        \"\"\"\n   339→        try:\n   340→            cur.execute(\"ALTER TABLE memories ADD COLUMN agent_scope TEXT DEFAULT 'private'\")\n   341→        except sqlite3.OperationalError as e:\n   342→            if \"duplicate column name\" not in str(e).lower():\n   343→                raise\n   344→\n   345→        cur.execute(\n   346→            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n   347→            (7, datetime.now(tz=UTC).isoformat()),\n   348→        )\n   349→\n   350→    def _migrate_v7_to_v8(self, cur: sqlite3.Cursor) -> None:\n   351→        \"\"\"Add integrity_hash column for tamper detection (H4a).\n   352→\n   353→        Stores HMAC-SHA256 hex digest computed over key|value|tier|source.\n   354→        Existing rows get NULL (hash computed on next save/update).\n   355→        \"\"\"\n   356→        try:\n   357→            cur.execute(\"ALTER TABLE memories ADD COLUMN integrity_hash TEXT\")\n   358→        except sqlite3.OperationalError as e:\n   359→            if \"duplicate column name\" not in str(e).lower():\n   360→                raise\n   361→\n   362→        cur.execute(\n   363→            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n   364→            (8, datetime.now(tz=UTC).isoformat()),\n   365→        )\n   366→\n   367→    def migrate_contradicted_to_temporal(self) -> int:\n   368→        \"\"\"Migrate ``contradicted`` entries with \"consolidated into\" to temporal fields.\n   369→\n   370→        For each entry where ``contradicted=1`` and ``contradiction_reason``\n   371→        matches ``consolidated into {key}``, sets ``invalid_at = updated_at``\n   372→        and ``superseded_by = {key}``.\n   373→\n   374→        Returns:\n   375→            Number of entries migrated.\n   376→        \"\"\"\n   377→        import re as _re\n   378→\n   379→        pattern = _re.compile(r\"consolidated into (\\S+)\", _re.IGNORECASE)\n   380→        count = 0\n   381→\n   382→        with self._lock:\n   383→            rows = self._conn.execute(\n   384→                \"SELECT key, updated_at, contradiction_reason, invalid_at \"\n   385→                \"FROM memories WHERE contradicted = 1 AND contradiction_reason IS NOT NULL\"\n   386→            ).fetchall()\n   387→\n   388→            for row in rows:\n   389→                # Skip if already migrated\n   390→                if row[\"invalid_at\"] is not None:\n   391→                    continue\n   392→                reason = row[\"contradiction_reason\"] or \"\"\n   393→                match = pattern.search(reason)\n   394→                if not match:\n   395→                    continue\n   396→                target_key = match.group(1)\n   397→                self._conn.execute(\n   398→                    \"UPDATE memories SET invalid_at = ?, superseded_by = ? WHERE key = ?\",\n   399→                    (row[\"updated_at\"], target_key, row[\"key\"]),\n   400→                )\n   401→                count += 1\n   402→\n   403→            if count > 0:\n   404→                self._conn.commit()\n   405→\n   406→        return count\n   407→\n   408→    # ------------------------------------------------------------------\n   409→    # CRUD operations\n   410→    # ------------------------------------------------------------------\n   411→\n   412→    def save(self, entry: MemoryEntry) -> None:\n   413→        \"\"\"Insert or replace a memory entry.\"\"\"\n   414→        tags_json = json.dumps(entry.tags, ensure_ascii=False)\n   415→        embedding_json: str | None = None\n   416→        if entry.embedding is not None:\n   417→            embedding_json = json.dumps(entry.embedding, ensure_ascii=False)\n   418→\n   419→        columns = [\n   420→            \"key\",\n   421→            \"value\",\n   422→            \"tier\",\n   423→            \"confidence\",\n   424→            \"source\",\n   425→            \"source_agent\",\n   426→            \"scope\",\n   427→            \"tags\",\n   428→            \"created_at\",\n   429→            \"updated_at\",\n   430→            \"last_accessed\",\n   431→            \"access_count\",\n   432→            \"branch\",\n   433→            \"last_reinforced\",\n   434→            \"reinforce_count\",\n   435→            \"contradicted\",\n   436→            \"contradiction_reason\",\n   437→            \"seeded_from\",\n   438→        ]\n   439→        placeholders = \", \".join(\"?\" * len(columns))\n   440→        values: tuple[Any, ...] = (\n   441→            entry.key,\n   442→            entry.value,\n   443→            entry.tier.value if hasattr(entry.tier, \"value\") else str(entry.tier),\n   444→            entry.confidence,\n   445→            entry.source.value,\n   446→            entry.source_agent,\n   447→            entry.scope.value,\n   448→            tags_json,\n   449→            entry.created_at,\n   450→            entry.updated_at,\n   451→            entry.last_accessed,\n   452→            entry.access_count,\n   453→            entry.branch,\n   454→            entry.last_reinforced,\n   455→            entry.reinforce_count,\n   456→            1 if entry.contradicted else 0,\n   457→            entry.contradiction_reason,\n   458→            entry.seeded_from,\n   459→        )\n   460→\n   461→        # Include embedding if schema supports it (v2+)\n   462→        schema_ver = self.get_schema_version()\n   463→        if schema_ver >= _SCHEMA_V4:\n   464→            columns.append(\"embedding\")\n   465→            values = (*values, embedding_json)\n   466→\n   467→        # Include temporal fields if schema supports it (v5+)\n   468→        if schema_ver >= _SCHEMA_V5:\n   469→            columns.extend([\"valid_at\", \"invalid_at\", \"superseded_by\"])\n   470→            values = (*values, entry.valid_at, entry.invalid_at, entry.superseded_by)\n   471→\n   472→        # Include agent_scope if schema supports it (v7+)\n   473→        if schema_ver >= _SCHEMA_V7:\n   474→            columns.append(\"agent_scope\")\n   475→            values = (*values, entry.agent_scope)\n   476→\n   477→        # Compute and include integrity hash if schema supports it (v8+)\n   478→        if schema_ver >= _SCHEMA_V8:\n   479→            from tapps_brain.integrity import compute_integrity_hash\n   480→\n   481→            tier_str = entry.tier.value if hasattr(entry.tier, \"value\") else str(entry.tier)\n   482→            source_str = entry.source.value if hasattr(entry.source, \"value\") else str(entry.source)\n   483→            integrity_hash = compute_integrity_hash(\n   484→                entry.key, entry.value, tier_str, source_str\n   485→            )\n   486→            columns.append(\"integrity_hash\")\n   487→            values = (*values, integrity_hash)\n   488→\n   489→        placeholders = \", \".join(\"?\" * len(columns))\n   490→\n   491→        cols = \", \".join(columns)\n   492→        with self._lock:\n   493→            self._conn.execute(\n   494→                f\"INSERT OR REPLACE INTO memories ({cols}) VALUES ({placeholders})\",\n   495→                values,\n   496→            )\n   497→            self._conn.commit()\n   498→        self._audit_log(\"save\", entry.key)\n   499→\n   500→    def get(self, key: str) -> MemoryEntry | None:\n   501→        \"\"\"Retrieve a single memory entry by key.\"\"\"\n   502→        with self._lock:\n   503→            row = self._conn.execute(\"SELECT * FROM memories WHERE key = ?\", (key,)).fetchone()\n   504→        if row is None:\n   505→            return None\n   506→        return self._row_to_entry(row)\n   507→\n   508→    def list_all(\n   509→        self,\n   510→        tier: str | None = None,\n   511→        scope: str | None = None,\n   512→        tags: list[str] | None = None,\n   513→    ) -> list[MemoryEntry]:\n   514→        \"\"\"List entries with optional filters.\"\"\"\n   515→        query = \"SELECT * FROM memories WHERE 1=1\"\n   516→        params: list[Any] = []\n   517→\n   518→        if tier is not None:\n   519→            query += \" AND tier = ?\"\n   520→            params.append(tier)\n   521→        if scope is not None:\n   522→            query += \" AND scope = ?\"\n   523→            params.append(scope)\n   524→\n   525→        with self._lock:\n   526→            rows = self._conn.execute(query, params).fetchall()\n   527→\n   528→        entries = [self._row_to_entry(r) for r in rows]\n   529→\n   530→        # Filter by tags in Python (tags stored as JSON array)\n   531→        if tags:\n   532→            tag_set = set(tags)\n   533→            entries = [e for e in entries if tag_set.intersection(e.tags)]\n   534→\n   535→        return entries\n   536→\n   537→    def delete(self, key: str) -> bool:\n   538→        \"\"\"Delete a memory entry by key. Returns True if deleted.\"\"\"\n   539→        with self._lock:\n   540→            cur = self._conn.execute(\"DELETE FROM memories WHERE key = ?\", (key,))\n   541→            self._conn.commit()\n   542→        deleted = cur.rowcount > 0\n   543→        if deleted:\n   544→            self._audit_log(\"delete\", key)\n   545→        return deleted\n   546→\n   547→    def search(self, query: str) -> list[MemoryEntry]:\n   548→        \"\"\"Full-text search via FTS5 across key, value, and tags.\"\"\"\n   549→        if not query.strip():\n   550→            return []\n   551→\n   552→        # Escape FTS5 special characters for safety\n   553→        safe_query = self._escape_fts_query(query)\n   554→        if not safe_query:\n   555→            return []\n   556→\n   557→        with self._lock:\n   558→            try:\n   559→                rows = self._conn.execute(\n   560→                    \"\"\"\n   561→                    SELECT m.* FROM memories m\n   562→                    JOIN memories_fts fts ON m.rowid = fts.rowid\n   563→                    WHERE memories_fts MATCH ?\n   564→                    \"\"\",\n   565→                    (safe_query,),\n   566→                ).fetchall()\n   567→            except sqlite3.OperationalError:\n   568→                logger.debug(\"fts_search_failed\", query=query)\n   569→                return []\n   570→\n   571→        return [self._row_to_entry(r) for r in rows]\n   572→\n   573→    def load_all(self) -> list[MemoryEntry]:\n   574→        \"\"\"Load all entries (for cold-start into in-memory cache).\"\"\"\n   575→        with self._lock:\n   576→            rows = self._conn.execute(\"SELECT * FROM memories\").fetchall()\n   577→        return [self._row_to_entry(r) for r in rows]\n   578→\n   579→    def count(self) -> int:\n   580→        \"\"\"Return the total number of memory entries.\"\"\"\n   581→        with self._lock:\n   582→            row = self._conn.execute(\"SELECT COUNT(*) FROM memories\").fetchone()\n   583→        return int(row[0]) if row else 0\n   584→\n   585→    def get_schema_version(self) -> int:\n   586→        \"\"\"Return the current schema version.\"\"\"\n   587→        with self._lock:\n   588→            row = self._conn.execute(\"SELECT MAX(version) FROM schema_version\").fetchone()\n   589→        return int(row[0]) if row and row[0] is not None else 0\n   590→\n   591→    def close(self) -> None:\n   592→        \"\"\"Close the database connection.\"\"\"\n   593→        with self._lock:\n   594→            self._conn.close()\n   595→\n   596→    # ------------------------------------------------------------------\n   597→    # Session index (Epic 65.10)\n   598→    # ------------------------------------------------------------------\n   599→\n   600→    def save_session_chunks(\n   601→        self,\n   602→        session_id: str,\n   603→        chunks: list[str],\n   604→        *,\n   605→        max_chunks: int = 50,\n   606→        max_chars_per_chunk: int = 500,\n   607→    ) -> int:\n   608→        \"\"\"Store session chunks for indexing. Returns count stored.\"\"\"\n   609→        if not chunks or not session_id.strip():\n   610→            return 0\n   611→        now = datetime.now(tz=UTC).isoformat()\n   612→        stored = 0\n   613→        with self._lock:\n   614→            for i, raw in enumerate(chunks[:max_chunks]):\n   615→                content = (raw or \"\")[:max_chars_per_chunk].strip()\n   616→                if not content:\n   617→                    continue\n   618→                try:\n   619→                    self._conn.execute(\n   620→                        \"\"\"\n   621→                        INSERT OR REPLACE INTO session_index\n   622→                        (session_id, chunk_index, content, created_at)\n   623→                        VALUES (?, ?, ?, ?)\n   624→                        \"\"\",\n   625→                        (session_id, i, content, now),\n   626→                    )\n   627→                    stored += 1\n   628→                except sqlite3.IntegrityError:\n   629→                    pass\n   630→            self._conn.commit()\n   631→        return stored\n   632→\n   633→    def search_session_index(self, query: str, limit: int = 10) -> list[dict[str, Any]]:\n   634→        \"\"\"Full-text search session index.\n   635→\n   636→        Returns list of {session_id, chunk_index, content, created_at}.\n   637→        \"\"\"\n   638→        if not query or not query.strip():\n   639→            return []\n   640→        safe = self._escape_fts_query(query)\n   641→        if not safe:\n   642→            return []\n   643→        with self._lock:\n   644→            try:\n   645→                rows = self._conn.execute(\n   646→                    \"\"\"\n   647→                    SELECT s.session_id, s.chunk_index, s.content, s.created_at\n   648→                    FROM session_index s\n   649→                    JOIN session_index_fts fts ON s.rowid = fts.rowid\n   650→                    WHERE session_index_fts MATCH ?\n   651→                    ORDER BY s.created_at DESC\n   652→                    LIMIT ?\n   653→                    \"\"\",\n   654→                    (safe, limit),\n   655→                ).fetchall()\n   656→            except sqlite3.OperationalError:\n   657→                logger.debug(\"session_index_fts_search_failed\", query=query)\n   658→                return []\n   659→        return [\n   660→            {\n   661→                \"session_id\": r[\"session_id\"],\n   662→                \"chunk_index\": r[\"chunk_index\"],\n   663→                \"content\": r[\"content\"],\n   664→                \"created_at\": r[\"created_at\"],\n   665→            }\n   666→            for r in rows\n   667→        ]\n   668→\n   669→    def delete_expired_session_chunks(self, ttl_days: int) -> int:\n   670→        \"\"\"Delete session chunks older than ttl_days. Returns count deleted.\"\"\"\n   671→        from datetime import timedelta\n   672→\n   673→        cutoff = (datetime.now(tz=UTC) - timedelta(days=ttl_days)).isoformat()\n   674→        with self._lock:\n   675→            cur = self._conn.execute(\"DELETE FROM session_index WHERE created_at < ?\", (cutoff,))\n   676→            self._conn.commit()\n   677→            return cur.rowcount\n   678→\n   679→    def count_session_chunks(self) -> int:\n   680→        \"\"\"Return total session index chunk count.\"\"\"\n   681→        with self._lock:\n   682→            row = self._conn.execute(\"SELECT COUNT(*) FROM session_index\").fetchone()\n   683→        return int(row[0]) if row else 0\n   684→\n   685→    # ------------------------------------------------------------------\n   686→    # Relations (Epic 65.12)\n   687→    # ------------------------------------------------------------------\n   688→\n   689→    def save_relation(\n   690→        self,\n   691→        subject: str,\n   692→        predicate: str,\n   693→        object_entity: str,\n   694→        source_entry_keys: list[str],\n   695→        confidence: float = 0.8,\n   696→    ) -> None:\n   697→        \"\"\"Insert or replace a relation triple.\"\"\"\n   698→        keys_json = json.dumps(source_entry_keys, ensure_ascii=False)\n   699→        now = datetime.now(tz=UTC).isoformat()\n   700→        with self._lock:\n   701→            self._conn.execute(\n   702→                \"INSERT OR REPLACE INTO relations \"\n   703→                \"(subject, predicate, object_entity, source_entry_keys, confidence, created_at) \"\n   704→                \"VALUES (?, ?, ?, ?, ?, ?)\",\n   705→                (subject, predicate, object_entity, keys_json, confidence, now),\n   706→            )\n   707→            self._conn.commit()\n   708→\n   709→    def list_relations(self) -> list[dict[str, Any]]:\n   710→        \"\"\"Return all stored relations as dicts.\"\"\"\n   711→        with self._lock:\n   712→            rows = self._conn.execute(\"SELECT * FROM relations\").fetchall()\n   713→        results: list[dict[str, Any]] = []\n   714→        for r in rows:\n   715→            try:\n   716→                keys = json.loads(r[\"source_entry_keys\"])\n   717→            except (json.JSONDecodeError, TypeError):\n   718→                keys = []\n   719→            results.append(\n   720→                {\n   721→                    \"subject\": r[\"subject\"],\n   722→                    \"predicate\": r[\"predicate\"],\n   723→                    \"object_entity\": r[\"object_entity\"],\n   724→                    \"source_entry_keys\": keys,\n   725→                    \"confidence\": r[\"confidence\"],\n   726→                    \"created_at\": r[\"created_at\"],\n   727→                }\n   728→            )\n   729→        return results\n   730→\n   731→    def count_relations(self) -> int:\n   732→        \"\"\"Return the total number of stored relations.\"\"\"\n   733→        with self._lock:\n   734→            row = self._conn.execute(\"SELECT COUNT(*) FROM relations\").fetchone()\n   735→        return int(row[0]) if row else 0\n   736→\n   737→    def save_relations(self, key: str, relations: list[RelationEntry]) -> int:\n   738→        \"\"\"Batch-save relations linked to a memory entry key.\n   739→\n   740→        Each relation's ``source_entry_keys`` is ensured to contain *key*.\n   741→        Existing triples are updated (INSERT OR REPLACE).\n   742→\n   743→        Returns:\n   744→            Number of relations saved.\n   745→        \"\"\"\n   746→        if not relations:\n   747→            return 0\n   748→        now = datetime.now(tz=UTC).isoformat()\n   749→        count = 0\n   750→        with self._lock:\n   751→            for rel in relations:\n   752→                source_keys = list(dict.fromkeys([*rel.source_entry_keys, key]))\n   753→                keys_json = json.dumps(source_keys, ensure_ascii=False)\n   754→                self._conn.execute(\n   755→                    \"INSERT OR REPLACE INTO relations \"\n   756→                    \"(subject, predicate, object_entity, source_entry_keys, \"\n   757→                    \"confidence, created_at) VALUES (?, ?, ?, ?, ?, ?)\",\n   758→                    (\n   759→                        rel.subject,\n   760→                        rel.predicate,\n   761→                        rel.object_entity,\n   762→                        keys_json,\n   763→                        rel.confidence,\n   764→                        now,\n   765→                    ),\n   766→                )\n   767→                count += 1\n   768→            self._conn.commit()\n   769→        return count\n   770→\n   771→    def load_relations(self, key: str) -> list[dict[str, Any]]:\n   772→        \"\"\"Load all relations whose ``source_entry_keys`` contains *key*.\"\"\"\n   773→        all_relations = self.list_relations()\n   774→        return [r for r in all_relations if key in r[\"source_entry_keys\"]]\n   775→\n   776→    def delete_relations(self, key: str) -> int:\n   777→        \"\"\"Delete all relations whose ``source_entry_keys`` contains *key*.\n   778→\n   779→        Returns:\n   780→            Number of relations deleted.\n   781→        \"\"\"\n   782→        with self._lock:\n   783→            rows = self._conn.execute(\"SELECT * FROM relations\").fetchall()\n   784→            count = 0\n   785→            for r in rows:\n   786→                try:\n   787→                    keys = json.loads(r[\"source_entry_keys\"])\n   788→                except (json.JSONDecodeError, TypeError):\n   789→                    keys = []\n   790→                if key in keys:\n   791→                    self._conn.execute(\n   792→                        \"DELETE FROM relations \"\n   793→                        \"WHERE subject = ? AND predicate = ? AND object_entity = ?\",\n   794→                        (r[\"subject\"], r[\"predicate\"], r[\"object_entity\"]),\n   795→                    )\n   796→                    count += 1\n   797→            if count > 0:\n   798→                self._conn.commit()\n   799→        return count\n   800→\n   801→    # ------------------------------------------------------------------\n   802→    # Private helpers\n   803→    # ------------------------------------------------------------------\n   804→\n   805→    @staticmethod\n   806→    def _row_to_entry(row: sqlite3.Row) -> MemoryEntry:\n   807→        \"\"\"Convert a SQLite Row to a MemoryEntry.\"\"\"\n   808→        tags_raw = row[\"tags\"]\n   809→        try:\n   810→            tags = json.loads(tags_raw) if tags_raw else []\n   811→        except (json.JSONDecodeError, TypeError):\n   812→            tags = []\n   813→\n   814→        embedding: list[float] | None = None\n   815→        try:\n   816→            emb_raw = row[\"embedding\"]\n   817→        except (KeyError, IndexError):\n   818→            emb_raw = None\n   819→        if emb_raw:\n   820→            try:\n   821→                parsed = json.loads(str(emb_raw))\n   822→                if isinstance(parsed, list) and all(isinstance(x, (int, float)) for x in parsed):\n   823→                    embedding = [float(x) for x in parsed]\n   824→            except (json.JSONDecodeError, TypeError):\n   825→                pass\n   826→\n   827→        # Read temporal fields (v5+), gracefully handle missing columns\n   828→        valid_at: str | None = None\n   829→        invalid_at: str | None = None\n   830→        superseded_by: str | None = None\n   831→        try:\n   832→            valid_at = row[\"valid_at\"]\n   833→            invalid_at = row[\"invalid_at\"]\n   834→            superseded_by = row[\"superseded_by\"]\n   835→        except (KeyError, IndexError):\n   836→            pass\n   837→\n   838→        # Read agent_scope (v7+), gracefully handle missing column\n   839→        agent_scope: str = \"private\"\n   840→        try:\n   841→            val = row[\"agent_scope\"]\n   842→            if val is not None:\n   843→                agent_scope = val\n   844→        except (KeyError, IndexError):\n   845→            pass\n   846→\n   847→        # Read integrity_hash (v8+), gracefully handle missing column\n   848→        integrity_hash: str | None = None\n   849→        try:\n   850→            integrity_hash = row[\"integrity_hash\"]\n   851→        except (KeyError, IndexError):\n   852→            pass\n   853→\n   854→        return MemoryEntry(\n   855→            key=row[\"key\"],\n   856→            value=row[\"value\"],\n   857→            tier=row[\"tier\"],\n   858→            confidence=row[\"confidence\"],\n   859→            source=row[\"source\"],\n   860→            source_agent=row[\"source_agent\"],\n   861→            scope=row[\"scope\"],\n   862→            tags=tags,\n   863→            created_at=row[\"created_at\"],\n   864→            updated_at=row[\"updated_at\"],\n   865→            last_accessed=row[\"last_accessed\"],\n   866→            access_count=row[\"access_count\"],\n   867→            branch=row[\"branch\"],\n   868→            last_reinforced=row[\"last_reinforced\"],\n   869→            reinforce_count=row[\"reinforce_count\"],\n   870→            contradicted=bool(row[\"contradicted\"]),\n   871→            contradiction_reason=row[\"contradiction_reason\"],\n   872→            seeded_from=row[\"seeded_from\"],\n   873→            embedding=embedding,\n   874→            valid_at=valid_at,\n   875→            invalid_at=invalid_at,\n   876→            superseded_by=superseded_by,\n   877→            agent_scope=agent_scope,\n   878→            integrity_hash=integrity_hash,\n   879→        )\n   880→\n   881→    @staticmethod\n   882→    def _escape_fts_query(query: str) -> str:\n   883→        \"\"\"Escape an FTS5 query string for safe matching.\n   884→\n   885→        Wraps each token in double quotes to treat them as literals.\n   886→        \"\"\"\n   887→        tokens = query.strip().split()\n   888→        if not tokens:\n   889→            return \"\"\n   890→        return \" \".join(f'\"{t}\"' for t in tokens)\n   891→\n   892→    def append_audit(\n   893→        self,\n   894→        action: str,\n   895→        key: str,\n   896→        extra: dict[str, Any] | None = None,\n   897→    ) -> None:\n   898→        \"\"\"Append an entry to the JSONL audit log with optional extra fields (EPIC-010).\"\"\"\n   899→        record: dict[str, Any] = {\n   900→            \"action\": action,\n   901→            \"key\": key,\n   902→            \"timestamp\": datetime.now(tz=UTC).isoformat(),\n   903→        }\n   904→        if extra:\n   905→            record.update(extra)\n   906→        try:\n   907→            with self._audit_path.open(\"a\", encoding=\"utf-8\") as fh:\n   908→                fh.write(json.dumps(record, ensure_ascii=False) + \"\\n\")\n   909→            self._maybe_truncate_audit()\n   910→        except OSError:\n   911→            logger.debug(\"audit_log_write_failed\", key=key, action=action)\n   912→\n   913→    def _audit_log(self, action: str, key: str) -> None:\n   914→        \"\"\"Append an entry to the JSONL audit log.\"\"\"\n   915→        record = {\n   916→            \"action\": action,\n   917→            \"key\": key,\n   918→            \"timestamp\": datetime.now(tz=UTC).isoformat(),\n   919→        }\n   920→        try:\n   921→            with self._audit_path.open(\"a\", encoding=\"utf-8\") as fh:\n   922→                fh.write(json.dumps(record, ensure_ascii=False) + \"\\n\")\n   923→            self._maybe_truncate_audit()\n   924→        except OSError:\n   925→            logger.debug(\"audit_log_write_failed\", key=key, action=action)\n   926→\n   927→    def _maybe_truncate_audit(self) -> None:\n   928→        \"\"\"Truncate audit log if it exceeds the max line count.\"\"\"\n   929→        try:\n   930→            lines = self._audit_path.read_text(encoding=\"utf-8\").splitlines()\n   931→            if len(lines) > _MAX_AUDIT_LINES:\n   932→                # Keep the most recent entries\n   933→                keep = lines[-_MAX_AUDIT_LINES:]\n   934→                self._audit_path.write_text(\"\\n\".join(keep) + \"\\n\", encoding=\"utf-8\")\n   935→        except OSError:\n   936→            pass\n   937→"}]},"parent_tool_use_id":null,"session_id":"9c6cb207-da68-4164-9f58-f8072bc99cd2","uuid":"129d757b-39a7-40f7-8770-580d0944dcfe","timestamp":"2026-03-22T22:15:28.408Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\cursor\\tapps-brain\\src\\tapps_brain\\persistence.py","content":"\"\"\"SQLite-backed persistence layer for the shared memory subsystem.\n\nUses WAL journal mode for concurrent reads during writes, FTS5 for\nfull-text search, and schema versioning with forward migrations.\nA JSONL audit log is maintained for debugging/compliance (append-only).\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport logging\nimport sqlite3\nimport threading\nfrom datetime import UTC, datetime\nfrom typing import TYPE_CHECKING, Any\n\nimport structlog\n\nif TYPE_CHECKING:\n    from pathlib import Path\n\n    from tapps_brain.relations import RelationEntry\n\nfrom tapps_brain.models import MemoryEntry\n\nlogger = structlog.get_logger(__name__)\n\n# Current schema version - bump when adding migrations.\n_SCHEMA_VERSION = 8\n\n# Previous schema versions for migration checks.\n_SCHEMA_V2 = 2\n_SCHEMA_V3 = 3\n_SCHEMA_V4 = 4\n_SCHEMA_V5 = 5\n_SCHEMA_V6 = 6\n_SCHEMA_V7 = 7\n_SCHEMA_V8 = 8\n\n# Maximum JSONL audit log lines before truncation.\n_MAX_AUDIT_LINES = 10_000\n\n\nclass MemoryPersistence:\n    \"\"\"SQLite-backed persistence for memory entries.\n\n    Storage directory: ``{project_root}/{store_dir}/memory/``\n\n    Default store_dir is ``.tapps-brain`` for standalone use.\n    TappsMCP passes ``.tapps-mcp`` for backward compatibility.\n\n    Files:\n    - ``memory.db`` -- SQLite database (WAL mode, FTS5)\n    - ``memory_log.jsonl`` -- append-only audit log\n    \"\"\"\n\n    def __init__(self, project_root: Path, *, store_dir: str = \".tapps-brain\") -> None:\n        self._store_dir = project_root / store_dir / \"memory\"\n        self._store_dir.mkdir(parents=True, exist_ok=True)\n        self._db_path = self._store_dir / \"memory.db\"\n        self._audit_path = self._store_dir / \"memory_log.jsonl\"\n        self._lock = threading.Lock()\n\n        try:\n            self._conn = self._connect()\n            self._ensure_schema()\n        except sqlite3.DatabaseError as exc:\n            _msg = f\"Database corrupt: {self._db_path}. Back up and delete to recover.\"\n            # Emit via stdlib logging so pytest caplog can capture it in tests\n            logging.getLogger(__name__).error(\"database_corrupt: %s\", _msg, exc_info=exc)\n            logger.error(\n                \"database_corrupt\",\n                path=str(self._db_path),\n                message=_msg,\n            )\n            raise\n\n    # ------------------------------------------------------------------\n    # Connection and schema\n    # ------------------------------------------------------------------\n\n    def _connect(self) -> sqlite3.Connection:\n        \"\"\"Open a SQLite connection with recommended pragmas.\"\"\"\n        conn = sqlite3.connect(\n            str(self._db_path),\n            check_same_thread=False,\n        )\n        conn.row_factory = sqlite3.Row\n        conn.execute(\"PRAGMA journal_mode=WAL\")\n        conn.execute(\"PRAGMA busy_timeout=5000\")\n        conn.execute(\"PRAGMA foreign_keys=ON\")\n        return conn\n\n    def _ensure_schema(self) -> None:\n        \"\"\"Create tables if absent and apply forward migrations.\"\"\"\n        with self._lock:\n            cur = self._conn.cursor()\n\n            # Schema version table\n            cur.execute(\n                \"CREATE TABLE IF NOT EXISTS schema_version \"\n                \"(version INTEGER NOT NULL, migrated_at TEXT NOT NULL)\"\n            )\n\n            # Check current version\n            row = cur.execute(\"SELECT MAX(version) FROM schema_version\").fetchone()\n            current_version: int = row[0] if row[0] is not None else 0\n\n            if current_version < 1:\n                self._create_v1_schema(cur)\n\n            if current_version < _SCHEMA_V2:\n                self._migrate_v1_to_v2(cur)\n            if current_version < _SCHEMA_V3:\n                self._migrate_v2_to_v3(cur)\n            if current_version < _SCHEMA_V4:\n                self._migrate_v3_to_v4(cur)\n            if current_version < _SCHEMA_V5:\n                self._migrate_v4_to_v5(cur)\n            if current_version < _SCHEMA_V6:\n                self._migrate_v5_to_v6(cur)\n            if current_version < _SCHEMA_V7:\n                self._migrate_v6_to_v7(cur)\n            if current_version < _SCHEMA_V8:\n                self._migrate_v7_to_v8(cur)\n\n            self._conn.commit()\n\n    def _create_v1_schema(self, cur: sqlite3.Cursor) -> None:\n        \"\"\"Create the initial v1 schema.\"\"\"\n        # Main memories table\n        cur.execute(\"\"\"\n            CREATE TABLE IF NOT EXISTS memories (\n                key TEXT NOT NULL,\n                value TEXT NOT NULL,\n                tier TEXT NOT NULL DEFAULT 'pattern',\n                confidence REAL NOT NULL DEFAULT 0.6,\n                source TEXT NOT NULL DEFAULT 'agent',\n                source_agent TEXT NOT NULL DEFAULT 'unknown',\n                scope TEXT NOT NULL DEFAULT 'project',\n                tags TEXT NOT NULL DEFAULT '[]',\n                created_at TEXT NOT NULL,\n                updated_at TEXT NOT NULL,\n                last_accessed TEXT NOT NULL,\n                access_count INTEGER NOT NULL DEFAULT 0,\n                branch TEXT,\n                last_reinforced TEXT,\n                reinforce_count INTEGER NOT NULL DEFAULT 0,\n                contradicted INTEGER NOT NULL DEFAULT 0,\n                contradiction_reason TEXT,\n                seeded_from TEXT,\n                PRIMARY KEY (key)\n            )\n        \"\"\")\n\n        # Indexes for common queries\n        cur.execute(\"CREATE INDEX IF NOT EXISTS idx_memories_tier ON memories(tier)\")\n        cur.execute(\"CREATE INDEX IF NOT EXISTS idx_memories_scope ON memories(scope)\")\n        cur.execute(\"CREATE INDEX IF NOT EXISTS idx_memories_confidence ON memories(confidence)\")\n\n        # FTS5 full-text search index\n        cur.execute(\"\"\"\n            CREATE VIRTUAL TABLE IF NOT EXISTS memories_fts\n            USING fts5(key, value, tags, content=memories, content_rowid=rowid)\n        \"\"\")\n\n        # Triggers to keep FTS in sync\n        cur.execute(\"\"\"\n            CREATE TRIGGER IF NOT EXISTS memories_ai AFTER INSERT ON memories BEGIN\n                INSERT INTO memories_fts(rowid, key, value, tags)\n                VALUES (new.rowid, new.key, new.value, new.tags);\n            END\n        \"\"\")\n        cur.execute(\"\"\"\n            CREATE TRIGGER IF NOT EXISTS memories_ad AFTER DELETE ON memories BEGIN\n                INSERT INTO memories_fts(memories_fts, rowid, key, value, tags)\n                VALUES ('delete', old.rowid, old.key, old.value, old.tags);\n            END\n        \"\"\")\n        cur.execute(\"\"\"\n            CREATE TRIGGER IF NOT EXISTS memories_au AFTER UPDATE ON memories BEGIN\n                INSERT INTO memories_fts(memories_fts, rowid, key, value, tags)\n                VALUES ('delete', old.rowid, old.key, old.value, old.tags);\n                INSERT INTO memories_fts(rowid, key, value, tags)\n                VALUES (new.rowid, new.key, new.value, new.tags);\n            END\n        \"\"\")\n\n        # Reserved for Epic 24 GC\n        cur.execute(\"\"\"\n            CREATE TABLE IF NOT EXISTS archived_memories (\n                key TEXT NOT NULL,\n                value TEXT NOT NULL,\n                tier TEXT NOT NULL,\n                confidence REAL NOT NULL,\n                source TEXT NOT NULL,\n                source_agent TEXT NOT NULL,\n                scope TEXT NOT NULL,\n                tags TEXT NOT NULL DEFAULT '[]',\n                created_at TEXT NOT NULL,\n                updated_at TEXT NOT NULL,\n                last_accessed TEXT NOT NULL,\n                access_count INTEGER NOT NULL DEFAULT 0,\n                branch TEXT,\n                last_reinforced TEXT,\n                reinforce_count INTEGER NOT NULL DEFAULT 0,\n                contradicted INTEGER NOT NULL DEFAULT 0,\n                contradiction_reason TEXT,\n                seeded_from TEXT,\n                archived_at TEXT NOT NULL\n            )\n        \"\"\")\n\n        # Record schema version\n        cur.execute(\n            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n            (1, datetime.now(tz=UTC).isoformat()),\n        )\n\n    def _migrate_v1_to_v2(self, cur: sqlite3.Cursor) -> None:\n        \"\"\"Add optional embedding column for semantic search (Epic 65.7).\n\n        Stores JSON array of floats. Existing rows get NULL.\n        \"\"\"\n        try:\n            cur.execute(\"ALTER TABLE memories ADD COLUMN embedding TEXT\")\n        except sqlite3.OperationalError as e:\n            if \"duplicate column name\" in str(e).lower():\n                pass  # Column already exists\n            else:\n                raise\n\n        cur.execute(\n            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n            (2, datetime.now(tz=UTC).isoformat()),\n        )\n\n    def _migrate_v2_to_v3(self, cur: sqlite3.Cursor) -> None:\n        \"\"\"Add session_index table for searchable session chunks (Epic 65.10).\"\"\"\n        cur.execute(\"\"\"\n            CREATE TABLE IF NOT EXISTS session_index (\n                session_id TEXT NOT NULL,\n                chunk_index INTEGER NOT NULL,\n                content TEXT NOT NULL,\n                created_at TEXT NOT NULL,\n                PRIMARY KEY (session_id, chunk_index)\n            )\n        \"\"\")\n        cur.execute(\n            \"CREATE INDEX IF NOT EXISTS idx_session_index_session ON session_index(session_id)\"\n        )\n        cur.execute(\"\"\"\n            CREATE VIRTUAL TABLE IF NOT EXISTS session_index_fts\n            USING fts5(session_id, content, content=session_index, content_rowid=rowid)\n        \"\"\")\n        cur.execute(\"\"\"\n            CREATE TRIGGER IF NOT EXISTS session_index_ai AFTER INSERT ON session_index BEGIN\n                INSERT INTO session_index_fts(rowid, session_id, content)\n                VALUES (new.rowid, new.session_id, new.content);\n            END\n        \"\"\")\n        cur.execute(\"\"\"\n            CREATE TRIGGER IF NOT EXISTS session_index_ad AFTER DELETE ON session_index BEGIN\n                INSERT INTO session_index_fts(session_index_fts, rowid, session_id, content)\n                VALUES ('delete', old.rowid, old.session_id, old.content);\n            END\n        \"\"\")\n        cur.execute(\"\"\"\n            CREATE TRIGGER IF NOT EXISTS session_index_au AFTER UPDATE ON session_index BEGIN\n                INSERT INTO session_index_fts(session_index_fts, rowid, session_id, content)\n                VALUES ('delete', old.rowid, old.session_id, old.content);\n                INSERT INTO session_index_fts(rowid, session_id, content)\n                VALUES (new.rowid, new.session_id, new.content);\n            END\n        \"\"\")\n        cur.execute(\n            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n            (3, datetime.now(tz=UTC).isoformat()),\n        )\n\n    def _migrate_v3_to_v4(self, cur: sqlite3.Cursor) -> None:\n        \"\"\"Add relations table for entity/relationship extraction (Epic 65.12).\"\"\"\n        cur.execute(\"\"\"\n            CREATE TABLE IF NOT EXISTS relations (\n                subject TEXT NOT NULL,\n                predicate TEXT NOT NULL,\n                object_entity TEXT NOT NULL,\n                source_entry_keys TEXT NOT NULL DEFAULT '[]',\n                confidence REAL NOT NULL DEFAULT 0.8,\n                created_at TEXT NOT NULL,\n                PRIMARY KEY (subject, predicate, object_entity)\n            )\n        \"\"\")\n        cur.execute(\"CREATE INDEX IF NOT EXISTS idx_relations_subject ON relations(subject)\")\n        cur.execute(\"CREATE INDEX IF NOT EXISTS idx_relations_object ON relations(object_entity)\")\n        cur.execute(\n            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n            (4, datetime.now(tz=UTC).isoformat()),\n        )\n\n    def _migrate_v4_to_v5(self, cur: sqlite3.Cursor) -> None:\n        \"\"\"Add bi-temporal columns for validity windows (EPIC-004).\n\n        Adds ``valid_at``, ``invalid_at``, ``superseded_by`` to memories\n        and creates an index for temporal queries.\n        \"\"\"\n        for col in (\"valid_at\", \"invalid_at\", \"superseded_by\"):\n            try:\n                cur.execute(f\"ALTER TABLE memories ADD COLUMN {col} TEXT\")\n            except sqlite3.OperationalError as e:\n                if \"duplicate column name\" not in str(e).lower():\n                    raise\n\n        cur.execute(\n            \"CREATE INDEX IF NOT EXISTS idx_memories_temporal ON memories(valid_at, invalid_at)\"\n        )\n\n        cur.execute(\n            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n            (5, datetime.now(tz=UTC).isoformat()),\n        )\n\n    def _migrate_v5_to_v6(self, cur: sqlite3.Cursor) -> None:\n        \"\"\"Schema v6 — observability hooks / version bump (EPIC-007).\n\n        No SQLite shape changes; bumps version so tooling can detect v6 stores.\n        \"\"\"\n        cur.execute(\n            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n            (6, datetime.now(tz=UTC).isoformat()),\n        )\n\n    def _migrate_v6_to_v7(self, cur: sqlite3.Cursor) -> None:\n        \"\"\"Add agent_scope column for Hive propagation (EPIC-011).\n\n        Adds ``agent_scope TEXT DEFAULT 'private'`` to memories table.\n        Existing entries default to ``'private'`` (no Hive propagation).\n        \"\"\"\n        try:\n            cur.execute(\"ALTER TABLE memories ADD COLUMN agent_scope TEXT DEFAULT 'private'\")\n        except sqlite3.OperationalError as e:\n            if \"duplicate column name\" not in str(e).lower():\n                raise\n\n        cur.execute(\n            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n            (7, datetime.now(tz=UTC).isoformat()),\n        )\n\n    def _migrate_v7_to_v8(self, cur: sqlite3.Cursor) -> None:\n        \"\"\"Add integrity_hash column for tamper detection (H4a).\n\n        Stores HMAC-SHA256 hex digest computed over key|value|tier|source.\n        Existing rows get NULL (hash computed on next save/update).\n        \"\"\"\n        try:\n            cur.execute(\"ALTER TABLE memories ADD COLUMN integrity_hash TEXT\")\n        except sqlite3.OperationalError as e:\n            if \"duplicate column name\" not in str(e).lower():\n                raise\n\n        cur.execute(\n            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n            (8, datetime.now(tz=UTC).isoformat()),\n        )\n\n    def migrate_contradicted_to_temporal(self) -> int:\n        \"\"\"Migrate ``contradicted`` entries with \"consolidated into\" to temporal fields.\n\n        For each entry where ``contradicted=1`` and ``contradiction_reason``\n        matches ``consolidated into {key}``, sets ``invalid_at = updated_at``\n        and ``superseded_by = {key}``.\n\n        Returns:\n            Number of entries migrated.\n        \"\"\"\n        import re as _re\n\n        pattern = _re.compile(r\"consolidated into (\\S+)\", _re.IGNORECASE)\n        count = 0\n\n        with self._lock:\n            rows = self._conn.execute(\n                \"SELECT key, updated_at, contradiction_reason, invalid_at \"\n                \"FROM memories WHERE contradicted = 1 AND contradiction_reason IS NOT NULL\"\n            ).fetchall()\n\n            for row in rows:\n                # Skip if already migrated\n                if row[\"invalid_at\"] is not None:\n                    continue\n                reason = row[\"contradiction_reason\"] or \"\"\n                match = pattern.search(reason)\n                if not match:\n                    continue\n                target_key = match.group(1)\n                self._conn.execute(\n                    \"UPDATE memories SET invalid_at = ?, superseded_by = ? WHERE key = ?\",\n                    (row[\"updated_at\"], target_key, row[\"key\"]),\n                )\n                count += 1\n\n            if count > 0:\n                self._conn.commit()\n\n        return count\n\n    # ------------------------------------------------------------------\n    # CRUD operations\n    # ------------------------------------------------------------------\n\n    def save(self, entry: MemoryEntry) -> None:\n        \"\"\"Insert or replace a memory entry.\"\"\"\n        tags_json = json.dumps(entry.tags, ensure_ascii=False)\n        embedding_json: str | None = None\n        if entry.embedding is not None:\n            embedding_json = json.dumps(entry.embedding, ensure_ascii=False)\n\n        columns = [\n            \"key\",\n            \"value\",\n            \"tier\",\n            \"confidence\",\n            \"source\",\n            \"source_agent\",\n            \"scope\",\n            \"tags\",\n            \"created_at\",\n            \"updated_at\",\n            \"last_accessed\",\n            \"access_count\",\n            \"branch\",\n            \"last_reinforced\",\n            \"reinforce_count\",\n            \"contradicted\",\n            \"contradiction_reason\",\n            \"seeded_from\",\n        ]\n        placeholders = \", \".join(\"?\" * len(columns))\n        values: tuple[Any, ...] = (\n            entry.key,\n            entry.value,\n            entry.tier.value if hasattr(entry.tier, \"value\") else str(entry.tier),\n            entry.confidence,\n            entry.source.value,\n            entry.source_agent,\n            entry.scope.value,\n            tags_json,\n            entry.created_at,\n            entry.updated_at,\n            entry.last_accessed,\n            entry.access_count,\n            entry.branch,\n            entry.last_reinforced,\n            entry.reinforce_count,\n            1 if entry.contradicted else 0,\n            entry.contradiction_reason,\n            entry.seeded_from,\n        )\n\n        # Include embedding if schema supports it (v2+)\n        schema_ver = self.get_schema_version()\n        if schema_ver >= _SCHEMA_V4:\n            columns.append(\"embedding\")\n            values = (*values, embedding_json)\n\n        # Include temporal fields if schema supports it (v5+)\n        if schema_ver >= _SCHEMA_V5:\n            columns.extend([\"valid_at\", \"invalid_at\", \"superseded_by\"])\n            values = (*values, entry.valid_at, entry.invalid_at, entry.superseded_by)\n\n        # Include agent_scope if schema supports it (v7+)\n        if schema_ver >= _SCHEMA_V7:\n            columns.append(\"agent_scope\")\n            values = (*values, entry.agent_scope)\n\n        # Compute and include integrity hash if schema supports it (v8+)\n        if schema_ver >= _SCHEMA_V8:\n            from tapps_brain.integrity import compute_integrity_hash\n\n            tier_str = entry.tier.value if hasattr(entry.tier, \"value\") else str(entry.tier)\n            source_str = entry.source.value if hasattr(entry.source, \"value\") else str(entry.source)\n            integrity_hash = compute_integrity_hash(\n                entry.key, entry.value, tier_str, source_str\n            )\n            columns.append(\"integrity_hash\")\n            values = (*values, integrity_hash)\n\n        placeholders = \", \".join(\"?\" * len(columns))\n\n        cols = \", \".join(columns)\n        with self._lock:\n            self._conn.execute(\n                f\"INSERT OR REPLACE INTO memories ({cols}) VALUES ({placeholders})\",\n                values,\n            )\n            self._conn.commit()\n        self._audit_log(\"save\", entry.key)\n\n    def get(self, key: str) -> MemoryEntry | None:\n        \"\"\"Retrieve a single memory entry by key.\"\"\"\n        with self._lock:\n            row = self._conn.execute(\"SELECT * FROM memories WHERE key = ?\", (key,)).fetchone()\n        if row is None:\n            return None\n        return self._row_to_entry(row)\n\n    def list_all(\n        self,\n        tier: str | None = None,\n        scope: str | None = None,\n        tags: list[str] | None = None,\n    ) -> list[MemoryEntry]:\n        \"\"\"List entries with optional filters.\"\"\"\n        query = \"SELECT * FROM memories WHERE 1=1\"\n        params: list[Any] = []\n\n        if tier is not None:\n            query += \" AND tier = ?\"\n            params.append(tier)\n        if scope is not None:\n            query += \" AND scope = ?\"\n            params.append(scope)\n\n        with self._lock:\n            rows = self._conn.execute(query, params).fetchall()\n\n        entries = [self._row_to_entry(r) for r in rows]\n\n        # Filter by tags in Python (tags stored as JSON array)\n        if tags:\n            tag_set = set(tags)\n            entries = [e for e in entries if tag_set.intersection(e.tags)]\n\n        return entries\n\n    def delete(self, key: str) -> bool:\n        \"\"\"Delete a memory entry by key. Returns True if deleted.\"\"\"\n        with self._lock:\n            cur = self._conn.execute(\"DELETE FROM memories WHERE key = ?\", (key,))\n            self._conn.commit()\n        deleted = cur.rowcount > 0\n        if deleted:\n            self._audit_log(\"delete\", key)\n        return deleted\n\n    def search(self, query: str) -> list[MemoryEntry]:\n        \"\"\"Full-text search via FTS5 across key, value, and tags.\"\"\"\n        if not query.strip():\n            return []\n\n        # Escape FTS5 special characters for safety\n        safe_query = self._escape_fts_query(query)\n        if not safe_query:\n            return []\n\n        with self._lock:\n            try:\n                rows = self._conn.execute(\n                    \"\"\"\n                    SELECT m.* FROM memories m\n                    JOIN memories_fts fts ON m.rowid = fts.rowid\n                    WHERE memories_fts MATCH ?\n                    \"\"\",\n                    (safe_query,),\n                ).fetchall()\n            except sqlite3.OperationalError:\n                logger.debug(\"fts_search_failed\", query=query)\n                return []\n\n        return [self._row_to_entry(r) for r in rows]\n\n    def load_all(self) -> list[MemoryEntry]:\n        \"\"\"Load all entries (for cold-start into in-memory cache).\"\"\"\n        with self._lock:\n            rows = self._conn.execute(\"SELECT * FROM memories\").fetchall()\n        return [self._row_to_entry(r) for r in rows]\n\n    def count(self) -> int:\n        \"\"\"Return the total number of memory entries.\"\"\"\n        with self._lock:\n            row = self._conn.execute(\"SELECT COUNT(*) FROM memories\").fetchone()\n        return int(row[0]) if row else 0\n\n    def get_schema_version(self) -> int:\n        \"\"\"Return the current schema version.\"\"\"\n        with self._lock:\n            row = self._conn.execute(\"SELECT MAX(version) FROM schema_version\").fetchone()\n        return int(row[0]) if row and row[0] is not None else 0\n\n    def close(self) -> None:\n        \"\"\"Close the database connection.\"\"\"\n        with self._lock:\n            self._conn.close()\n\n    # ------------------------------------------------------------------\n    # Session index (Epic 65.10)\n    # ------------------------------------------------------------------\n\n    def save_session_chunks(\n        self,\n        session_id: str,\n        chunks: list[str],\n        *,\n        max_chunks: int = 50,\n        max_chars_per_chunk: int = 500,\n    ) -> int:\n        \"\"\"Store session chunks for indexing. Returns count stored.\"\"\"\n        if not chunks or not session_id.strip():\n            return 0\n        now = datetime.now(tz=UTC).isoformat()\n        stored = 0\n        with self._lock:\n            for i, raw in enumerate(chunks[:max_chunks]):\n                content = (raw or \"\")[:max_chars_per_chunk].strip()\n                if not content:\n                    continue\n                try:\n                    self._conn.execute(\n                        \"\"\"\n                        INSERT OR REPLACE INTO session_index\n                        (session_id, chunk_index, content, created_at)\n                        VALUES (?, ?, ?, ?)\n                        \"\"\",\n                        (session_id, i, content, now),\n                    )\n                    stored += 1\n                except sqlite3.IntegrityError:\n                    pass\n            self._conn.commit()\n        return stored\n\n    def search_session_index(self, query: str, limit: int = 10) -> list[dict[str, Any]]:\n        \"\"\"Full-text search session index.\n\n        Returns list of {session_id, chunk_index, content, created_at}.\n        \"\"\"\n        if not query or not query.strip():\n            return []\n        safe = self._escape_fts_query(query)\n        if not safe:\n            return []\n        with self._lock:\n            try:\n                rows = self._conn.execute(\n                    \"\"\"\n                    SELECT s.session_id, s.chunk_index, s.content, s.created_at\n                    FROM session_index s\n                    JOIN session_index_fts fts ON s.rowid = fts.rowid\n                    WHERE session_index_fts MATCH ?\n                    ORDER BY s.created_at DESC\n                    LIMIT ?\n                    \"\"\",\n                    (safe, limit),\n                ).fetchall()\n            except sqlite3.OperationalError:\n                logger.debug(\"session_index_fts_search_failed\", query=query)\n                return []\n        return [\n            {\n                \"session_id\": r[\"session_id\"],\n                \"chunk_index\": r[\"chunk_index\"],\n                \"content\": r[\"content\"],\n                \"created_at\": r[\"created_at\"],\n            }\n            for r in rows\n        ]\n\n    def delete_expired_session_chunks(self, ttl_days: int) -> int:\n        \"\"\"Delete session chunks older than ttl_days. Returns count deleted.\"\"\"\n        from datetime import timedelta\n\n        cutoff = (datetime.now(tz=UTC) - timedelta(days=ttl_days)).isoformat()\n        with self._lock:\n            cur = self._conn.execute(\"DELETE FROM session_index WHERE created_at < ?\", (cutoff,))\n            self._conn.commit()\n            return cur.rowcount\n\n    def count_session_chunks(self) -> int:\n        \"\"\"Return total session index chunk count.\"\"\"\n        with self._lock:\n            row = self._conn.execute(\"SELECT COUNT(*) FROM session_index\").fetchone()\n        return int(row[0]) if row else 0\n\n    # ------------------------------------------------------------------\n    # Relations (Epic 65.12)\n    # ------------------------------------------------------------------\n\n    def save_relation(\n        self,\n        subject: str,\n        predicate: str,\n        object_entity: str,\n        source_entry_keys: list[str],\n        confidence: float = 0.8,\n    ) -> None:\n        \"\"\"Insert or replace a relation triple.\"\"\"\n        keys_json = json.dumps(source_entry_keys, ensure_ascii=False)\n        now = datetime.now(tz=UTC).isoformat()\n        with self._lock:\n            self._conn.execute(\n                \"INSERT OR REPLACE INTO relations \"\n                \"(subject, predicate, object_entity, source_entry_keys, confidence, created_at) \"\n                \"VALUES (?, ?, ?, ?, ?, ?)\",\n                (subject, predicate, object_entity, keys_json, confidence, now),\n            )\n            self._conn.commit()\n\n    def list_relations(self) -> list[dict[str, Any]]:\n        \"\"\"Return all stored relations as dicts.\"\"\"\n        with self._lock:\n            rows = self._conn.execute(\"SELECT * FROM relations\").fetchall()\n        results: list[dict[str, Any]] = []\n        for r in rows:\n            try:\n                keys = json.loads(r[\"source_entry_keys\"])\n            except (json.JSONDecodeError, TypeError):\n                keys = []\n            results.append(\n                {\n                    \"subject\": r[\"subject\"],\n                    \"predicate\": r[\"predicate\"],\n                    \"object_entity\": r[\"object_entity\"],\n                    \"source_entry_keys\": keys,\n                    \"confidence\": r[\"confidence\"],\n                    \"created_at\": r[\"created_at\"],\n                }\n            )\n        return results\n\n    def count_relations(self) -> int:\n        \"\"\"Return the total number of stored relations.\"\"\"\n        with self._lock:\n            row = self._conn.execute(\"SELECT COUNT(*) FROM relations\").fetchone()\n        return int(row[0]) if row else 0\n\n    def save_relations(self, key: str, relations: list[RelationEntry]) -> int:\n        \"\"\"Batch-save relations linked to a memory entry key.\n\n        Each relation's ``source_entry_keys`` is ensured to contain *key*.\n        Existing triples are updated (INSERT OR REPLACE).\n\n        Returns:\n            Number of relations saved.\n        \"\"\"\n        if not relations:\n            return 0\n        now = datetime.now(tz=UTC).isoformat()\n        count = 0\n        with self._lock:\n            for rel in relations:\n                source_keys = list(dict.fromkeys([*rel.source_entry_keys, key]))\n                keys_json = json.dumps(source_keys, ensure_ascii=False)\n                self._conn.execute(\n                    \"INSERT OR REPLACE INTO relations \"\n                    \"(subject, predicate, object_entity, source_entry_keys, \"\n                    \"confidence, created_at) VALUES (?, ?, ?, ?, ?, ?)\",\n                    (\n                        rel.subject,\n                        rel.predicate,\n                        rel.object_entity,\n                        keys_json,\n                        rel.confidence,\n                        now,\n                    ),\n                )\n                count += 1\n            self._conn.commit()\n        return count\n\n    def load_relations(self, key: str) -> list[dict[str, Any]]:\n        \"\"\"Load all relations whose ``source_entry_keys`` contains *key*.\"\"\"\n        all_relations = self.list_relations()\n        return [r for r in all_relations if key in r[\"source_entry_keys\"]]\n\n    def delete_relations(self, key: str) -> int:\n        \"\"\"Delete all relations whose ``source_entry_keys`` contains *key*.\n\n        Returns:\n            Number of relations deleted.\n        \"\"\"\n        with self._lock:\n            rows = self._conn.execute(\"SELECT * FROM relations\").fetchall()\n            count = 0\n            for r in rows:\n                try:\n                    keys = json.loads(r[\"source_entry_keys\"])\n                except (json.JSONDecodeError, TypeError):\n                    keys = []\n                if key in keys:\n                    self._conn.execute(\n                        \"DELETE FROM relations \"\n                        \"WHERE subject = ? AND predicate = ? AND object_entity = ?\",\n                        (r[\"subject\"], r[\"predicate\"], r[\"object_entity\"]),\n                    )\n                    count += 1\n            if count > 0:\n                self._conn.commit()\n        return count\n\n    # ------------------------------------------------------------------\n    # Private helpers\n    # ------------------------------------------------------------------\n\n    @staticmethod\n    def _row_to_entry(row: sqlite3.Row) -> MemoryEntry:\n        \"\"\"Convert a SQLite Row to a MemoryEntry.\"\"\"\n        tags_raw = row[\"tags\"]\n        try:\n            tags = json.loads(tags_raw) if tags_raw else []\n        except (json.JSONDecodeError, TypeError):\n            tags = []\n\n        embedding: list[float] | None = None\n        try:\n            emb_raw = row[\"embedding\"]\n        except (KeyError, IndexError):\n            emb_raw = None\n        if emb_raw:\n            try:\n                parsed = json.loads(str(emb_raw))\n                if isinstance(parsed, list) and all(isinstance(x, (int, float)) for x in parsed):\n                    embedding = [float(x) for x in parsed]\n            except (json.JSONDecodeError, TypeError):\n                pass\n\n        # Read temporal fields (v5+), gracefully handle missing columns\n        valid_at: str | None = None\n        invalid_at: str | None = None\n        superseded_by: str | None = None\n        try:\n            valid_at = row[\"valid_at\"]\n            invalid_at = row[\"invalid_at\"]\n            superseded_by = row[\"superseded_by\"]\n        except (KeyError, IndexError):\n            pass\n\n        # Read agent_scope (v7+), gracefully handle missing column\n        agent_scope: str = \"private\"\n        try:\n            val = row[\"agent_scope\"]\n            if val is not None:\n                agent_scope = val\n        except (KeyError, IndexError):\n            pass\n\n        # Read integrity_hash (v8+), gracefully handle missing column\n        integrity_hash: str | None = None\n        try:\n            integrity_hash = row[\"integrity_hash\"]\n        except (KeyError, IndexError):\n            pass\n\n        return MemoryEntry(\n            key=row[\"key\"],\n            value=row[\"value\"],\n            tier=row[\"tier\"],\n            confidence=row[\"confidence\"],\n            source=row[\"source\"],\n            source_agent=row[\"source_agent\"],\n            scope=row[\"scope\"],\n            tags=tags,\n            created_at=row[\"created_at\"],\n            updated_at=row[\"updated_at\"],\n            last_accessed=row[\"last_accessed\"],\n            access_count=row[\"access_count\"],\n            branch=row[\"branch\"],\n            last_reinforced=row[\"last_reinforced\"],\n            reinforce_count=row[\"reinforce_count\"],\n            contradicted=bool(row[\"contradicted\"]),\n            contradiction_reason=row[\"contradiction_reason\"],\n            seeded_from=row[\"seeded_from\"],\n            embedding=embedding,\n            valid_at=valid_at,\n            invalid_at=invalid_at,\n            superseded_by=superseded_by,\n            agent_scope=agent_scope,\n            integrity_hash=integrity_hash,\n        )\n\n    @staticmethod\n    def _escape_fts_query(query: str) -> str:\n        \"\"\"Escape an FTS5 query string for safe matching.\n\n        Wraps each token in double quotes to treat them as literals.\n        \"\"\"\n        tokens = query.strip().split()\n        if not tokens:\n            return \"\"\n        return \" \".join(f'\"{t}\"' for t in tokens)\n\n    def append_audit(\n        self,\n        action: str,\n        key: str,\n        extra: dict[str, Any] | None = None,\n    ) -> None:\n        \"\"\"Append an entry to the JSONL audit log with optional extra fields (EPIC-010).\"\"\"\n        record: dict[str, Any] = {\n            \"action\": action,\n            \"key\": key,\n            \"timestamp\": datetime.now(tz=UTC).isoformat(),\n        }\n        if extra:\n            record.update(extra)\n        try:\n            with self._audit_path.open(\"a\", encoding=\"utf-8\") as fh:\n                fh.write(json.dumps(record, ensure_ascii=False) + \"\\n\")\n            self._maybe_truncate_audit()\n        except OSError:\n            logger.debug(\"audit_log_write_failed\", key=key, action=action)\n\n    def _audit_log(self, action: str, key: str) -> None:\n        \"\"\"Append an entry to the JSONL audit log.\"\"\"\n        record = {\n            \"action\": action,\n            \"key\": key,\n            \"timestamp\": datetime.now(tz=UTC).isoformat(),\n        }\n        try:\n            with self._audit_path.open(\"a\", encoding=\"utf-8\") as fh:\n                fh.write(json.dumps(record, ensure_ascii=False) + \"\\n\")\n            self._maybe_truncate_audit()\n        except OSError:\n            logger.debug(\"audit_log_write_failed\", key=key, action=action)\n\n    def _maybe_truncate_audit(self) -> None:\n        \"\"\"Truncate audit log if it exceeds the max line count.\"\"\"\n        try:\n            lines = self._audit_path.read_text(encoding=\"utf-8\").splitlines()\n            if len(lines) > _MAX_AUDIT_LINES:\n                # Keep the most recent entries\n                keep = lines[-_MAX_AUDIT_LINES:]\n                self._audit_path.write_text(\"\\n\".join(keep) + \"\\n\", encoding=\"utf-8\")\n        except OSError:\n            pass\n","numLines":937,"startLine":1,"totalLines":937}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MbAjcZoFADRwUbvLAQxRTs","type":"tool_result","content":"     1→\"\"\"Pydantic v2 models for the shared memory subsystem.\"\"\"\n     2→\n     3→from __future__ import annotations\n     4→\n     5→import re\n     6→from datetime import UTC, datetime\n     7→from enum import StrEnum\n     8→from typing import Any, ClassVar\n     9→\n    10→from pydantic import BaseModel, Field, field_validator, model_validator\n    11→\n    12→\n    13→def _utc_now_iso() -> str:\n    14→    \"\"\"Return the current UTC time as an ISO-8601 string.\"\"\"\n    15→    return datetime.now(tz=UTC).isoformat()\n    16→\n    17→\n    18→# ---------------------------------------------------------------------------\n    19→# Enums\n    20→# ---------------------------------------------------------------------------\n    21→\n    22→_KEY_SLUG_PATTERN = re.compile(r\"^[a-z0-9][a-z0-9._-]{0,127}$\")\n    23→\n    24→\n    25→class MemoryTier(StrEnum):\n    26→    \"\"\"Decay classification for memory entries.\"\"\"\n    27→\n    28→    architectural = \"architectural\"  # slow decay - project structure, key decisions\n    29→    pattern = \"pattern\"  # medium decay - coding patterns, conventions\n    30→    procedural = \"procedural\"  # medium decay - how to do (workflows, steps); Epic 65.11\n    31→    context = \"context\"  # fast decay - session-specific context\n    32→\n    33→\n    34→class MemorySource(StrEnum):\n    35→    \"\"\"Origin of a memory entry.\"\"\"\n    36→\n    37→    human = \"human\"  # explicitly set by a developer\n    38→    agent = \"agent\"  # created by an AI agent\n    39→    inferred = \"inferred\"  # derived from analysis\n    40→    system = \"system\"  # created by TappsMCP internals\n    41→\n    42→\n    43→class MemoryScope(StrEnum):\n    44→    \"\"\"Visibility scope of a memory entry.\"\"\"\n    45→\n    46→    project = \"project\"  # visible across the entire project\n    47→    branch = \"branch\"  # scoped to a git branch\n    48→    session = \"session\"  # ephemeral, current session only\n    49→    shared = \"shared\"  # eligible for cross-project federation\n    50→\n    51→\n    52→# ---------------------------------------------------------------------------\n    53→# Source-based confidence defaults\n    54→# ---------------------------------------------------------------------------\n    55→\n    56→_SOURCE_CONFIDENCE_DEFAULTS: dict[MemorySource, float] = {\n    57→    MemorySource.human: 0.95,\n    58→    MemorySource.agent: 0.6,\n    59→    MemorySource.inferred: 0.4,\n    60→    MemorySource.system: 0.9,\n    61→}\n    62→\n    63→# ---------------------------------------------------------------------------\n    64→# Limits\n    65→# ---------------------------------------------------------------------------\n    66→\n    67→MAX_KEY_LENGTH: int = 128\n    68→MAX_VALUE_LENGTH: int = 4096\n    69→MAX_TAGS: int = 10\n    70→\n    71→\n    72→def tier_str(tier: MemoryTier | str) -> str:\n    73→    \"\"\"Return the string value of a tier, handling both MemoryTier enum and str.\"\"\"\n    74→    return tier.value if isinstance(tier, MemoryTier) else str(tier)\n    75→\n    76→\n    77→# ---------------------------------------------------------------------------\n    78→# Models\n    79→# ---------------------------------------------------------------------------\n    80→\n    81→\n    82→class MemoryEntry(BaseModel):\n    83→    \"\"\"A single memory entry in the shared memory store.\"\"\"\n    84→\n    85→    key: str = Field(description=\"Unique slug identifier (max 128 chars).\")\n    86→    value: str = Field(description=\"Memory content (max 4096 chars).\")\n    87→    tier: MemoryTier | str = Field(default=MemoryTier.pattern, description=\"Decay classification.\")\n    88→    confidence: float = Field(\n    89→        default=-1.0,\n    90→        ge=-1.0,\n    91→        le=1.0,\n    92→        description=\"Confidence score 0.0-1.0. -1.0 means use source default.\",\n    93→    )\n    94→    source: MemorySource = Field(default=MemorySource.agent, description=\"Who created this memory.\")\n    95→    source_agent: str = Field(\n    96→        default=\"unknown\", description=\"Agent identifier (e.g. 'claude-code').\"\n    97→    )\n    98→    scope: MemoryScope = Field(default=MemoryScope.project, description=\"Visibility scope.\")\n    99→    tags: list[str] = Field(default_factory=list, description=\"Free-form tags for search (max 10).\")\n   100→    created_at: str = Field(default_factory=_utc_now_iso, description=\"ISO-8601 UTC creation time.\")\n   101→    updated_at: str = Field(\n   102→        default_factory=_utc_now_iso, description=\"ISO-8601 UTC last update time.\"\n   103→    )\n   104→    last_accessed: str = Field(\n   105→        default_factory=_utc_now_iso, description=\"ISO-8601 UTC last access time.\"\n   106→    )\n   107→    access_count: int = Field(default=0, ge=0, description=\"Read access count.\")\n   108→    branch: str | None = Field(default=None, description=\"Git branch (required when scope=branch).\")\n   109→\n   110→    # Reserved for Epic 24 (Memory Intelligence)\n   111→    last_reinforced: str | None = Field(\n   112→        default=None, description=\"ISO-8601 UTC, set by reinforce action.\"\n   113→    )\n   114→    reinforce_count: int = Field(default=0, ge=0, description=\"Total reinforcements.\")\n   115→    contradicted: bool = Field(default=False, description=\"Set by contradiction detection.\")\n   116→    contradiction_reason: str | None = Field(default=None, description=\"Reason for contradiction.\")\n   117→\n   118→    # Reserved for Epic 25 (Memory Retrieval & Integration)\n   119→    seeded_from: str | None = Field(default=None, description=\"Populated by profile seeding.\")\n   120→\n   121→    # Optional embedding for semantic search (Epic 65.7)\n   122→    embedding: list[float] | None = Field(\n   123→        default=None,\n   124→        description=\"Vector embedding for semantic search when enabled.\",\n   125→    )\n   126→\n   127→    # Hive agent scope (EPIC-011)\n   128→    agent_scope: str = Field(\n   129→        default=\"private\",\n   130→        description=\"Hive propagation scope: 'private' | 'domain' | 'hive'.\",\n   131→    )\n   132→\n   133→    # Bi-temporal versioning (EPIC-004)\n   134→    valid_at: str | None = Field(\n   135→        default=None,\n   136→        description=\"ISO-8601 UTC: when this fact became true in the real world.\",\n   137→    )\n   138→    invalid_at: str | None = Field(\n   139→        default=None,\n   140→        description=\"ISO-8601 UTC: when this fact stopped being true.\",\n   141→    )\n   142→    superseded_by: str | None = Field(\n   143→        default=None,\n   144→        description=\"Key of the entry that replaced this one.\",\n   145→    )\n   146→\n   147→    # Integrity hash for tamper detection (H4a)\n   148→    integrity_hash: str | None = Field(\n   149→        default=None,\n   150→        description=\"HMAC-SHA256 hex digest computed over key|value|tier|source.\",\n   151→    )\n   152→\n   153→    # Class-level constants (not serialised)\n   154→    _KEY_PATTERN: ClassVar[re.Pattern[str]] = _KEY_SLUG_PATTERN\n   155→\n   156→    @field_validator(\"key\")\n   157→    @classmethod\n   158→    def _validate_key(cls, v: str) -> str:\n   159→        if not _KEY_SLUG_PATTERN.match(v):\n   160→            msg = (\n   161→                f\"Key must be a lowercase slug (letters, digits, dots, hyphens, \"\n   162→                f\"underscores), 1-{MAX_KEY_LENGTH} chars, starting with alphanumeric. \"\n   163→                f\"Got: {v!r}\"\n   164→            )\n   165→            raise ValueError(msg)\n   166→        return v\n   167→\n   168→    @field_validator(\"value\")\n   169→    @classmethod\n   170→    def _validate_value(cls, v: str) -> str:\n   171→        if len(v) > MAX_VALUE_LENGTH:\n   172→            msg = f\"Value exceeds max length ({len(v)} > {MAX_VALUE_LENGTH}).\"\n   173→            raise ValueError(msg)\n   174→        if not v.strip():\n   175→            msg = \"Value must not be empty or whitespace-only.\"\n   176→            raise ValueError(msg)\n   177→        return v\n   178→\n   179→    @field_validator(\"tags\")\n   180→    @classmethod\n   181→    def _validate_tags(cls, v: list[str]) -> list[str]:\n   182→        if len(v) > MAX_TAGS:\n   183→            msg = f\"Too many tags ({len(v)} > {MAX_TAGS}).\"\n   184→            raise ValueError(msg)\n   185→        return v\n   186→\n   187→    @model_validator(mode=\"after\")\n   188→    def _apply_defaults_and_validate(self) -> MemoryEntry:\n   189→        # Apply source-based confidence default\n   190→        if self.confidence < 0:\n   191→            object.__setattr__(\n   192→                self,\n   193→                \"confidence\",\n   194→                _SOURCE_CONFIDENCE_DEFAULTS.get(self.source, 0.5),\n   195→            )\n   196→\n   197→        # Branch required when scope=branch\n   198→        if self.scope == MemoryScope.branch and not self.branch:\n   199→            msg = \"Branch name is required when scope is 'branch'.\"\n   200→            raise ValueError(msg)\n   201→\n   202→        # Temporal validation: invalid_at must be after valid_at\n   203→        if (\n   204→            self.valid_at is not None\n   205→            and self.invalid_at is not None\n   206→            and self.invalid_at <= self.valid_at\n   207→        ):\n   208→            msg = \"invalid_at must be after valid_at.\"\n   209→            raise ValueError(msg)\n   210→\n   211→        return self\n   212→\n   213→    def is_temporally_valid(self, as_of: str | None = None) -> bool:\n   214→        \"\"\"Check whether this entry is valid at the given point in time.\n   215→\n   216→        If *as_of* is ``None``, uses the current UTC time. An entry with\n   217→        both ``valid_at`` and ``invalid_at`` set to ``None`` is always valid.\n   218→\n   219→        The window is ``[valid_at, invalid_at)`` — inclusive start, exclusive end.\n   220→        \"\"\"\n   221→        ts = as_of or _utc_now_iso()\n   222→        if self.valid_at is not None and ts < self.valid_at:\n   223→            return False\n   224→        return not (self.invalid_at is not None and ts >= self.invalid_at)\n   225→\n   226→    @property\n   227→    def is_superseded(self) -> bool:\n   228→        \"\"\"Return ``True`` if this entry has been superseded (invalid_at in the past).\"\"\"\n   229→        if self.invalid_at is None:\n   230→            return False\n   231→        return _utc_now_iso() >= self.invalid_at\n   232→\n   233→\n   234→# ---------------------------------------------------------------------------\n   235→# Auto-recall models (Epic 003)\n   236→# ---------------------------------------------------------------------------\n   237→\n   238→\n   239→class RecallResult(BaseModel):\n   240→    \"\"\"Result of an auto-recall operation.\n   241→\n   242→    Returned by ``RecallOrchestrator.recall()`` and the ``RecallHookLike``\n   243→    protocol. Contains the formatted memory section ready for injection,\n   244→    metadata about which memories were selected, and timing information.\n   245→    \"\"\"\n   246→\n   247→    memory_section: str = Field(\n   248→        default=\"\",\n   249→        description=\"Formatted markdown section for injection into the prompt.\",\n   250→    )\n   251→    memories: list[dict[str, Any]] = Field(\n   252→        default_factory=list,\n   253→        description=\"List of injected memory summaries (key, confidence, tier, score, stale).\",\n   254→    )\n   255→    token_count: int = Field(\n   256→        default=0,\n   257→        ge=0,\n   258→        description=\"Estimated token count of the injected memory section.\",\n   259→    )\n   260→    recall_time_ms: float = Field(\n   261→        default=0.0,\n   262→        ge=0.0,\n   263→        description=\"Time taken for the recall operation in milliseconds.\",\n   264→    )\n   265→    truncated: bool = Field(\n   266→        default=False,\n   267→        description=\"Whether the results were truncated due to token budget.\",\n   268→    )\n   269→    memory_count: int = Field(\n   270→        default=0,\n   271→        ge=0,\n   272→        description=\"Number of memories injected.\",\n   273→    )\n   274→    hive_memory_count: int = Field(\n   275→        default=0,\n   276→        ge=0,\n   277→        description=\"Number of memories from the Hive (EPIC-011).\",\n   278→    )\n   279→\n   280→\n   281→class MemorySnapshot(BaseModel):\n   282→    \"\"\"Full-state snapshot of the memory store for export/serialization.\"\"\"\n   283→\n   284→    project_root: str = Field(description=\"Project root path.\")\n   285→    entries: list[MemoryEntry] = Field(default_factory=list, description=\"All memory entries.\")\n   286→    total_count: int = Field(default=0, ge=0, description=\"Total entry count.\")\n   287→    tier_counts: dict[str, int] = Field(default_factory=dict, description=\"Count per tier.\")\n   288→    exported_at: str = Field(default_factory=_utc_now_iso, description=\"ISO-8601 UTC export time.\")\n   289→\n   290→\n   291→# ---------------------------------------------------------------------------\n   292→# Consolidation models (Epic 58)\n   293→# ---------------------------------------------------------------------------\n   294→\n   295→\n   296→class ConsolidationReason(StrEnum):\n   297→    \"\"\"Why entries were consolidated.\"\"\"\n   298→\n   299→    similarity = \"similarity\"  # Jaccard + TF-IDF similarity above threshold\n   300→    same_topic = \"same_topic\"  # Same tier + overlapping tags\n   301→    supersession = \"supersession\"  # Newer entry references older entry\n   302→    manual = \"manual\"  # User-triggered consolidation\n   303→\n   304→\n   305→class ConsolidatedEntry(MemoryEntry):\n   306→    \"\"\"A memory entry that consolidates multiple source entries.\n   307→\n   308→    Inherits all MemoryEntry fields and adds provenance tracking.\n   309→    Source entries are marked as `consolidated: true` but retained.\n   310→    \"\"\"\n   311→\n   312→    source_ids: list[str] = Field(\n   313→        default_factory=list,\n   314→        description=\"Keys of entries that were consolidated into this one.\",\n   315→    )\n   316→    consolidated_at: str = Field(\n   317→        default_factory=_utc_now_iso,\n   318→        description=\"ISO-8601 UTC timestamp when consolidation occurred.\",\n   319→    )\n   320→    consolidation_reason: ConsolidationReason = Field(\n   321→        default=ConsolidationReason.similarity,\n   322→        description=\"Why the entries were consolidated.\",\n   323→    )\n   324→    is_consolidated: bool = Field(\n   325→        default=True,\n   326→        description=\"Always True for ConsolidatedEntry.\",\n   327→    )\n   328→"}]},"parent_tool_use_id":null,"session_id":"9c6cb207-da68-4164-9f58-f8072bc99cd2","uuid":"d42f2256-3350-47ff-bc8f-81d1d8733530","timestamp":"2026-03-22T22:15:28.436Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\cursor\\tapps-brain\\src\\tapps_brain\\models.py","content":"\"\"\"Pydantic v2 models for the shared memory subsystem.\"\"\"\n\nfrom __future__ import annotations\n\nimport re\nfrom datetime import UTC, datetime\nfrom enum import StrEnum\nfrom typing import Any, ClassVar\n\nfrom pydantic import BaseModel, Field, field_validator, model_validator\n\n\ndef _utc_now_iso() -> str:\n    \"\"\"Return the current UTC time as an ISO-8601 string.\"\"\"\n    return datetime.now(tz=UTC).isoformat()\n\n\n# ---------------------------------------------------------------------------\n# Enums\n# ---------------------------------------------------------------------------\n\n_KEY_SLUG_PATTERN = re.compile(r\"^[a-z0-9][a-z0-9._-]{0,127}$\")\n\n\nclass MemoryTier(StrEnum):\n    \"\"\"Decay classification for memory entries.\"\"\"\n\n    architectural = \"architectural\"  # slow decay - project structure, key decisions\n    pattern = \"pattern\"  # medium decay - coding patterns, conventions\n    procedural = \"procedural\"  # medium decay - how to do (workflows, steps); Epic 65.11\n    context = \"context\"  # fast decay - session-specific context\n\n\nclass MemorySource(StrEnum):\n    \"\"\"Origin of a memory entry.\"\"\"\n\n    human = \"human\"  # explicitly set by a developer\n    agent = \"agent\"  # created by an AI agent\n    inferred = \"inferred\"  # derived from analysis\n    system = \"system\"  # created by TappsMCP internals\n\n\nclass MemoryScope(StrEnum):\n    \"\"\"Visibility scope of a memory entry.\"\"\"\n\n    project = \"project\"  # visible across the entire project\n    branch = \"branch\"  # scoped to a git branch\n    session = \"session\"  # ephemeral, current session only\n    shared = \"shared\"  # eligible for cross-project federation\n\n\n# ---------------------------------------------------------------------------\n# Source-based confidence defaults\n# ---------------------------------------------------------------------------\n\n_SOURCE_CONFIDENCE_DEFAULTS: dict[MemorySource, float] = {\n    MemorySource.human: 0.95,\n    MemorySource.agent: 0.6,\n    MemorySource.inferred: 0.4,\n    MemorySource.system: 0.9,\n}\n\n# ---------------------------------------------------------------------------\n# Limits\n# ---------------------------------------------------------------------------\n\nMAX_KEY_LENGTH: int = 128\nMAX_VALUE_LENGTH: int = 4096\nMAX_TAGS: int = 10\n\n\ndef tier_str(tier: MemoryTier | str) -> str:\n    \"\"\"Return the string value of a tier, handling both MemoryTier enum and str.\"\"\"\n    return tier.value if isinstance(tier, MemoryTier) else str(tier)\n\n\n# ---------------------------------------------------------------------------\n# Models\n# ---------------------------------------------------------------------------\n\n\nclass MemoryEntry(BaseModel):\n    \"\"\"A single memory entry in the shared memory store.\"\"\"\n\n    key: str = Field(description=\"Unique slug identifier (max 128 chars).\")\n    value: str = Field(description=\"Memory content (max 4096 chars).\")\n    tier: MemoryTier | str = Field(default=MemoryTier.pattern, description=\"Decay classification.\")\n    confidence: float = Field(\n        default=-1.0,\n        ge=-1.0,\n        le=1.0,\n        description=\"Confidence score 0.0-1.0. -1.0 means use source default.\",\n    )\n    source: MemorySource = Field(default=MemorySource.agent, description=\"Who created this memory.\")\n    source_agent: str = Field(\n        default=\"unknown\", description=\"Agent identifier (e.g. 'claude-code').\"\n    )\n    scope: MemoryScope = Field(default=MemoryScope.project, description=\"Visibility scope.\")\n    tags: list[str] = Field(default_factory=list, description=\"Free-form tags for search (max 10).\")\n    created_at: str = Field(default_factory=_utc_now_iso, description=\"ISO-8601 UTC creation time.\")\n    updated_at: str = Field(\n        default_factory=_utc_now_iso, description=\"ISO-8601 UTC last update time.\"\n    )\n    last_accessed: str = Field(\n        default_factory=_utc_now_iso, description=\"ISO-8601 UTC last access time.\"\n    )\n    access_count: int = Field(default=0, ge=0, description=\"Read access count.\")\n    branch: str | None = Field(default=None, description=\"Git branch (required when scope=branch).\")\n\n    # Reserved for Epic 24 (Memory Intelligence)\n    last_reinforced: str | None = Field(\n        default=None, description=\"ISO-8601 UTC, set by reinforce action.\"\n    )\n    reinforce_count: int = Field(default=0, ge=0, description=\"Total reinforcements.\")\n    contradicted: bool = Field(default=False, description=\"Set by contradiction detection.\")\n    contradiction_reason: str | None = Field(default=None, description=\"Reason for contradiction.\")\n\n    # Reserved for Epic 25 (Memory Retrieval & Integration)\n    seeded_from: str | None = Field(default=None, description=\"Populated by profile seeding.\")\n\n    # Optional embedding for semantic search (Epic 65.7)\n    embedding: list[float] | None = Field(\n        default=None,\n        description=\"Vector embedding for semantic search when enabled.\",\n    )\n\n    # Hive agent scope (EPIC-011)\n    agent_scope: str = Field(\n        default=\"private\",\n        description=\"Hive propagation scope: 'private' | 'domain' | 'hive'.\",\n    )\n\n    # Bi-temporal versioning (EPIC-004)\n    valid_at: str | None = Field(\n        default=None,\n        description=\"ISO-8601 UTC: when this fact became true in the real world.\",\n    )\n    invalid_at: str | None = Field(\n        default=None,\n        description=\"ISO-8601 UTC: when this fact stopped being true.\",\n    )\n    superseded_by: str | None = Field(\n        default=None,\n        description=\"Key of the entry that replaced this one.\",\n    )\n\n    # Integrity hash for tamper detection (H4a)\n    integrity_hash: str | None = Field(\n        default=None,\n        description=\"HMAC-SHA256 hex digest computed over key|value|tier|source.\",\n    )\n\n    # Class-level constants (not serialised)\n    _KEY_PATTERN: ClassVar[re.Pattern[str]] = _KEY_SLUG_PATTERN\n\n    @field_validator(\"key\")\n    @classmethod\n    def _validate_key(cls, v: str) -> str:\n        if not _KEY_SLUG_PATTERN.match(v):\n            msg = (\n                f\"Key must be a lowercase slug (letters, digits, dots, hyphens, \"\n                f\"underscores), 1-{MAX_KEY_LENGTH} chars, starting with alphanumeric. \"\n                f\"Got: {v!r}\"\n            )\n            raise ValueError(msg)\n        return v\n\n    @field_validator(\"value\")\n    @classmethod\n    def _validate_value(cls, v: str) -> str:\n        if len(v) > MAX_VALUE_LENGTH:\n            msg = f\"Value exceeds max length ({len(v)} > {MAX_VALUE_LENGTH}).\"\n            raise ValueError(msg)\n        if not v.strip():\n            msg = \"Value must not be empty or whitespace-only.\"\n            raise ValueError(msg)\n        return v\n\n    @field_validator(\"tags\")\n    @classmethod\n    def _validate_tags(cls, v: list[str]) -> list[str]:\n        if len(v) > MAX_TAGS:\n            msg = f\"Too many tags ({len(v)} > {MAX_TAGS}).\"\n            raise ValueError(msg)\n        return v\n\n    @model_validator(mode=\"after\")\n    def _apply_defaults_and_validate(self) -> MemoryEntry:\n        # Apply source-based confidence default\n        if self.confidence < 0:\n            object.__setattr__(\n                self,\n                \"confidence\",\n                _SOURCE_CONFIDENCE_DEFAULTS.get(self.source, 0.5),\n            )\n\n        # Branch required when scope=branch\n        if self.scope == MemoryScope.branch and not self.branch:\n            msg = \"Branch name is required when scope is 'branch'.\"\n            raise ValueError(msg)\n\n        # Temporal validation: invalid_at must be after valid_at\n        if (\n            self.valid_at is not None\n            and self.invalid_at is not None\n            and self.invalid_at <= self.valid_at\n        ):\n            msg = \"invalid_at must be after valid_at.\"\n            raise ValueError(msg)\n\n        return self\n\n    def is_temporally_valid(self, as_of: str | None = None) -> bool:\n        \"\"\"Check whether this entry is valid at the given point in time.\n\n        If *as_of* is ``None``, uses the current UTC time. An entry with\n        both ``valid_at`` and ``invalid_at`` set to ``None`` is always valid.\n\n        The window is ``[valid_at, invalid_at)`` — inclusive start, exclusive end.\n        \"\"\"\n        ts = as_of or _utc_now_iso()\n        if self.valid_at is not None and ts < self.valid_at:\n            return False\n        return not (self.invalid_at is not None and ts >= self.invalid_at)\n\n    @property\n    def is_superseded(self) -> bool:\n        \"\"\"Return ``True`` if this entry has been superseded (invalid_at in the past).\"\"\"\n        if self.invalid_at is None:\n            return False\n        return _utc_now_iso() >= self.invalid_at\n\n\n# ---------------------------------------------------------------------------\n# Auto-recall models (Epic 003)\n# ---------------------------------------------------------------------------\n\n\nclass RecallResult(BaseModel):\n    \"\"\"Result of an auto-recall operation.\n\n    Returned by ``RecallOrchestrator.recall()`` and the ``RecallHookLike``\n    protocol. Contains the formatted memory section ready for injection,\n    metadata about which memories were selected, and timing information.\n    \"\"\"\n\n    memory_section: str = Field(\n        default=\"\",\n        description=\"Formatted markdown section for injection into the prompt.\",\n    )\n    memories: list[dict[str, Any]] = Field(\n        default_factory=list,\n        description=\"List of injected memory summaries (key, confidence, tier, score, stale).\",\n    )\n    token_count: int = Field(\n        default=0,\n        ge=0,\n        description=\"Estimated token count of the injected memory section.\",\n    )\n    recall_time_ms: float = Field(\n        default=0.0,\n        ge=0.0,\n        description=\"Time taken for the recall operation in milliseconds.\",\n    )\n    truncated: bool = Field(\n        default=False,\n        description=\"Whether the results were truncated due to token budget.\",\n    )\n    memory_count: int = Field(\n        default=0,\n        ge=0,\n        description=\"Number of memories injected.\",\n    )\n    hive_memory_count: int = Field(\n        default=0,\n        ge=0,\n        description=\"Number of memories from the Hive (EPIC-011).\",\n    )\n\n\nclass MemorySnapshot(BaseModel):\n    \"\"\"Full-state snapshot of the memory store for export/serialization.\"\"\"\n\n    project_root: str = Field(description=\"Project root path.\")\n    entries: list[MemoryEntry] = Field(default_factory=list, description=\"All memory entries.\")\n    total_count: int = Field(default=0, ge=0, description=\"Total entry count.\")\n    tier_counts: dict[str, int] = Field(default_factory=dict, description=\"Count per tier.\")\n    exported_at: str = Field(default_factory=_utc_now_iso, description=\"ISO-8601 UTC export time.\")\n\n\n# ---------------------------------------------------------------------------\n# Consolidation models (Epic 58)\n# ---------------------------------------------------------------------------\n\n\nclass ConsolidationReason(StrEnum):\n    \"\"\"Why entries were consolidated.\"\"\"\n\n    similarity = \"similarity\"  # Jaccard + TF-IDF similarity above threshold\n    same_topic = \"same_topic\"  # Same tier + overlapping tags\n    supersession = \"supersession\"  # Newer entry references older entry\n    manual = \"manual\"  # User-triggered consolidation\n\n\nclass ConsolidatedEntry(MemoryEntry):\n    \"\"\"A memory entry that consolidates multiple source entries.\n\n    Inherits all MemoryEntry fields and adds provenance tracking.\n    Source entries are marked as `consolidated: true` but retained.\n    \"\"\"\n\n    source_ids: list[str] = Field(\n        default_factory=list,\n        description=\"Keys of entries that were consolidated into this one.\",\n    )\n    consolidated_at: str = Field(\n        default_factory=_utc_now_iso,\n        description=\"ISO-8601 UTC timestamp when consolidation occurred.\",\n    )\n    consolidation_reason: ConsolidationReason = Field(\n        default=ConsolidationReason.similarity,\n        description=\"Why the entries were consolidated.\",\n    )\n    is_consolidated: bool = Field(\n        default=True,\n        description=\"Always True for ConsolidatedEntry.\",\n    )\n","numLines":328,"startLine":1,"totalLines":328}}}
