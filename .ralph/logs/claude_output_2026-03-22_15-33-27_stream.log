{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016fJgV5KeTVN1qtsysi4LZr","type":"tool_result","content":"  1696→def _handle_profile_info(store: MemoryStore, _p: _Params) -> dict[str, Any]:\n  1697→    \"\"\"Handle the profile_info action -- show active profile details.\"\"\"\n  1698→    profile = getattr(store, \"profile\", None)\n  1699→    if profile is None:\n  1700→        return {\n  1701→            \"action\": \"profile_info\",\n  1702→            \"active_profile\": \"repo-brain\",\n  1703→            \"source\": \"default\",\n  1704→            \"layers\": [],\n  1705→            \"scoring_weights\": {},\n  1706→            \"promotion_enabled\": False,\n  1707→        }\n  1708→\n  1709→    layers = []\n  1710→    promotion_enabled = False\n  1711→    for layer in profile.layers:\n  1712→        layer_info: dict[str, Any] = {\n  1713→            \"name\": layer.name,\n  1714→            \"description\": getattr(layer, \"description\", \"\"),\n  1715→            \"half_life_days\": layer.half_life_days,\n  1716→            \"decay_model\": layer.decay_model,\n  1717→            \"confidence_floor\": layer.confidence_floor,\n  1718→        }\n  1719→        if getattr(layer, \"promotion_to\", None):\n  1720→            layer_info[\"promotion_to\"] = layer.promotion_to\n  1721→            promotion_enabled = True\n  1722→        if getattr(layer, \"demotion_to\", None):\n  1723→            layer_info[\"demotion_to\"] = layer.demotion_to\n  1724→        layers.append(layer_info)\n  1725→\n  1726→    scoring = profile.scoring\n  1727→    return {\n  1728→        \"action\": \"profile_info\",\n  1729→        \"active_profile\": profile.name,\n  1730→        \"description\": profile.description,\n  1731→        \"source\": _detect_profile_source(store),\n  1732→        \"layers\": layers,\n  1733→        \"scoring_weights\": {\n  1734→            \"relevance\": getattr(scoring, \"relevance_weight\", 0.4),\n  1735→            \"confidence\": getattr(scoring, \"confidence_weight\", 0.3),\n  1736→            \"recency\": getattr(scoring, \"recency_weight\", 0.15),\n  1737→            \"frequency\": getattr(scoring, \"frequency_weight\", 0.15),\n  1738→        },\n  1739→        \"promotion_enabled\": promotion_enabled,\n  1740→        \"limits\": {\n  1741→            \"max_entries\": getattr(profile.limits, \"max_entries\", 1500),\n  1742→            \"max_value_length\": getattr(profile.limits, \"max_value_length\", 4096),\n  1743→        },\n  1744→    }\n  1745→\n  1746→\n  1747→def _handle_profile_list(_store: MemoryStore, _p: _Params) -> dict[str, Any]:\n  1748→    \"\"\"Handle the profile_list action -- list available profiles.\"\"\"\n  1749→    try:\n  1750→        from tapps_brain.profile import get_builtin_profile, list_builtin_profiles\n  1751→    except ImportError:\n  1752→        return {\n  1753→            \"action\": \"profile_list\",\n  1754→            \"profiles\": [{\"name\": \"repo-brain\", \"description\": \"Default profile\", \"layers\": 4}],\n  1755→            \"total\": 1,\n  1756→            \"degraded\": True,\n  1757→            \"message\": \"Profile module not available in installed tapps-brain version.\",\n  1758→        }\n  1759→\n  1760→    names = list_builtin_profiles()\n  1761→    profiles = []\n  1762→    for name in names:\n  1763→        try:\n  1764→            prof = get_builtin_profile(name)\n  1765→            profiles.append({\n  1766→                \"name\": prof.name,\n  1767→                \"description\": prof.description,\n  1768→                \"layers\": len(prof.layers),\n  1769→                \"decay_models\": sorted({la.decay_model for la in prof.layers}),\n  1770→            })\n  1771→        except Exception:\n  1772→            profiles.append({\"name\": name, \"description\": \"(failed to load)\", \"layers\": 0})\n  1773→\n  1774→    return {\n  1775→        \"action\": \"profile_list\",\n  1776→        \"profiles\": profiles,\n  1777→        \"total\": len(profiles),\n  1778→    }\n  1779→\n  1780→\n  1781→def _handle_profile_switch(store: MemoryStore, p: _Params) -> dict[str, Any]:\n  1782→    \"\"\"Handle the profile_switch action -- switch to a different memory profile.\"\"\"\n  1783→    target_name = p.value.strip() if p.value else \"\"\n  1784→    if not target_name:\n  1785→        return {\"error\": \"missing_value\", \"message\": \"Profile name is required (pass as value).\"}\n  1786→\n  1787→    try:\n  1788→        from tapps_brain.profile import get_builtin_profile, list_builtin_profiles\n  1789→    except ImportError:\n  1790→        return {\n  1791→            \"error\": \"unsupported\",\n  1792→            \"message\": \"Profile switching requires tapps-brain >= 1.1.0.\",\n  1793→        }\n  1794→\n  1795→    available = list_builtin_profiles()\n  1796→    if target_name not in available:\n  1797→        return {\n  1798→            \"error\": \"unknown_profile\",\n  1799→            \"message\": f\"Profile '{target_name}' not found. Available: {', '.join(available)}\",\n  1800→        }\n  1801→\n  1802→    old_profile = store.profile\n  1803→    old_name = old_profile.name if old_profile else \"repo-brain\"\n  1804→\n  1805→    if old_name == target_name:\n  1806→        return {\n  1807→            \"action\": \"profile_switch\",\n  1808→            \"previous_profile\": old_name,\n  1809→            \"active_profile\": target_name,\n  1810→            \"changed\": False,\n  1811→            \"message\": f\"Already using profile '{target_name}'.\",\n  1812→        }\n  1813→\n  1814→    # Persist choice to .tapps-brain/profile.yaml\n  1815→    new_profile = get_builtin_profile(target_name)\n  1816→\n  1817→    try:\n  1818→        import yaml\n  1819→\n  1820→        profile_dir = store.project_root / \".tapps-brain\"\n  1821→        profile_dir.mkdir(parents=True, exist_ok=True)\n  1822→        profile_path = profile_dir / \"profile.yaml\"\n  1823→        profile_path.write_text(\n  1824→            yaml.dump(\n  1825→                {\"profile\": {\"name\": target_name, \"extends\": target_name}},\n  1826→                default_flow_style=False,\n  1827→            ),\n  1828→            encoding=\"utf-8\",\n  1829→        )\n  1830→    except Exception:\n  1831→        pass  # Non-fatal -- switch still works for this session\n  1832→\n  1833→    # Reset the store singleton so next access picks up the new profile\n  1834→    from tapps_mcp.server_helpers import _reset_memory_store_cache\n  1835→\n  1836→    _reset_memory_store_cache()\n  1837→\n  1838→    layer_summary = \", \".join(\n  1839→        f\"{la.name} ({la.half_life_days}d)\" for la in new_profile.layers\n  1840→    )\n  1841→    return {\n  1842→        \"action\": \"profile_switch\",\n  1843→        \"previous_profile\": old_name,\n  1844→        \"active_profile\": target_name,\n  1845→        \"changed\": True,\n  1846→        \"layers\": layer_summary,\n  1847→        \"description\": new_profile.description,\n  1848→        \"store_metadata\": _store_metadata(_get_memory_store()),\n  1849→    }\n  1850→\n  1851→\n  1852→def _detect_profile_source(store: MemoryStore) -> str:\n  1853→    \"\"\"Detect how the active profile was resolved.\"\"\"\n  1854→    project_yaml = store.project_root / \".tapps-brain\" / \"profile.yaml\"\n  1855→    if project_yaml.exists():\n  1856→        return \"project_override\"\n  1857→    user_yaml = Path.home() / \".tapps-brain\" / \"profile.yaml\"\n  1858→    if user_yaml.exists():\n  1859→        return \"user_global\"\n  1860→    return \"default\"\n  1861→\n  1862→\n  1863→# ---------------------------------------------------------------------------\n  1864→# Dispatch table — maps action names to handler functions\n  1865→# ---------------------------------------------------------------------------\n  1866→\n  1867→_DISPATCH: dict[str, Callable[[MemoryStore, _Params], dict[str, Any]]] = {\n  1868→    \"save\": _handle_save,\n  1869→    \"save_bulk\": _handle_save_bulk,\n  1870→    \"get\": _handle_get,\n  1871→    \"list\": _handle_list,\n  1872→    \"delete\": _handle_delete,\n  1873→    \"search\": _handle_search,\n  1874→    \"reinforce\": _handle_reinforce,\n  1875→    \"gc\": _handle_gc,\n  1876→    \"contradictions\": _handle_contradictions,\n  1877→    \"reseed\": _handle_reseed,\n  1878→    \"import\": _handle_import,\n  1879→    \"export\": _handle_export,\n  1880→    \"consolidate\": _handle_consolidate,\n  1881→    \"unconsolidate\": _handle_unconsolidate,\n  1882→    \"federate_register\": _handle_federate_register,\n  1883→    \"federate_publish\": _handle_federate_publish,\n  1884→    \"federate_subscribe\": _handle_federate_subscribe,\n  1885→    \"federate_sync\": _handle_federate_sync,\n  1886→    \"federate_search\": _handle_federate_search,\n  1887→    \"federate_status\": _handle_federate_status,\n  1888→    \"index_session\": _handle_index_session,\n  1889→    \"maintain\": _handle_maintain,\n  1890→    # Epic M1: Security surface\n  1891→    \"safety_check\": _handle_safety_check,\n  1892→    \"verify_integrity\": _handle_verify_integrity,\n  1893→    # Epic M2: Profile & lifecycle management\n  1894→    \"profile_info\": _handle_profile_info,\n  1895→    \"profile_list\": _handle_profile_list,"}]},"parent_tool_use_id":"toolu_01Bx6P8eG3k7xKdAfwtembt7","session_id":"b61393de-68e8-4cff-8475-056605bcfefe","uuid":"c17f63c6-fcc2-42da-8cc6-f985f931e9af","timestamp":"2026-03-22T22:34:14.818Z"}
