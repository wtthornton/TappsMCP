   decay_model: \"exponential\"\n    52→      decay_exponent: 1.0\n    53→      confidence_floor: 0.0\n    54→      promotion_to: \"short-term\"\n    55→      promotion_threshold:\n    56→        min_access_count: 2\n    57→        min_age_days: 1\n    58→        min_confidence: 0.3\n    59→      demotion_to: null\n    60→\n    61→  scoring:\n    62→    relevance: 0.30\n    63→    confidence: 0.20\n    64→    recency: 0.30\n    65→    frequency: 0.20\n    66→    bm25_norm_k: 5.0\n    67→    frequency_cap: 20\n    68→\n    69→  source_confidence:\n    70→    human: 0.95\n    71→    agent: 0.60\n    72→    inferred: 0.40\n    73→    system: 0.90\n    74→\n    75→  source_ceilings:\n    76→    human: 0.95\n    77→    agent: 0.85\n    78→    inferred: 0.70\n    79→    system: 0.95\n    80→\n    81→  gc:\n    82→    floor_retention_days: 30\n    83→    session_expiry_days: 7\n    84→    contradicted_threshold: 0.2\n    85→    stale_threshold: 0.3\n    86→\n    87→  recall:\n    88→    default_token_budget: 3000\n    89→    default_engagement: \"high\"\n    90→    min_score: 0.3\n    91→    min_confidence: 0.1\n    92→\n    93→  limits:\n    94→    max_entries: 500\n    95→    max_key_length: 128\n    96→    max_value_length: 4096\n    97→    max_tags: 10\n    98→"}]},"parent_tool_use_id":"toolu_016KdoUJBwnaS5YhsoypjwQk","session_id":"b61393de-68e8-4cff-8475-056605bcfefe","uuid":"2fcf2375-9543-4366-8b80-49feb8eba8ea","timestamp":"2026-03-22T22:34:00.822Z"}
