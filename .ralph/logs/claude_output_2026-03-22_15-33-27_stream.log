{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01E2vaUjb3e4i1dn4DXLiwJU","type":"tool_result","content":"  1696→def _handle_profile_info(store: MemoryStore, _p: _Params) -> dict[str, Any]:\n  1697→    \"\"\"Handle the profile_info action -- show active profile details.\"\"\"\n  1698→    profile = getattr(store, \"profile\", None)\n  1699→    if profile is None:\n  1700→        return {\n  1701→            \"action\": \"profile_info\",\n  1702→            \"active_profile\": \"repo-brain\",\n  1703→            \"source\": \"default\",\n  1704→            \"layers\": [],\n  1705→            \"scoring_weights\": {},\n  1706→            \"promotion_enabled\": False,\n  1707→        }\n  1708→\n  1709→    layers = []\n  1710→    promotion_enabled = False\n  1711→    for layer in profile.layers:\n  1712→        layer_info: dict[str, Any] = {\n  1713→            \"name\": layer.name,\n  1714→            \"description\": getattr(layer, \"description\", \"\"),\n  1715→            \"half_life_days\": layer.half_life_days,\n  1716→            \"decay_model\": layer.decay_model,\n  1717→            \"confidence_floor\": layer.confidence_floor,\n  1718→        }\n  1719→        if getattr(layer, \"promotion_to\", None):\n  1720→            layer_info[\"promotion_to\"] = layer.promotion_to\n  1721→            promotion_enabled = True\n  1722→        if getattr(layer, \"demotion_to\", None):\n  1723→            layer_info[\"demotion_to\"] = layer.demotion_to\n  1724→        layers.append(layer_info)\n  1725→\n  1726→    scoring = profile.scoring\n  1727→    return {\n  1728→        \"action\": \"profile_info\",\n  1729→        \"active_profile\": profile.name,\n  1730→        \"description\": profile.description,\n  1731→        \"source\": _detect_profile_source(store),\n  1732→        \"layers\": layers,\n  1733→        \"scoring_weights\": {\n  1734→            \"relevance\": getattr(scoring, \"relevance_weight\", 0.4),\n  1735→            \"confidence\": getattr(scoring, \"confidence_weight\", 0.3),\n  1736→            \"recency\": getattr(scoring, \"recency_weight\", 0.15),\n  1737→            \"frequency\": getattr(scoring, \"frequency_weight\", 0.15),\n  1738→        },\n  1739→        \"promotion_enabled\": promotion_enabled,\n  1740→        \"limits\": {\n  1741→            \"max_entries\": getattr(profile.limits, \"max_entries\", 1500),\n  1742→            \"max_value_length\": getattr(profile.limits, \"max_value_length\", 4096),\n  1743→        },\n  1744→    }\n  1745→\n  1746→\n  1747→def _handle_profile_list(_store: MemoryStore, _p: _Params) -> dict[str, Any]:\n  1748→    \"\"\"Handle the profile_list action -- list available profiles.\"\"\"\n  1749→    try:\n  1750→        from tapps_brain.profile import get_builtin_profile, list_builtin_profiles\n  1751→    except ImportError:\n  1752→        return {\n  1753→            \"action\": \"profile_list\",\n  1754→            \"profiles\": [{\"name\": \"repo-brain\", \"description\": \"Default profile\", \"layers\": 4}],\n  1755→            \"total\": 1,\n  1756→            \"degraded\": True,\n  1757→            \"message\": \"Profile module not available in installed tapps-brain version.\",\n  1758→        }\n  1759→\n  1760→    names = list_builtin_profiles()\n  1761→    profiles = []\n  1762→    for name in names:\n  1763→        try:\n  1764→            prof = get_builtin_profile(name)\n  1765→            profiles.append({\n  1766→                \"name\": prof.name,\n  1767→                \"description\": prof.description,\n  1768→                \"layers\": len(prof.layers),\n  1769→                \"decay_models\": sorted({la.decay_model for la in prof.layers}),\n  1770→            })\n  1771→        except Exception:\n  1772→            profiles.append({\"name\": name, \"description\": \"(failed to load)\", \"layers\": 0})\n  1773→\n  1774→    return {\n  1775→        \"action\": \"profile_list\","}]},"parent_tool_use_id":null,"session_id":"b61393de-68e8-4cff-8475-056605bcfefe","uuid":"e8c302d0-6540-48b5-bce9-e2b9420be964","timestamp":"2026-03-22T22:35:29.103Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\cursor\\TappMCP\\packages\\tapps-mcp\\src\\tapps_mcp\\server_memory_tools.py","content":"def _handle_profile_info(store: MemoryStore, _p: _Params) -> dict[str, Any]:\n    \"\"\"Handle the profile_info action -- show active profile details.\"\"\"\n    profile = getattr(store, \"profile\", None)\n    if profile is None:\n        return {\n            \"action\": \"profile_info\",\n            \"active_profile\": \"repo-brain\",\n            \"source\": \"default\",\n            \"layers\": [],\n            \"scoring_weights\": {},\n            \"promotion_enabled\": False,\n        }\n\n    layers = []\n    promotion_enabled = False\n    for layer in profile.layers:\n        layer_info: dict[str, Any] = {\n            \"name\": layer.name,\n            \"description\": getattr(layer, \"description\", \"\"),\n            \"half_life_days\": layer.half_life_days,\n            \"decay_model\": layer.decay_model,\n            \"confidence_floor\": layer.confidence_floor,\n        }\n        if getattr(layer, \"promotion_to\", None):\n            layer_info[\"promotion_to\"] = layer.promotion_to\n            promotion_enabled = True\n        if getattr(layer, \"demotion_to\", None):\n            layer_info[\"demotion_to\"] = layer.demotion_to\n        layers.append(layer_info)\n\n    scoring = profile.scoring\n    return {\n        \"action\": \"profile_info\",\n        \"active_profile\": profile.name,\n        \"description\": profile.description,\n        \"source\": _detect_profile_source(store),\n        \"layers\": layers,\n        \"scoring_weights\": {\n            \"relevance\": getattr(scoring, \"relevance_weight\", 0.4),\n            \"confidence\": getattr(scoring, \"confidence_weight\", 0.3),\n            \"recency\": getattr(scoring, \"recency_weight\", 0.15),\n            \"frequency\": getattr(scoring, \"frequency_weight\", 0.15),\n        },\n        \"promotion_enabled\": promotion_enabled,\n        \"limits\": {\n            \"max_entries\": getattr(profile.limits, \"max_entries\", 1500),\n            \"max_value_length\": getattr(profile.limits, \"max_value_length\", 4096),\n        },\n    }\n\n\ndef _handle_profile_list(_store: MemoryStore, _p: _Params) -> dict[str, Any]:\n    \"\"\"Handle the profile_list action -- list available profiles.\"\"\"\n    try:\n        from tapps_brain.profile import get_builtin_profile, list_builtin_profiles\n    except ImportError:\n        return {\n            \"action\": \"profile_list\",\n            \"profiles\": [{\"name\": \"repo-brain\", \"description\": \"Default profile\", \"layers\": 4}],\n            \"total\": 1,\n            \"degraded\": True,\n            \"message\": \"Profile module not available in installed tapps-brain version.\",\n        }\n\n    names = list_builtin_profiles()\n    profiles = []\n    for name in names:\n        try:\n            prof = get_builtin_profile(name)\n            profiles.append({\n                \"name\": prof.name,\n                \"description\": prof.description,\n                \"layers\": len(prof.layers),\n                \"decay_models\": sorted({la.decay_model for la in prof.layers}),\n            })\n        except Exception:\n            profiles.append({\"name\": name, \"description\": \"(failed to load)\", \"layers\": 0})\n\n    return {\n        \"action\": \"profile_list\",","numLines":80,"startLine":1696,"totalLines":2201}}}
