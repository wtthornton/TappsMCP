{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016vUDviYmu4MF8tnU9Dywns","type":"tool_result","content":"   670→            updates = _reinforce(entry, decay_cfg, confidence_boost=confidence_boost)\n   671→            updated = entry.model_copy(update=updates)\n   672→            self._entries[key] = updated\n   673→\n   674→        self._persistence.save(updated)\n   675→\n   676→        # EPIC-010: Check promotion after reinforcement\n   677→        if self._profile is not None:\n   678→            try:\n   679→                from tapps_brain.promotion import PromotionEngine\n   680→\n   681→                engine = PromotionEngine(decay_cfg)\n   682→                target_tier = engine.check_promotion(updated, self._profile)\n   683→                if target_tier is not None:\n   684→                    old_tier = str(updated.tier)\n   685→                    promoted = updated.model_copy(\n   686→                        update={\"tier\": target_tier, \"updated_at\": _utc_now_iso()}\n   687→                    )\n   688→                    with self._lock:\n   689→                        self._entries[key] = promoted\n   690→                    self._persistence.save(promoted)\n   691→                    self._persistence.append_audit(\n   692→                        action=\"promote\",\n   693→                        key=key,\n   694→                        extra={\n   695→                            \"from_tier\": old_tier,\n   696→                            \"to_tier\": target_tier,\n   697→                            \"access_count\": updated.access_count,\n   698→                            \"reinforce_count\": updated.reinforce_count,\n   699→                        },\n   700→                    )\n   701→                    logger.info(\n   702→                        \"memory_promoted\",\n   703→                        key=key,\n   704→                        from_tier=old_tier,\n   705→                        to_tier=target_tier,\n   706→                    )\n   707→                    return promoted\n   708→            except Exception:\n   709→                logger.debug(\"promotion_check_failed\", key=key, exc_info=True)\n   710→\n   711→        return updated\n   712→\n   713→    # ------------------------------------------------------------------\n   714→    # Extraction ingestion (Story 002.3)\n   715→    # ------------------------------------------------------------------\n   716→\n   717→    def ingest_context(\n   718→        self,\n   719→        context: str,\n   720→        *,\n   721→        source: str = \"agent\",\n   722→        capture_prompt: str = \"\",\n   723→        agent_scope: str = \"private\",\n   724→    ) -> list[str]:\n   725→        \"\"\"Extract durable facts from context and save new entries.\n   726→\n   727→        Uses rule-based pattern matching to find decision-like statements\n   728→        and saves them as memory entries. Existing keys are skipped.\n   729→\n   730→        Args:\n   731→            context: Raw session/transcript text to scan.\n   732→            source: Source attribution for created entries.\n   733→            capture_prompt: Optional guidance for extraction.\n   734→            agent_scope: Hive propagation scope for captured facts —\n   735→                ``'private'`` (default), ``'domain'``, or ``'hive'``.\n   736→\n   737→        Returns:\n   738→            List of keys for newly created entries.\n   739→        \"\"\"\n   740→        from tapps_brain.extraction import extract_durable_facts\n   741→\n   742→        facts = extract_durable_facts(context, capture_prompt)\n   743→        created_keys: list[str] = []\n   744→\n   745→        for fact in facts:\n   746→            key = fact[\"key\"]\n   747→            # Skip if already exists\n   748→            with self._lock:\n   749→                if key in self._entries:\n   750→                    continue\n   751→\n   752→            result = self.save(\n   753→                key=key,\n   754→                value=fact[\"value\"],\n   755→                tier=fact[\"tier\"],\n   756→                source=source,\n   757→                agent_scope=agent_scope,\n   758→            )\n   759→            if isinstance(result, MemoryEntry):\n   760→                created_keys.append(key)\n   761→\n   762→        return created_keys\n   763→\n   764→    # ------------------------------------------------------------------\n   765→    # Session indexing (Story 002.4)\n   766→    # ------------------------------------------------------------------\n   767→\n   768→    def index_session(self, session_id: str, chunks: list[str]) -> int:\n   769→        \"\"\"Index session chunks for later search."}]},"parent_tool_use_id":"toolu_01Bx6P8eG3k7xKdAfwtembt7","session_id":"b61393de-68e8-4cff-8475-056605bcfefe","uuid":"fbf755ce-c8eb-4d3d-a394-8d3b961a7edb","timestamp":"2026-03-22T22:34:07.646Z"}
