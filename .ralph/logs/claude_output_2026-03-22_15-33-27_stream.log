{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TUanYYGfjVgcNKWLsPEK55","type":"tool_result","content":"   264→def decay_config_from_profile(profile: object) -> DecayConfig:\n   265→    \"\"\"Build a ``DecayConfig`` from a ``MemoryProfile`` instance.\n   266→\n   267→    Populates ``layer_half_lives``, ``layer_confidence_floors``,\n   268→    ``profile_source_ceilings``, and per-layer decay model overrides\n   269→    from the profile's layer definitions.\n   270→\n   271→    The four legacy ``*_half_life_days`` fields are set from matching\n   272→    layer names (architectural/pattern/procedural/context) so that code\n   273→    using the old enum-based lookup still works.\n   274→    \"\"\"\n   275→    from tapps_brain.profile import MemoryProfile\n   276→\n   277→    if not isinstance(profile, MemoryProfile):\n   278→        return DecayConfig()\n   279→\n   280→    layer_half_lives: dict[str, int] = {}\n   281→    layer_floors: dict[str, float] = {}\n   282→    layer_models: dict[str, str] = {}\n   283→    layer_exponents: dict[str, float] = {}\n   284→    layer_importance_tags: dict[str, dict[str, float]] = {}\n   285→\n   286→    for layer in profile.layers:\n   287→        layer_half_lives[layer.name] = layer.half_life_days\n   288→        layer_floors[layer.name] = layer.confidence_floor\n   289→        if layer.decay_model != \"exponential\":\n   290→            layer_models[layer.name] = layer.decay_model\n   291→        if layer.decay_exponent != 1.0:\n   292→            layer_exponents[layer.name] = layer.decay_exponent\n   293→        if layer.importance_tags:\n   294→            layer_importance_tags[layer.name] = dict(layer.importance_tags)\n   295→\n   296→    # Map legacy fields from matching layer names\n   297→    legacy: dict[str, Any] = {}\n   298→    legacy_map = {\n   299→        \"architectural\": \"architectural_half_life_days\",\n   300→        \"pattern\": \"pattern_half_life_days\",\n   301→        \"procedural\": \"procedural_half_life_days\",\n   302→        \"context\": \"context_half_life_days\",\n   303→    }\n   304→    for name, attr in legacy_map.items():\n   305→        if name in layer_half_lives:\n   306→            legacy[attr] = layer_half_lives[name]\n   307→\n   308→    # Source ceilings from profile\n   309→    ceilings = dict(profile.source_ceilings)\n   310→\n   311→    # Global confidence floor (min of all layer floors, or profile default)\n   312→    global_floor = min(layer_floors.values()) if layer_floors else 0.1\n   313→\n   314→    return DecayConfig(\n   315→        **legacy,\n   316→        confidence_floor=global_floor,\n   317→        human_confidence_ceiling=ceilings.get(\"human\", 0.95),\n   318→        agent_confidence_ceiling=ceilings.get(\"agent\", 0.85),\n   319→        inferred_confidence_ceiling=ceilings.get(\"inferred\", 0.70),\n   320→        system_confidence_ceiling=ceilings.get(\"system\", 0.95),\n   321→        layer_half_lives=layer_half_lives,\n   322→        layer_confidence_floors=layer_floors,\n   323→        profile_source_ceilings=ceilings,\n   324→        layer_decay_models=layer_models,\n   325→        layer_decay_exponents=layer_exponents,\n   326→        layer_importance_tags=layer_importance_tags,\n   327→    )\n   328→"}]},"parent_tool_use_id":"toolu_01Bx6P8eG3k7xKdAfwtembt7","session_id":"b61393de-68e8-4cff-8475-056605bcfefe","uuid":"143d3f9f-1385-4684-9f48-241cbc78490b","timestamp":"2026-03-22T22:34:19.637Z"}
