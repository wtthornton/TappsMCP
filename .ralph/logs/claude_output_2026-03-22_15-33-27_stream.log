{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018Ex2LkvkFhCnG8a5LFJv1j","type":"tool_result","content":"     1→\"\"\"Tests for the promotion and demotion engine (EPIC-010).\"\"\"\n     2→\n     3→from __future__ import annotations\n     4→\n     5→import math\n     6→from datetime import UTC, datetime\n     7→\n     8→import pytest\n     9→\n    10→from tapps_brain.decay import DecayConfig\n    11→from tapps_brain.models import MemoryTier\n    12→from tapps_brain.profile import (\n    13→    LayerDefinition,\n    14→    MemoryProfile,\n    15→    PromotionThreshold,\n    16→    ScoringConfig,\n    17→)\n    18→from tapps_brain.promotion import PromotionEngine\n    19→from tests.factories import make_entry\n    20→\n    21→# ---------------------------------------------------------------------------\n    22→# Helpers\n    23→# ---------------------------------------------------------------------------\n    24→\n    25→# Fixed reference points for deterministic tests\n    26→_JAN_1 = datetime(2025, 1, 1, tzinfo=UTC)\n    27→_JAN_15 = datetime(2025, 1, 15, tzinfo=UTC)\n    28→_JAN_1_ISO = _JAN_1.isoformat()\n    29→_JAN_15_ISO = _JAN_15.isoformat()\n    30→\n    31→\n    32→def _make_profile(layers: list[LayerDefinition]) -> MemoryProfile:\n    33→    \"\"\"Build a ``MemoryProfile`` with the given layers and valid scoring weights.\"\"\"\n    34→    return MemoryProfile(\n    35→        name=\"test-profile\",\n    36→        layers=layers,\n    37→        scoring=ScoringConfig(\n    38→            relevance=0.40,\n    39→            confidence=0.30,\n    40→            recency=0.15,\n    41→            frequency=0.15,\n    42→        ),\n    43→    )\n    44→\n    45→\n    46→# ---------------------------------------------------------------------------\n    47→# Promotion tests\n    48→# ---------------------------------------------------------------------------\n    49→\n    50→\n    51→class TestCheckPromotion:\n    52→    \"\"\"Tests for PromotionEngine.check_promotion.\"\"\"\n    53→\n    54→    def test_promotion_triggers_at_threshold(self) -> None:\n    55→        \"\"\"Entry exceeding all promotion criteria gets promoted.\"\"\"\n    56→        layers = [\n    57→            LayerDefinition(\n    58→                name=\"context\",\n    59→                half_life_days=14,\n    60→                promotion_to=\"procedural\",\n    61→                promotion_threshold=PromotionThreshold(\n    62→                    min_access_count=5,\n    63→                    min_age_days=7,\n    64→                    min_confidence=0.5,\n    65→                ),\n    66→            ),\n    67→            LayerDefinition(name=\"procedural\", half_life_days=30),\n    68→        ]\n    69→        profile = _make_profile(layers)\n    70→        # Confidence 0.8 with updated_at close to 'now' so decayed confidence\n    71→        # stays above min_confidence=0.5. Decay reference is updated_at (Jan 12),\n    72→        # only 3 days before now (Jan 15): 0.8 * 0.5^(3/14) ~ 0.69 > 0.5.\n    73→        _jan_12_iso = datetime(2025, 1, 12, tzinfo=UTC).isoformat()\n    74→        entry = make_entry(\n    75→            key=\"test-promo\",\n    76→            tier=MemoryTier.context,\n    77→            confidence=0.8,\n    78→            access_count=6,\n    79→            created_at=_JAN_1_ISO,\n    80→            updated_at=_jan_12_iso,\n    81→            last_accessed=_jan_12_iso,\n    82→        )\n    83→        engine = PromotionEngine()\n    84→        result = engine.check_promotion(entry, profile, now=_JAN_15)\n    85→        assert result == \"procedural\"\n    86→\n    87→    def test_no_promotion_below_access_count(self) -> None:\n    88→        \"\"\"Entry below min_access_count is not promoted.\"\"\"\n    89→        layers = [\n    90→            LayerDefinition(\n    91→                name=\"context\",\n    92→                half_life_days=14,\n    93→                promotion_to=\"procedural\",\n    94→                promotion_threshold=PromotionThreshold(\n    95→                    min_access_count=5,\n    96→                    min_age_days=7,\n    97→                    min_confidence=0.5,\n    98→                ),\n    99→            ),\n   100→            LayerDefinition(name=\"procedural\", half_life_days=30),\n   101→        ]\n   102→        profile = _make_profile(layers)\n   103→        entry = make_entry(\n   104→            key=\"test-below\",\n   105→            tier=MemoryTier.context,\n   106→            confidence=0.8,\n   107→            access_count=3,\n   108→            created_at=_JAN_1_ISO,\n   109→            updated_at=_JAN_1_ISO,\n   110→            last_accessed=_JAN_1_ISO,\n   111→        )\n   112→        engine = PromotionEngine()\n   113→        result = engine.check_promotion(entry, profile, now=_JAN_15)\n   114→        assert result is None\n   115→\n   116→    def test_no_promotion_without_threshold(self) -> None:\n   117→        \"\"\"Layer with no promotion_threshold returns None.\"\"\"\n   118→        layers = [\n   119→            LayerDefinition(\n   120→                name=\"context\",\n   121→                half_life_days=14,\n   122→                promotion_to=\"procedural\",\n   123→                # promotion_threshold intentionally omitted\n   124→            ),\n   125→            LayerDefinition(name=\"procedural\", half_life_days=30),\n   126→        ]\n   127→        profile = _make_profile(layers)\n   128→        entry = make_entry(\n   129→            key=\"test-no-thresh\",\n   130→            tier=MemoryTier.context,\n   131→            confidence=0.8,\n   132→            access_count=10,\n   133→            created_at=_JAN_1_ISO,\n   134→            updated_at=_JAN_1_ISO,\n   135→            last_accessed=_JAN_1_ISO,\n   136→        )\n   137→        engine = PromotionEngine()\n   138→        result = engine.check_promotion(entry, profile, now=_JAN_15)\n   139→        assert result is None\n   140→\n   141→    def test_no_promotion_at_top_tier(self) -> None:\n   142→        \"\"\"Layer with promotion_to=None returns None.\"\"\"\n   143→        layers = [\n   144→            LayerDefinition(\n   145→                name=\"architectural\",\n   146→                half_life_days=180,\n   147→                # promotion_to is None by default\n   148→                promotion_threshold=PromotionThreshold(\n   149→                    min_access_count=1,\n   150→                    min_age_days=1,\n   151→                    min_confidence=0.1,\n   152→                ),\n   153→            ),\n   154→        ]\n   155→        profile = _make_profile(layers)\n   156→        entry = make_entry(\n   157→            key=\"test-top\",\n   158→            tier=MemoryTier.architectural,\n   159→            confidence=0.9,\n   160→            access_count=20,\n   161→            created_at=_JAN_1_ISO,\n   162→            updated_at=_JAN_1_ISO,\n   163→            last_accessed=_JAN_1_ISO,\n   164→        )\n   165→        engine = PromotionEngine()\n   166→        result = engine.check_promotion(entry, profile, now=_JAN_15)\n   167→        assert result is None\n   168→\n   169→    def test_no_promotion_for_non_profile(self) -> None:\n   170→        \"\"\"Passing a non-MemoryProfile object returns None.\"\"\"\n   171→        entry = make_entry(\n   172→            key=\"test-non-profile\",\n   173→            tier=MemoryTier.context,\n   174→            confidence=0.8,\n   175→            access_count=10,\n   176→            created_at=_JAN_1_ISO,\n   177→            updated_at=_JAN_1_ISO,\n   178→            last_accessed=_JAN_1_ISO,\n   179→        )\n   180→        engine = PromotionEngine()\n   181→        result = engine.check_promotion(entry, {\"not\": \"a profile\"}, now=_JAN_15)\n   182→        assert result is None\n   183→\n   184→\n   185→# ---------------------------------------------------------------------------\n   186→# Demotion tests\n   187→# ---------------------------------------------------------------------------\n   188→\n   189→\n   190→class TestCheckDemotion:\n   191→    \"\"\"Tests for PromotionEngine.check_demotion.\"\"\"\n   192→\n   193→    def test_demotion_on_stale_entry(self) -> None:\n   194→        \"\"\"Entry with low effective confidence and no recent access is demoted.\"\"\"\n   195→        layers = [\n   196→            LayerDefinition(\n   197→                name=\"pattern\",\n   198→                half_life_days=60,\n   199→                confidence_floor=0.1,\n   200→                demotion_to=\"context\","}]},"parent_tool_use_id":"toolu_01Bx6P8eG3k7xKdAfwtembt7","session_id":"b61393de-68e8-4cff-8475-056605bcfefe","uuid":"d046daf9-3637-47d3-9325-b819e2fa6bcd","timestamp":"2026-03-22T22:34:07.890Z"}
