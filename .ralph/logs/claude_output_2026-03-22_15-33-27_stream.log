{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Jnizt3ajx19QeTHmXRjBig","type":"tool_result","content":"     1→\"\"\"Time-based decay engine for memory confidence.\n     2→\n     3→Recalculates confidence on read using exponential decay with\n     4→tier-specific half-lives. No background threads or timers -\n     5→decay is computed lazily when memories are accessed.\n     6→\"\"\"\n     7→\n     8→from __future__ import annotations\n     9→\n    10→import math\n    11→from datetime import UTC, datetime\n    12→from typing import Any\n    13→\n    14→from pydantic import BaseModel, Field\n    15→\n    16→from tapps_brain.models import MemoryEntry, MemorySource, MemoryTier\n    17→\n    18→# Default threshold below which a memory is considered stale.\n    19→_DEFAULT_STALE_THRESHOLD = 0.3\n    20→\n    21→# Seconds per day for time calculations.\n    22→_SECONDS_PER_DAY = 86400.0\n    23→\n    24→# ---------------------------------------------------------------------------\n    25→# Configuration\n    26→# ---------------------------------------------------------------------------\n    27→\n    28→\n    29→class DecayConfig(BaseModel):\n    30→    \"\"\"Configuration for memory confidence decay.\"\"\"\n    31→\n    32→    # Tier-specific half-lives (days)\n    33→    architectural_half_life_days: int = Field(default=180, ge=1)\n    34→    pattern_half_life_days: int = Field(default=60, ge=1)\n    35→    procedural_half_life_days: int = Field(\n    36→        default=30,\n    37→        ge=1,\n    38→        description=\"Epic 65.11: how-to workflows, steps (between pattern=60, context=14)\",\n    39→    )\n    40→    context_half_life_days: int = Field(default=14, ge=1)\n    41→\n    42→    # Confidence bounds\n    43→    confidence_floor: float = Field(default=0.1, ge=0.0, le=1.0)\n    44→    human_confidence_ceiling: float = Field(default=0.95, ge=0.0, le=1.0)\n    45→    agent_confidence_ceiling: float = Field(default=0.85, ge=0.0, le=1.0)\n    46→    inferred_confidence_ceiling: float = Field(default=0.70, ge=0.0, le=1.0)\n    47→    system_confidence_ceiling: float = Field(default=0.95, ge=0.0, le=1.0)\n    48→\n    49→    # Profile-based layer half-lives (EPIC-010): maps tier name → half-life\n    50→    layer_half_lives: dict[str, int] = Field(default_factory=dict)\n    51→    # Profile-based per-layer confidence floors (EPIC-010)\n    52→    layer_confidence_floors: dict[str, float] = Field(default_factory=dict)\n    53→    # Profile-based source ceilings (EPIC-010)\n    54→    profile_source_ceilings: dict[str, float] = Field(default_factory=dict)\n    55→\n    56→    # Decay model configuration (EPIC-010)\n    57→    decay_model: str = Field(default=\"exponential\")\n    58→    decay_exponent: float = Field(default=1.0, ge=0.1, le=5.0)\n    59→    # Per-layer decay model overrides (EPIC-010)\n    60→    layer_decay_models: dict[str, str] = Field(default_factory=dict)\n    61→    layer_decay_exponents: dict[str, float] = Field(default_factory=dict)\n    62→\n    63→    # Per-layer importance tags (EPIC-010)\n    64→    layer_importance_tags: dict[str, dict[str, float]] = Field(default_factory=dict)\n    65→\n    66→\n    67→# ---------------------------------------------------------------------------\n    68→# Half-life lookup\n    69→# ---------------------------------------------------------------------------\n    70→\n    71→_TIER_HALF_LIFE_ATTR: dict[MemoryTier, str] = {\n    72→    MemoryTier.architectural: \"architectural_half_life_days\",\n    73→    MemoryTier.pattern: \"pattern_half_life_days\",\n    74→    MemoryTier.procedural: \"procedural_half_life_days\",\n    75→    MemoryTier.context: \"context_half_life_days\",\n    76→}\n    77→\n    78→_SOURCE_CEILING_ATTR: dict[MemorySource, str] = {\n    79→    MemorySource.human: \"human_confidence_ceiling\",\n    80→    MemorySource.agent: \"agent_confidence_ceiling\",\n    81→    MemorySource.inferred: \"inferred_confidence_ceiling\",\n    82→    MemorySource.system: \"system_confidence_ceiling\",\n    83→}\n    84→\n    85→\n    86→# ---------------------------------------------------------------------------\n    87→# Core decay functions\n    88→# ---------------------------------------------------------------------------\n    89→\n    90→\n    91→def _get_half_life(tier: MemoryTier | str, config: DecayConfig) -> int:\n    92→    \"\"\"Return the half-life in days for a given tier.\n    93→\n    94→    Checks profile-based ``layer_half_lives`` first (EPIC-010), then\n    95→    falls back to the hardcoded ``MemoryTier`` → attribute mapping.\n    96→    \"\"\"\n    97→    tier_str = tier.value if isinstance(tier, MemoryTier) else str(tier)\n    98→\n    99→    # EPIC-010: profile-based lookup\n   100→    if tier_str in config.layer_half_lives:"}]},"parent_tool_use_id":"toolu_01Bx6P8eG3k7xKdAfwtembt7","session_id":"b61393de-68e8-4cff-8475-056605bcfefe","uuid":"c73105fe-27ae-46fa-8743-63a178a752a9","timestamp":"2026-03-22T22:34:12.918Z"}
