{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EaWE8AXAeBYrtBwd7PjANB","type":"tool_result","content":"     1→\"\"\"Reinforcement system for memory entries.\n     2→\n     3→Enables agents and humans to reinforce memories, resetting the decay\n     4→clock and optionally boosting confidence within source-based ceilings.\n     5→\"\"\"\n     6→\n     7→from __future__ import annotations\n     8→\n     9→from datetime import UTC, datetime\n    10→\n    11→import structlog\n    12→\n    13→from tapps_brain.decay import DecayConfig, _get_ceiling\n    14→from tapps_brain.models import MemoryEntry  # noqa: TC001\n    15→\n    16→logger = structlog.get_logger(__name__)\n    17→\n    18→# Maximum allowed confidence boost per reinforcement.\n    19→_MAX_CONFIDENCE_BOOST = 0.2\n    20→\n    21→\n    22→def reinforce(\n    23→    entry: MemoryEntry,\n    24→    config: DecayConfig,\n    25→    *,\n    26→    confidence_boost: float = 0.0,\n    27→    now: datetime | None = None,\n    28→) -> dict[str, object]:\n    29→    \"\"\"Reinforce a memory entry, resetting its decay clock.\n    30→\n    31→    Returns a dict of fields to update on the entry via\n    32→    ``store.update_fields()``. Does NOT mutate the entry directly.\n    33→\n    34→    Parameters:\n    35→        entry: The memory entry to reinforce.\n    36→        config: Decay configuration for ceiling enforcement.\n    37→        confidence_boost: Optional confidence increase (0.0-0.2).\n    38→        now: Override for current time (for testing).\n    39→\n    40→    Returns:\n    41→        Dict of field names to new values for ``update_fields()``.\n    42→    \"\"\"\n    43→    if now is None:\n    44→        now = datetime.now(tz=UTC)\n    45→\n    46→    # Clamp boost\n    47→    boost = max(0.0, min(confidence_boost, _MAX_CONFIDENCE_BOOST))\n    48→\n    49→    # Calculate new confidence with ceiling enforcement\n    50→    ceiling = _get_ceiling(entry.source, config)\n    51→    new_confidence = min(entry.confidence + boost, ceiling)\n    52→\n    53→    now_iso = now.isoformat()\n    54→\n    55→    return {\n    56→        \"last_reinforced\": now_iso,\n    57→        \"reinforce_count\": entry.reinforce_count + 1,\n    58→        \"confidence\": new_confidence,\n    59→        \"updated_at\": now_iso,\n    60→        \"access_count\": entry.access_count + 1,\n    61→    }\n    62→"}]},"parent_tool_use_id":"toolu_016KdoUJBwnaS5YhsoypjwQk","session_id":"b61393de-68e8-4cff-8475-056605bcfefe","uuid":"99f747fc-3d2f-4b1b-afda-9e4c01b1d0b6","timestamp":"2026-03-22T22:34:23.852Z"}
