{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KBENqtWYM73AtkcoZUF8CG","type":"tool_result","content":"     1→profile:\n     2→  name: \"repo-brain\"\n     3→  version: \"1.0\"\n     4→  description: \"Memory for code repositories and AI coding assistants\"\n     5→\n     6→  layers:\n     7→    - name: \"architectural\"\n     8→      description: \"System decisions, tech stack, infrastructure\"\n     9→      half_life_days: 180\n    10→      decay_model: \"exponential\"\n    11→      decay_exponent: 1.0\n    12→      confidence_floor: 0.10\n    13→      importance_tags:\n    14→        critical: 2.0\n    15→        security: 1.5\n    16→      promotion_to: null\n    17→      demotion_to: \"pattern\"\n    18→\n    19→    - name: \"pattern\"\n    20→      description: \"Coding conventions, API patterns, design patterns\"\n    21→      half_life_days: 60\n    22→      decay_model: \"exponential\"\n    23→      decay_exponent: 1.0\n    24→      confidence_floor: 0.10\n    25→      importance_tags:\n    26→        critical: 1.5\n    27→      promotion_to: \"architectural\"\n    28→      promotion_threshold:\n    29→        min_access_count: 10\n    30→        min_age_days: 30\n    31→        min_confidence: 0.7\n    32→      demotion_to: \"context\"\n    33→\n    34→    - name: \"procedural\"\n    35→      description: \"Workflows, deployment steps, build commands\"\n    36→      half_life_days: 30\n    37→      decay_model: \"exponential\"\n    38→      decay_exponent: 1.0\n    39→      confidence_floor: 0.10\n    40→      promotion_to: \"pattern\"\n    41→      promotion_threshold:\n    42→        min_access_count: 8\n    43→        min_age_days: 14\n    44→        min_confidence: 0.6\n    45→      demotion_to: \"context\"\n    46→\n    47→    - name: \"context\"\n    48→      description: \"Session-specific facts, current task details\"\n    49→      half_life_days: 14\n    50→      decay_model: \"exponential\"\n    51→      decay_exponent: 1.0\n    52→      confidence_floor: 0.05\n    53→      promotion_to: \"procedural\"\n    54→      promotion_threshold:\n    55→        min_access_count: 5\n    56→        min_age_days: 7\n    57→        min_confidence: 0.5\n    58→      demotion_to: null\n    59→\n    60→  scoring:\n    61→    relevance: 0.40\n    62→    confidence: 0.30\n    63→    recency: 0.15\n    64→    frequency: 0.15\n    65→    bm25_norm_k: 5.0\n    66→    frequency_cap: 20\n    67→\n    68→  source_confidence:\n    69→    human: 0.95\n    70→    agent: 0.60\n    71→    inferred: 0.40\n    72→    system: 0.90\n    73→\n    74→  source_ceilings:\n    75→    human: 0.95\n    76→    agent: 0.85\n    77→    inferred: 0.70\n    78→    system: 0.95\n    79→\n    80→  gc:\n    81→    floor_retention_days: 30\n    82→    session_expiry_days: 7\n    83→    contradicted_threshold: 0.2\n    84→    stale_threshold: 0.3\n    85→\n    86→  recall:\n    87→    default_token_budget: 2000\n    88→    default_engagement: \"high\"\n    89→    min_score: 0.3\n    90→    min_confidence: 0.1\n    91→\n    92→  limits:\n    93→    max_entries: 500\n    94→    max_key_length: 128\n    95→    max_value_length: 4096\n    96→    max_tags: 10\n    97→"}]},"parent_tool_use_id":"toolu_01Bx6P8eG3k7xKdAfwtembt7","session_id":"b61393de-68e8-4cff-8475-056605bcfefe","uuid":"aae36bed-6d81-4bf0-b455-25d1726aa1ca","timestamp":"2026-03-22T22:33:53.538Z"}
