{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HugqcCp9TxQ2EQoryrfVqG","type":"tool_result","content":"   200→        source: \"human\", \"agent\", \"inferred\", or \"system\" (default: \"agent\").\n   201→        source_agent: Agent identifier (default: \"unknown\").\n   202→        scope: \"project\", \"branch\", or \"session\" (default: \"project\").\n   203→        tags: Comma-separated tags for categorization (optional).\n   204→        branch: Git branch name (required when scope=\"branch\").\n   205→        query: Search query (for search and consolidate actions).\n   206→        confidence: Override default confidence 0.0-1.0 (optional, -1 for default).\n   207→        ranked: When True (default), search returns BM25-ranked results with scores.\n   208→        limit: Max results for search/list (0 = use defaults: 10 for search, 50 for list).\n   209→        include_summary: When True (default), list/search include one-line summaries.\n   210→        file_path: File path for import/export actions.\n   211→        overwrite: When True, import overwrites existing keys (default: False).\n   212→        entries: JSON array of objects for save_bulk action. Each object must have\n   213→            \"key\" and \"value\", and may optionally include \"tier\", \"tags\", \"scope\".\n   214→            Maximum 50 entries per call.\n   215→        entry_ids: Comma-separated entry keys for consolidate action. If provided,\n   216→            consolidates these specific entries. If not provided, uses query to find\n   217→            similar entries.\n   218→        dry_run: When True, preview consolidation without making changes (default: False).\n   219→        include_sources: When True, search/list includes source entries of consolidated\n   220→            memories (default: False). By default, entries that were consolidated into\n   221→            other entries are filtered out to avoid duplicates. (Epic 58, Story 58.5)\n   222→        safety_bypass: When True, skip content safety checks for save/save_bulk.\n   223→            Only honored when source=\"system\" or memory.safety.allow_bypass is True.\n   224→            Agent/inferred sources cannot self-bypass. (H3c)\n   225→\n   226→    Actions:\n   227→        save: Store a new memory or update an existing one.\n   228→        save_bulk: Save multiple memories in one call (requires entries parameter).\n   229→        get: Retrieve a memory by key.\n   230→        list: List all memories with optional filters.\n   231→        delete: Remove a memory by key.\n   232→        search: Full-text search across memories.\n   233→        reinforce: Boost confidence and reset decay clock for a memory (requires key).\n   234→        gc: Run garbage collection to archive stale/contradicted memories.\n   235→        contradictions: Detect memories that contradict observable project state.\n   236→        reseed: Re-seed memory from project profile (only updates auto-seeded entries).\n   237→        import: Import memories from a JSON file (requires file_path).\n   238→        export: Export memories to JSON or Markdown (format: json|markdown, optional\n   239→            file_path, tier, scope filters, include_frontmatter, group_by).\n   240→        consolidate: Merge related entries into a consolidated entry with provenance.\n   241→            Use entry_ids for explicit keys or query to find similar entries.\n   242→            Use dry_run=True to preview. (Epic 58, Story 58.4)\n   243→        unconsolidate: Undo a consolidation. Restores source entries and removes the\n   244→            consolidated entry. Requires key of the consolidated entry. (Epic 58, Story 58.6)\n   245→        federate_register: Register this project in the federation hub for cross-project sharing.\n   246→            Optional project_id (auto-detected) and tags. (Epic 64)\n   247→        federate_publish: Publish shared-scope memories to the federation hub.\n   248→            Optional key list to publish specific entries. (Epic 64)\n   249→        federate_subscribe: Subscribe to memories from other projects.\n   250→            Requires sources (comma-separated project IDs). Optional tags, min_confidence. (Epic 64)\n   251→        federate_sync: Pull subscribed memories from the hub into local store. (Epic 64)\n   252→        federate_search: Search across local and federated memories. Uses query param. (Epic 64)\n   253→        federate_status: Show federation hub status and registered projects. (Epic 64)\n   254→        validate: Validate memories against authoritative documentation via Context7. (Epic 62)\n   255→            Params: key (single), query (search), stale_only, dry_run, max_entries.\n   256→        safety_check: Pre-flight content safety validation. Checks value for prompt\n   257→            injection patterns without saving. Returns flagged patterns and match count.\n   258→            (Epic M1)\n   259→        verify_integrity: Check all memory entries for tampering. Computes content\n   260→            hashes and reports any mismatches. (Epic M1)\n   261→        profile_info: Show the active memory profile with layer details, decay config,\n   262→            scoring weights, and promotion status. (Epic M2)\n   263→        profile_list: List all available built-in profiles with descriptions. (Epic M2)\n   264→        profile_switch: Switch to a different memory profile. Pass the profile name as\n   265→            value (e.g., \"research-knowledge\"). Persists choice and resets the store. (Epic M2)\n   266→    \"\"\"\n   267→    await ensure_session_initialized()\n   268→    _record_call(\"tapps_memory\")\n   269→\n   270→    t0 = time.perf_counter()\n   271→\n   272→    if action not in _VALID_ACTIONS:\n   273→        return error_response(\n   274→            \"tapps_memory\",\n   275→            \"invalid_action\",\n   276→            f\"Invalid action '{action}'. Must be one of: {', '.join(sorted(_VALID_ACTIONS))}\",\n   277→        )\n   278→\n   279→    try:\n   280→        store = _get_memory_store()\n   281→    except Exception as exc:\n   282→        return error_response(\n   283→            \"tapps_memory\",\n   284→            \"store_init_failed\",\n   285→            f\"Failed to initialize memory store: {exc}\",\n   286→        )\n   287→\n   288→    tag_list = [t.strip() for t in tags.split(\",\") if t.strip()] if tags else []\n   289→    entry_id_list = [e.strip() for e in entry_ids.split(\",\") if e.strip()] if entry_ids else []\n   290→    source_list = [s.strip() for s in sources.split(\",\") if s.strip()] if sources else []\n   291→\n   292→    params = _Params(\n   293→        key=key,\n   294→        value=value,\n   295→        tier=tier,\n   296→        source=source,\n   297→        source_agent=source_agent,\n   298→        scope=scope,\n   299→        tag_list=tag_list,\n   300→        branch=branch,\n   301→        query=query,\n   302→        confidence=confidence,\n   303→        ranked=ranked,\n   304→        limit=limit,\n   305→        include_summary=include_summary,\n   306→        file_path=file_path,\n   307→        overwrite=overwrite,\n   308→        entries=entries,\n   309→        entry_ids=entry_id_list,\n   310→        dry_run=dry_run,\n   311→        include_sources=include_sources,\n   312→        project_id=project_id,\n   313→        sources=source_list,\n   314→        min_confidence=min_confidence,\n   315→        include_hub=include_hub,\n   316→        stale_only=stale_only,\n   317→        max_entries=max_entries,\n   318→        export_format=format,\n   319→        include_frontmatter=include_frontmatter,\n   320→        export_group_by=group_by,\n   321→        include_session_index=include_session_index,\n   322→        session_id=session_id,\n   323→        chunks=chunks,\n   324→        safety_bypass=safety_bypass,\n   325→    )\n   326→\n   327→    try:\n   328→        if action in _ASYNC_ACTIONS:\n   329→            result_data = await _ASYNC_DISPATCH[action](store, params)\n   330→        else:\n   331→            result_data = _DISPATCH[action](store, params)\n   332→    except Exception as exc:\n   333→        return error_response(\n   334→            \"tapps_memory\",\n   335→            \"action_failed\",\n   336→            f\"Memory {action} failed: {exc}\",\n   337→        )\n   338→\n   339→    elapsed = int((time.perf_counter() - t0) * 1000)\n   340→    return success_response(\"tapps_memory\", elapsed, result_data)\n   341→\n   342→\n   343→# ---------------------------------------------------------------------------\n   344→# Action handlers\n   345→# ---------------------------------------------------------------------------\n   346→\n   347→\n   348→def _handle_save(store: MemoryStore, p: _Params) -> dict[str, Any]:\n   349→    \"\"\"Handle the save action.\"\"\"\n   350→    if not p.key:\n   351→        return {\"error\": \"missing_key\", \"message\": \"Key is required for save.\"}\n   352→    if not p.value:\n   353→        return {\"error\": \"missing_value\", \"message\": \"Value is required for save.\"}\n   354→\n   355→    # --- Content safety pre-flight ---\n   356→    from tapps_core.config.settings import load_settings\n   357→\n   358→    settings = load_settings()\n   359→    enforcement = settings.memory.safety.enforcement\n   360→\n   361→    # Bypass access control (H3c): only source=\"system\" or explicit config\n   362→    # may skip safety checks. Agent/inferred sources cannot self-bypass.\n   363→    bypass_allowed = p.safety_bypass and (\n   364→        p.source == \"system\" or settings.memory.safety.allow_bypass\n   365→    )\n   366→    if p.safety_bypass and not bypass_allowed:\n   367→        logger.warning(\n   368→            \"memory_save_bypass_denied\",\n   369→            key=p.key,\n   370→            source=p.source,\n   371→            reason=\"safety_bypass requires source='system' or allow_bypass config\",\n   372→        )\n   373→\n   374→    safety_info: dict[str, Any] | None = None\n   375→    if not bypass_allowed:\n   376→        try:\n   377→            from tapps_brain.safety import check_content_safety\n   378→\n   379→            safety_result = check_content_safety(p.value)\n   380→            if not safety_result.safe:\n   381→                logger.warning(\n   382→                    \"memory_save_safety_flagged\",\n   383→                    key=p.key,\n   384→                    flagged_patterns=safety_result.flagged_patterns,\n   385→                    match_count=safety_result.match_count,\n   386→                    enforcement=enforcement,\n   387→                )\n   388→                safety_info = {\n   389→                    \"safe\": False,\n   390→                    \"flagged_patterns\": safety_result.flagged_patterns,\n   391→                    \"match_count\": safety_result.match_count,\n   392→                    \"warning\": safety_result.warning,\n   393→                    \"enforcement\": enforcement,\n   394→                }\n   395→                if enforcement == \"block\":\n   396→                    return {\n   397→                        \"error\": \"content_blocked\",\n   398→                        \"message\": (\n   399→                            \"Content flagged by safety check and enforcement is 'block'. \""}]},"parent_tool_use_id":"toolu_01Bx6P8eG3k7xKdAfwtembt7","session_id":"b61393de-68e8-4cff-8475-056605bcfefe","uuid":"daa7c2e0-26c9-4cd8-a054-990ee974f061","timestamp":"2026-03-22T22:34:10.354Z"}
