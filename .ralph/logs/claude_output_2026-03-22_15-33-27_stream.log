{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M99GhajgqKPjNzw7WPAtex","type":"tool_result","content":"     1→\"\"\"Configurable memory profiles — pluggable layers and scoring (EPIC-010).\n     2→\n     3→Defines the ``MemoryProfile`` data model and loading/resolution functions.\n     4→Profiles are YAML files that configure layer definitions (tiers), decay\n     5→parameters, scoring weights, GC thresholds, and recall defaults.\n     6→\n     7→The default ``repo-brain`` profile reproduces current hardcoded behavior\n     8→exactly, ensuring zero behavior change for existing users.\n     9→\"\"\"\n    10→\n    11→from __future__ import annotations\n    12→\n    13→import importlib.resources\n    14→from pathlib import Path\n    15→from typing import Literal\n    16→\n    17→import yaml\n    18→from pydantic import BaseModel, Field, model_validator\n    19→\n    20→# ---------------------------------------------------------------------------\n    21→# Sub-models\n    22→# ---------------------------------------------------------------------------\n    23→\n    24→\n    25→class PromotionThreshold(BaseModel):\n    26→    \"\"\"Criteria for promoting a memory to a higher layer.\"\"\"\n    27→\n    28→    min_access_count: int = Field(default=5, ge=1)\n    29→    min_age_days: int = Field(default=7, ge=1)\n    30→    min_confidence: float = Field(default=0.5, ge=0.0, le=1.0)\n    31→\n    32→\n    33→class LayerDefinition(BaseModel):\n    34→    \"\"\"A single memory layer (tier) definition within a profile.\"\"\"\n    35→\n    36→    name: str\n    37→    description: str = \"\"\n    38→    half_life_days: int = Field(ge=1)\n    39→    decay_model: Literal[\"exponential\", \"power_law\"] = \"exponential\"\n    40→    decay_exponent: float = Field(default=1.0, ge=0.1, le=5.0)\n    41→    confidence_floor: float = Field(default=0.1, ge=0.0, le=1.0)\n    42→    importance_tags: dict[str, float] = Field(default_factory=dict)\n    43→    promotion_to: str | None = None\n    44→    promotion_threshold: PromotionThreshold | None = None\n    45→    demotion_to: str | None = None\n    46→\n    47→\n    48→class ScoringConfig(BaseModel):\n    49→    \"\"\"Composite scoring weight configuration.\"\"\"\n    50→\n    51→    relevance: float = Field(default=0.40, ge=0.0, le=1.0)\n    52→    confidence: float = Field(default=0.30, ge=0.0, le=1.0)\n    53→    recency: float = Field(default=0.15, ge=0.0, le=1.0)\n    54→    frequency: float = Field(default=0.15, ge=0.0, le=1.0)\n    55→    bm25_norm_k: float = Field(default=5.0, ge=0.1)\n    56→    frequency_cap: int = Field(default=20, ge=1)\n    57→\n    58→    _WEIGHT_SUM_LO: float = 0.95\n    59→    _WEIGHT_SUM_HI: float = 1.05\n    60→\n    61→    @model_validator(mode=\"after\")\n    62→    def _weights_sum_check(self) -> ScoringConfig:\n    63→        total = self.relevance + self.confidence + self.recency + self.frequency\n    64→        if not (self._WEIGHT_SUM_LO <= total <= self._WEIGHT_SUM_HI):\n    65→            msg = (\n    66→                f\"Scoring weights must sum to ~1.0 (got {total:.3f}). \"\n    67→                f\"relevance={self.relevance}, confidence={self.confidence}, \"\n    68→                f\"recency={self.recency}, frequency={self.frequency}\"\n    69→            )\n    70→            raise ValueError(msg)\n    71→        return self\n    72→\n    73→\n    74→class GCConfig(BaseModel):\n    75→    \"\"\"Garbage collection configuration.\"\"\"\n    76→\n    77→    floor_retention_days: int = Field(default=30, ge=1)\n    78→    session_expiry_days: int = Field(default=7, ge=1)\n    79→    contradicted_threshold: float = Field(default=0.2, ge=0.0, le=1.0)\n    80→    stale_threshold: float = Field(default=0.3, ge=0.0, le=1.0)\n    81→\n    82→\n    83→class RecallProfileConfig(BaseModel):\n    84→    \"\"\"Recall / injection defaults.\"\"\"\n    85→\n    86→    default_token_budget: int = Field(default=2000, ge=100)\n    87→    default_engagement: Literal[\"low\", \"medium\", \"high\"] = \"high\"\n    88→    min_score: float = Field(default=0.3, ge=0.0, le=1.0)\n    89→    min_confidence: float = Field(default=0.1, ge=0.0, le=1.0)\n    90→\n    91→\n    92→class LimitsConfig(BaseModel):\n    93→    \"\"\"Store limits configuration.\"\"\"\n    94→\n    95→    max_entries: int = Field(default=500, ge=1)\n    96→    max_key_length: int = Field(default=128, ge=1)\n    97→    max_value_length: int = Field(default=4096, ge=1)\n    98→    max_tags: int = Field(default=10, ge=1)\n    99→\n   100→\n   101→class HiveConfig(BaseModel):\n   102→    \"\"\"Hive propagation configuration (EPIC-011).\n   103→\n   104→    Controls how memories flow between the local store and the Hive.\n   105→    When absent or all defaults, Hive is effectively disabled.\n   106→    \"\"\"\n   107→\n   108→    auto_propagate_tiers: list[str] = Field(\n   109→        default_factory=list,\n   110→        description=\"Tiers that auto-propagate to the Hive (e.g. ['architectural']).\",\n   111→    )\n   112→    private_tiers: list[str] = Field(\n   113→        default_factory=list,\n   114→        description=\"Tiers that never propagate (e.g. ['context']).\",\n   115→    )\n   116→    conflict_policy: str = Field(\n   117→        default=\"supersede\",\n   118→        description=(\n   119→            \"Conflict resolution: 'supersede' | 'source_authority'\"\n   120→            \" | 'confidence_max' | 'last_write_wins'.\"\n   121→        ),\n   122→    )\n   123→    recall_weight: float = Field(\n   124→        default=0.8,\n   125→        ge=0.0,\n   126→        le=1.0,\n   127→        description=\"Weight multiplier for Hive results in recall (0.0-1.0).\",\n   128→    )\n   129→\n   130→\n   131→# ---------------------------------------------------------------------------\n   132→# Main profile model\n   133→# ---------------------------------------------------------------------------\n   134→\n   135→_DEFAULT_SOURCE_CONFIDENCE: dict[str, float] = {\n   136→    \"human\": 0.95,\n   137→    \"agent\": 0.60,\n   138→    \"inferred\": 0.40,\n   139→    \"system\": 0.90,\n   140→}\n   141→\n   142→_DEFAULT_SOURCE_CEILINGS: dict[str, float] = {\n   143→    \"human\": 0.95,\n   144→    \"agent\": 0.85,\n   145→    \"inferred\": 0.70,\n   146→    \"system\": 0.95,\n   147→}\n   148→\n   149→\n   150→class MemoryProfile(BaseModel):\n   151→    \"\"\"A complete memory profile configuration.\n   152→\n   153→    Loaded from YAML at ``MemoryStore`` init time. The default\n   154→    ``repo-brain`` profile reproduces current hardcoded behavior exactly.\n   155→    \"\"\"\n   156→\n   157→    name: str\n   158→    version: str = \"1.0\"\n   159→    extends: str | None = None\n   160→    description: str = \"\"\n   161→    layers: list[LayerDefinition]\n   162→    scoring: ScoringConfig = Field(default_factory=ScoringConfig)\n   163→    source_confidence: dict[str, float] = Field(\n   164→        default_factory=lambda: dict(_DEFAULT_SOURCE_CONFIDENCE)\n   165→    )\n   166→    source_ceilings: dict[str, float] = Field(\n   167→        default_factory=lambda: dict(_DEFAULT_SOURCE_CEILINGS)\n   168→    )\n   169→    gc: GCConfig = Field(default_factory=GCConfig)\n   170→    recall: RecallProfileConfig = Field(default_factory=RecallProfileConfig)\n   171→    limits: LimitsConfig = Field(default_factory=LimitsConfig)\n   172→    hive: HiveConfig = Field(default_factory=HiveConfig)\n   173→\n   174→    @model_validator(mode=\"after\")\n   175→    def _validate_layers(self) -> MemoryProfile:\n   176→        names = [layer.name for layer in self.layers]\n   177→        if len(names) != len(set(names)):\n   178→            seen: set[str] = set()\n   179→            dupes = [n for n in names if n in seen or seen.add(n)]  # type: ignore[func-returns-value]\n   180→            msg = f\"Layer names must be unique. Duplicates: {dupes}\"\n   181→            raise ValueError(msg)\n   182→\n   183→        # Validate promotion/demotion targets reference existing layers\n   184→        name_set = set(names)\n   185→        for layer in self.layers:\n   186→            if layer.promotion_to and layer.promotion_to not in name_set:\n   187→                msg = (\n   188→                    f\"Layer '{layer.name}' has promotion_to='{layer.promotion_to}' \"\n   189→                    f\"which is not a defined layer.\"\n   190→                )\n   191→                raise ValueError(msg)\n   192→            if layer.demotion_to and layer.demotion_to not in name_set:\n   193→                msg = (\n   194→                    f\"Layer '{layer.name}' has demotion_to='{layer.demotion_to}' \"\n   195→                    f\"which is not a defined layer.\"\n   196→                )\n   197→                raise ValueError(msg)\n   198→        return self\n   199→\n   200→    def get_layer(self, name: str) -> LayerDefinition | None:\n   201→        \"\"\"Return the layer definition for *name*, or ``None``.\"\"\"\n   202→        for layer in self.layers:\n   203→            if layer.name == name:\n   204→                return layer\n   205→        return None\n   206→\n   207→    def get_layer_or_default(self, name: str) -> LayerDefinition:\n   208→        \"\"\"Return the layer for *name*, falling back to the shortest half-life layer.\"\"\"\n   209→        layer = self.get_layer(name)\n   210→        if layer is not None:\n   211→            return layer\n   212→        # Fallback: shortest half-life layer\n   213→        return min(self.layers, key=lambda la: la.half_life_days)\n   214→\n   215→    @property\n   216→    def layer_names(self) -> list[str]:\n   217→        \"\"\"Return the ordered list of layer names.\"\"\"\n   218→        return [layer.name for layer in self.layers]\n   219→\n   220→\n   221→# ---------------------------------------------------------------------------\n   222→# Profile loading\n   223→# ---------------------------------------------------------------------------\n   224→\n   225→_MAX_INHERITANCE_DEPTH = 3\n   226→\n   227→\n   228→def load_profile(path: Path) -> MemoryProfile:\n   229→    \"\"\"Load and validate a profile from a YAML file.\n   230→\n   231→    The YAML is expected to have a top-level ``profile`` key.\n   232→\n   233→    Raises:\n   234→        FileNotFoundError: If *path* does not exist.\n   235→        ValueError: If the YAML is invalid or fails validation.\n   236→    \"\"\"\n   237→    text = path.read_text(encoding=\"utf-8\")\n   238→    data = yaml.safe_load(text)\n   239→    if not isinstance(data, dict):\n   240→        msg = f\"Profile YAML must be a mapping, got {type(data).__name__}\"\n   241→        raise ValueError(msg)\n   242→\n   243→    profile_data = data.get(\"profile\", data)\n   244→    return MemoryProfile.model_validate(profile_data)\n   245→\n   246→\n   247→def _builtin_profiles_dir() -> Path:\n   248→    \"\"\"Return the path to the built-in profiles directory.\"\"\"\n   249→    ref = importlib.resources.files(\"tapps_brain\") / \"profiles\"\n   250→    # files() returns a Traversable; for our purposes it's always a Path\n   251→    return Path(str(ref))\n   252→\n   253→\n   254→def get_builtin_profile(name: str) -> MemoryProfile:\n   255→    \"\"\"Load a built-in profile by name.\n   256→\n   257→    Raises:\n   258→        FileNotFoundError: If no built-in profile with that name exists.\n   259→    \"\"\"\n   260→    profiles_dir = _builtin_profiles_dir()\n   261→    path = profiles_dir / f\"{name}.yaml\"\n   262→    if not path.exists():\n   263→        available = list_builtin_profiles()\n   264→        msg = f\"No built-in profile '{name}'. Available: {available}\"\n   265→        raise FileNotFoundError(msg)\n   266→    return load_profile(path)\n   267→\n   268→\n   269→def list_builtin_profiles() -> list[str]:\n   270→    \"\"\"Return the names of all available built-in profiles.\"\"\"\n   271→    profiles_dir = _builtin_profiles_dir()\n   272→    if not profiles_dir.exists():\n   273→        return []\n   274→    return sorted(p.stem for p in profiles_dir.glob(\"*.yaml\"))\n   275→\n   276→\n   277→def _merge_profiles(child: MemoryProfile, parent: MemoryProfile) -> MemoryProfile:\n   278→    \"\"\"Merge a child profile onto a parent profile.\n   279→\n   280→    Child layers with matching names replace parent layers; new child\n   281→    layers are appended. Scalar configs (scoring, gc, etc.) from the\n   282→    child override the parent.\n   283→    \"\"\"\n   284→    # Start with parent layers, override with child layers by name\n   285→    parent_layers = {la.name: la for la in parent.layers}\n   286→    for child_layer in child.layers:\n   287→        parent_layers[child_layer.name] = child_layer\n   288→    merged_layers = list(parent_layers.values())\n   289→\n   290→    # Child scalars override parent (Pydantic defaults are used if child didn't set them)\n   291→    return MemoryProfile(\n   292→        name=child.name,\n   293→        version=child.version,\n   294→        extends=None,  # Resolved — no further inheritance\n   295→        description=child.description or parent.description,\n   296→        layers=merged_layers,\n   297→        scoring=child.scoring,\n   298→        source_confidence={**parent.source_confidence, **child.source_confidence},\n   299→        source_ceilings={**parent.source_ceilings, **child.source_ceilings},\n   300→        gc=child.gc,\n   301→        recall=child.recall,\n   302→        limits=child.limits,\n   303→    )\n   304→\n   305→\n   306→def _resolve_inheritance(profile: MemoryProfile, depth: int = 0) -> MemoryProfile:\n   307→    \"\"\"Resolve profile inheritance up to ``_MAX_INHERITANCE_DEPTH``.\"\"\"\n   308→    if profile.extends is None:\n   309→        return profile\n   310→    if depth >= _MAX_INHERITANCE_DEPTH:\n   311→        msg = (\n   312→            f\"Profile inheritance depth exceeds maximum ({_MAX_INHERITANCE_DEPTH}). \"\n   313→            f\"Chain: {profile.name} extends {profile.extends}\"\n   314→        )\n   315→        raise ValueError(msg)\n   316→\n   317→    parent = get_builtin_profile(profile.extends)\n   318→    parent = _resolve_inheritance(parent, depth + 1)\n   319→    return _merge_profiles(profile, parent)\n   320→\n   321→\n   322→def resolve_profile(\n   323→    project_dir: Path,\n   324→    profile_name: str | None = None,\n   325→) -> MemoryProfile:\n   326→    \"\"\"Resolve the active profile using the resolution order.\n   327→\n   328→    Resolution order:\n   329→    1. ``{project_dir}/.tapps-brain/profile.yaml`` (project-specific)\n   330→    2. ``~/.tapps-brain/profile.yaml`` (user-global)\n   331→    3. Built-in profile by *profile_name* (default: ``repo-brain``)\n   332→\n   333→    Inheritance via ``extends`` is resolved after loading.\n   334→    \"\"\"\n   335→    # 1. Project-specific profile\n   336→    project_profile = project_dir / \".tapps-brain\" / \"profile.yaml\"\n   337→    if project_profile.exists():\n   338→        profile = load_profile(project_profile)\n   339→        return _resolve_inheritance(profile)\n   340→\n   341→    # 2. User-global profile\n   342→    user_profile = Path.home() / \".tapps-brain\" / \"profile.yaml\"\n   343→    if user_profile.exists():\n   344→        profile = load_profile(user_profile)\n   345→        return _resolve_inheritance(profile)\n   346→\n   347→    # 3. Built-in profile\n   348→    name = profile_name or \"repo-brain\"\n   349→    profile = get_builtin_profile(name)\n   350→    return _resolve_inheritance(profile)\n   351→"}]},"parent_tool_use_id":"toolu_01Bx6P8eG3k7xKdAfwtembt7","session_id":"b61393de-68e8-4cff-8475-056605bcfefe","uuid":"8f4759e4-c568-4f08-aba8-16cb0b834b08","timestamp":"2026-03-22T22:33:53.802Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BWVkAw6cTCThoFZTtUdvoG","type":"tool_result","content":"     1→\"\"\"Promotion and demotion engine for memory entries (EPIC-010).\n     2→\n     3→Checks whether a memory entry qualifies for promotion to a higher\n     4→tier or demotion to a lower tier based on the active profile's layer\n     5→definitions and access patterns.\n     6→\n     7→Key mechanisms:\n     8→- **Promotion** checked on reinforcement: if access_count, age, and\n     9→  confidence all exceed the layer's promotion threshold, entry moves up.\n    10→- **Demotion** checked during GC: if effective confidence is near the\n    11→  floor and the entry hasn't been accessed within its half-life, it\n    12→  moves down instead of being archived.\n    13→- **Desirable difficulty bonus**: reinforcement boost scales with\n    14→  ``(1.0 - decayed_confidence)`` — nearly-forgotten memories get bigger\n    15→  boosts (Roediger & Karpicke 2006).\n    16→- **Stability growth**: effective half-life grows with\n    17→  ``log1p(reinforce_count) * 0.3`` multiplier (Jost's First Law).\n    18→\"\"\"\n    19→\n    20→from __future__ import annotations\n    21→\n    22→import math\n    23→from datetime import UTC, datetime\n    24→from typing import TYPE_CHECKING\n    25→\n    26→from tapps_brain.decay import (\n    27→    DecayConfig,\n    28→    _days_since,\n    29→    calculate_decayed_confidence,\n    30→)\n    31→\n    32→if TYPE_CHECKING:\n    33→    from tapps_brain.models import MemoryEntry\n    34→\n    35→\n    36→class PromotionEngine:\n    37→    \"\"\"Evaluates promotion and demotion criteria for memory entries.\"\"\"\n    38→\n    39→    def __init__(self, config: DecayConfig | None = None) -> None:\n    40→        self._config = config or DecayConfig()\n    41→\n    42→    def check_promotion(\n    43→        self,\n    44→        entry: MemoryEntry,\n    45→        profile: object,  # MemoryProfile\n    46→        *,\n    47→        now: datetime | None = None,\n    48→    ) -> str | None:\n    49→        \"\"\"Check if *entry* qualifies for promotion.\n    50→\n    51→        Returns the target tier name if promotion criteria are met,\n    52→        or ``None`` if no promotion should occur.\n    53→\n    54→        Promotion criteria (all must be met):\n    55→        - Layer defines ``promotion_to`` (not None)\n    56→        - Layer defines ``promotion_threshold``\n    57→        - ``entry.access_count >= threshold.min_access_count``\n    58→        - ``age_days >= threshold.min_age_days``\n    59→        - ``effective_confidence >= threshold.min_confidence``\n    60→        \"\"\"\n    61→        from tapps_brain.profile import MemoryProfile\n    62→\n    63→        if not isinstance(profile, MemoryProfile):\n    64→            return None\n    65→\n    66→        tier_name = entry.tier.value if hasattr(entry.tier, \"value\") else str(entry.tier)\n    67→        layer = profile.get_layer(tier_name)\n    68→        if layer is None or layer.promotion_to is None or layer.promotion_threshold is None:\n    69→            return None\n    70→\n    71→        threshold = layer.promotion_threshold\n    72→        if now is None:\n    73→            now = datetime.now(tz=UTC)\n    74→\n    75→        # Check access count\n    76→        if entry.access_count < threshold.min_access_count:\n    77→            return None\n    78→\n    79→        # Check age\n    80→        age_days = _days_since(entry.created_at, now)\n    81→        if age_days < threshold.min_age_days:\n    82→            return None\n    83→\n    84→        # Check effective confidence\n    85→        eff_conf = calculate_decayed_confidence(entry, self._config, now=now)\n    86→        if eff_conf < threshold.min_confidence:\n    87→            return None\n    88→\n    89→        return layer.promotion_to\n    90→\n    91→    def check_demotion(\n    92→        self,\n    93→        entry: MemoryEntry,\n    94→        profile: object,  # MemoryProfile\n    95→        *,\n    96→        now: datetime | None = None,\n    97→    ) -> str | None:\n    98→        \"\"\"Check if *entry* should be demoted to a lower tier.\n    99→\n   100→        Returns the target tier name if demotion criteria are met,\n   101→        or ``None`` if no demotion should occur.\n   102→\n   103→        Demotion criteria (all must be met):\n   104→        - Layer defines ``demotion_to`` (not None)\n   105→        - Effective confidence near the confidence floor (within 1.5x)\n   106→        - No access within the layer's half-life period\n   107→        \"\"\"\n   108→        from tapps_brain.profile import MemoryProfile\n   109→\n   110→        if not isinstance(profile, MemoryProfile):\n   111→            return None\n   112→\n   113→        tier_name = entry.tier.value if hasattr(entry.tier, \"value\") else str(entry.tier)\n   114→        layer = profile.get_layer(tier_name)\n   115→        if layer is None or layer.demotion_to is None:\n   116→            return None\n   117→\n   118→        if now is None:\n   119→            now = datetime.now(tz=UTC)\n   120→\n   121→        eff_conf = calculate_decayed_confidence(entry, self._config, now=now)\n   122→\n   123→        # Near floor: effective confidence <= floor * 1.5\n   124→        if eff_conf > layer.confidence_floor * 1.5:\n   125→            return None\n   126→\n   127→        # No access within half-life period\n   128→        days_since_access = _days_since(entry.last_accessed, now)\n   129→        if days_since_access < layer.half_life_days:\n   130→            return None\n   131→\n   132→        return layer.demotion_to\n   133→\n   134→    @staticmethod\n   135→    def desirable_difficulty_bonus(\n   136→        entry: MemoryEntry,\n   137→        base_boost: float,\n   138→        config: DecayConfig,\n   139→        *,\n   140→        now: datetime | None = None,\n   141→    ) -> float:\n   142→        \"\"\"Scale reinforcement boost by how decayed the memory is.\n   143→\n   144→        Nearly-forgotten memories get bigger boosts (Roediger & Karpicke 2006).\n   145→        Returns the adjusted boost value.\n   146→        \"\"\"\n   147→        decayed = calculate_decayed_confidence(entry, config, now=now)\n   148→        difficulty_bonus = 1.0 - decayed\n   149→        return base_boost * (1.0 + difficulty_bonus)\n   150→\n   151→    @staticmethod\n   152→    def effective_half_life(base_half_life: int, reinforce_count: int) -> float:\n   153→        \"\"\"Compute effective half-life with stability growth.\n   154→\n   155→        Reinforced memories decay more slowly (Jost's First Law):\n   156→        ``base * (1.0 + log1p(reinforce_count) * 0.3)``\n   157→\n   158→        A memory with reinforce_count=10 gets base x 1.72.\n   159→        \"\"\"\n   160→        stability_growth = 1.0 + math.log1p(reinforce_count) * 0.3\n   161→        return base_half_life * stability_growth\n   162→"}]},"parent_tool_use_id":"toolu_01Bx6P8eG3k7xKdAfwtembt7","session_id":"b61393de-68e8-4cff-8475-056605bcfefe","uuid":"1a135c32-3d15-4fd7-a087-51322913739e","timestamp":"2026-03-22T22:33:53.769Z"}
