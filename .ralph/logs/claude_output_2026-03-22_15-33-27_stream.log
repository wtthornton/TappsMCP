{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01D2P7Kf1rxUysHnMyLw8mmo","type":"tool_result","content":"     1→\"\"\"In-memory cache backed by SQLite for the shared memory subsystem.\n     2→\n     3→Provides fast reads from an in-memory dict with write-through to SQLite.\n     4→RAG safety checks on save prevent prompt injection in stored content.\n     5→Auto-consolidation triggers on save when enabled (Epic 58).\n     6→\"\"\"\n     7→\n     8→from __future__ import annotations\n     9→\n    10→import sqlite3\n    11→import threading\n    12→from dataclasses import dataclass\n    13→from typing import TYPE_CHECKING, Any\n    14→\n    15→import structlog\n    16→\n    17→from tapps_brain.models import (\n    18→    MemoryEntry,\n    19→    MemoryScope,\n    20→    MemorySnapshot,\n    21→    MemorySource,\n    22→    MemoryTier,\n    23→    _utc_now_iso,\n    24→)\n    25→from tapps_brain.persistence import MemoryPersistence\n    26→\n    27→if TYPE_CHECKING:\n    28→    from pathlib import Path\n    29→\n    30→    from tapps_brain.embeddings import EmbeddingProvider\n    31→    from tapps_brain.hive import HiveStore\n    32→\n    33→from tapps_brain.metrics import MetricsCollector, MetricsSnapshot, MetricsTimer, StoreHealthReport\n    34→from tapps_brain.rate_limiter import RateLimiterConfig, SlidingWindowRateLimiter\n    35→from tapps_brain.relations import RelationEntry, extract_relations\n    36→from tapps_brain.safety import check_content_safety\n    37→\n    38→logger = structlog.get_logger(__name__)\n    39→\n    40→# Maximum number of memories per project.\n    41→_MAX_ENTRIES = 500\n    42→\n    43→# Valid Hive propagation scope values.\n    44→VALID_AGENT_SCOPES: tuple[str, ...] = (\"private\", \"domain\", \"hive\")\n    45→\n    46→# RAG safety match count threshold for blocking content.\n    47→# (moved up for visibility, original kept below for compat)\n    48→\n    49→\n    50→def _validate_write_rules(\n    51→    key: str,\n    52→    value: str,\n    53→    write_rules: Any,  # noqa: ANN401\n    54→) -> str | None:\n    55→    \"\"\"Validate memory save against write rules (Epic 65.17).\n    56→\n    57→    Returns None if valid, or an error message string if invalid.\n    58→    \"\"\"\n    59→    if write_rules is None:\n    60→        return None\n    61→\n    62→    enforced = getattr(write_rules, \"enforced\", False)\n    63→    if not enforced:\n    64→        return None\n    65→\n    66→    # Check blocked keywords\n    67→    blocked = getattr(write_rules, \"block_sensitive_keywords\", [])\n    68→    combined = f\"{key} {value}\".lower()\n    69→    for kw in blocked:\n    70→        if kw.lower() in combined:\n    71→            return f\"Blocked by write rule: contains sensitive keyword '{kw}'\"\n    72→\n    73→    # Check min length\n    74→    min_len = getattr(write_rules, \"min_value_length\", 0)\n    75→    if min_len > 0 and len(value) < min_len:\n    76→        return f\"Value too short ({len(value)} < {min_len} chars)\"\n    77→\n    78→    # Check max length\n    79→    max_len = getattr(write_rules, \"max_value_length\", 4096)\n    80→    if len(value) > max_len:\n    81→        return f\"Value too long ({len(value)} > {max_len} chars)\"\n    82→\n    83→    return None\n    84→\n    85→\n    86→# RAG safety match count threshold for blocking content.\n    87→_RAG_BLOCK_THRESHOLD = 3\n    88→\n    89→\n    90→@dataclass\n    91→class ConsolidationConfig:\n    92→    \"\"\"Configuration for auto-consolidation on save.\"\"\"\n    93→\n    94→    enabled: bool = False\n    95→    threshold: float = 0.7\n    96→    min_entries: int = 3\n    97→\n    98→    def to_dict(self) -> dict[str, object]:\n    99→        \"\"\"Return config as a plain dict.\"\"\"\n   100→        return {\n   101→            \"enabled\": self.enabled,\n   102→            \"threshold\": self.threshold,\n   103→            \"min_entries\": self.min_entries,\n   104→        }\n   105→\n   106→\n   107→class MemoryStore:\n   108→    \"\"\"In-memory cache with SQLite write-through persistence.\n   109→\n   110→    Thread-safe via ``threading.Lock``. Write-through: every mutation\n   111→    updates both the in-memory dict and SQLite synchronously.\n   112→    Auto-consolidation triggers on save when enabled (Epic 58).\n   113→    \"\"\"\n   114→\n   115→    def __init__(\n   116→        self,\n   117→        project_root: Path,\n   118→        *,\n   119→        store_dir: str = \".tapps-brain\",\n   120→        consolidation_config: ConsolidationConfig | None = None,\n   121→        embedding_provider: EmbeddingProvider | None = None,\n   122→        write_rules: Any = None,  # noqa: ANN401\n   123→        lookup_engine: Any = None,  # noqa: ANN401\n   124→        profile: Any = None,  # noqa: ANN401  # MemoryProfile | None (EPIC-010)\n   125→        hive_store: HiveStore | None = None,\n   126→        hive_agent_id: str = \"unknown\",\n   127→        rate_limiter_config: RateLimiterConfig | None = None,\n   128→    ) -> None:\n   129→        self._project_root = project_root\n   130→        self._rate_limiter = SlidingWindowRateLimiter(rate_limiter_config)\n   131→        try:\n   132→            self._persistence = MemoryPersistence(project_root, store_dir=store_dir)\n   133→        except sqlite3.DatabaseError:\n   134→            _db_path = project_root / store_dir / \"memory\" / \"memory.db\"\n   135→            logger.error(\n   136→                \"database_corrupt\",\n   137→                path=str(_db_path),\n   138→                message=f\"Database corrupt: {_db_path}. Back up and delete to recover.\",\n   139→            )\n   140→            raise\n   141→        self._lock = threading.Lock()\n   142→        self._consolidation_config = consolidation_config or ConsolidationConfig()\n   143→        self._embedding_provider = embedding_provider\n   144→        self._write_rules = write_rules\n   145→        self._lookup_engine = lookup_engine\n   146→        self._consolidation_in_progress = False\n   147→        from tapps_brain.gc import GCConfig as _GCConfig\n   148→\n   149→        self._gc_config = _GCConfig()\n   150→        self._metrics = MetricsCollector()\n   151→        self._hive_store = hive_store\n   152→        self._hive_agent_id = hive_agent_id\n   153→\n   154→        # EPIC-010: resolve and store the active profile\n   155→        self._profile = self._resolve_profile(project_root, profile)\n   156→\n   157→        # Cold-start: load all entries into memory\n   158→        self._entries: dict[str, MemoryEntry] = {}\n   159→        for entry in self._persistence.load_all():\n   160→            self._entries[entry.key] = entry\n   161→\n   162→        # Cold-start: load all relations into memory, indexed by entry key\n   163→        self._relations: dict[str, list[dict[str, Any]]] = {}\n   164→        all_relations = self._persistence.list_relations()\n   165→        for rel in all_relations:\n   166→            for src_key in rel[\"source_entry_keys\"]:\n   167→                self._relations.setdefault(src_key, []).append(rel)\n   168→\n   169→        logger.info(\n   170→            \"memory_store_initialized\",\n   171→            project_root=str(project_root),\n   172→            entry_count=len(self._entries),\n   173→            relation_count=len(all_relations),\n   174→            auto_consolidation=self._consolidation_config.enabled,\n   175→        )\n   176→\n   177→    @property\n   178→    def project_root(self) -> Path:\n   179→        \"\"\"Return the project root path.\"\"\"\n   180→        return self._project_root\n   181→\n   182→    def get_consolidation_config(self) -> ConsolidationConfig:\n   183→        \"\"\"Return the active consolidation configuration.\"\"\"\n   184→        return self._consolidation_config\n   185→\n   186→    def set_consolidation_config(self, config: ConsolidationConfig) -> None:\n   187→        \"\"\"Update the consolidation configuration.\"\"\"\n   188→        self._consolidation_config = config\n   189→\n   190→    def get_gc_config(self) -> Any:  # noqa: ANN401\n   191→        \"\"\"Return the active GCConfig instance.\"\"\"\n   192→        return self._gc_config\n   193→\n   194→    def set_gc_config(self, config: Any) -> None:  # noqa: ANN401\n   195→        \"\"\"Update the GC configuration at runtime.\"\"\"\n   196→        self._gc_config = config\n   197→\n   198→    @property\n   199→    def rate_limiter(self) -> SlidingWindowRateLimiter:\n   200→        \"\"\"Return the rate limiter instance for stats/config access.\"\"\"\n   201→        return self._rate_limiter\n   202→\n   203→    @staticmethod\n   204→    def _resolve_profile(project_root: Path, profile: Any) -> Any:  # noqa: ANN401\n   205→        \"\"\"Resolve the active memory profile (EPIC-010).\n   206→\n   207→        When *profile* is an explicit ``MemoryProfile``, use it directly.\n   208→        Otherwise, attempt resolution from project/user/built-in defaults.\n   209→        Falls back gracefully to ``None`` if the profile module isn't\n   210→        available or no profile files exist.\n   211→        \"\"\"\n   212→        if profile is not None:\n   213→            return profile\n   214→        try:\n   215→            from tapps_brain.profile import resolve_profile as _resolve\n   216→\n   217→            return _resolve(project_root)\n   218→        except Exception:\n   219→            return None\n   220→\n   221→    @property\n   222→    def profile(self) -> Any:  # noqa: ANN401\n   223→        \"\"\"Return the active ``MemoryProfile``, or ``None``.\"\"\"\n   224→        return self._profile\n   225→\n   226→    def _get_decay_config(self) -> Any:  # noqa: ANN401\n   227→        \"\"\"Return a ``DecayConfig`` derived from the active profile (EPIC-010).\"\"\"\n   228→        if self._profile is not None:\n   229→            try:\n   230→                from tapps_brain.decay import decay_config_from_profile\n   231→\n   232→                return decay_config_from_profile(self._profile)\n   233→            except Exception:\n   234→                pass\n   235→        from tapps_brain.decay import DecayConfig\n   236→\n   237→        return DecayConfig()\n   238→\n   239→    # ------------------------------------------------------------------\n   240→    # CRUD operations\n   241→    # ------------------------------------------------------------------\n   242→\n   243→    def save(\n   244→        self,\n   245→        key: str,\n   246→        value: str,\n   247→        tier: str = \"pattern\",\n   248→        source: str = \"agent\",\n   249→        source_agent: str = \"unknown\",\n   250→        scope: str = \"project\",\n   251→        tags: list[str] | None = None,\n   252→        branch: str | None = None,\n   253→        confidence: float = -1.0,\n   254→        agent_scope: str = \"private\",\n   255→        *,\n   256→        skip_consolidation: bool = False,\n   257→        batch_context: str | None = None,\n   258→    ) -> MemoryEntry | dict[str, Any]:\n   259→        \"\"\"Save or update a memory entry.\n   260→\n   261→        Returns the saved ``MemoryEntry``, or an error dict if RAG safety\n   262→        blocks the content.\n   263→\n   264→        Args:\n   265→            key: Unique identifier for the memory.\n   266→            value: Memory content.\n   267→            tier: Memory tier (architectural, pattern, context).\n   268→            source: Source of the memory (human, agent, inferred, system).\n   269→            source_agent: Identifier of the agent saving the memory.\n   270→            scope: Visibility scope (project, branch, session).\n   271→            agent_scope: Hive propagation scope (private, domain, hive).\n   272→            tags: Tags for categorization.\n   273→            branch: Git branch name (required when scope=branch).\n   274→            confidence: Confidence score (-1.0 for auto from source).\n   275→            skip_consolidation: If True, skip auto-consolidation check.\n   276→            batch_context: Operation context for rate limit exemption\n   277→                (e.g. \"import_markdown\", \"seed\", \"federation_sync\", \"consolidate\").\n   278→        \"\"\"\n   279→        # agent_scope enum validation\n   280→        if agent_scope not in VALID_AGENT_SCOPES:\n   281→            return {\n   282→                \"error\": \"invalid_agent_scope\",\n   283→                \"message\": (\n   284→                    f\"Invalid agent_scope {agent_scope!r}. Valid values: {list(VALID_AGENT_SCOPES)}\"\n   285→                ),\n   286→                \"valid_values\": list(VALID_AGENT_SCOPES),\n   287→            }\n   288→\n   289→        # Write rules validation (Epic 65.17)\n   290→        wr_error = _validate_write_rules(key, value, self._write_rules)\n   291→        if wr_error is not None:\n   292→            return {\n   293→                \"error\": \"write_rules_violation\",\n   294→                \"message\": wr_error,\n   295→            }\n   296→\n   297→        # Rate limit check (H6a) — warn-only, never blocks\n   298→        rate_result = self._rate_limiter.check(batch_context=batch_context)\n   299→        if rate_result.minute_exceeded or rate_result.session_exceeded:\n   300→            logger.warning("}]},"parent_tool_use_id":"toolu_01Bx6P8eG3k7xKdAfwtembt7","session_id":"b61393de-68e8-4cff-8475-056605bcfefe","uuid":"d82db949-6cea-4cd7-9da3-599464a6a816","timestamp":"2026-03-22T22:34:05.403Z"}
