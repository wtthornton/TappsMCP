{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JDkNjg6e7AC6d1PnbXyDEF","type":"tool_result","content":"73:    \"profile_info\",\n74:    \"profile_list\",\n75:    \"profile_switch\",\n196:            \"profile_info\", \"profile_list\", \"profile_switch\".\n261:        profile_info: Show the active memory profile with layer details, decay config,\n263:        profile_list: List all available built-in profiles with descriptions. (Epic M2)\n264:        profile_switch: Switch to a different memory profile. Pass the profile name as\n1696:def _handle_profile_info(store: MemoryStore, _p: _Params) -> dict[str, Any]:\n1697:    \"\"\"Handle the profile_info action -- show active profile details.\"\"\"\n1701:            \"action\": \"profile_info\",\n1728:        \"action\": \"profile_info\",\n1747:def _handle_profile_list(_store: MemoryStore, _p: _Params) -> dict[str, Any]:\n1748:    \"\"\"Handle the profile_list action -- list available profiles.\"\"\"\n1753:            \"action\": \"profile_list\",\n1775:        \"action\": \"profile_list\",\n1781:def _handle_profile_switch(store: MemoryStore, p: _Params) -> dict[str, Any]:\n1782:    \"\"\"Handle the profile_switch action -- switch to a different memory profile.\"\"\"\n1807:            \"action\": \"profile_switch\",\n1842:        \"action\": \"profile_switch\",\n1894:    \"profile_info\": _handle_profile_info,\n1895:    \"profile_list\": _handle_profile_list,\n1896:    \"profile_switch\": _handle_profile_switch,"}]},"parent_tool_use_id":"toolu_01Bx6P8eG3k7xKdAfwtembt7","session_id":"b61393de-68e8-4cff-8475-056605bcfefe","uuid":"7c82746f-5fc2-4290-8f4d-f95db9458956","timestamp":"2026-03-22T22:34:12.657Z"}
