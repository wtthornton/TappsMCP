{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013FZZ6gxZwtjEWvYyRAXe7p","type":"tool_result","content":"     1→\"\"\"Tests for the promotion and demotion engine (EPIC-010).\"\"\"\n     2→\n     3→from __future__ import annotations\n     4→\n     5→import math\n     6→from datetime import UTC, datetime\n     7→\n     8→import pytest\n     9→\n    10→from tapps_brain.decay import DecayConfig\n    11→from tapps_brain.models import MemoryTier\n    12→from tapps_brain.profile import (\n    13→    LayerDefinition,\n    14→    MemoryProfile,\n    15→    PromotionThreshold,\n    16→    ScoringConfig,\n    17→)\n    18→from tapps_brain.promotion import PromotionEngine\n    19→from tests.factories import make_entry\n    20→\n    21→# ---------------------------------------------------------------------------\n    22→# Helpers\n    23→# ---------------------------------------------------------------------------\n    24→\n    25→# Fixed reference points for deterministic tests\n    26→_JAN_1 = datetime(2025, 1, 1, tzinfo=UTC)\n    27→_JAN_15 = datetime(2025, 1, 15, tzinfo=UTC)\n    28→_JAN_1_ISO = _JAN_1.isoformat()\n    29→_JAN_15_ISO = _JAN_15.isoformat()\n    30→\n    31→\n    32→def _make_profile(layers: list[LayerDefinition]) -> MemoryProfile:\n    33→    \"\"\"Build a ``MemoryProfile`` with the given layers and valid scoring weights.\"\"\"\n    34→    return MemoryProfile(\n    35→        name=\"test-profile\",\n    36→        layers=layers,\n    37→        scoring=ScoringConfig(\n    38→            relevance=0.40,\n    39→            confidence=0.30,\n    40→            recency=0.15,\n    41→            frequency=0.15,\n    42→        ),\n    43→    )\n    44→\n    45→\n    46→# ---------------------------------------------------------------------------\n    47→# Promotion tests\n    48→# ---------------------------------------------------------------------------\n    49→\n    50→\n    51→class TestCheckPromotion:\n    52→    \"\"\"Tests for PromotionEngine.check_promotion.\"\"\"\n    53→\n    54→    def test_promotion_triggers_at_threshold(self) -> None:\n    55→        \"\"\"Entry exceeding all promotion criteria gets promoted.\"\"\"\n    56→        layers = [\n    57→            LayerDefinition(\n    58→                name=\"context\",\n    59→                half_life_days=14,\n    60→                promotion_to=\"procedural\",\n    61→                promotion_threshold=PromotionThreshold(\n    62→                    min_access_count=5,\n    63→                    min_age_days=7,\n    64→                    min_confidence=0.5,\n    65→                ),\n    66→            ),\n    67→            LayerDefinition(name=\"procedural\", half_life_days=30),\n    68→        ]\n    69→        profile = _make_profile(layers)\n    70→        # Confidence 0.8 with updated_at close to 'now' so decayed confidence\n    71→        # stays above min_confidence=0.5. Decay reference is updated_at (Jan 12),\n    72→        # only 3 days before now (Jan 15): 0.8 * 0.5^(3/14) ~ 0.69 > 0.5.\n    73→        _jan_12_iso = datetime(2025, 1, 12, tzinfo=UTC).isoformat()\n    74→        entry = make_entry(\n    75→            key=\"test-promo\",\n    76→            tier=MemoryTier.context,\n    77→            confidence=0.8,\n    78→            access_count=6,\n    79→            created_at=_JAN_1_ISO,\n    80→            updated_at=_jan_12_iso,\n    81→            last_accessed=_jan_12_iso,\n    82→        )\n    83→        engine = PromotionEngine()\n    84→        result = engine.check_promotion(entry, profile, now=_JAN_15)\n    85→        assert result == \"procedural\"\n    86→\n    87→    def test_no_promotion_below_access_count(self) -> None:\n    88→        \"\"\"Entry below min_access_count is not promoted.\"\"\"\n    89→        layers = [\n    90→            LayerDefinition(\n    91→                name=\"context\",\n    92→                half_life_days=14,\n    93→                promotion_to=\"procedural\",\n    94→                promotion_threshold=PromotionThreshold(\n    95→                    min_access_count=5,\n    96→                    min_age_days=7,\n    97→                    min_confidence=0.5,\n    98→                ),\n    99→            ),\n   100→            LayerDefinition(name=\"procedural\", half_life_days=30),\n   101→        ]\n   102→        profile = _make_profile(layers)\n   103→        entry = make_entry(\n   104→            key=\"test-below\",\n   105→            tier=MemoryTier.context,\n   106→            confidence=0.8,\n   107→            access_count=3,\n   108→            created_at=_JAN_1_ISO,\n   109→            updated_at=_JAN_1_ISO,\n   110→            last_accessed=_JAN_1_ISO,\n   111→        )\n   112→        engine = PromotionEngine()\n   113→        result = engine.check_promotion(entry, profile, now=_JAN_15)\n   114→        assert result is None\n   115→\n   116→    def test_no_promotion_without_threshold(self) -> None:\n   117→        \"\"\"Layer with no promotion_threshold returns None.\"\"\"\n   118→        layers = [\n   119→            LayerDefinition(\n   120→                name=\"context\",\n   121→                half_life_days=14,\n   122→                promotion_to=\"procedural\",\n   123→                # promotion_threshold intentionally omitted\n   124→            ),\n   125→            LayerDefinition(name=\"procedural\", half_life_days=30),\n   126→        ]\n   127→        profile = _make_profile(layers)\n   128→        entry = make_entry(\n   129→            key=\"test-no-thresh\",\n   130→            tier=MemoryTier.context,\n   131→            confidence=0.8,\n   132→            access_count=10,\n   133→            created_at=_JAN_1_ISO,\n   134→            updated_at=_JAN_1_ISO,\n   135→            last_accessed=_JAN_1_ISO,\n   136→        )\n   137→        engine = PromotionEngine()\n   138→        result = engine.check_promotion(entry, profile, now=_JAN_15)\n   139→        assert result is None\n   140→\n   141→    def test_no_promotion_at_top_tier(self) -> None:\n   142→        \"\"\"Layer with promotion_to=None returns None.\"\"\"\n   143→        layers = [\n   144→            LayerDefinition(\n   145→                name=\"architectural\",\n   146→                half_life_days=180,\n   147→                # promotion_to is None by default\n   148→                promotion_threshold=PromotionThreshold(\n   149→                    min_access_count=1,\n   150→                    min_age_days=1,\n   151→                    min_confidence=0.1,\n   152→                ),\n   153→            ),\n   154→        ]\n   155→        profile = _make_profile(layers)\n   156→        entry = make_entry(\n   157→            key=\"test-top\",\n   158→            tier=MemoryTier.architectural,\n   159→            confidence=0.9,\n   160→            access_count=20,\n   161→            created_at=_JAN_1_ISO,\n   162→            updated_at=_JAN_1_ISO,\n   163→            last_accessed=_JAN_1_ISO,\n   164→        )\n   165→        engine = PromotionEngine()\n   166→        result = engine.check_promotion(entry, profile, now=_JAN_15)\n   167→        assert result is None\n   168→\n   169→    def test_no_promotion_for_non_profile(self) -> None:\n   170→        \"\"\"Passing a non-MemoryProfile object returns None.\"\"\"\n   171→        entry = make_entry(\n   172→            key=\"test-non-profile\",\n   173→            tier=MemoryTier.context,\n   174→            confidence=0.8,\n   175→            access_count=10,\n   176→            created_at=_JAN_1_ISO,\n   177→            updated_at=_JAN_1_ISO,\n   178→            last_accessed=_JAN_1_ISO,\n   179→        )\n   180→        engine = PromotionEngine()\n   181→        result = engine.check_promotion(entry, {\"not\": \"a profile\"}, now=_JAN_15)\n   182→        assert result is None\n   183→\n   184→\n   185→# ---------------------------------------------------------------------------\n   186→# Demotion tests\n   187→# ---------------------------------------------------------------------------\n   188→\n   189→\n   190→class TestCheckDemotion:\n   191→    \"\"\"Tests for PromotionEngine.check_demotion.\"\"\"\n   192→\n   193→    def test_demotion_on_stale_entry(self) -> None:\n   194→        \"\"\"Entry with low effective confidence and no recent access is demoted.\"\"\"\n   195→        layers = [\n   196→            LayerDefinition(\n   197→                name=\"pattern\",\n   198→                half_life_days=60,\n   199→                confidence_floor=0.1,\n   200→                demotion_to=\"context\",\n   201→            ),\n   202→            LayerDefinition(name=\"context\", half_life_days=14),\n   203→        ]\n   204→        profile = _make_profile(layers)\n   205→        # Confidence low enough that decayed value will be near the floor.\n   206→        # confidence_floor * 1.5 = 0.15; we need decayed confidence <= 0.15.\n   207→        # Use confidence=0.15, updated 200 days ago so it decays well below floor.\n   208→        entry = make_entry(\n   209→            key=\"test-demote\",\n   210→            tier=MemoryTier.pattern,\n   211→            confidence=0.15,\n   212→            access_count=1,\n   213→            created_at=_JAN_1_ISO,\n   214→            updated_at=_JAN_1_ISO,\n   215→            last_accessed=_JAN_1_ISO,\n   216→        )\n   217→        # now = Jan 1 + 200 days; days_since_access=200 > half_life_days=60\n   218→        now = datetime(2025, 7, 20, tzinfo=UTC)\n   219→        engine = PromotionEngine()\n   220→        result = engine.check_demotion(entry, profile, now=now)\n   221→        assert result == \"context\"\n   222→\n   223→    def test_no_demotion_when_recently_accessed(self) -> None:\n   224→        \"\"\"Entry accessed within half-life period is not demoted.\"\"\"\n   225→        layers = [\n   226→            LayerDefinition(\n   227→                name=\"pattern\",\n   228→                half_life_days=60,\n   229→                confidence_floor=0.1,\n   230→                demotion_to=\"context\",\n   231→            ),\n   232→            LayerDefinition(name=\"context\", half_life_days=14),\n   233→        ]\n   234→        profile = _make_profile(layers)\n   235→        # Low confidence but accessed very recently (now == last_accessed).\n   236→        entry = make_entry(\n   237→            key=\"test-recent\",\n   238→            tier=MemoryTier.pattern,\n   239→            confidence=0.12,\n   240→            access_count=1,\n   241→            created_at=_JAN_1_ISO,\n   242→            updated_at=_JAN_1_ISO,\n   243→            last_accessed=_JAN_15_ISO,\n   244→        )\n   245→        engine = PromotionEngine()\n   246→        result = engine.check_demotion(entry, profile, now=_JAN_15)\n   247→        assert result is None\n   248→\n   249→    def test_no_demotion_when_confidence_high(self) -> None:\n   250→        \"\"\"Entry with high effective confidence is not demoted.\"\"\"\n   251→        layers = [\n   252→            LayerDefinition(\n   253→                name=\"pattern\",\n   254→                half_life_days=60,\n   255→                confidence_floor=0.1,\n   256→                demotion_to=\"context\",\n   257→            ),\n   258→            LayerDefinition(name=\"context\", half_life_days=14),\n   259→        ]\n   260→        profile = _make_profile(layers)\n   261→        entry = make_entry(\n   262→            key=\"test-high-conf\",\n   263→            tier=MemoryTier.pattern,\n   264→            confidence=0.9,\n   265→            access_count=5,\n   266→            created_at=_JAN_1_ISO,\n   267→            updated_at=_JAN_1_ISO,\n   268→            last_accessed=_JAN_1_ISO,\n   269→        )\n   270→        engine = PromotionEngine()\n   271→        # Only 14 days later: confidence ~0.9 * 0.5^(14/60) ~ 0.77 >> 0.15\n   272→        result = engine.check_demotion(entry, profile, now=_JAN_15)\n   273→        assert result is None\n   274→\n   275→    def test_no_demotion_at_bottom_tier(self) -> None:\n   276→        \"\"\"Layer with demotion_to=None returns None.\"\"\"\n   277→        layers = [\n   278→            LayerDefinition(\n   279→                name=\"context\",\n   280→                half_life_days=14,\n   281→                # demotion_to is None by default\n   282→            ),\n   283→        ]\n   284→        profile = _make_profile(layers)\n   285→        entry = make_entry(\n   286→            key=\"test-bottom\",\n   287→            tier=MemoryTier.context,\n   288→            confidence=0.12,\n   289→            access_count=0,\n   290→            created_at=_JAN_1_ISO,\n   291→            updated_at=_JAN_1_ISO,\n   292→            last_accessed=_JAN_1_ISO,\n   293→        )\n   294→        engine = PromotionEngine()\n   295→        now = datetime(2025, 7, 20, tzinfo=UTC)\n   296→        result = engine.check_demotion(entry, profile, now=now)\n   297→        assert result is None\n   298→\n   299→    def test_no_demotion_for_non_profile(self) -> None:\n   300→        \"\"\"Passing a non-MemoryProfile object returns None.\"\"\"\n   301→        entry = make_entry(\n   302→            key=\"test-non-profile-d\",\n   303→            tier=MemoryTier.pattern,\n   304→            confidence=0.12,\n   305→            access_count=0,\n   306→            created_at=_JAN_1_ISO,\n   307→            updated_at=_JAN_1_ISO,\n   308→            last_accessed=_JAN_1_ISO,\n   309→        )\n   310→        engine = PromotionEngine()\n   311→        result = engine.check_demotion(entry, \"not-a-profile\", now=_JAN_15)\n   312→        assert result is None\n   313→\n   314→\n   315→# ---------------------------------------------------------------------------\n   316→# Desirable difficulty bonus\n   317→# ---------------------------------------------------------------------------\n   318→\n   319→\n   320→class TestDesirableDifficultyBonus:\n   321→    \"\"\"Tests for PromotionEngine.desirable_difficulty_bonus.\"\"\"\n   322→\n   323→    def test_low_decayed_confidence_gets_bigger_boost(self) -> None:\n   324→        \"\"\"Nearly-forgotten memory (decayed ~0.2) gets larger boost than fresh memory.\"\"\"\n   325→        config = DecayConfig(context_half_life_days=14, confidence_floor=0.0)\n   326→        base_boost = 0.1\n   327→\n   328→        # Entry with confidence=0.2, updated at now so decayed confidence == 0.2\n   329→        entry_low = make_entry(\n   330→            key=\"test-low-decay\",\n   331→            tier=MemoryTier.context,\n   332→            confidence=0.2,\n   333→            updated_at=_JAN_15_ISO,\n   334→            last_accessed=_JAN_15_ISO,\n   335→        )\n   336→        boost_low = PromotionEngine.desirable_difficulty_bonus(\n   337→            entry_low, base_boost, config, now=_JAN_15\n   338→        )\n   339→        # decayed = 0.2 (just updated), bonus = 0.1 * (1 + (1.0 - 0.2)) = 0.1 * 1.8 = 0.18\n   340→        assert boost_low == pytest.approx(0.18, abs=0.01)\n   341→\n   342→        # Entry with confidence=0.8, updated at now so decayed confidence == 0.8\n   343→        entry_high = make_entry(\n   344→            key=\"test-high-decay\",\n   345→            tier=MemoryTier.context,\n   346→            confidence=0.8,\n   347→            updated_at=_JAN_15_ISO,\n   348→            last_accessed=_JAN_15_ISO,\n   349→        )\n   350→        boost_high = PromotionEngine.desirable_difficulty_bonus(\n   351→            entry_high, base_boost, config, now=_JAN_15\n   352→        )\n   353→        # decayed = 0.8, bonus = 0.1 * (1 + 0.2) = 0.12\n   354→        assert boost_high == pytest.approx(0.12, abs=0.01)\n   355→\n   356→        # Low-confidence entry gets a bigger boost\n   357→        assert boost_low > boost_high\n   358→\n   359→\n   360→# ---------------------------------------------------------------------------\n   361→# Effective half-life\n   362→# ---------------------------------------------------------------------------\n   363→\n   364→\n   365→class TestEffectiveHalfLife:\n   366→    \"\"\"Tests for PromotionEngine.effective_half_life.\"\"\"\n   367→\n   368→    def test_zero_reinforcements_returns_base(self) -> None:\n   369→        \"\"\"With reinforce_count=0, effective half-life equals base.\"\"\"\n   370→        base = 60\n   371→        result = PromotionEngine.effective_half_life(base, 0)\n   372→        # log1p(0) == 0, so multiplier == 1.0\n   373→        assert result == pytest.approx(60.0)\n   374→\n   375→    def test_ten_reinforcements_growth(self) -> None:\n   376→        \"\"\"With reinforce_count=10, effective half-life is ~base * 1.72.\"\"\"\n   377→        base = 60\n   378→        result = PromotionEngine.effective_half_life(base, 10)\n   379→        # 1.0 + log1p(10) * 0.3 = 1.0 + ln(11) * 0.3 ~ 1.0 + 2.3979 * 0.3 ~ 1.7194\n   380→        expected = base * (1.0 + math.log1p(10) * 0.3)\n   381→        assert result == pytest.approx(expected)\n   382→        assert result == pytest.approx(base * 1.72, abs=0.5)\n   383→\n   384→    def test_half_life_grows_monotonically(self) -> None:\n   385→        \"\"\"More reinforcements always produce longer half-lives.\"\"\"\n   386→        base = 30\n   387→        prev = PromotionEngine.effective_half_life(base, 0)\n   388→        for count in [1, 3, 5, 10, 50, 100]:\n   389→            current = PromotionEngine.effective_half_life(base, count)\n   390→            assert current > prev, f\"half-life did not grow at reinforce_count={count}\"\n   391→            prev = current\n   392→"}]},"parent_tool_use_id":"toolu_016KdoUJBwnaS5YhsoypjwQk","session_id":"b61393de-68e8-4cff-8475-056605bcfefe","uuid":"53f620e9-eee1-4b51-b3bb-6aa5eb7f3ae1","timestamp":"2026-03-22T22:34:01.281Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CFf7jgvQa2Z9mAvkzBzv5M","type":"tool_result","content":"     1→\"\"\"Template promotion gate for version management.\n     2→\n     3→Evaluates whether a candidate template version should be promoted\n     4→based on resolution rate improvements, redundancy thresholds,\n     5→sample size requirements, and significance thresholds.\n     6→\"\"\"\n     7→\n     8→from __future__ import annotations\n     9→\n    10→from typing import TYPE_CHECKING\n    11→\n    12→import structlog\n    13→from pydantic import BaseModel, ConfigDict, Field\n    14→\n    15→if TYPE_CHECKING:\n    16→    from tapps_mcp.benchmark.template_versions import TemplateVersion, TemplateVersionStore\n    17→\n    18→__all__ = [\n    19→    \"PromotionCriteria\",\n    20→    \"PromotionDecision\",\n    21→    \"auto_promote\",\n    22→    \"evaluate_promotion\",\n    23→]\n    24→\n    25→logger = structlog.get_logger(__name__)\n    26→\n    27→\n    28→# ---------------------------------------------------------------------------\n    29→# Models\n    30→# ---------------------------------------------------------------------------\n    31→\n    32→\n    33→class PromotionCriteria(BaseModel):\n    34→    \"\"\"Criteria for approving a template version promotion.\"\"\"\n    35→\n    36→    model_config = ConfigDict(frozen=True)\n    37→\n    38→    min_resolution_delta: float = Field(\n    39→        default=0.0,\n    40→        description=\"Minimum resolution rate improvement over current version.\",\n    41→    )\n    42→    max_redundancy: float = Field(\n    43→        default=0.5,\n    44→        ge=0.0,\n    45→        le=1.0,\n    46→        description=\"Maximum acceptable redundancy score.\",\n    47→    )\n    48→    min_instances_evaluated: int = Field(\n    49→        default=20,\n    50→        ge=1,\n    51→        description=\"Minimum number of instances that must be evaluated.\",\n    52→    )\n    53→    significance_threshold: float = Field(\n    54→        default=0.1,\n    55→        ge=0.0,\n    56→        description=\"Minimum absolute resolution delta to consider meaningful.\",\n    57→    )\n    58→\n    59→\n    60→class PromotionDecision(BaseModel):\n    61→    \"\"\"Decision result from promotion evaluation.\"\"\"\n    62→\n    63→    model_config = ConfigDict(frozen=True)\n    64→\n    65→    approved: bool = Field(description=\"Whether the promotion is approved.\")\n    66→    reason: str = Field(description=\"Explanation for the decision.\")\n    67→    warnings: list[str] = Field(\n    68→        default_factory=list,\n    69→        description=\"Non-blocking warnings about the candidate.\",\n    70→    )\n    71→\n    72→\n    73→# ---------------------------------------------------------------------------\n    74→# Evaluation\n    75→# ---------------------------------------------------------------------------\n    76→\n    77→\n    78→def evaluate_promotion(\n    79→    candidate: TemplateVersion,\n    80→    current: TemplateVersion | None,\n    81→    criteria: PromotionCriteria,\n    82→) -> PromotionDecision:\n    83→    \"\"\"Evaluate whether a candidate version should be promoted.\n    84→\n    85→    Checks the candidate against the promotion criteria:\n    86→    1. Candidate must have benchmark scores\n    87→    2. Enough instances must have been evaluated\n    88→    3. Resolution rate must improve over current (if present)\n    89→    4. Redundancy must be within threshold\n    90→    5. Improvement must be above significance threshold\n    91→\n    92→    Args:\n    93→        candidate: Candidate template version to evaluate.\n    94→        current: Currently promoted version (``None`` if first promotion).\n    95→        criteria: Promotion criteria to apply.\n    96→\n    97→    Returns:\n    98→        Promotion decision with approval status and reasoning.\n    99→    \"\"\"\n   100→    warnings: list[str] = []\n   101→\n   102→    # Check 1: Candidate must have benchmark scores\n   103→    if candidate.benchmark_scores is None:\n   104→        return PromotionDecision(\n   105→            approved=False,\n   106→            reason=\"Candidate has no benchmark scores recorded.\",\n   107→            warnings=warnings,\n   108→        )\n   109→\n   110→    candidate_rate = candidate.benchmark_scores.resolution_rate\n   111→    candidate_instances = candidate.benchmark_scores.total_instances\n   112→\n   113→    # Check 2: Minimum instances evaluated\n   114→    if candidate_instances < criteria.min_instances_evaluated:\n   115→        return PromotionDecision(\n   116→            approved=False,\n   117→            reason=(\n   118→                f\"Insufficient evaluation: {candidate_instances} instances \"\n   119→                f\"evaluated, minimum required is {criteria.min_instances_evaluated}.\"\n   120→            ),\n   121→            warnings=warnings,\n   122→        )\n   123→\n   124→    # Check 3: Redundancy threshold\n   125→    if candidate.redundancy_score is not None:\n   126→        if candidate.redundancy_score > criteria.max_redundancy:\n   127→            return PromotionDecision(\n   128→                approved=False,\n   129→                reason=(\n   130→                    f\"Redundancy too high: {candidate.redundancy_score:.2f} \"\n   131→                    f\"exceeds maximum of {criteria.max_redundancy:.2f}.\"\n   132→                ),\n   133→                warnings=warnings,\n   134→            )\n   135→    else:\n   136→        warnings.append(\"No redundancy score available for candidate.\")\n   137→\n   138→    # Check 4: Resolution rate improvement over current\n   139→    if current is not None and current.benchmark_scores is not None:\n   140→        current_rate = current.benchmark_scores.resolution_rate\n   141→\n   142→        delta = candidate_rate - current_rate\n   143→\n   144→        if delta < criteria.min_resolution_delta:\n   145→            return PromotionDecision(\n   146→                approved=False,\n   147→                reason=(\n   148→                    f\"Resolution rate did not improve enough: \"\n   149→                    f\"{candidate_rate:.1%} vs current {current_rate:.1%} \"\n   150→                    f\"(delta {delta:+.1%}, minimum required \"\n   151→                    f\"{criteria.min_resolution_delta:+.1%}).\"\n   152→                ),\n   153→                warnings=warnings,\n   154→            )\n   155→\n   156→        # Check 5: Significance threshold\n   157→        if abs(delta) < criteria.significance_threshold:\n   158→            warnings.append(\n   159→                f\"Resolution delta ({delta:+.1%}) is below \"\n   160→                f\"significance threshold ({criteria.significance_threshold:.1%}).\"\n   161→            )\n   162→\n   163→        reason = (\n   164→            f\"Approved: resolution rate improved from \"\n   165→            f\"{current_rate:.1%} to {candidate_rate:.1%} \"\n   166→            f\"(delta {delta:+.1%}).\"\n   167→        )\n   168→    else:\n   169→        # No current version to compare against - approve if scores exist\n   170→        reason = (\n   171→            f\"Approved: first promotion with {candidate_rate:.1%} \"\n   172→            f\"resolution rate across {candidate_instances} instances.\"\n   173→        )\n   174→        if current is None:\n   175→            warnings.append(\"No current promoted version to compare against.\")\n   176→\n   177→    logger.info(\n   178→        \"promotion_evaluated\",\n   179→        version=candidate.version,\n   180→        approved=True,\n   181→        rate=round(candidate_rate, 4),\n   182→        warnings=warnings,\n   183→    )\n   184→\n   185→    return PromotionDecision(\n   186→        approved=True,\n   187→        reason=reason,\n   188→        warnings=warnings,\n   189→    )\n   190→\n   191→\n   192→def auto_promote(\n   193→    candidate_version: int,\n   194→    store: TemplateVersionStore,\n   195→) -> bool:\n   196→    \"\"\"Automatically evaluate and promote a candidate version.\n   197→\n   198→    Looks up the candidate version, finds the current best for the\n   199→    same engagement level, evaluates against default criteria, and\n   200→    promotes if approved.\n   201→\n   202→    Args:\n   203→        candidate_version: Version number of the candidate.\n   204→        store: Template version store.\n   205→\n   206→    Returns:\n   207→        ``True`` if the version was promoted, ``False`` otherwise.\n   208→    \"\"\"\n   209→    history = store.get_history(\"\", limit=1000)\n   210→    candidate: TemplateVersion | None = None\n   211→    for v in history:\n   212→        if v.version == candidate_version:\n   213→            candidate = v\n   214→            break\n   215→\n   216→    if candidate is None:\n   217→        # Try fetching directly from the store\n   218→        all_levels = (\"high\", \"medium\", \"low\")\n   219→        for level in all_levels:\n   220→            versions = store.get_history(level, limit=1000)\n   221→            for v in versions:\n   222→                if v.version == candidate_version:\n   223→                    candidate = v\n   224→                    break\n   225→            if candidate is not None:\n   226→                break\n   227→\n   228→    if candidate is None:\n   229→        logger.warning(\n   230→            \"auto_promote_candidate_not_found\",\n   231→            version=candidate_version,\n   232→        )\n   233→        return False\n   234→\n   235→    current = store.get_best(candidate.engagement_level)\n   236→    criteria = PromotionCriteria()\n   237→    decision = evaluate_promotion(candidate, current, criteria)\n   238→\n   239→    if decision.approved:\n   240→        store.promote(candidate_version, decision.reason)\n   241→        logger.info(\n   242→            \"auto_promote_success\",\n   243→            version=candidate_version,\n   244→            reason=decision.reason,\n   245→        )\n   246→        return True\n   247→\n   248→    logger.info(\n   249→        \"auto_promote_rejected\",\n   250→        version=candidate_version,\n   251→        reason=decision.reason,\n   252→    )\n   253→    return False\n   254→"}]},"parent_tool_use_id":"toolu_01Bx6P8eG3k7xKdAfwtembt7","session_id":"b61393de-68e8-4cff-8475-056605bcfefe","uuid":"806ee445-e29e-4672-b25b-1be82381996c","timestamp":"2026-03-22T22:34:01.228Z"}
