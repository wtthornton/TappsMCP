{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01H4Jy4hme2yZdBQeatu9aDj","type":"tool_result","content":"     1→\"\"\"Garbage collection and archival for memory entries.\n     2→\n     3→Archives memories that have decayed below usefulness for sustained\n     4→periods. Archived memories are moved to a separate table and appended\n     5→to an external JSONL file for visibility.\n     6→\"\"\"\n     7→\n     8→from __future__ import annotations\n     9→\n    10→import json\n    11→from dataclasses import dataclass, field\n    12→from datetime import UTC, datetime\n    13→from typing import TYPE_CHECKING\n    14→\n    15→import structlog\n    16→from pydantic import BaseModel, Field\n    17→\n    18→from tapps_brain.decay import DecayConfig, calculate_decayed_confidence\n    19→\n    20→if TYPE_CHECKING:\n    21→    from pathlib import Path\n    22→\n    23→    from tapps_brain.models import MemoryEntry\n    24→\n    25→logger = structlog.get_logger(__name__)\n    26→\n    27→# Days a memory must remain at floor confidence before archival.\n    28→_FLOOR_RETENTION_DAYS = 30\n    29→\n    30→# Days after session end before session-scoped memories are archived.\n    31→_SESSION_EXPIRY_DAYS = 7\n    32→\n    33→# Confidence threshold for contradicted memory archival.\n    34→_CONTRADICTED_ARCHIVE_THRESHOLD = 0.2\n    35→\n    36→\n    37→# ---------------------------------------------------------------------------\n    38→# Models\n    39→# ---------------------------------------------------------------------------\n    40→\n    41→\n    42→@dataclass\n    43→class GCConfig:\n    44→    \"\"\"Runtime-configurable garbage collection thresholds.\"\"\"\n    45→\n    46→    floor_retention_days: int = field(default=_FLOOR_RETENTION_DAYS)\n    47→    session_expiry_days: int = field(default=_SESSION_EXPIRY_DAYS)\n    48→    contradicted_threshold: float = field(default=_CONTRADICTED_ARCHIVE_THRESHOLD)\n    49→\n    50→    def to_dict(self) -> dict[str, object]:\n    51→        \"\"\"Return config as a plain dict.\"\"\"\n    52→        return {\n    53→            \"floor_retention_days\": self.floor_retention_days,\n    54→            \"session_expiry_days\": self.session_expiry_days,\n    55→            \"contradicted_threshold\": self.contradicted_threshold,\n    56→        }\n    57→\n    58→\n    59→class GCResult(BaseModel):\n    60→    \"\"\"Result of a garbage collection run.\"\"\"\n    61→\n    62→    archived_count: int = Field(default=0, ge=0)\n    63→    remaining_count: int = Field(default=0, ge=0)\n    64→    archived_keys: list[str] = Field(default_factory=list)\n    65→\n    66→\n    67→# ---------------------------------------------------------------------------\n    68→# Collector\n    69→# ---------------------------------------------------------------------------\n    70→\n    71→\n    72→class MemoryGarbageCollector:\n    73→    \"\"\"Archives stale memories from the active store.\"\"\"\n    74→\n    75→    def __init__(\n    76→        self,\n    77→        config: DecayConfig | None = None,\n    78→        *,\n    79→        floor_retention_days: int | None = None,\n    80→        session_expiry_days: int | None = None,\n    81→        contradicted_threshold: float | None = None,\n    82→        gc_config: GCConfig | None = None,\n    83→    ) -> None:\n    84→        self._config = config or DecayConfig()\n    85→        # GCConfig takes precedence; individual kwargs override its defaults.\n    86→        _gc = gc_config or GCConfig()\n    87→        self._floor_retention_days = (\n    88→            floor_retention_days if floor_retention_days is not None else _gc.floor_retention_days\n    89→        )\n    90→        self._session_expiry_days = (\n    91→            session_expiry_days if session_expiry_days is not None else _gc.session_expiry_days\n    92→        )\n    93→        self._contradicted_threshold = (\n    94→            contradicted_threshold\n    95→            if contradicted_threshold is not None\n    96→            else _gc.contradicted_threshold\n    97→        )\n    98→\n    99→    def identify_candidates(\n   100→        self,\n   101→        entries: list[MemoryEntry],\n   102→        *,\n   103→        now: datetime | None = None,\n   104→    ) -> list[MemoryEntry]:\n   105→        \"\"\"Return entries that should be archived.\n   106→\n   107→        Archive criteria (any one triggers archival):\n   108→        - Effective confidence <= floor for 30+ consecutive days\n   109→        - Contradicted AND effective confidence < 0.2\n   110→        - Session-scoped AND session ended 7+ days ago\n   111→        \"\"\"\n   112→        if now is None:\n   113→            now = datetime.now(tz=UTC)\n   114→\n   115→        candidates: list[MemoryEntry] = []\n   116→        for entry in entries:\n   117→            if self._should_archive(entry, now):\n   118→                candidates.append(entry)\n   119→        return candidates\n   120→\n   121→    def _should_archive(self, entry: MemoryEntry, now: datetime) -> bool:\n   122→        \"\"\"Check if a single entry meets any archival criterion.\"\"\"\n   123→        effective = calculate_decayed_confidence(entry, self._config, now=now)\n   124→\n   125→        # Criterion 1: at floor confidence for extended period\n   126→        if effective <= self._config.confidence_floor:\n   127→            days_at_floor = self._days_at_floor(entry, now)\n   128→            if days_at_floor >= self._floor_retention_days:\n   129→                return True\n   130→\n   131→        # Criterion 2: contradicted and low confidence\n   132→        if entry.contradicted and effective < self._contradicted_threshold:\n   133→            return True\n   134→\n   135→        # Criterion 3: expired session-scoped memory\n   136→        if entry.scope == \"session\":\n   137→            days_since_update = _days_since_timestamp(entry.updated_at, now)\n   138→            if days_since_update >= self._session_expiry_days:\n   139→                return True\n   140→\n   141→        return False\n   142→\n   143→    def _days_at_floor(self, entry: MemoryEntry, now: datetime) -> float:\n   144→        \"\"\"Estimate how long a memory has been at the confidence floor.\n   145→\n   146→        Uses the decay formula in reverse to find when confidence\n   147→        first reached the floor.\n   148→        \"\"\"\n   149→        from tapps_brain.decay import _days_since, _decay_reference_time, _get_half_life\n   150→\n   151→        half_life = _get_half_life(entry.tier, self._config)\n   152→        ref_time = _decay_reference_time(entry)\n   153→        total_days = _days_since(ref_time, now)\n   154→\n   155→        if entry.confidence <= 0 or self._config.confidence_floor <= 0:\n   156→            return total_days\n   157→\n   158→        # Solve: floor = confidence * 0.5^(days_to_floor / half_life)\n   159→        # days_to_floor = half_life * log2(confidence / floor)\n   160→        import math\n   161→\n   162→        ratio = entry.confidence / self._config.confidence_floor\n   163→        if ratio <= 1.0:\n   164→            return total_days  # was already at or below floor from the start\n   165→\n   166→        days_to_floor = half_life * math.log2(ratio)\n   167→        return max(total_days - days_to_floor, 0.0)\n   168→\n   169→    @staticmethod\n   170→    def append_to_archive(\n   171→        entries: list[MemoryEntry],\n   172→        archive_path: Path,\n   173→    ) -> None:\n   174→        \"\"\"Append archived entries to a JSONL file for external visibility.\"\"\"\n   175→        archive_path.parent.mkdir(parents=True, exist_ok=True)\n   176→        now_iso = datetime.now(tz=UTC).isoformat()\n   177→\n   178→        try:\n   179→            with archive_path.open(\"a\", encoding=\"utf-8\") as fh:\n   180→                for entry in entries:\n   181→                    record = entry.model_dump()\n   182→                    record[\"archived_at\"] = now_iso\n   183→                    fh.write(json.dumps(record, ensure_ascii=False) + \"\\n\")\n   184→        except OSError:\n   185→            logger.warning(\"archive_write_failed\", path=str(archive_path), exc_info=True)\n   186→\n   187→\n   188→# ---------------------------------------------------------------------------\n   189→# Helpers\n   190→# ---------------------------------------------------------------------------\n   191→\n   192→\n   193→def _days_since_timestamp(iso_timestamp: str, now: datetime) -> float:\n   194→    \"\"\"Return fractional days since an ISO-8601 timestamp.\"\"\"\n   195→    try:\n   196→        ts = datetime.fromisoformat(iso_timestamp)\n   197→        if ts.tzinfo is None:\n   198→            ts = ts.replace(tzinfo=UTC)\n   199→    except (ValueError, TypeError):\n   200→        return 0.0"}]},"parent_tool_use_id":"toolu_016KdoUJBwnaS5YhsoypjwQk","session_id":"b61393de-68e8-4cff-8475-056605bcfefe","uuid":"5f088987-65ac-4385-9d3d-e38c9bbbf305","timestamp":"2026-03-22T22:34:10.601Z"}
