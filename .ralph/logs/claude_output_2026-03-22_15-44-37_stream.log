{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SJSisUo4YjjymkLJwEN3na","type":"tool_result","content":"   566→    def search(\n   567→        self,\n   568→        query: str,\n   569→        tags: list[str] | None = None,\n   570→        tier: str | None = None,\n   571→        scope: str | None = None,\n   572→        as_of: str | None = None,\n   573→    ) -> list[MemoryEntry]:\n   574→        \"\"\"Search via FTS5, with optional post-filters.\n   575→\n   576→        Args:\n   577→            query: Search query string.\n   578→            tags: Filter by tags.\n   579→            tier: Filter by tier.\n   580→            scope: Filter by scope.\n   581→            as_of: ISO-8601 timestamp for point-in-time temporal filtering.\n   582→                When set, only entries valid at that time are returned.\n   583→                When ``None`` (default), temporally invalid entries are excluded\n   584→                using the current time.\n   585→        \"\"\"\n   586→        self._metrics.increment(\"store.search\")\n   587→        with MetricsTimer(self._metrics, \"store.search_ms\"):\n   588→            results = self._persistence.search(query)\n   589→\n   590→            if tier is not None:\n   591→                results = [r for r in results if r.tier == tier]\n   592→            if scope is not None:\n   593→                results = [r for r in results if r.scope == scope]\n   594→            if tags:\n   595→                tag_set = set(tags)\n   596→                results = [r for r in results if tag_set.intersection(r.tags)]\n   597→\n   598→            # Temporal filtering (EPIC-004)\n   599→            results = [r for r in results if r.is_temporally_valid(as_of)]\n   600→\n   601→            self._metrics.increment(\"store.search.results\", len(results))\n   602→            return results\n   603→\n   604→    def update_fields(self, key: str, **fields: Any) -> MemoryEntry | None:  # noqa: ANN401\n   605→        \"\"\"Partial update of specific fields on an existing entry.\n   606→\n   607→        Preserves immutable fields like ``created_at``. Used by Epic 24\n   608→        decay/contradiction/reinforcement systems.\n   609→        \"\"\"\n   610→        with self._lock:\n   611→            entry = self._entries.get(key)\n   612→            if entry is None:\n   613→                return None\n   614→\n   615→            fields[\"updated_at\"] = _utc_now_iso()\n   616→            updated = entry.model_copy(update=fields)\n   617→            self._entries[key] = updated\n   618→\n   619→        self._persistence.save(updated)\n   620→        return updated\n   621→\n   622→    def count(self) -> int:\n   623→        \"\"\"Return the total number of memory entries.\"\"\"\n   624→        with self._lock:\n   625→            return len(self._entries)\n   626→\n   627→    def snapshot(self) -> MemorySnapshot:\n   628→        \"\"\"Return a serializable snapshot of the full memory state.\"\"\"\n   629→        with self._lock:\n   630→            entries = list(self._entries.values())\n   631→\n   632→        tier_counts: dict[str, int] = {}\n   633→        for entry in entries:\n   634→            tier_val = entry.tier.value if isinstance(entry.tier, MemoryTier) else str(entry.tier)\n   635→            tier_counts[tier_val] = tier_counts.get(tier_val, 0) + 1\n   636→\n   637→        return MemorySnapshot(\n   638→            project_root=str(self._project_root),\n   639→            entries=entries,\n   640→            total_count=len(entries),\n   641→            tier_counts=tier_counts,\n   642→        )\n   643→\n   644→    # ------------------------------------------------------------------\n   645→    # Reinforcement (Story 002.2)\n   646→    # ------------------------------------------------------------------\n   647→\n   648→    def reinforce(self, key: str, *, confidence_boost: float = 0.0) -> MemoryEntry:\n   649→        \"\"\"Reinforce a memory entry, resetting its decay clock atomically.\n   650→\n   651→        Args:\n   652→            key: The memory entry key to reinforce.\n   653→            confidence_boost: Optional confidence increase (0.0-0.2).\n   654→\n   655→        Returns:\n   656→            The updated ``MemoryEntry``.\n   657→\n   658→        Raises:\n   659→            KeyError: If the entry does not exist.\n   660→        \"\"\"\n   661→        from tapps_brain.reinforcement import reinforce as _reinforce\n   662→\n   663→        decay_cfg = self._get_decay_config()\n   664→\n   665→        with self._lock:\n   666→            entry = self._entries.get(key)\n   667→            if entry is None:\n   668→                raise KeyError(key)\n   669→\n   670→            updates = _reinforce(entry, decay_cfg, confidence_boost=confidence_boost)\n   671→            updated = entry.model_copy(update=updates)\n   672→            self._entries[key] = updated\n   673→\n   674→        self._persistence.save(updated)\n   675→\n   676→        # EPIC-010: Check promotion after reinforcement\n   677→        if self._profile is not None:\n   678→            try:\n   679→                from tapps_brain.promotion import PromotionEngine\n   680→\n   681→                engine = PromotionEngine(decay_cfg)\n   682→                target_tier = engine.check_promotion(updated, self._profile)\n   683→                if target_tier is not None:\n   684→                    old_tier = str(updated.tier)\n   685→                    promoted = updated.model_copy("}]},"parent_tool_use_id":"toolu_01GMYqRL7Arce5h4vZrADgHe","session_id":"4c2bbd2a-1a06-4e1e-9000-d7a8b9bf3b8b","uuid":"96ac2725-04f3-4d45-bfc9-5874753bf47d","timestamp":"2026-03-22T22:47:06.117Z"}
