{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015gA9cS7h4uQNrvpuYfRqFt","type":"tool_result","content":"     1→\"\"\"Optional reranker for memory retrieval (Epic 65.9).\n     2→\n     3→Cross-encoder reranking improves precision after BM25/hybrid retrieval.\n     4→Pass top-20 candidates to reranker and return reranked top_k.\n     5→\n     6→Providers: noop (passthrough), cohere (API, optional dependency).\n     7→\"\"\"\n     8→\n     9→from __future__ import annotations\n    10→\n    11→import importlib.util\n    12→from typing import Protocol, runtime_checkable\n    13→\n    14→import structlog\n    15→\n    16→logger = structlog.get_logger(__name__)\n    17→\n    18→# Top candidates to pass to reranker (Epic 65.9)\n    19→RERANKER_TOP_CANDIDATES = 20\n    20→\n    21→\n    22→@runtime_checkable\n    23→class Reranker(Protocol):\n    24→    \"\"\"Protocol for memory reranking.\n    25→\n    26→    Input: query, list of (entry_key, value) pairs.\n    27→    Output: top_k (entry_key, relevance_score) pairs, ordered by relevance.\n    28→    \"\"\"\n    29→\n    30→    def rerank(\n    31→        self,\n    32→        query: str,\n    33→        candidates: list[tuple[str, str]],\n    34→        top_k: int,\n    35→    ) -> list[tuple[str, float]]:\n    36→        \"\"\"Rerank candidates by relevance to the query.\n    37→\n    38→        Args:\n    39→            query: Search query.\n    40→            candidates: List of (entry_key, value) pairs.\n    41→            top_k: Maximum number of results to return.\n    42→\n    43→        Returns:\n    44→            List of (entry_key, score) pairs, ordered by relevance descending.\n    45→        \"\"\"\n    46→        ...\n    47→\n    48→\n    49→class NoopReranker:\n    50→    \"\"\"Passthrough reranker that preserves order and assigns scores from position.\"\"\"\n    51→\n    52→    def rerank(\n    53→        self,\n    54→        query: str,\n    55→        candidates: list[tuple[str, str]],\n    56→        top_k: int,\n    57→    ) -> list[tuple[str, float]]:\n    58→        \"\"\"Return top_k candidates in order with position-based scores.\n    59→\n    60→        Score = 1.0 - (index / max(1, len(candidates))) to preserve ranking.\n    61→        \"\"\"\n    62→        result: list[tuple[str, float]] = []\n    63→        n = max(1, len(candidates))\n    64→        for i, (key, _) in enumerate(candidates[:top_k]):\n    65→            score = 1.0 - (i / n)\n    66→            result.append((key, round(score, 4)))\n    67→        return result\n    68→\n    69→\n    70→def _create_cohere_reranker(\n    71→    api_key: str,\n    72→    model: str = \"rerank-v3.5\",\n    73→) -> CohereReranker | None:\n    74→    \"\"\"Create CohereReranker if cohere is available.\"\"\"\n    75→    if importlib.util.find_spec(\"cohere\") is None:\n    76→        logger.debug(\"cohere_reranker_unavailable\", reason=\"cohere package not installed\")\n    77→        return None\n    78→    return CohereReranker(api_key=api_key, model=model)\n    79→\n    80→\n    81→class CohereReranker:\n    82→    \"\"\"Cohere API reranker for memory retrieval.\n    83→\n    84→    Requires: pip install cohere\n    85→    API key: memory.reranker.api_key or COHERE_API_KEY env.\n    86→    \"\"\"\n    87→\n    88→    def __init__(self, api_key: str, model: str = \"rerank-v3.5\") -> None:\n    89→        self._api_key = api_key\n    90→        self._model = model\n    91→\n    92→    def rerank(\n    93→        self,\n    94→        query: str,\n    95→        candidates: list[tuple[str, str]],\n    96→        top_k: int,\n    97→    ) -> list[tuple[str, float]]:\n    98→        \"\"\"Rerank candidates using Cohere Rerank API.\"\"\"\n    99→        if not candidates:\n   100→            return []\n   101→        if not self._api_key:\n   102→            logger.debug(\"cohere_reranker_skipped\", reason=\"no_api_key\")\n   103→            return _noop_fallback(candidates, top_k)\n   104→\n   105→        try:\n   106→            import cohere\n   107→        except ImportError:\n   108→            logger.debug(\"cohere_reranker_fallback\", reason=\"cohere not installed\")\n   109→            return _noop_fallback(candidates, top_k)\n   110→\n   111→        keys = [k for k, _ in candidates]\n   112→        documents = [v for _, v in candidates]\n   113→        effective_top_k = min(top_k, len(candidates))\n   114→\n   115→        try:\n   116→            # Support both Client (v1) and ClientV2\n   117→            if hasattr(cohere, \"ClientV2\"):\n   118→                client = cohere.ClientV2(api_key=self._api_key)\n   119→                response = client.rerank(\n   120→                    model=self._model,\n   121→                    query=query,\n   122→                    documents=documents,\n   123→                    top_n=effective_top_k,\n   124→                )\n   125→            else:\n   126→                client = cohere.Client(api_key=self._api_key)\n   127→                response = client.rerank(\n   128→                    model=self._model,\n   129→                    query=query,\n   130→                    documents=documents,\n   131→                    top_n=effective_top_k,\n   132→                )\n   133→        except Exception as e:\n   134→            logger.warning(\n   135→                \"cohere_reranker_failed\",\n   136→                reason=str(e),\n   137→                fallback=\"noop\",\n   138→            )\n   139→            return _noop_fallback(candidates, top_k)\n   140→\n   141→        # Cohere returns results with index and relevance_score\n   142→        result: list[tuple[str, float]] = []\n   143→        for item in response.results:\n   144→            idx = item.index\n   145→            if 0 <= idx < len(keys):\n   146→                score = float(getattr(item, \"relevance_score\", 1.0))\n   147→                result.append((keys[idx], round(score, 4)))\n   148→        return result\n   149→\n   150→\n   151→def _noop_fallback(\n   152→    candidates: list[tuple[str, str]],\n   153→    top_k: int,\n   154→) -> list[tuple[str, float]]:\n   155→    \"\"\"Fallback when reranker fails: preserve order, assign position scores.\"\"\"\n   156→    return NoopReranker().rerank(\"\", candidates, top_k)\n   157→\n   158→\n   159→def get_reranker(\n   160→    enabled: bool,\n   161→    provider: str,\n   162→    top_k: int = 10,\n   163→    api_key: str | None = None,\n   164→) -> Reranker:\n   165→    \"\"\"Create a Reranker from config.\n   166→\n   167→    Args:\n   168→        enabled: Whether reranking is enabled.\n   169→        provider: \"noop\" or \"cohere\".\n   170→        top_k: Default top_k for reranking.\n   171→        api_key: API key for Cohere (required when provider=cohere).\n   172→\n   173→    Returns:\n   174→        NoopReranker when disabled or provider=noop; CohereReranker when\n   175→        provider=cohere and api_key set; otherwise NoopReranker.\n   176→    \"\"\"\n   177→    if not enabled:\n   178→        return NoopReranker()\n   179→\n   180→    if provider == \"cohere\" and api_key:\n   181→        cohere_reranker = _create_cohere_reranker(api_key)\n   182→        if cohere_reranker is not None:\n   183→            return cohere_reranker\n   184→        logger.debug(\"cohere_reranker_fallback_to_noop\", reason=\"unavailable\")\n   185→\n   186→    return NoopReranker()\n   187→"}]},"parent_tool_use_id":"toolu_01GMYqRL7Arce5h4vZrADgHe","session_id":"4c2bbd2a-1a06-4e1e-9000-d7a8b9bf3b8b","uuid":"c890133b-28cf-465c-b8ad-d68fd2e0a775","timestamp":"2026-03-22T22:47:08.296Z"}
