{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PKy8BzWCcx1VHzqHB1V1We","type":"tool_result","content":"     1→\"\"\"Shared test fixtures for tapps-brain.\"\"\"\n     2→\n     3→from __future__ import annotations\n     4→\n     5→import importlib.util\n     6→from typing import TYPE_CHECKING\n     7→\n     8→import pytest\n     9→\n    10→if TYPE_CHECKING:\n    11→    from pathlib import Path\n    12→\n    13→_HAS_TYPER = importlib.util.find_spec(\"typer\") is not None\n    14→_HAS_MCP = importlib.util.find_spec(\"mcp\") is not None\n    15→\n    16→\n    17→def pytest_collection_modifyitems(config, items):\n    18→    \"\"\"Auto-skip tests marked requires_cli / requires_mcp when extras are missing.\"\"\"\n    19→    skip_cli = pytest.mark.skip(reason=\"requires [cli] extra (typer)\")\n    20→    skip_mcp = pytest.mark.skip(reason=\"requires [mcp] extra (mcp)\")\n    21→    for item in items:\n    22→        if \"requires_cli\" in item.keywords and not _HAS_TYPER:\n    23→            item.add_marker(skip_cli)\n    24→        if \"requires_mcp\" in item.keywords and not _HAS_MCP:\n    25→            item.add_marker(skip_mcp)\n    26→\n    27→\n    28→@pytest.fixture()\n    29→def tmp_project(tmp_path: Path) -> Path:\n    30→    \"\"\"Provide a temporary project root directory.\"\"\"\n    31→    return tmp_path\n    32→\n    33→\n    34→@pytest.fixture()\n    35→def tmp_project_with_git(tmp_path: Path) -> Path:\n    36→    \"\"\"Provide a temporary project root with a git repo.\"\"\"\n    37→    import subprocess\n    38→\n    39→    subprocess.run([\"git\", \"init\"], cwd=str(tmp_path), capture_output=True, check=True)\n    40→    return tmp_path\n    41→"}]},"parent_tool_use_id":"toolu_01Xzfu4twbN6y7LmLAQN294h","session_id":"4c2bbd2a-1a06-4e1e-9000-d7a8b9bf3b8b","uuid":"aab8d08c-39b8-4c29-bb5c-bcefdcf58320","timestamp":"2026-03-22T22:46:51.342Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017q2NurnH3fucgK8T4oYUEG","type":"tool_result","content":"     1→\"\"\"Tests for ranked memory retrieval (Epic 25, Story 25.1 + Epic 34.2 BM25).\"\"\"\n     2→\n     3→from __future__ import annotations\n     4→\n     5→from datetime import UTC, datetime, timedelta\n     6→from unittest.mock import MagicMock, patch\n     7→\n     8→import pytest\n     9→\n    10→from tapps_brain.decay import DecayConfig\n    11→from tapps_brain.models import (\n    12→    MemoryEntry,\n    13→    MemorySource,\n    14→    MemoryTier,\n    15→)\n    16→from tapps_brain.reranker import NoopReranker\n    17→from tapps_brain.retrieval import MemoryRetriever, ScoredMemory\n    18→from tests.factories import make_entry\n    19→\n    20→# ---------------------------------------------------------------------------\n    21→# Helpers\n    22→# ---------------------------------------------------------------------------\n    23→\n    24→_NOW = datetime(2026, 2, 27, 12, 0, 0, tzinfo=UTC)\n    25→_RECENT = (_NOW - timedelta(days=1)).isoformat()\n    26→_OLD = (_NOW - timedelta(days=90)).isoformat()\n    27→_VERY_OLD = (_NOW - timedelta(days=365)).isoformat()\n    28→\n    29→\n    30→def _make_entry(\n    31→    key: str = \"test-key\",\n    32→    value: str = \"test value\",\n    33→    *,\n    34→    tier: MemoryTier = MemoryTier.pattern,\n    35→    confidence: float = 0.8,\n    36→    source: MemorySource = MemorySource.agent,\n    37→    updated_at: str = \"\",\n    38→    access_count: int = 0,\n    39→    contradicted: bool = False,\n    40→    tags: list[str] | None = None,\n    41→) -> MemoryEntry:\n    42→    return make_entry(\n    43→        key=key,\n    44→        value=value,\n    45→        tier=tier,\n    46→        confidence=confidence,\n    47→        source=source,\n    48→        updated_at=updated_at or _RECENT,\n    49→        created_at=updated_at or _RECENT,\n    50→        last_accessed=updated_at or _RECENT,\n    51→        access_count=access_count,\n    52→        contradicted=contradicted,\n    53→        tags=tags,\n    54→    )\n    55→\n    56→\n    57→def _make_store(entries: list[MemoryEntry] | None = None) -> MagicMock:\n    58→    \"\"\"Create a mock MemoryStore with search and list_all.\"\"\"\n    59→    store = MagicMock()\n    60→    entries = entries or []\n    61→\n    62→    store.list_all.return_value = entries\n    63→    # store.search returns the same entries (simulating FTS match)\n    64→    store.search.return_value = entries\n    65→\n    66→    entry_map = {e.key: e for e in entries}\n    67→    store.get.side_effect = lambda k, **kwargs: entry_map.get(k)\n    68→\n    69→    return store\n    70→\n    71→\n    72→# ---------------------------------------------------------------------------\n    73→# ScoredMemory model tests\n    74→# ---------------------------------------------------------------------------\n    75→\n    76→\n    77→class TestScoredMemory:\n    78→    def test_scored_memory_creation(self) -> None:\n    79→        entry = _make_entry()\n    80→        scored = ScoredMemory(\n    81→            entry=entry,\n    82→            score=0.75,\n    83→            effective_confidence=0.8,\n    84→            bm25_relevance=0.5,\n    85→            stale=False,\n    86→        )\n    87→        assert scored.score == 0.75\n    88→        assert scored.entry.key == \"test-key\"\n    89→\n    90→\n    91→# ---------------------------------------------------------------------------\n    92→# MemoryRetriever tests\n    93→# ---------------------------------------------------------------------------\n    94→\n    95→\n    96→class TestMemoryRetriever:\n    97→    def test_empty_query_returns_empty(self) -> None:\n    98→        retriever = MemoryRetriever()\n    99→        store = _make_store([_make_entry()])\n   100→        assert retriever.search(\"\", store) == []\n   101→        assert retriever.search(\"   \", store) == []\n   102→\n   103→    def test_no_matching_entries(self) -> None:\n   104→        retriever = MemoryRetriever()\n   105→        entries = [_make_entry(\"unrelated-key\", \"no match here\")]\n   106→        store = _make_store(entries)\n   107→        # store.search returns empty for non-matching query\n   108→        store.search.return_value = []\n   109→\n   110→        results = retriever.search(\"completely different query\", store)\n   111→        assert len(results) == 0\n   112→\n   113→    def test_exact_key_match_ranks_highest(self) -> None:\n   114→        entries = [\n   115→            _make_entry(\"jwt-auth\", \"JWT authentication config\", confidence=0.7),\n   116→            _make_entry(\"auth-setup\", \"Authentication setup details\", confidence=0.7),\n   117→        ]\n   118→        retriever = MemoryRetriever()\n   119→        store = _make_store(entries)\n   120→\n   121→        results = retriever.search(\"jwt-auth\", store)\n   122→        assert len(results) >= 1\n   123→        assert results[0].entry.key == \"jwt-auth\"\n   124→\n   125→    def test_high_confidence_outranks_low(self) -> None:\n   126→        entries = [\n   127→            _make_entry(\n   128→                \"low-conf\",\n   129→                \"test framework value\",\n   130→                confidence=0.3,\n   131→                updated_at=_RECENT,\n   132→            ),\n   133→            _make_entry(\n   134→                \"high-conf\",\n   135→                \"test framework value\",\n   136→                confidence=0.9,\n   137→                updated_at=_RECENT,\n   138→            ),\n   139→        ]\n   140→        retriever = MemoryRetriever()\n   141→        store = _make_store(entries)\n   142→\n   143→        results = retriever.search(\"test framework\", store)\n   144→        assert len(results) == 2\n   145→        assert results[0].entry.key == \"high-conf\"\n   146→\n   147→    def test_recent_memory_outranks_old(self) -> None:\n   148→        entries = [\n   149→            _make_entry(\n   150→                \"old-memory\",\n   151→                \"database config setup\",\n   152→                confidence=0.8,\n   153→                updated_at=_OLD,\n   154→            ),\n   155→            _make_entry(\n   156→                \"new-memory\",\n   157→                \"database config setup\",\n   158→                confidence=0.8,\n   159→                updated_at=_RECENT,\n   160→            ),\n   161→        ]\n   162→        retriever = MemoryRetriever()\n   163→        store = _make_store(entries)\n   164→\n   165→        results = retriever.search(\"database config\", store)\n   166→        assert len(results) == 2\n   167→        assert results[0].entry.key == \"new-memory\"\n   168→\n   169→    def test_contradicted_excluded_by_default(self) -> None:\n   170→        entries = [\n   171→            _make_entry(\"good-key\", \"valid memory\", contradicted=False),\n   172→            _make_entry(\"bad-key\", \"contradicted memory\", contradicted=True),\n   173→        ]\n   174→        retriever = MemoryRetriever()\n   175→        store = _make_store(entries)\n   176→\n   177→        results = retriever.search(\"memory\", store)\n   178→        keys = [r.entry.key for r in results]\n   179→        assert \"bad-key\" not in keys\n   180→\n   181→    def test_contradicted_included_when_requested(self) -> None:\n   182→        entries = [\n   183→            _make_entry(\"bad-key\", \"contradicted memory\", contradicted=True),\n   184→        ]\n   185→        retriever = MemoryRetriever()\n   186→        store = _make_store(entries)\n   187→\n   188→        results = retriever.search(\"contradicted memory\", store, include_contradicted=True)\n   189→        assert len(results) == 1\n   190→        assert results[0].entry.key == \"bad-key\"\n   191→\n   192→    def test_result_limit_respected(self) -> None:\n   193→        entries = [_make_entry(f\"key-{i}\", f\"matching value {i}\") for i in range(20)]\n   194→        retriever = MemoryRetriever()\n   195→        store = _make_store(entries)\n   196→\n   197→        results = retriever.search(\"matching value\", store, limit=5)\n   198→        assert len(results) <= 5\n   199→\n   200→    def test_max_limit_capped(self) -> None:\n   201→        entries = [_make_entry(f\"key-{i}\", f\"value {i}\") for i in range(60)]\n   202→        retriever = MemoryRetriever()\n   203→        store = _make_store(entries)\n   204→\n   205→        results = retriever.search(\"value\", store, limit=100)\n   206→        assert len(results) <= 50\n   207→\n   208→    def test_low_confidence_filtered(self) -> None:\n   209→        entries = [\n   210→            _make_entry(\n   211→                \"very-low\",\n   212→                \"matching text\",\n   213→                confidence=0.05,\n   214→                updated_at=_VERY_OLD,\n   215→            ),\n   216→        ]\n   217→        retriever = MemoryRetriever(config=DecayConfig())\n   218→        store = _make_store(entries)\n   219→\n   220→        # Confidence floor is 0.1, so entry decays to 0.1.\n   221→        # Use min_confidence > 0.1 to filter it out.\n   222→        results = retriever.search(\"matching text\", store, min_confidence=0.2)\n   223→        assert len(results) == 0\n   224→\n   225→    def test_frequency_affects_ranking(self) -> None:\n   226→        entries = [\n   227→            _make_entry(\n   228→                \"rarely-accessed\",\n   229→                \"shared pattern data\",\n   230→                access_count=1,\n   231→                confidence=0.8,\n   232→            ),\n   233→            _make_entry(\n   234→                \"often-accessed\",\n   235→                \"shared pattern data\",\n   236→                access_count=20,\n   237→                confidence=0.8,\n   238→            ),\n   239→        ]\n   240→        retriever = MemoryRetriever()\n   241→        store = _make_store(entries)\n   242→\n   243→        results = retriever.search(\"shared pattern\", store)\n   244→        assert len(results) == 2\n   245→        assert results[0].entry.key == \"often-accessed\"\n   246→\n   247→    def test_fallback_to_like_search(self) -> None:\n   248→        \"\"\"When FTS5 search returns no results, fallback to LIKE.\"\"\"\n   249→        entries = [_make_entry(\"my-key\", \"some matching content\")]\n   250→        retriever = MemoryRetriever()\n   251→        store = _make_store(entries)\n   252→        # store.search raises exception = FTS5 unavailable\n   253→        store.search.side_effect = Exception(\"FTS5 not available\")\n   254→\n   255→        results = retriever.search(\"matching content\", store)\n   256→        assert len(results) == 1\n   257→\n   258→    def test_word_overlap_scoring(self) -> None:\n   259→        entry = _make_entry(\"test-key\", \"python fastapi web framework\")\n   260→        score = MemoryRetriever._word_overlap_score(\"python fastapi\", entry)\n   261→        assert score > 0.0\n   262→\n   263→\n   264→# ---------------------------------------------------------------------------\n   265→# Scoring helpers\n   266→# ---------------------------------------------------------------------------\n   267→\n   268→\n   269→class TestScoringHelpers:\n   270→    def test_normalize_relevance_zero(self) -> None:\n   271→        retriever = MemoryRetriever()\n   272→        assert retriever._normalize_relevance(0.0) == 0.0\n   273→\n   274→    def test_normalize_relevance_positive(self) -> None:\n   275→        # BM25 normalization: score / (score + 5.0)\n   276→        retriever = MemoryRetriever()\n   277→        score = retriever._normalize_relevance(5.0)\n   278→        assert 0.0 < score < 1.0\n   279→        assert score == pytest.approx(0.5)\n   280→\n   281→    def test_normalize_relevance_large(self) -> None:\n   282→        retriever = MemoryRetriever()\n   283→        score = retriever._normalize_relevance(100.0)\n   284→        assert score > 0.9\n   285→\n   286→    def test_recency_score_recent(self) -> None:\n   287→        entry = _make_entry(updated_at=_NOW.isoformat())\n   288→        score = MemoryRetriever._recency_score(entry, _NOW)\n   289→        assert score == pytest.approx(1.0, abs=0.01)\n   290→\n   291→    def test_recency_score_old(self) -> None:\n   292→        entry = _make_entry(updated_at=_OLD)\n   293→        score = MemoryRetriever._recency_score(entry, _NOW)\n   294→        assert score < 0.1\n   295→\n   296→    def test_frequency_score_zero(self) -> None:\n   297→        retriever = MemoryRetriever()\n   298→        entry = _make_entry(access_count=0)\n   299→        assert retriever._frequency_score(entry) == 0.0\n   300→\n   301→    def test_frequency_score_capped(self) -> None:\n   302→        retriever = MemoryRetriever()\n   303→        entry = _make_entry(access_count=100)\n   304→        assert retriever._frequency_score(entry) == 1.0\n   305→\n   306→\n   307→# ---------------------------------------------------------------------------\n   308→# BM25 integration tests (Epic 34.2)\n   309→# ---------------------------------------------------------------------------\n   310→\n   311→\n   312→class TestBM25Integration:\n   313→    \"\"\"Tests for BM25-based relevance scoring in MemoryRetriever.\"\"\"\n   314→\n   315→    def test_stemming_matches_related_words(self) -> None:\n   316→        \"\"\"'testing' query should match a memory about 'test' via stemming.\"\"\"\n   317→        entries = [\n   318→            _make_entry(\"test-framework\", \"test framework configuration\"),\n   319→            _make_entry(\"unrelated\", \"database connection pooling\"),\n   320→        ]\n   321→        retriever = MemoryRetriever()\n   322→        store = _make_store(entries)\n   323→\n   324→        results = retriever.search(\"testing\", store)\n   325→        assert len(results) >= 1\n   326→        assert results[0].entry.key == \"test-framework\"\n   327→\n   328→    def test_idf_rare_term_scores_higher(self) -> None:\n   329→        \"\"\"A rare term should produce higher BM25 relevance than a common one.\"\"\"\n   330→        entries = [\n   331→            _make_entry(\"python-setup\", \"python setup guide\", confidence=0.8),\n   332→            _make_entry(\"python-web\", \"python web framework\", confidence=0.8),\n   333→            _make_entry(\"python-data\", \"python data science\", confidence=0.8),\n   334→            _make_entry(\"rust-setup\", \"rust setup guide\", confidence=0.8),\n   335→        ]\n   336→        retriever = MemoryRetriever()\n   337→        store = _make_store(entries)\n   338→\n   339→        # \"rust\" is rare (1 doc), \"python\" is common (3 docs)\n   340→        rust_results = retriever.search(\"rust\", store)\n   341→        python_results = retriever.search(\"python\", store)\n   342→\n   343→        # The rust match should have higher BM25 relevance\n   344→        assert len(rust_results) >= 1\n   345→        assert len(python_results) >= 1\n   346→        assert rust_results[0].bm25_relevance > python_results[0].bm25_relevance\n   347→\n   348→    def test_composite_scoring_still_works(self) -> None:\n   349→        \"\"\"BM25 integration preserves composite scoring formula.\"\"\"\n   350→        entries = [\n   351→            _make_entry(\n   352→                \"high-conf\",\n   353→                \"python framework config\",\n   354→                confidence=0.9,\n   355→                updated_at=_RECENT,\n   356→                access_count=10,\n   357→            ),\n   358→            _make_entry(\n   359→                \"low-conf\",\n   360→                \"python framework config\",\n   361→                confidence=0.3,\n   362→                updated_at=_RECENT,\n   363→                access_count=1,\n   364→            ),\n   365→        ]\n   366→        retriever = MemoryRetriever()\n   367→        store = _make_store(entries)\n   368→\n   369→        results = retriever.search(\"python framework\", store)\n   370→        assert len(results) == 2\n   371→        # High confidence + high frequency should outrank\n   372→        assert results[0].entry.key == \"high-conf\"\n   373→        # Both should have positive composite scores\n   374→        assert all(r.score > 0 for r in results)\n   375→        # bm25_relevance should be populated\n   376→        assert all(r.bm25_relevance >= 0 for r in results)\n   377→\n   378→    def test_fallback_to_word_overlap_on_bm25_error(self) -> None:\n   379→        \"\"\"If BM25 scoring fails, fall back to word overlap.\"\"\"\n   380→        entries = [_make_entry(\"my-key\", \"python framework setup\")]\n   381→        retriever = MemoryRetriever()\n   382→        store = _make_store(entries)\n   383→\n   384→        # Force BM25 to fail by corrupting internal state\n   385→        with patch.object(retriever._bm25, \"score\", side_effect=RuntimeError(\"BM25 broken\")):\n   386→            results = retriever.search(\"python framework\", store)\n   387→            # Should still get results via word overlap fallback\n   388→            assert len(results) >= 1\n   389→\n   390→    def test_index_invalidation_on_store_size_change(self) -> None:\n   391→        \"\"\"BM25 index should rebuild when store size changes.\"\"\"\n   392→        entries_v1 = [\n   393→            _make_entry(\"key-a\", \"alpha content\"),\n   394→        ]\n   395→        entries_v2 = [\n   396→            _make_entry(\"key-a\", \"alpha content\"),\n   397→            _make_entry(\"key-b\", \"beta content\"),\n   398→        ]\n   399→        retriever = MemoryRetriever()\n   400→\n   401→        # First search builds index for 1 entry\n   402→        store_v1 = _make_store(entries_v1)\n   403→        retriever.search(\"alpha\", store_v1)\n   404→        assert retriever._bm25_corpus_size == 1\n   405→\n   406→        # Second search with 2 entries should rebuild\n   407→        store_v2 = _make_store(entries_v2)\n   408→        retriever.search(\"beta\", store_v2)\n   409→        assert retriever._bm25_corpus_size == 2\n   410→\n   411→    def test_empty_store_returns_no_results(self) -> None:\n   412→        \"\"\"An empty store should return no results.\"\"\"\n   413→        retriever = MemoryRetriever()\n   414→        store = _make_store([])\n   415→        store.search.return_value = []\n   416→\n   417→        results = retriever.search(\"anything\", store)\n   418→        assert results == []\n   419→\n   420→    def test_bm25_relevance_field_populated(self) -> None:\n   421→        \"\"\"The bm25_relevance field should be populated with BM25 score.\"\"\"\n   422→        entries = [_make_entry(\"pytest-config\", \"pytest configuration details\")]\n   423→        retriever = MemoryRetriever()\n   424→        store = _make_store(entries)\n   425→\n   426→        results = retriever.search(\"pytest config\", store)\n   427→        assert len(results) == 1\n   428→        assert results[0].bm25_relevance > 0.0\n   429→        assert results[0].bm25_relevance <= 1.0\n   430→\n   431→    def test_word_overlap_still_available_as_method(self) -> None:\n   432→        \"\"\"_word_overlap_score should still be available as a fallback.\"\"\"\n   433→        entry = _make_entry(\"test-key\", \"python web framework\")\n   434→        score = MemoryRetriever._word_overlap_score(\"python web\", entry)\n   435→        assert score > 0.0\n   436→\n   437→    def test_entry_to_document_includes_tags(self) -> None:\n   438→        \"\"\"Document text should include key, value, and tags.\"\"\"\n   439→        entry = _make_entry(\"my-key\", \"my value\", tags=[\"tag1\", \"tag2\"])\n   440→        doc = MemoryRetriever._entry_to_document(entry)\n   441→        assert \"my-key\" in doc\n   442→        assert \"my value\" in doc\n   443→        assert \"tag1\" in doc\n   444→        assert \"tag2\" in doc\n   445→\n   446→    def test_semantic_disabled_uses_bm25_only(self) -> None:\n   447→        \"\"\"Epic 65.8: When semantic_enabled=False, BM25-only (no regression).\"\"\"\n   448→        entries = [\n   449→            _make_entry(\"key-a\", \"python testing framework\"),\n   450→            _make_entry(\"key-b\", \"python web server\"),\n   451→        ]\n   452→        retriever = MemoryRetriever(semantic_enabled=False)\n   453→        store = _make_store(entries)\n   454→\n   455→        results = retriever.search(\"python testing\", store)\n   456→        assert len(results) >= 1\n   457→        assert results[0].entry.key == \"key-a\"\n   458→\n   459→    def test_hybrid_falls_back_to_bm25_when_vector_empty(self) -> None:\n   460→        \"\"\"Epic 65.8: When embedder unavailable, hybrid falls back to BM25.\"\"\"\n   461→        entries = [_make_entry(\"my-key\", \"matching content\")]\n   462→        retriever = MemoryRetriever(semantic_enabled=True)\n   463→        store = _make_store(entries)\n   464→\n   465→        with patch(\n   466→            \"tapps_brain.retrieval.MemoryRetriever._vector_search\",\n   467→            return_value=[],\n   468→        ):\n   469→            results = retriever.search(\"matching content\", store)\n   470→        assert len(results) >= 1\n   471→        assert results[0].entry.key == \"my-key\"\n   472→\n   473→    def test_hybrid_merges_rrf_when_both_return_results(self) -> None:\n   474→        \"\"\"Epic 65.8: Hybrid merges BM25 + vector via RRF.\"\"\"\n   475→        entries = [\n   476→            _make_entry(\"a\", \"python framework\"),\n   477→            _make_entry(\"b\", \"testing library\"),\n   478→            _make_entry(\"c\", \"database config\"),\n   479→        ]\n   480→        retriever = MemoryRetriever(semantic_enabled=True)\n   481→        store = _make_store(entries)\n   482→\n   483→        def mock_vector_search(\n   484→            query: str, store: object, limit: int = 20\n   485→        ) -> list[tuple[str, float]]:\n   486→            return [(\"b\", 0.9), (\"a\", 0.7), (\"c\", 0.5)][:limit]\n   487→\n   488→        with patch.object(retriever, \"_vector_search\", side_effect=mock_vector_search):\n   489→            results = retriever.search(\"python\", store, limit=5)\n   490→        assert len(results) >= 1\n   491→        keys = [r.entry.key for r in results]\n   492→        assert \"a\" in keys or \"b\" in keys or \"c\" in keys\n   493→\n   494→    def test_bm25_multi_term_query(self) -> None:\n   495→        \"\"\"Multi-term queries should match entries with multiple terms.\"\"\"\n   496→        entries = [\n   497→            _make_entry(\"full-match\", \"python testing framework config\"),\n   498→            _make_entry(\"partial-match\", \"python web server\"),\n   499→            _make_entry(\"no-match\", \"database connection pooling\"),\n   500→        ]\n   501→        retriever = MemoryRetriever()\n   502→        store = _make_store(entries)\n   503→\n   504→        results = retriever.search(\"python testing framework\", store)\n   505→        # full-match should rank first (matches more query terms)\n   506→        assert len(results) >= 1\n   507→        assert results[0].entry.key == \"full-match\"\n   508→\n   509→\n   510→# ---------------------------------------------------------------------------\n   511→# Reranker integration (Epic 65.9)\n   512→# ---------------------------------------------------------------------------\n   513→\n   514→\n   515→class TestRerankerIntegration:\n   516→    \"\"\"Tests for optional reranking in MemoryRetriever.\"\"\"\n   517→\n   518→    def test_reranker_reorders_results(self) -> None:\n   519→        \"\"\"When reranker reverses order, final order follows reranker.\"\"\"\n   520→        entries = [\n   521→            _make_entry(\"key-a\", \"python framework\"),\n   522→            _make_entry(\"key-b\", \"testing library\"),\n   523→            _make_entry(\"key-c\", \"database config\"),\n   524→        ]\n   525→\n   526→        # NoopReranker preserves order, so use a custom reranker that reverses\n   527→        class ReverseReranker:\n   528→            def rerank(\n   529→                self,\n   530→                query: str,\n   531→                candidates: list[tuple[str, str]],\n   532→                top_k: int,\n   533→            ) -> list[tuple[str, float]]:\n   534→                reversed_cands = list(reversed(candidates[:top_k]))\n   535→                return [(k, 1.0 - i / 10) for i, (k, _) in enumerate(reversed_cands)]\n   536→\n   537→        retriever = MemoryRetriever(\n   538→            reranker=ReverseReranker(),\n   539→            reranker_enabled=True,\n   540→        )\n   541→        store = _make_store(entries)\n   542→\n   543→        results = retriever.search(\"python testing database\", store, limit=3)\n   544→        assert len(results) >= 1\n   545→        # ReverseReranker puts last candidate first\n   546→        assert results[0].entry.key == \"key-c\"\n   547→\n   548→    def test_reranker_disabled_uses_composite_order(self) -> None:\n   549→        \"\"\"When reranker disabled, original composite order is used.\"\"\"\n   550→        entries = [\n   551→            _make_entry(\"high-conf\", \"matching content\", confidence=0.9),\n   552→            _make_entry(\"low-conf\", \"matching content\", confidence=0.3),\n   553→        ]\n   554→        retriever = MemoryRetriever(reranker=NoopReranker(), reranker_enabled=False)\n   555→        store = _make_store(entries)\n   556→\n   557→        results = retriever.search(\"matching content\", store)\n   558→        assert len(results) == 2\n   559→        assert results[0].entry.key == \"high-conf\"\n   560→\n   561→    def test_reranker_failure_fallback(self) -> None:\n   562→        \"\"\"When reranker raises, fall back to original order.\"\"\"\n   563→        entries = [\n   564→            _make_entry(\"key-a\", \"content a\"),\n   565→            _make_entry(\"key-b\", \"content b\"),\n   566→        ]\n   567→        fail_reranker = MagicMock()\n   568→        fail_reranker.rerank.side_effect = RuntimeError(\"API down\")\n   569→\n   570→        retriever = MemoryRetriever(\n   571→            reranker=fail_reranker,\n   572→            reranker_enabled=True,\n   573→        )\n   574→        store = _make_store(entries)\n   575→\n   576→        results = retriever.search(\"content\", store)\n   577→        assert len(results) == 2\n   578→        # Original composite order preserved on failure\n   579→        assert results[0].entry.key in (\"key-a\", \"key-b\")\n   580→\n   581→\n   582→class TestTemporalFiltering:\n   583→    \"\"\"Tests for temporal filtering in retriever (EPIC-004, STORY-004.3).\"\"\"\n   584→\n   585→    def test_superseded_excluded_by_default(self) -> None:\n   586→        \"\"\"Entries with invalid_at in the past are excluded by default.\"\"\"\n   587→        entries = [\n   588→            _make_entry(\"v1\", \"old pricing plan\", updated_at=_RECENT),\n   589→            _make_entry(\"v2\", \"new pricing plan\", updated_at=_RECENT),\n   590→        ]\n   591→        # Manually set v1 as superseded\n   592→        entries[0] = entries[0].model_copy(\n   593→            update={\"invalid_at\": \"2020-01-01T00:00:00+00:00\", \"superseded_by\": \"v2\"}\n   594→        )\n   595→        entries[1] = entries[1].model_copy(update={\"valid_at\": _RECENT})\n   596→\n   597→        retriever = MemoryRetriever()\n   598→        store = _make_store(entries)\n   599→        results = retriever.search(\"pricing plan\", store)\n   600→        keys = [r.entry.key for r in results]\n   601→        assert \"v1\" not in keys\n   602→        assert \"v2\" in keys\n   603→\n   604→    def test_superseded_included_with_flag(self) -> None:\n   605→        \"\"\"include_superseded=True returns temporally invalid entries marked stale.\"\"\"\n   606→        entries = [\n   607→            _make_entry(\"old-fact\", \"old technology stack\", updated_at=_RECENT),\n   608→            _make_entry(\"new-fact\", \"new technology stack\", updated_at=_RECENT),\n   609→        ]\n   610→        entries[0] = entries[0].model_copy(\n   611→            update={\"invalid_at\": \"2020-01-01T00:00:00+00:00\", \"superseded_by\": \"new-fact\"}\n   612→        )\n   613→\n   614→        retriever = MemoryRetriever()\n   615→        store = _make_store(entries)\n   616→        results = retriever.search(\"technology stack\", store, include_superseded=True)\n   617→        keys = [r.entry.key for r in results]\n   618→        assert \"old-fact\" in keys\n   619→\n   620→        old = next(r for r in results if r.entry.key == \"old-fact\")\n   621→        assert old.stale is True\n   622→\n   623→    def test_as_of_point_in_time(self) -> None:\n   624→        \"\"\"as_of parameter returns entries valid at that timestamp.\"\"\"\n   625→        entries = [\n   626→            _make_entry(\"versioned\", \"database version info\", updated_at=_RECENT),\n   627→        ]\n   628→        entries[0] = entries[0].model_copy(\n   629→            update={\n   630→                \"valid_at\": \"2026-01-01T00:00:00+00:00\",\n   631→                \"invalid_at\": \"2026-06-01T00:00:00+00:00\",\n   632→            }\n   633→        )\n   634→\n   635→        retriever = MemoryRetriever()\n   636→        store = _make_store(entries)\n   637→\n   638→        # Within window\n   639→        results_in = retriever.search(\"database version\", store, as_of=\"2026-03-01T00:00:00+00:00\")\n   640→        assert any(r.entry.key == \"versioned\" for r in results_in)\n   641→\n   642→        # Outside window\n   643→        results_out = retriever.search(\"database version\", store, as_of=\"2026-07-01T00:00:00+00:00\")\n   644→        assert not any(r.entry.key == \"versioned\" for r in results_out)\n   645→\n   646→    def test_superseded_penalty(self) -> None:\n   647→        \"\"\"Superseded entries included via flag get a score penalty.\"\"\"\n   648→        entries = [\n   649→            _make_entry(\"active\", \"current active data\", confidence=0.8, updated_at=_RECENT),\n   650→            _make_entry(\"superseded\", \"old superseded data\", confidence=0.8, updated_at=_RECENT),\n   651→        ]\n   652→        entries[1] = entries[1].model_copy(update={\"invalid_at\": \"2020-01-01T00:00:00+00:00\"})\n   653→\n   654→        retriever = MemoryRetriever()\n   655→        store = _make_store(entries)\n   656→        results = retriever.search(\"data\", store, include_superseded=True)\n   657→\n   658→        active = next((r for r in results if r.entry.key == \"active\"), None)\n   659→        superseded = next((r for r in results if r.entry.key == \"superseded\"), None)\n   660→        assert active is not None\n   661→        assert superseded is not None\n   662→        assert active.score > superseded.score\n   663→"}]},"parent_tool_use_id":"toolu_01Xzfu4twbN6y7LmLAQN294h","session_id":"4c2bbd2a-1a06-4e1e-9000-d7a8b9bf3b8b","uuid":"5d45659a-850d-42d5-ab11-58ebcab86716","timestamp":"2026-03-22T22:46:51.504Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012GepkKaBH1ybJv1VR2B536","type":"tool_result","content":"     1→\"\"\"Integration tests for ranked retrieval with real MemoryStore + SQLite.\n     2→\n     3→Uses real MemoryStore (no mocks), real SQLite/FTS5, real BM25 scoring,\n     4→and real decay computation. All databases use tmp_path for isolation.\n     5→\n     6→Story: STORY-001.3 from EPIC-001\n     7→\"\"\"\n     8→\n     9→from __future__ import annotations\n    10→\n    11→from datetime import UTC, datetime, timedelta\n    12→from typing import TYPE_CHECKING\n    13→\n    14→import pytest\n    15→\n    16→from tapps_brain.decay import DecayConfig\n    17→from tapps_brain.retrieval import MemoryRetriever, ScoredMemory\n    18→from tapps_brain.store import MemoryStore\n    19→\n    20→if TYPE_CHECKING:\n    21→    from pathlib import Path\n    22→\n    23→\n    24→# ---------------------------------------------------------------------------\n    25→# Fixtures\n    26→# ---------------------------------------------------------------------------\n    27→\n    28→\n    29→@pytest.fixture()\n    30→def store(tmp_path: Path) -> MemoryStore:\n    31→    \"\"\"Create a real MemoryStore backed by SQLite in a temp directory.\"\"\"\n    32→    s = MemoryStore(tmp_path)\n    33→    yield s\n    34→    s.close()\n    35→\n    36→\n    37→@pytest.fixture()\n    38→def retriever() -> MemoryRetriever:\n    39→    \"\"\"Create a MemoryRetriever with default decay config.\"\"\"\n    40→    return MemoryRetriever(config=DecayConfig())\n    41→\n    42→\n    43→def _save(\n    44→    store: MemoryStore,\n    45→    key: str,\n    46→    value: str,\n    47→    *,\n    48→    tier: str = \"pattern\",\n    49→    tags: list[str] | None = None,\n    50→    confidence: float = -1.0,\n    51→    source: str = \"agent\",\n    52→) -> None:\n    53→    \"\"\"Helper to save a memory entry with sensible defaults.\"\"\"\n    54→    result = store.save(\n    55→        key=key,\n    56→        value=value,\n    57→        tier=tier,\n    58→        tags=tags or [],\n    59→        confidence=confidence,\n    60→        source=source,\n    61→    )\n    62→    assert not isinstance(result, dict), f\"save failed: {result}\"\n    63→\n    64→\n    65→def _backdate_entry(store: MemoryStore, key: str, days_ago: int) -> None:\n    66→    \"\"\"Backdate an entry's updated_at by manipulating internal state.\n    67→\n    68→    MemoryStore.update_fields always overrides updated_at with now(),\n    69→    so we directly modify the in-memory entry and persist it to SQLite.\n    70→    This is acceptable in tests to simulate time passage.\n    71→    \"\"\"\n    72→    old_time = (datetime.now(tz=UTC) - timedelta(days=days_ago)).isoformat()\n    73→    with store._lock:\n    74→        entry = store._entries.get(key)\n    75→        assert entry is not None, f\"Entry {key!r} not found\"\n    76→        updated = entry.model_copy(update={\"updated_at\": old_time})\n    77→        store._entries[key] = updated\n    78→    store._persistence.save(updated)\n    79→\n    80→\n    81→# ---------------------------------------------------------------------------\n    82→# BM25 scoring against real FTS5\n    83→# ---------------------------------------------------------------------------\n    84→\n    85→\n    86→class TestBM25WithRealFTS5:\n    87→    \"\"\"Verify BM25 scoring works end-to-end with real FTS5 candidate retrieval.\"\"\"\n    88→\n    89→    def test_exact_keyword_match_ranks_highest(\n    90→        self, store: MemoryStore, retriever: MemoryRetriever\n    91→    ) -> None:\n    92→        _save(store, \"python-logging\", \"Use structlog for structured logging in Python\")\n    93→        _save(store, \"java-logging\", \"Use SLF4J for logging in Java applications\")\n    94→        _save(store, \"database-setup\", \"PostgreSQL is the primary database engine\")\n    95→\n    96→        results = retriever.search(\"python logging\", store)\n    97→\n    98→        assert len(results) >= 1\n    99→        assert results[0].entry.key == \"python-logging\"\n   100→        assert results[0].bm25_relevance > 0.0\n   101→        assert results[0].score > 0.0\n   102→\n   103→    def test_multiple_term_match_scores_higher_than_single(\n   104→        self, store: MemoryStore, retriever: MemoryRetriever\n   105→    ) -> None:\n   106→        \"\"\"Entry containing all query terms should score highest via BM25.\"\"\"\n   107→        _save(\n   108→            store,\n   109→            \"api-auth\",\n   110→            \"API authentication uses JWT tokens for security\",\n   111→        )\n   112→        _save(\n   113→            store,\n   114→            \"api-design\",\n   115→            \"API design follows REST conventions with JSON responses\",\n   116→        )\n   117→        _save(\n   118→            store,\n   119→            \"auth-tokens\",\n   120→            \"JWT tokens expire after 24 hours for security\",\n   121→        )\n   122→\n   123→        # Use a query that FTS5 will match broadly\n   124→        results = retriever.search(\"API JWT tokens authentication\", store)\n   125→\n   126→        assert len(results) >= 1\n   127→        # api-auth mentions API, authentication, JWT, tokens -- all query terms\n   128→        assert results[0].entry.key == \"api-auth\"\n   129→\n   130→    def test_no_results_for_absent_terms(\n   131→        self, store: MemoryStore, retriever: MemoryRetriever\n   132→    ) -> None:\n   133→        _save(store, \"python-setup\", \"Install Python 3.12 using pyenv\")\n   134→\n   135→        results = retriever.search(\"kubernetes deployment\", store)\n   136→\n   137→        # May return 0 results or results with very low scores\n   138→        for r in results:\n   139→            assert r.bm25_relevance < 0.3\n   140→\n   141→    def test_empty_query_returns_empty(\n   142→        self, store: MemoryStore, retriever: MemoryRetriever\n   143→    ) -> None:\n   144→        _save(store, \"some-entry\", \"Some content here\")\n   145→        assert retriever.search(\"\", store) == []\n   146→        assert retriever.search(\"   \", store) == []\n   147→\n   148→    def test_bm25_relevance_is_normalized(\n   149→        self, store: MemoryStore, retriever: MemoryRetriever\n   150→    ) -> None:\n   151→        _save(\n   152→            store,\n   153→            \"testing-guide\",\n   154→            \"pytest is used for all unit and integration testing\",\n   155→        )\n   156→        _save(\n   157→            store,\n   158→            \"ci-pipeline\",\n   159→            \"CI pipeline runs pytest with coverage reporting\",\n   160→        )\n   161→\n   162→        results = retriever.search(\"pytest testing\", store)\n   163→\n   164→        for r in results:\n   165→            assert 0.0 <= r.bm25_relevance <= 1.0\n   166→\n   167→    def test_tags_contribute_to_bm25_scoring(\n   168→        self, store: MemoryStore, retriever: MemoryRetriever\n   169→    ) -> None:\n   170→        _save(\n   171→            store,\n   172→            \"deploy-config\",\n   173→            \"Deployment configuration for production\",\n   174→            tags=[\"docker\", \"kubernetes\"],\n   175→        )\n   176→        _save(\n   177→            store,\n   178→            \"local-dev\",\n   179→            \"Local development setup instructions\",\n   180→            tags=[\"development\"],\n   181→        )\n   182→\n   183→        results = retriever.search(\"docker\", store)\n   184→\n   185→        assert len(results) >= 1\n   186→        assert results[0].entry.key == \"deploy-config\"\n   187→\n   188→\n   189→# ---------------------------------------------------------------------------\n   190→# Contradicted entry exclusion\n   191→# ---------------------------------------------------------------------------\n   192→\n   193→\n   194→class TestContradictedEntryExclusion:\n   195→    \"\"\"Verify contradicted entries are excluded from results by default.\"\"\"\n   196→\n   197→    def test_contradicted_entries_excluded_by_default(\n   198→        self, store: MemoryStore, retriever: MemoryRetriever\n   199→    ) -> None:\n   200→        _save(store, \"old-pattern\", \"Use callbacks for async operations\")\n   201→        _save(store, \"new-pattern\", \"Use async/await for async operations\")\n   202→\n   203→        store.update_fields(\n   204→            \"old-pattern\",\n   205→            contradicted=True,\n   206→            contradiction_reason=\"Superseded by async/await pattern\",\n   207→        )\n   208→\n   209→        results = retriever.search(\"async operations\", store)\n   210→\n   211→        result_keys = [r.entry.key for r in results]\n   212→        assert \"old-pattern\" not in result_keys\n   213→        assert \"new-pattern\" in result_keys\n   214→\n   215→    def test_contradicted_entries_included_when_requested(\n   216→        self, store: MemoryStore, retriever: MemoryRetriever\n   217→    ) -> None:\n   218→        _save(store, \"old-api\", \"REST API v1 uses XML responses\")\n   219→        _save(store, \"new-api\", \"REST API v2 uses JSON responses\")\n   220→\n   221→        store.update_fields(\n   222→            \"old-api\",\n   223→            contradicted=True,\n   224→            contradiction_reason=\"Replaced by v2\",\n   225→        )\n   226→\n   227→        results = retriever.search(\"REST API responses\", store, include_contradicted=True)\n   228→\n   229→        result_keys = [r.entry.key for r in results]\n   230→        assert \"old-api\" in result_keys\n   231→        assert \"new-api\" in result_keys\n   232→\n   233→    def test_consolidated_source_entries_excluded_by_default(\n   234→        self, store: MemoryStore, retriever: MemoryRetriever\n   235→    ) -> None:\n   236→        _save(store, \"pattern-a\", \"Use pytest fixtures for test setup\")\n   237→        _save(store, \"pattern-b\", \"Use pytest parametrize for test variations\")\n   238→        _save(\n   239→            store,\n   240→            \"consolidated-patterns\",\n   241→            \"Use pytest fixtures and parametrize\",\n   242→        )\n   243→\n   244→        store.update_fields(\n   245→            \"pattern-a\",\n   246→            contradicted=True,\n   247→            contradiction_reason=\"Consolidated into consolidated-patterns\",\n   248→        )\n   249→        store.update_fields(\n   250→            \"pattern-b\",\n   251→            contradicted=True,\n   252→            contradiction_reason=\"Consolidated into consolidated-patterns\",\n   253→        )\n   254→\n   255→        results = retriever.search(\"pytest\", store)\n   256→\n   257→        result_keys = [r.entry.key for r in results]\n   258→        assert \"pattern-a\" not in result_keys\n   259→        assert \"pattern-b\" not in result_keys\n   260→        assert \"consolidated-patterns\" in result_keys\n   261→\n   262→    def test_consolidated_sources_included_when_requested(\n   263→        self, store: MemoryStore, retriever: MemoryRetriever\n   264→    ) -> None:\n   265→        _save(store, \"src-entry\", \"Original pattern about logging\")\n   266→        _save(store, \"merged-entry\", \"Consolidated logging pattern\")\n   267→\n   268→        store.update_fields(\n   269→            \"src-entry\",\n   270→            contradicted=True,\n   271→            contradiction_reason=\"Consolidated into merged-entry\",\n   272→        )\n   273→\n   274→        results = retriever.search(\"logging pattern\", store, include_sources=True)\n   275→\n   276→        result_keys = [r.entry.key for r in results]\n   277→        assert \"src-entry\" in result_keys\n   278→\n   279→\n   280→# ---------------------------------------------------------------------------\n   281→# Stale / decayed entries rank lower\n   282→# ---------------------------------------------------------------------------\n   283→\n   284→\n   285→class TestDecayedEntriesRankLower:\n   286→    \"\"\"Verify that stale/decayed entries rank lower than fresh entries.\"\"\"\n   287→\n   288→    def test_recent_entry_ranks_above_old_entry(\n   289→        self, store: MemoryStore, retriever: MemoryRetriever\n   290→    ) -> None:\n   291→        _save(store, \"old-deploy\", \"Deploy using Docker compose for production\")\n   292→        _save(store, \"new-deploy\", \"Deploy using Docker compose with health checks\")\n   293→\n   294→        # Backdate old entry via internal state (update_fields overrides updated_at)\n   295→        _backdate_entry(store, \"old-deploy\", days_ago=90)\n   296→\n   297→        results = retriever.search(\"Docker compose deploy\", store)\n   298→\n   299→        assert len(results) == 2\n   300→        # Fresh entry should rank higher due to recency component\n   301→        assert results[0].entry.key == \"new-deploy\"\n   302→        assert results[0].score > results[1].score\n   303→\n   304→    def test_context_tier_decays_faster_than_architectural(self, tmp_path: Path) -> None:\n   305→        \"\"\"Context tier (14d half-life) decays faster than architectural (180d).\"\"\"\n   306→        s = MemoryStore(tmp_path)\n   307→        try:\n   308→            config = DecayConfig()\n   309→            ret = MemoryRetriever(config=config)\n   310→\n   311→            _save(\n   312→                s,\n   313→                \"arch-decision\",\n   314→                \"Database migration strategy uses alembic for schema changes\",\n   315→                tier=\"architectural\",\n   316→                confidence=0.9,\n   317→                source=\"human\",\n   318→            )\n   319→            _save(\n   320→                s,\n   321→                \"ctx-decision\",\n   322→                \"Database migration running today uses alembic schema update\",\n   323→                tier=\"context\",\n   324→                confidence=0.9,\n   325→                source=\"human\",\n   326→            )\n   327→\n   328→            # Backdate both entries to 30 days ago\n   329→            _backdate_entry(s, \"arch-decision\", days_ago=30)\n   330→            _backdate_entry(s, \"ctx-decision\", days_ago=30)\n   331→\n   332→            results = ret.search(\"database migration alembic schema\", s)\n   333→\n   334→            assert len(results) == 2\n   335→            arch = next(r for r in results if r.entry.key == \"arch-decision\")\n   336→            ctx = next(r for r in results if r.entry.key == \"ctx-decision\")\n   337→\n   338→            # Architectural should retain more confidence after 30 days\n   339→            assert arch.effective_confidence > ctx.effective_confidence\n   340→        finally:\n   341→            s.close()\n   342→\n   343→    def test_stale_flag_set_for_heavily_decayed_entries(self, tmp_path: Path) -> None:\n   344→        \"\"\"Context entry backdated 120 days should be marked stale.\"\"\"\n   345→        s = MemoryStore(tmp_path)\n   346→        try:\n   347→            config = DecayConfig()\n   348→            ret = MemoryRetriever(config=config)\n   349→\n   350→            _save(\n   351→                s,\n   352→                \"ancient-entry\",\n   353→                \"Very old context about temporary feature flag setup\",\n   354→                tier=\"context\",\n   355→                confidence=0.5,\n   356→                source=\"agent\",\n   357→            )\n   358→\n   359→            # Backdate 120 days (context half-life is 14d, so ~8.5 half-lives)\n   360→            _backdate_entry(s, \"ancient-entry\", days_ago=120)\n   361→\n   362→            results = ret.search(\"feature flag setup\", s, min_confidence=0.0)\n   363→\n   364→            assert len(results) >= 1\n   365→            r = next(r for r in results if r.entry.key == \"ancient-entry\")\n   366→            assert r.stale is True\n   367→            assert r.effective_confidence < 0.3\n   368→        finally:\n   369→            s.close()\n   370→\n   371→    def test_min_confidence_filters_decayed_entries(\n   372→        self, store: MemoryStore, retriever: MemoryRetriever\n   373→    ) -> None:\n   374→        _save(\n   375→            store,\n   376→            \"decayed-entry\",\n   377→            \"Temporary context about sprint planning process\",\n   378→            tier=\"context\",\n   379→            confidence=0.4,\n   380→            source=\"agent\",\n   381→        )\n   382→\n   383→        # Backdate heavily (context half-life 14d, 60 days = ~4 half-lives)\n   384→        _backdate_entry(store, \"decayed-entry\", days_ago=60)\n   385→\n   386→        # After 60 days with context tier: 0.4 * 0.5^(60/14) ~ 0.02\n   387→        # min_confidence=0.1 should filter it (floor is 0.1 though)\n   388→        # DecayConfig.confidence_floor=0.1 clamps it, so use min > 0.1\n   389→        results = retriever.search(\"sprint planning\", store, min_confidence=0.15)\n   390→\n   391→        result_keys = [r.entry.key for r in results]\n   392→        assert \"decayed-entry\" not in result_keys\n   393→\n   394→\n   395→# ---------------------------------------------------------------------------\n   396→# Hybrid search fallback paths\n   397→# ---------------------------------------------------------------------------\n   398→\n   399→\n   400→class TestHybridSearchFallback:\n   401→    \"\"\"Verify fallback behavior when semantic search is not available.\"\"\"\n   402→\n   403→    def test_non_semantic_uses_bm25_path(self, store: MemoryStore) -> None:\n   404→        ret = MemoryRetriever(semantic_enabled=False)\n   405→\n   406→        _save(store, \"test-entry\", \"Unit testing with pytest and fixtures\")\n   407→\n   408→        results = ret.search(\"pytest fixtures\", store)\n   409→\n   410→        assert len(results) >= 1\n   411→        assert results[0].entry.key == \"test-entry\"\n   412→        assert results[0].bm25_relevance > 0.0\n   413→\n   414→    def test_semantic_enabled_without_embedder_falls_back(self, store: MemoryStore) -> None:\n   415→        \"\"\"When semantic_enabled=True but no embedder, should still work.\"\"\"\n   416→        ret = MemoryRetriever(semantic_enabled=True)\n   417→\n   418→        _save(store, \"fallback-entry\", \"Fallback search behavior documentation\")\n   419→\n   420→        results = ret.search(\"fallback search\", store)\n   421→\n   422→        # Should return results via BM25 fallback even with semantic enabled\n   423→        assert len(results) >= 1\n   424→        assert results[0].entry.key == \"fallback-entry\"\n   425→\n   426→    def test_full_corpus_bm25_scan_fallback(\n   427→        self, store: MemoryStore, retriever: MemoryRetriever\n   428→    ) -> None:\n   429→        \"\"\"BM25 full scan finds entries even if FTS5 misses.\"\"\"\n   430→        _save(\n   431→            store,\n   432→            \"arch-overview\",\n   433→            \"The system architecture uses microservices\",\n   434→        )\n   435→\n   436→        results = retriever.search(\"microservices architecture\", store)\n   437→\n   438→        assert len(results) >= 1\n   439→        found_keys = [r.entry.key for r in results]\n   440→        assert \"arch-overview\" in found_keys\n   441→\n   442→\n   443→# ---------------------------------------------------------------------------\n   444→# Composite scoring integration\n   445→# ---------------------------------------------------------------------------\n   446→\n   447→\n   448→class TestCompositeScoringIntegration:\n   449→    \"\"\"Verify all scoring components work together in real retrieval.\"\"\"\n   450→\n   451→    def test_high_confidence_entry_ranks_higher(\n   452→        self, store: MemoryStore, retriever: MemoryRetriever\n   453→    ) -> None:\n   454→        \"\"\"High-confidence entry should outscore low-confidence with same text.\"\"\"\n   455→        _save(\n   456→            store,\n   457→            \"low-conf\",\n   458→            \"Testing approach uses mocks for external services\",\n   459→            confidence=0.3,\n   460→        )\n   461→        _save(\n   462→            store,\n   463→            \"high-conf\",\n   464→            \"Testing approach uses mocks for external services\",\n   465→            confidence=0.95,\n   466→            source=\"human\",\n   467→        )\n   468→\n   469→        results = retriever.search(\"testing mocks external services\", store)\n   470→\n   471→        assert len(results) == 2\n   472→        assert results[0].entry.key == \"high-conf\"\n   473→\n   474→    def test_frequently_accessed_entry_gets_frequency_boost(\n   475→        self, store: MemoryStore, retriever: MemoryRetriever\n   476→    ) -> None:\n   477→        _save(\n   478→            store,\n   479→            \"popular-entry\",\n   480→            \"Docker container orchestration with compose\",\n   481→        )\n   482→        _save(\n   483→            store,\n   484→            \"rare-entry\",\n   485→            \"Docker container orchestration with swarm\",\n   486→        )\n   487→\n   488→        # Simulate frequent access\n   489→        for _ in range(15):\n   490→            store.get(\"popular-entry\")\n   491→\n   492→        results = retriever.search(\"Docker container orchestration\", store)\n   493→\n   494→        assert len(results) == 2\n   495→        popular = next(r for r in results if r.entry.key == \"popular-entry\")\n   496→        rare = next(r for r in results if r.entry.key == \"rare-entry\")\n   497→        assert popular.score > rare.score\n   498→\n   499→    def test_exact_key_match_gets_bonus(\n   500→        self, store: MemoryStore, retriever: MemoryRetriever\n   501→    ) -> None:\n   502→        _save(\n   503→            store,\n   504→            \"database-setup\",\n   505→            \"Configure PostgreSQL with connection pooling\",\n   506→        )\n   507→        _save(\n   508→            store,\n   509→            \"db-pooling\",\n   510→            \"Database connection pool sizing guidelines\",\n   511→        )\n   512→\n   513→        results = retriever.search(\"database-setup\", store)\n   514→\n   515→        assert len(results) >= 1\n   516→        assert results[0].entry.key == \"database-setup\"\n   517→\n   518→    def test_limit_parameter_respected(\n   519→        self, store: MemoryStore, retriever: MemoryRetriever\n   520→    ) -> None:\n   521→        for i in range(10):\n   522→            _save(\n   523→                store,\n   524→                f\"entry-{i:02d}\",\n   525→                f\"Testing topic number {i} with pytest\",\n   526→            )\n   527→\n   528→        results = retriever.search(\"testing pytest\", store, limit=3)\n   529→        assert len(results) <= 3\n   530→\n   531→    def test_scored_memory_fields_populated(\n   532→        self, store: MemoryStore, retriever: MemoryRetriever\n   533→    ) -> None:\n   534→        _save(\n   535→            store,\n   536→            \"check-fields\",\n   537→            \"Verify all scored memory fields are populated\",\n   538→        )\n   539→\n   540→        results = retriever.search(\"scored memory fields\", store)\n   541→\n   542→        assert len(results) >= 1\n   543→        r: ScoredMemory = results[0]\n   544→        assert r.score > 0.0\n   545→        assert 0.0 <= r.effective_confidence <= 1.0\n   546→        assert 0.0 <= r.bm25_relevance <= 1.0\n   547→        assert isinstance(r.stale, bool)\n   548→        assert r.entry.key == \"check-fields\"\n   549→"}]},"parent_tool_use_id":"toolu_01Xzfu4twbN6y7LmLAQN294h","session_id":"4c2bbd2a-1a06-4e1e-9000-d7a8b9bf3b8b","uuid":"0dad4895-46a9-4989-bc5d-1c46d577b819","timestamp":"2026-03-22T22:46:51.563Z"}
