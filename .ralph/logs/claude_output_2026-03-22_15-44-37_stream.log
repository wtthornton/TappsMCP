{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019aTgcF4VTmgDZzHuuhssEH","type":"tool_result","content":"     1→\"\"\"Tests for memory.bm25 — BM25 scoring engine.\"\"\"\n     2→\n     3→from __future__ import annotations\n     4→\n     5→import math\n     6→\n     7→from tapps_brain.bm25 import (\n     8→    _STOP_WORDS,\n     9→    BM25Scorer,\n    10→    preprocess,\n    11→    stem,\n    12→)\n    13→\n    14→# ---------------------------------------------------------------------------\n    15→# stem()\n    16→# ---------------------------------------------------------------------------\n    17→\n    18→\n    19→class TestStem:\n    20→    def test_strips_ing(self) -> None:\n    21→        assert stem(\"running\") == \"runn\"\n    22→\n    23→    def test_strips_ed(self) -> None:\n    24→        assert stem(\"walked\") == \"walk\"\n    25→\n    26→    def test_strips_ly(self) -> None:\n    27→        assert stem(\"quickly\") == \"quick\"\n    28→\n    29→    def test_strips_tion(self) -> None:\n    30→        assert stem(\"creation\") == \"crea\"\n    31→\n    32→    def test_strips_ment(self) -> None:\n    33→        assert stem(\"development\") == \"develop\"\n    34→\n    35→    def test_strips_ness(self) -> None:\n    36→        assert stem(\"darkness\") == \"dark\"\n    37→\n    38→    def test_strips_er(self) -> None:\n    39→        assert stem(\"faster\") == \"fast\"\n    40→\n    41→    def test_strips_est(self) -> None:\n    42→        assert stem(\"fastest\") == \"fast\"\n    43→\n    44→    def test_strips_s(self) -> None:\n    45→        assert stem(\"tests\") == \"test\"\n    46→\n    47→    def test_no_strip_short_word(self) -> None:\n    48→        # \"us\" - stripping \"s\" would leave \"u\" (< 3 chars)\n    49→        assert stem(\"us\") == \"us\"\n    50→\n    51→    def test_no_strip_when_stem_too_short(self) -> None:\n    52→        # \"bing\" - stripping \"ing\" leaves \"b\" (< 3 chars)\n    53→        assert stem(\"bing\") == \"bing\"\n    54→\n    55→    def test_no_matching_suffix(self) -> None:\n    56→        assert stem(\"python\") == \"python\"\n    57→\n    58→\n    59→# ---------------------------------------------------------------------------\n    60→# preprocess()\n    61→# ---------------------------------------------------------------------------\n    62→\n    63→\n    64→class TestPreprocess:\n    65→    def test_lowercases(self) -> None:\n    66→        result = preprocess(\"Hello World\")\n    67→        assert \"hello\" in result\n    68→        assert \"world\" in result\n    69→\n    70→    def test_removes_stop_words(self) -> None:\n    71→        result = preprocess(\"the quick brown fox\")\n    72→        assert \"the\" not in result\n    73→        # \"quick\" stems to \"quick\" (stripping \"ly\" would leave \"quick\" but no \"ly\" suffix)\n    74→        assert \"quick\" in result\n    75→\n    76→    def test_stems_tokens(self) -> None:\n    77→        result = preprocess(\"running tests quickly\")\n    78→        assert \"runn\" in result\n    79→        assert \"test\" in result\n    80→        assert \"quick\" in result\n    81→\n    82→    def test_empty_input(self) -> None:\n    83→        assert preprocess(\"\") == []\n    84→\n    85→    def test_only_stop_words(self) -> None:\n    86→        assert preprocess(\"the a an is\") == []\n    87→\n    88→    def test_strips_punctuation(self) -> None:\n    89→        result = preprocess(\"hello, world! foo-bar\")\n    90→        assert result == [\"hello\", \"world\", \"foo\", \"bar\"]\n    91→\n    92→\n    93→# ---------------------------------------------------------------------------\n    94→# Stop words sanity\n    95→# ---------------------------------------------------------------------------\n    96→\n    97→\n    98→class TestStopWords:\n    99→    def test_contains_common_words(self) -> None:\n   100→        for word in (\"the\", \"is\", \"and\", \"of\", \"to\", \"in\", \"a\"):"}]},"parent_tool_use_id":"toolu_01Xzfu4twbN6y7LmLAQN294h","session_id":"4c2bbd2a-1a06-4e1e-9000-d7a8b9bf3b8b","uuid":"d808bce9-ae4b-4120-930a-bf33d9e7e476","timestamp":"2026-03-22T22:46:55.878Z"}
