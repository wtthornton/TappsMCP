3→        # Epic 65.14: Apply retrieval policy tag filtering\n   274→        if self._retrieval_policy is not None:\n   275→            blocked_tags = set(getattr(self._retrieval_policy, \"block_sensitive_tags\", []))\n   276→            if blocked_tags:\n   277→                scored = [s for s in scored if not blocked_tags.intersection(s.entry.tags)]\n   278→\n   279→        # Sort by score descending\n   280→        scored.sort(key=lambda s: s.score, reverse=True)\n   281→\n   282→        # Epic 65.9: optional reranking of top-20 -> top_k\n   283→        if self._reranker_enabled and self._reranker is not None and scored:\n   284→            scored = self._apply_reranker(query, scored, limit)\n   285→\n   286→        return scored[:limit]\n   287→\n   288→    def _apply_reranker(\n   289→        self,\n   290→        query: str,\n   291→        scored: list[ScoredMemory],\n   292→        limit: int,\n   293→    ) -> list[ScoredMemory]:\n   294→        \"\"\"Apply reranker to top candidates; fallback to original order on failure.\"\"\"\n   295→        assert self._reranker is not None  # caller checks before calling\n   296→        top_candidates = scored[:RERANKER_TOP_CANDIDATES]\n   297→        candidates = [(sm.entry.key, sm.entry.value) for sm in top_candidates]\n   298→        effective_top_k = min(limit, len(candidates))\n   299→\n   300→        try:\n   301→            reranked = self._reranker.rerank(query, candidates, top_k=effective_top_k)\n   302→        except Exception as e:\n   303→            logger.warning(\n   304→                \"reranker_failed_fallback_to_original\",\n   305→                reason=str(e),\n   306→            )\n   307→            return scored\n   308→\n   309→        if not reranked:"}]},"parent_tool_use_id":"toolu_01GMYqRL7Arce5h4vZrADgHe","session_id":"4c2bbd2a-1a06-4e1e-9000-d7a8b9bf3b8b","uuid":"341fff37-3f43-4de2-964d-0357519bf751","timestamp":"2026-03-22T22:47:18.651Z"}
