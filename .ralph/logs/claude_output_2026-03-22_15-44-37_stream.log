{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WbqQEn1prGUVFCsFqg1Jwz","type":"tool_result","content":"   100→    if tier_str in config.layer_half_lives:\n   101→        return config.layer_half_lives[tier_str]\n   102→\n   103→    # Fallback: enum-based attribute lookup\n   104→    if isinstance(tier, MemoryTier):\n   105→        attr = _TIER_HALF_LIFE_ATTR[tier]\n   106→        return int(getattr(config, attr))\n   107→\n   108→    # Try converting string to MemoryTier\n   109→    try:\n   110→        tier_enum = MemoryTier(tier_str)\n   111→        attr = _TIER_HALF_LIFE_ATTR[tier_enum]\n   112→        return int(getattr(config, attr))\n   113→    except ValueError:\n   114→        pass\n   115→\n   116→    # Unknown tier: use the shortest default half-life (context=14)\n   117→    return config.context_half_life_days\n   118→\n   119→\n   120→def _get_ceiling(source: MemorySource | str, config: DecayConfig) -> float:\n   121→    \"\"\"Return the confidence ceiling for a given source type.\n   122→\n   123→    Checks profile-based ``profile_source_ceilings`` first (EPIC-010),\n   124→    then falls back to the hardcoded attribute mapping.\n   125→    \"\"\"\n   126→    source_str = source.value if isinstance(source, MemorySource) else str(source)\n   127→\n   128→    # EPIC-010: profile-based ceilings\n   129→    if source_str in config.profile_source_ceilings:\n   130→        return config.profile_source_ceilings[source_str]\n   131→\n   132→    # Fallback: enum-based attribute lookup\n   133→    if isinstance(source, MemorySource):\n   134→        attr = _SOURCE_CEILING_ATTR.get(source, \"agent_confidence_ceiling\")\n   135→        return float(getattr(config, attr))\n   136→\n   137→    try:\n   138→        source_enum = MemorySource(source_str)\n   139→        attr = _SOURCE_CEILING_ATTR.get(source_enum, \"agent_confidence_ceiling\")\n   140→        return float(getattr(config, attr))\n   141→    except ValueError:\n   142→        return config.agent_confidence_ceiling\n   143→\n   144→\n   145→def _get_confidence_floor(tier: MemoryTier | str, config: DecayConfig) -> float:\n   146→    \"\"\"Return the confidence floor for a given tier.\n   147→\n   148→    Checks profile-based ``layer_confidence_floors`` first (EPIC-010),\n   149→    then falls back to the global ``confidence_floor``.\n   150→    \"\"\"\n   151→    tier_str = tier.value if isinstance(tier, MemoryTier) else str(tier)\n   152→    if tier_str in config.layer_confidence_floors:\n   153→        return config.layer_confidence_floors[tier_str]\n   154→    return config.confidence_floor\n   155→\n   156→\n   157→def _days_since(iso_timestamp: str, now: datetime | None = None) -> float:\n   158→    \"\"\"Return fractional days elapsed since an ISO-8601 timestamp.\"\"\"\n   159→    if now is None:\n   160→        now = datetime.now(tz=UTC)\n   161→    try:\n   162→        ts = datetime.fromisoformat(iso_timestamp)\n   163→        if ts.tzinfo is None:\n   164→            ts = ts.replace(tzinfo=UTC)\n   165→    except (ValueError, TypeError):\n   166→        return 0.0\n   167→    delta = now - ts\n   168→    return max(delta.total_seconds() / _SECONDS_PER_DAY, 0.0)\n   169→\n   170→\n   171→def _decay_reference_time(entry: MemoryEntry) -> str:\n   172→    \"\"\"Return the timestamp from which decay is measured.\n   173→\n   174→    Uses ``last_reinforced`` if set, otherwise ``updated_at``.\n   175→    \"\"\"\n   176→    if entry.last_reinforced:\n   177→        return entry.last_reinforced\n   178→    return entry.updated_at\n   179→\n   180→\n   181→def calculate_decayed_confidence(\n   182→    entry: MemoryEntry,\n   183→    config: DecayConfig,\n   184→    *,\n   185→    now: datetime | None = None,\n   186→) -> float:\n   187→    \"\"\"Calculate the time-decayed confidence for a memory entry.\n   188→\n   189→    Uses exponential decay by default: ``confidence * 0.5^(days / half_life)``.\n   190→    When ``decay_model=\"power_law\"`` (EPIC-010), uses:\n   191→    ``confidence * (1 + days / (k * half_life))^(-beta)``.\n   192→    The result is clamped to ``[confidence_floor, source_ceiling]``.\n   193→    \"\"\"\n   194→    half_life = _get_half_life(entry.tier, config)\n   195→    ceiling = _get_ceiling(entry.source, config)\n   196→    floor = _get_confidence_floor(entry.tier, config)\n   197→\n   198→    ref_time = _decay_reference_time(entry)\n   199→    days = _days_since(ref_time, now)\n   200→\n   201→    # Determine decay model for this tier (EPIC-010)\n   202→    tier_str = entry.tier.value if isinstance(entry.tier, MemoryTier) else str(entry.tier)\n   203→\n   204→    # EPIC-010: Importance tags — boost effective half-life\n   205→    effective_hl = float(half_life)\n   206→    importance_tags = config.layer_importance_tags.get(tier_str, {})\n   207→    if importance_tags and entry.tags:\n   208→        max_multiplier = 1.0\n   209→        for tag in entry.tags:\n   210→            if tag in importance_tags:\n   211→                max_multiplier = max(max_multiplier, importance_tags[tag])\n   212→        effective_hl = half_life * max_multiplier\n   213→\n   214→    decay_model = config.layer_decay_models.get(tier_str, config.decay_model)\n   215→\n   216→    if decay_model == \"power_law\":\n   217→        # Power-law decay: C0 x (1 + t / (k x H))^(-beta)\n   218→        beta = config.layer_decay_exponents.get(tier_str, config.decay_exponent)\n   219→        k = 9.0  # Scaling constant (from FSRS)\n   220→        decay_factor = math.pow(1.0 + days / (k * effective_hl), -beta)\n   221→    else:\n   222→        # Exponential decay: confidence * 0.5^(days / half_life)\n   223→        decay_factor = math.pow(0.5, days / effective_hl)\n   224→\n   225→    decayed = entry.confidence * decay_factor\n   226→\n   227→    # Clamp to [floor, ceiling]\n   228→    return max(floor, min(ceiling, decayed))\n   229→\n   230→\n   231→def is_stale(\n   232→    entry: MemoryEntry,\n   233→    config: DecayConfig,\n   234→    threshold: float = _DEFAULT_STALE_THRESHOLD,\n   235→    *,\n   236→    now: datetime | None = None,\n   237→) -> bool:\n   238→    \"\"\"Return True if the memory's effective confidence is below *threshold*.\"\"\"\n   239→    effective = calculate_decayed_confidence(entry, config, now=now)\n   240→    return effective < threshold\n   241→\n   242→\n   243→def get_effective_confidence(\n   244→    entry: MemoryEntry,\n   245→    config: DecayConfig,\n   246→    *,\n   247→    now: datetime | None = None,\n   248→) -> tuple[float, bool]:\n   249→    \"\"\"Return ``(decayed_confidence, is_stale)`` for a memory entry."}]},"parent_tool_use_id":"toolu_01GMYqRL7Arce5h4vZrADgHe","session_id":"4c2bbd2a-1a06-4e1e-9000-d7a8b9bf3b8b","uuid":"3e149fa4-e22d-4cc5-9700-9deab0ee0527","timestamp":"2026-03-22T22:47:10.154Z"}
