{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FSCGkPhmZznktdn9Ypnrhz","type":"tool_result","content":"     1→\"\"\"Shared test factories for tapps-brain.\n     2→\n     3→Provides a single ``make_entry`` helper that covers all parameter\n     4→variants previously scattered across per-file ``_make_entry`` helpers.\n     5→\"\"\"\n     6→\n     7→from __future__ import annotations\n     8→\n     9→from datetime import UTC, datetime\n    10→\n    11→from tapps_brain.models import (\n    12→    MemoryEntry,\n    13→    MemoryScope,\n    14→    MemorySource,\n    15→    MemoryTier,\n    16→)\n    17→\n    18→\n    19→def make_entry(\n    20→    key: str = \"test-key\",\n    21→    value: str = \"test value\",\n    22→    *,\n    23→    tier: MemoryTier = MemoryTier.pattern,\n    24→    confidence: float = -1.0,\n    25→    source: MemorySource | str = MemorySource.agent,\n    26→    source_agent: str = \"test\",\n    27→    scope: MemoryScope = MemoryScope.project,\n    28→    tags: list[str] | None = None,\n    29→    branch: str | None = None,\n    30→    created_at: str | None = None,\n    31→    updated_at: str | None = None,\n    32→    last_accessed: str | None = None,\n    33→    access_count: int = 0,\n    34→    last_reinforced: str | None = None,\n    35→    reinforce_count: int = 0,\n    36→    contradicted: bool = False,\n    37→    contradiction_reason: str | None = None,\n    38→    seeded_from: str | None = None,\n    39→    valid_at: str | None = None,\n    40→    invalid_at: str | None = None,\n    41→    superseded_by: str | None = None,\n    42→) -> MemoryEntry:\n    43→    \"\"\"Create a ``MemoryEntry`` with sensible test defaults.\n    44→\n    45→    Every parameter accepted by ``MemoryEntry`` can be overridden.\n    46→    Timestamp fields default to *now* when not supplied.\n    47→\n    48→    The ``confidence`` default of ``-1.0`` triggers the model's\n    49→    source-based default (0.95 for human, 0.6 for agent, etc.).\n    50→    Pass an explicit float to override.\n    51→    \"\"\"\n    52→    now_iso = datetime.now(tz=UTC).isoformat()\n    53→\n    54→    kwargs: dict[str, object] = {\n    55→        \"key\": key,\n    56→        \"value\": value,\n    57→        \"tier\": tier,\n    58→        \"source\": source,\n    59→        \"source_agent\": source_agent,\n    60→        \"scope\": scope,\n    61→        \"tags\": tags or [],\n    62→        \"branch\": branch,\n    63→        \"created_at\": created_at or now_iso,\n    64→        \"updated_at\": updated_at or now_iso,\n    65→        \"last_accessed\": last_accessed or now_iso,\n    66→        \"access_count\": access_count,\n    67→        \"last_reinforced\": last_reinforced,\n    68→        \"reinforce_count\": reinforce_count,\n    69→        \"contradicted\": contradicted,\n    70→        \"contradiction_reason\": contradiction_reason,\n    71→        \"seeded_from\": seeded_from,\n    72→        \"valid_at\": valid_at,\n    73→        \"invalid_at\": invalid_at,\n    74→        \"superseded_by\": superseded_by,\n    75→    }\n    76→\n    77→    if confidence != -1.0:\n    78→        kwargs[\"confidence\"] = confidence\n    79→\n    80→    return MemoryEntry(**kwargs)  # type: ignore[arg-type]\n    81→"}]},"parent_tool_use_id":"toolu_01Xzfu4twbN6y7LmLAQN294h","session_id":"4c2bbd2a-1a06-4e1e-9000-d7a8b9bf3b8b","uuid":"24774ad9-5602-4668-b9ce-2084ca61a236","timestamp":"2026-03-22T22:46:55.593Z"}
