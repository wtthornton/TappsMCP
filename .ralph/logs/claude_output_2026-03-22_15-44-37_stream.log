{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G55HkeurFTqHU2aTnewvRa","type":"tool_result","content":"  1998→def _ranked_search(\n  1999→    store: MemoryStore,\n  2000→    query: str,\n  2001→    limit: int,\n  2002→    include_summary: bool,\n  2003→    include_sources: bool = False,\n  2004→    include_session_index: bool = False,\n  2005→) -> dict[str, Any]:\n  2006→    \"\"\"Execute ranked BM25 search via MemoryRetriever (hybrid + reranker when enabled).\n  2007→\n  2008→    When include_session_index and memory.session_index.enabled, merges session\n  2009→    index hits with memory results (Epic 65.10).\n  2010→    \"\"\"\n  2011→    from tapps_core.config.settings import load_settings\n  2012→    from tapps_core.memory.reranker import get_reranker\n  2013→    from tapps_core.memory.retrieval import MemoryRetriever\n  2014→\n  2015→    settings = load_settings()\n  2016→    rr = settings.memory.reranker\n  2017→    reranker = (\n  2018→        get_reranker(\n  2019→            enabled=rr.enabled,\n  2020→            provider=rr.provider,\n  2021→            top_k=rr.top_k,\n  2022→            api_key=rr.api_key,\n  2023→        )\n  2024→        if rr.enabled\n  2025→        else None\n  2026→    )\n  2027→    retriever = MemoryRetriever(\n  2028→        semantic_enabled=settings.memory.semantic_search.enabled,\n  2029→        hybrid_config=settings.memory.hybrid,\n  2030→        reranker=reranker,\n  2031→        reranker_enabled=rr.enabled,\n  2032→        relations_enabled=settings.memory.relations.enabled,\n  2033→        expand_queries=settings.memory.relations.expand_queries,\n  2034→    )\n  2035→    scored = retriever.search(query, store, limit=limit, include_sources=include_sources)\n  2036→\n  2037→    # M3: Graph-boosted recall -- density-gated activation (>= 10 relation triples)\n  2038→    graph_boost_min_relations = 10\n  2039→    graph_boost_factor = 0.1\n  2040→    graph_boosted = False\n  2041→    connected: dict[str, int] = {}\n  2042→    if scored and hasattr(store, \"count_relations\"):\n  2043→        try:\n  2044→            rel_count = store.count_relations()\n  2045→            if rel_count >= graph_boost_min_relations:\n  2046→                graph_boosted = True\n  2047→                # Collect result keys\n  2048→                result_keys = {sm.entry.key for sm in scored}\n  2049→                # Build connected map: key -> min hop distance\n  2050→                for sm in scored:\n  2051→                    try:\n  2052→                        related = store.find_related(sm.entry.key, max_hops=2)\n  2053→                    except (KeyError, AttributeError):\n  2054→                        continue\n  2055→                    for rel_key, hop in related:\n  2056→                        if rel_key in result_keys and (\n  2057→                            rel_key not in connected or hop < connected[rel_key]\n  2058→                        ):\n  2059→                            connected[rel_key] = hop\n  2060→                # Apply additive boost inversely proportional to hop distance\n  2061→                if connected:\n  2062→                    for sm in scored:\n  2063→                        if sm.entry.key in connected:\n  2064→                            hop = connected[sm.entry.key]\n  2065→                            hop_boost = graph_boost_factor / hop\n  2066→                            sm.score = min(sm.score + hop_boost, 1.0)\n  2067→                    scored.sort(key=lambda s: s.score, reverse=True)\n  2068→        except Exception:\n  2069→            logger.debug(\"graph_boost_skipped\", reason=\"count_relations unavailable\")\n  2070→\n  2071→    result_entries: list[dict[str, Any]] = []\n  2072→    for i, sm in enumerate(scored):\n  2073→        entry_data = (\n  2074→            _summarize_entry(sm.entry)\n  2075→            if include_summary and i >= _FULL_VALUE_THRESHOLD\n  2076→            else sm.entry.model_dump()\n  2077→        )\n  2078→        entry_dict: dict[str, Any] = {\n  2079→            \"entry\": entry_data,\n  2080→            \"score\": sm.score,\n  2081→            \"effective_confidence\": sm.effective_confidence,\n  2082→            \"stale\": sm.stale,\n  2083→            \"source\": \"memory\",\n  2084→        }\n  2085→        if graph_boosted and sm.entry.key in connected:\n  2086→            entry_dict[\"graph_boosted\"] = True\n  2087→        result_entries.append(entry_dict)\n  2088→\n  2089→    # Epic 65.10: optionally include session index hits\n  2090→    if include_session_index and settings.memory.session_index.enabled:\n  2091→        from tapps_core.memory.session_index import search_session_index\n  2092→\n  2093→        sess_limit = min(limit, 5)\n  2094→        sess_hits = search_session_index(store.project_root, query, limit=sess_limit)\n  2095→        for i, hit in enumerate(sess_hits):\n  2096→            score = 0.7 - (i * 0.05)\n  2097→            result_entries.append(\n  2098→                {\n  2099→                    \"session_chunk\": {\n  2100→                        \"session_id\": hit[\"session_id\"],\n  2101→                        \"chunk_index\": hit[\"chunk_index\"],\n  2102→                        \"content\": hit[\"content\"][:200] + (\"...\" if len(hit[\"content\"]) > 200 else \"\"),\n  2103→                        \"created_at\": hit[\"created_at\"],\n  2104→                    },\n  2105→                    \"score\": max(0.4, score),\n  2106→                    \"effective_confidence\": 0.5,\n  2107→                    \"stale\": False,\n  2108→                    \"source\": \"session_index\",\n  2109→                }\n  2110→            )\n  2111→        result_entries.sort(key=lambda x: x[\"score\"], reverse=True)\n  2112→        result_entries = result_entries[:limit]\n  2113→\n  2114→    result: dict[str, Any] = {\n  2115→        \"action\": \"search\",\n  2116→        \"ranked\": True,\n  2117→        \"graph_boost_active\": graph_boosted,\n  2118→        \"results\": result_entries,\n  2119→        \"total_count\": len(result_entries),\n  2120→        \"returned_count\": len(result_entries),\n  2121→        \"query\": query,\n  2122→        \"store_metadata\": _store_metadata(store),\n  2123→    }\n  2124→    return result\n  2125→\n  2126→\n  2127→# Marker text for consolidated source entries"}]},"parent_tool_use_id":null,"session_id":"4c2bbd2a-1a06-4e1e-9000-d7a8b9bf3b8b","uuid":"97a7e258-5f6b-4cae-b0d3-3e2037aef4f4","timestamp":"2026-03-22T22:48:31.185Z","tool_use_result":{"type":"text","file":{"filePath":"/mnt/c/cursor/TappMCP/packages/tapps-mcp/src/tapps_mcp/server_memory_tools.py","content":"def _ranked_search(\n    store: MemoryStore,\n    query: str,\n    limit: int,\n    include_summary: bool,\n    include_sources: bool = False,\n    include_session_index: bool = False,\n) -> dict[str, Any]:\n    \"\"\"Execute ranked BM25 search via MemoryRetriever (hybrid + reranker when enabled).\n\n    When include_session_index and memory.session_index.enabled, merges session\n    index hits with memory results (Epic 65.10).\n    \"\"\"\n    from tapps_core.config.settings import load_settings\n    from tapps_core.memory.reranker import get_reranker\n    from tapps_core.memory.retrieval import MemoryRetriever\n\n    settings = load_settings()\n    rr = settings.memory.reranker\n    reranker = (\n        get_reranker(\n            enabled=rr.enabled,\n            provider=rr.provider,\n            top_k=rr.top_k,\n            api_key=rr.api_key,\n        )\n        if rr.enabled\n        else None\n    )\n    retriever = MemoryRetriever(\n        semantic_enabled=settings.memory.semantic_search.enabled,\n        hybrid_config=settings.memory.hybrid,\n        reranker=reranker,\n        reranker_enabled=rr.enabled,\n        relations_enabled=settings.memory.relations.enabled,\n        expand_queries=settings.memory.relations.expand_queries,\n    )\n    scored = retriever.search(query, store, limit=limit, include_sources=include_sources)\n\n    # M3: Graph-boosted recall -- density-gated activation (>= 10 relation triples)\n    graph_boost_min_relations = 10\n    graph_boost_factor = 0.1\n    graph_boosted = False\n    connected: dict[str, int] = {}\n    if scored and hasattr(store, \"count_relations\"):\n        try:\n            rel_count = store.count_relations()\n            if rel_count >= graph_boost_min_relations:\n                graph_boosted = True\n                # Collect result keys\n                result_keys = {sm.entry.key for sm in scored}\n                # Build connected map: key -> min hop distance\n                for sm in scored:\n                    try:\n                        related = store.find_related(sm.entry.key, max_hops=2)\n                    except (KeyError, AttributeError):\n                        continue\n                    for rel_key, hop in related:\n                        if rel_key in result_keys and (\n                            rel_key not in connected or hop < connected[rel_key]\n                        ):\n                            connected[rel_key] = hop\n                # Apply additive boost inversely proportional to hop distance\n                if connected:\n                    for sm in scored:\n                        if sm.entry.key in connected:\n                            hop = connected[sm.entry.key]\n                            hop_boost = graph_boost_factor / hop\n                            sm.score = min(sm.score + hop_boost, 1.0)\n                    scored.sort(key=lambda s: s.score, reverse=True)\n        except Exception:\n            logger.debug(\"graph_boost_skipped\", reason=\"count_relations unavailable\")\n\n    result_entries: list[dict[str, Any]] = []\n    for i, sm in enumerate(scored):\n        entry_data = (\n            _summarize_entry(sm.entry)\n            if include_summary and i >= _FULL_VALUE_THRESHOLD\n            else sm.entry.model_dump()\n        )\n        entry_dict: dict[str, Any] = {\n            \"entry\": entry_data,\n            \"score\": sm.score,\n            \"effective_confidence\": sm.effective_confidence,\n            \"stale\": sm.stale,\n            \"source\": \"memory\",\n        }\n        if graph_boosted and sm.entry.key in connected:\n            entry_dict[\"graph_boosted\"] = True\n        result_entries.append(entry_dict)\n\n    # Epic 65.10: optionally include session index hits\n    if include_session_index and settings.memory.session_index.enabled:\n        from tapps_core.memory.session_index import search_session_index\n\n        sess_limit = min(limit, 5)\n        sess_hits = search_session_index(store.project_root, query, limit=sess_limit)\n        for i, hit in enumerate(sess_hits):\n            score = 0.7 - (i * 0.05)\n            result_entries.append(\n                {\n                    \"session_chunk\": {\n                        \"session_id\": hit[\"session_id\"],\n                        \"chunk_index\": hit[\"chunk_index\"],\n                        \"content\": hit[\"content\"][:200] + (\"...\" if len(hit[\"content\"]) > 200 else \"\"),\n                        \"created_at\": hit[\"created_at\"],\n                    },\n                    \"score\": max(0.4, score),\n                    \"effective_confidence\": 0.5,\n                    \"stale\": False,\n                    \"source\": \"session_index\",\n                }\n            )\n        result_entries.sort(key=lambda x: x[\"score\"], reverse=True)\n        result_entries = result_entries[:limit]\n\n    result: dict[str, Any] = {\n        \"action\": \"search\",\n        \"ranked\": True,\n        \"graph_boost_active\": graph_boosted,\n        \"results\": result_entries,\n        \"total_count\": len(result_entries),\n        \"returned_count\": len(result_entries),\n        \"query\": query,\n        \"store_metadata\": _store_metadata(store),\n    }\n    return result\n\n\n# Marker text for consolidated source entries","numLines":130,"startLine":1998,"totalLines":2240}}}
