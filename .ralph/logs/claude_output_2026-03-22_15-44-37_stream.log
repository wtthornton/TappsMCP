{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011ehTnh1owEduGtxt3kQ1CE","type":"tool_result","content":"     1→\"\"\"Tests for source_trust multiplier in composite retrieval scoring (M2).\"\"\"\n     2→\n     3→from __future__ import annotations\n     4→\n     5→from datetime import UTC, datetime, timedelta\n     6→from unittest.mock import MagicMock\n     7→\n     8→import pytest\n     9→\n    10→from tapps_brain.models import MemoryEntry, MemorySource, MemoryTier\n    11→from tapps_brain.profile import ScoringConfig, _DEFAULT_SOURCE_TRUST\n    12→from tapps_brain.retrieval import MemoryRetriever, _DEFAULT_SOURCE_TRUST as _RET_DEFAULT_TRUST\n    13→from tests.factories import make_entry\n    14→\n    15→# ---------------------------------------------------------------------------\n    16→# Helpers\n    17→# ---------------------------------------------------------------------------\n    18→\n    19→_NOW = datetime(2026, 3, 22, 12, 0, 0, tzinfo=UTC)\n    20→_RECENT = (_NOW - timedelta(days=1)).isoformat()\n    21→\n    22→\n    23→def _make_entry(\n    24→    key: str = \"test-key\",\n    25→    value: str = \"test value\",\n    26→    *,\n    27→    confidence: float = 0.8,\n    28→    source: MemorySource = MemorySource.agent,\n    29→    access_count: int = 5,\n    30→) -> MemoryEntry:\n    31→    return make_entry(\n    32→        key=key,\n    33→        value=value,\n    34→        confidence=confidence,\n    35→        source=source,\n    36→        updated_at=_RECENT,\n    37→        created_at=_RECENT,\n    38→        last_accessed=_RECENT,\n    39→        access_count=access_count,\n    40→    )\n    41→\n    42→\n    43→def _make_store(entries: list[MemoryEntry]) -> MagicMock:\n    44→    store = MagicMock()\n    45→    store.list_all.return_value = entries\n    46→    store.search.return_value = entries\n    47→    entry_map = {e.key: e for e in entries}\n    48→    store.get.side_effect = lambda k, **kwargs: entry_map.get(k)\n    49→    return store\n    50→\n    51→\n    52→# ---------------------------------------------------------------------------\n    53→# ScoringConfig source_trust tests\n    54→# ---------------------------------------------------------------------------\n    55→\n    56→\n    57→class TestScoringConfigSourceTrust:\n    58→    def test_default_source_trust_values(self) -> None:\n    59→        config = ScoringConfig()\n    60→        assert config.source_trust == {\n    61→            \"human\": 1.0,\n    62→            \"system\": 0.9,\n    63→            \"agent\": 0.7,\n    64→            \"inferred\": 0.5,\n    65→        }\n    66→\n    67→    def test_custom_source_trust_accepted(self) -> None:\n    68→        config = ScoringConfig(source_trust={\"human\": 1.0, \"agent\": 0.5})\n    69→        assert config.source_trust[\"agent\"] == 0.5\n    70→\n    71→    def test_weight_sum_unaffected_by_source_trust(self) -> None:\n    72→        \"\"\"source_trust is a multiplier, not a weight — weight sum check ignores it.\"\"\"\n    73→        config = ScoringConfig(source_trust={\"human\": 2.0, \"agent\": 0.1})\n    74→        assert config.relevance + config.confidence + config.recency + config.frequency == pytest.approx(1.0)\n    75→\n    76→    def test_defaults_match_retrieval_module(self) -> None:\n    77→        \"\"\"Profile defaults and retrieval module defaults must agree.\"\"\"\n    78→        assert _DEFAULT_SOURCE_TRUST == _RET_DEFAULT_TRUST\n    79→\n    80→\n    81→# ---------------------------------------------------------------------------\n    82→# MemoryRetriever source_trust wiring tests\n    83→# ---------------------------------------------------------------------------\n    84→\n    85→\n    86→class TestRetrieverSourceTrust:\n    87→    def test_default_source_trust_loaded(self) -> None:\n    88→        retriever = MemoryRetriever()\n    89→        assert retriever._source_trust == _RET_DEFAULT_TRUST\n    90→\n    91→    def test_scoring_config_source_trust_loaded(self) -> None:\n    92→        config = ScoringConfig(source_trust={\"human\": 1.0, \"agent\": 0.3})\n    93→        retriever = MemoryRetriever(scoring_config=config)\n    94→        assert retriever._source_trust[\"agent\"] == 0.3\n    95→\n    96→    def test_scoring_config_without_source_trust_uses_default(self) -> None:\n    97→        \"\"\"If scoring_config has no source_trust attr, use module default.\"\"\"\n    98→\n    99→        class BareConfig:\n   100→            relevance = 0.40\n   101→            confidence = 0.30\n   102→            recency = 0.15\n   103→            frequency = 0.15\n   104→            bm25_norm_k = 5.0\n   105→            frequency_cap = 20\n   106→\n   107→        retriever = MemoryRetriever(scoring_config=BareConfig())\n   108→        assert retriever._source_trust == _RET_DEFAULT_TRUST\n   109→\n   110→\n   111→# ---------------------------------------------------------------------------\n   112→# Ranking impact tests\n   113→# ---------------------------------------------------------------------------\n   114→\n   115→\n   116→class TestSourceTrustRanking:\n   117→    def test_human_outranks_inferred_same_content(self) -> None:\n   118→        \"\"\"human (trust=1.0) should outrank inferred (trust=0.5) given equal signals.\"\"\"\n   119→        entries = [\n   120→            _make_entry(\"from-inferred\", \"shared data pattern\", source=MemorySource.inferred),\n   121→            _make_entry(\"from-human\", \"shared data pattern\", source=MemorySource.human),\n   122→        ]\n   123→        retriever = MemoryRetriever()\n   124→        store = _make_store(entries)\n   125→\n   126→        results = retriever.search(\"shared data pattern\", store)\n   127→        assert len(results) == 2\n   128→        assert results[0].entry.key == \"from-human\"\n   129→        assert results[0].score > results[1].score\n   130→\n   131→    def test_human_outranks_agent_same_content(self) -> None:\n   132→        \"\"\"human (trust=1.0) should outrank agent (trust=0.7) given equal signals.\"\"\"\n   133→        entries = [\n   134→            _make_entry(\"from-agent\", \"api design pattern\", source=MemorySource.agent),\n   135→            _make_entry(\"from-human\", \"api design pattern\", source=MemorySource.human),\n   136→        ]\n   137→        retriever = MemoryRetriever()\n   138→        store = _make_store(entries)\n   139→\n   140→        results = retriever.search(\"api design pattern\", store)\n   141→        assert len(results) == 2\n   142→        assert results[0].entry.key == \"from-human\"\n   143→\n   144→    def test_system_outranks_agent(self) -> None:\n   145→        \"\"\"system (trust=0.9) should outrank agent (trust=0.7) given equal signals.\"\"\"\n   146→        entries = [\n   147→            _make_entry(\"from-agent\", \"config setup data\", source=MemorySource.agent),\n   148→            _make_entry(\"from-system\", \"config setup data\", source=MemorySource.system),\n   149→        ]\n   150→        retriever = MemoryRetriever()\n   151→        store = _make_store(entries)\n   152→\n   153→        results = retriever.search(\"config setup data\", store)\n   154→        assert len(results) == 2\n   155→        assert results[0].entry.key == \"from-system\"\n   156→\n   157→    def test_source_trust_ordering_all_sources(self) -> None:\n   158→        \"\"\"All four sources should rank in trust order: human > system > agent > inferred.\"\"\"\n   159→        entries = [\n   160→            _make_entry(\"from-inferred\", \"common query term match\", source=MemorySource.inferred),\n   161→            _make_entry(\"from-agent\", \"common query term match\", source=MemorySource.agent),\n   162→            _make_entry(\"from-system\", \"common query term match\", source=MemorySource.system),\n   163→            _make_entry(\"from-human\", \"common query term match\", source=MemorySource.human),\n   164→        ]\n   165→        retriever = MemoryRetriever()\n   166→        store = _make_store(entries)\n   167→\n   168→        results = retriever.search(\"common query term match\", store)\n   169→        assert len(results) == 4\n   170→        keys = [r.entry.key for r in results]\n   171→        assert keys == [\"from-human\", \"from-system\", \"from-agent\", \"from-inferred\"]\n   172→\n   173→    def test_custom_trust_reverses_ranking(self) -> None:\n   174→        \"\"\"Custom trust config can invert the default ordering.\"\"\"\n   175→        config = ScoringConfig(source_trust={\"human\": 0.5, \"agent\": 1.0})\n   176→        entries = [\n   177→            _make_entry(\"from-human\", \"database config\", source=MemorySource.human),\n   178→            _make_entry(\"from-agent\", \"database config\", source=MemorySource.agent),\n   179→        ]\n   180→        retriever = MemoryRetriever(scoring_config=config)\n   181→        store = _make_store(entries)\n   182→\n   183→        results = retriever.search(\"database config\", store)\n   184→        assert len(results) == 2\n   185→        # Agent has trust=1.0, human has trust=0.5 — agent wins\n   186→        assert results[0].entry.key == \"from-agent\"\n   187→\n   188→    def test_unknown_source_defaults_to_1(self) -> None:\n   189→        \"\"\"An entry with an unrecognized source string gets trust=1.0 (no penalty).\"\"\"\n   190→        entry = _make_entry(\"custom-source\", \"test data\")\n   191→        # Manually set source to a string not in the trust dict\n   192→        entry = entry.model_copy(update={\"source\": \"custom\"})\n   193→\n   194→        retriever = MemoryRetriever()\n   195→        store = _make_store([entry])\n   196→\n   197→        results = retriever.search(\"test data\", store)\n   198→        assert len(results) == 1\n   199→        # Score should be positive (not zeroed out)\n   200→        assert results[0].score > 0\n   201→\n   202→    def test_trust_1_preserves_original_score(self) -> None:\n   203→        \"\"\"Trust=1.0 should not modify the composite score (identity multiplier).\"\"\"\n   204→        config = ScoringConfig(\n   205→            source_trust={\"human\": 1.0, \"agent\": 1.0, \"system\": 1.0, \"inferred\": 1.0}\n   206→        )\n   207→        entries = [_make_entry(\"test-key\", \"framework config\", source=MemorySource.agent)]\n   208→        retriever_default = MemoryRetriever()\n   209→        retriever_all_one = MemoryRetriever(scoring_config=config)\n   210→        store = _make_store(entries)\n   211→\n   212→        # With trust=1.0 for all, agent default is 0.7 → score differs\n   213→        # But if we set agent=1.0 explicitly, it should be higher\n   214→        results_one = retriever_all_one.search(\"framework config\", store)\n   215→        results_default = retriever_default.search(\"framework config\", store)\n   216→        assert len(results_one) == 1\n   217→        assert len(results_default) == 1\n   218→        # All-1.0 should produce >= default (agent default is 0.7)\n   219→        assert results_one[0].score >= results_default[0].score\n   220→\n   221→\n   222→# ---------------------------------------------------------------------------\n   223→# Profile YAML loading test\n   224→# ---------------------------------------------------------------------------\n   225→\n   226→\n   227→class TestProfileSourceTrustLoading:\n   228→    def test_repo_brain_profile_has_source_trust(self) -> None:\n   229→        from tapps_brain.profile import get_builtin_profile\n   230→\n   231→        profile = get_builtin_profile(\"repo-brain\")\n   232→        assert profile.scoring.source_trust == {\n   233→            \"human\": 1.0,\n   234→            \"system\": 0.9,\n   235→            \"agent\": 0.7,\n   236→            \"inferred\": 0.5,\n   237→        }\n   238→"}]},"parent_tool_use_id":"toolu_01Xzfu4twbN6y7LmLAQN294h","session_id":"4c2bbd2a-1a06-4e1e-9000-d7a8b9bf3b8b","uuid":"e87d2d1b-3425-47fd-baa1-9b10fce99f03","timestamp":"2026-03-22T22:46:50.988Z"}
