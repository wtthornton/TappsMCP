{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Sb1kstpqAcvptdD4j4Lx5Z","type":"tool_result","content":"     1→\"\"\"BM25 scoring engine for memory retrieval.\n     2→\n     3→Implements Okapi BM25 with basic text preprocessing (lowercasing,\n     4→stop-word removal, suffix stripping).  Pure Python, no external deps.\n     5→\"\"\"\n     6→\n     7→from __future__ import annotations\n     8→\n     9→import math\n    10→import re\n    11→from dataclasses import dataclass, field\n    12→\n    13→# ---------------------------------------------------------------------------\n    14→# Stop words (~50 common English words)\n    15→# ---------------------------------------------------------------------------\n    16→\n    17→_STOP_WORDS: frozenset[str] = frozenset(\n    18→    {\n    19→        \"a\",\n    20→        \"an\",\n    21→        \"and\",\n    22→        \"are\",\n    23→        \"as\",\n    24→        \"at\",\n    25→        \"be\",\n    26→        \"but\",\n    27→        \"by\",\n    28→        \"do\",\n    29→        \"for\",\n    30→        \"from\",\n    31→        \"had\",\n    32→        \"has\",\n    33→        \"have\",\n    34→        \"he\",\n    35→        \"her\",\n    36→        \"him\",\n    37→        \"his\",\n    38→        \"how\",\n    39→        \"i\",\n    40→        \"if\",\n    41→        \"in\",\n    42→        \"into\",\n    43→        \"is\",\n    44→        \"it\",\n    45→        \"its\",\n    46→        \"me\",\n    47→        \"my\",\n    48→        \"no\",\n    49→        \"not\",\n    50→        \"of\",\n    51→        \"on\",\n    52→        \"or\",\n    53→        \"our\",\n    54→        \"she\",\n    55→        \"so\",\n    56→        \"that\",\n    57→        \"the\",\n    58→        \"their\",\n    59→        \"them\",\n    60→        \"then\",\n    61→        \"there\",\n    62→        \"they\",\n    63→        \"this\",\n    64→        \"to\",\n    65→        \"up\",\n    66→        \"us\",\n    67→        \"was\",\n    68→        \"we\",\n    69→        \"what\",\n    70→        \"when\",\n    71→        \"which\",\n    72→        \"who\",\n    73→        \"will\",\n    74→        \"with\",\n    75→        \"you\",\n    76→        \"your\",\n    77→    }\n    78→)\n    79→\n    80→# ---------------------------------------------------------------------------\n    81→# Stemming (basic suffix stripping)\n    82→# ---------------------------------------------------------------------------\n    83→\n    84→_SUFFIX_ORDER: tuple[str, ...] = (\n    85→    \"tion\",\n    86→    \"ment\",\n    87→    \"ness\",\n    88→    \"ing\",\n    89→    \"est\",\n    90→    \"er\",\n    91→    \"ed\",\n    92→    \"ly\",\n    93→    \"s\",\n    94→)\n    95→\n    96→_MIN_STEM_LENGTH = 3\n    97→\n    98→\n    99→def stem(word: str) -> str:\n   100→    \"\"\"Apply basic suffix stripping to *word*.\n   101→\n   102→    Strips the first matching suffix from ``_SUFFIX_ORDER`` provided\n   103→    the remaining stem has at least ``_MIN_STEM_LENGTH`` characters.\n   104→    \"\"\"\n   105→    for suffix in _SUFFIX_ORDER:\n   106→        if word.endswith(suffix) and len(word) - len(suffix) >= _MIN_STEM_LENGTH:\n   107→            return word[: -len(suffix)]\n   108→    return word\n   109→\n   110→\n   111→# ---------------------------------------------------------------------------\n   112→# Preprocessing\n   113→# ---------------------------------------------------------------------------\n   114→\n   115→_WORD_RE = re.compile(r\"[a-z0-9]+\")\n   116→\n   117→\n   118→def preprocess(text: str) -> list[str]:\n   119→    \"\"\"Lowercase, tokenise, remove stop words, and stem.\"\"\"\n   120→    tokens = _WORD_RE.findall(text.lower())\n   121→    return [stem(t) for t in tokens if t not in _STOP_WORDS]\n   122→\n   123→\n   124→# ---------------------------------------------------------------------------\n   125→# BM25 scorer\n   126→# ---------------------------------------------------------------------------\n   127→\n   128→_DEFAULT_K1 = 1.2\n   129→_DEFAULT_B = 0.75\n   130→\n   131→\n   132→@dataclass\n   133→class BM25Scorer:\n   134→    \"\"\"Okapi BM25 ranking function over a pre-built document index.\n   135→\n   136→    Usage::\n   137→\n   138→        scorer = BM25Scorer()\n   139→        scorer.build_index([\"doc one text\", \"doc two text\"])\n   140→        scores = scorer.score(\"query text\")\n   141→    \"\"\"\n   142→\n   143→    k1: float = _DEFAULT_K1\n   144→    b: float = _DEFAULT_B\n   145→\n   146→    # Internal state (populated by build_index)\n   147→    _doc_count: int = field(default=0, init=False, repr=False)\n   148→    _avgdl: float = field(default=0.0, init=False, repr=False)\n   149→    _doc_lens: list[int] = field(default_factory=list, init=False, repr=False)\n   150→    _doc_terms: list[list[str]] = field(default_factory=list, init=False, repr=False)\n   151→    _df: dict[str, int] = field(default_factory=dict, init=False, repr=False)\n   152→    _idf: dict[str, float] = field(default_factory=dict, init=False, repr=False)\n   153→\n   154→    # ------------------------------------------------------------------\n   155→    # Index building\n   156→    # ------------------------------------------------------------------\n   157→\n   158→    def build_index(self, documents: list[str]) -> None:\n   159→        \"\"\"Preprocess *documents* and compute IDF values.\"\"\"\n   160→        self._doc_terms = [preprocess(doc) for doc in documents]\n   161→        self._doc_count = len(self._doc_terms)\n   162→        self._doc_lens = [len(terms) for terms in self._doc_terms]\n   163→        total_len = sum(self._doc_lens)\n   164→        self._avgdl = total_len / self._doc_count if self._doc_count else 0.0\n   165→\n   166→        # Document frequency\n   167→        self._df = {}\n   168→        for terms in self._doc_terms:\n   169→            for term in set(terms):\n   170→                self._df[term] = self._df.get(term, 0) + 1\n   171→\n   172→        # IDF: log((N - df + 0.5) / (df + 0.5) + 1)\n   173→        self._idf = {}\n   174→        n = self._doc_count\n   175→        for term, df in self._df.items():\n   176→            self._idf[term] = math.log((n - df + 0.5) / (df + 0.5) + 1.0)\n   177→\n   178→    # ------------------------------------------------------------------\n   179→    # Scoring\n   180→    # ------------------------------------------------------------------\n   181→\n   182→    def score(self, query: str) -> list[float]:\n   183→        \"\"\"Score every indexed document against *query*.\n   184→\n   185→        Returns a list of BM25 scores (one per document) in index order.\n   186→        \"\"\"\n   187→        query_terms = preprocess(query)\n   188→        if not self._doc_count or not query_terms:\n   189→            return [0.0] * self._doc_count\n   190→\n   191→        scores: list[float] = []\n   192→        for idx in range(self._doc_count):\n   193→            scores.append(self._score_doc(query_terms, idx))\n   194→        return scores\n   195→\n   196→    def score_batch(self, queries: list[str]) -> list[list[float]]:\n   197→        \"\"\"Score every indexed document against each query in *queries*.\n   198→\n   199→        Returns a list of score-lists, one per query.\n   200→        \"\"\"\n   201→        return [self.score(q) for q in queries]\n   202→\n   203→    # ------------------------------------------------------------------\n   204→    # Internal\n   205→    # ------------------------------------------------------------------\n   206→\n   207→    def _score_doc(self, query_terms: list[str], doc_idx: int) -> float:\n   208→        \"\"\"BM25 score for a single document.\"\"\"\n   209→        doc_terms = self._doc_terms[doc_idx]\n   210→        dl = self._doc_lens[doc_idx]\n   211→\n   212→        # Term frequencies in this document\n   213→        tf_map: dict[str, int] = {}\n   214→        for t in doc_terms:\n   215→            tf_map[t] = tf_map.get(t, 0) + 1\n   216→\n   217→        total = 0.0\n   218→        for qt in query_terms:\n   219→            idf = self._idf.get(qt, 0.0)\n   220→            tf = tf_map.get(qt, 0)\n   221→            if tf == 0:\n   222→                continue\n   223→            # TF saturation\n   224→            numerator = tf * (self.k1 + 1.0)\n   225→            denominator = tf + self.k1 * (1.0 - self.b + self.b * dl / self._avgdl)\n   226→            total += idf * numerator / denominator\n   227→        return total\n   228→"}]},"parent_tool_use_id":"toolu_01GMYqRL7Arce5h4vZrADgHe","session_id":"4c2bbd2a-1a06-4e1e-9000-d7a8b9bf3b8b","uuid":"0e60378c-b23c-4871-9a2c-8f40d2b0c0a7","timestamp":"2026-03-22T22:47:06.352Z"}
