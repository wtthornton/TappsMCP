{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XLpmimNr7sS7rKdnBvxiHL","type":"tool_result","content":"     1→\"\"\"Ranked memory retrieval with composite scoring.\n     2→\n     3→Upgrades memory search from simple keyword matching to scored,\n     4→ranked retrieval combining text relevance with memory-specific\n     5→signals (confidence, recency, access frequency).\n     6→\n     7→Uses BM25 (Okapi) for text relevance scoring with automatic\n     8→index building and invalidation. Epic 65.8: hybrid BM25 + vector\n     9→search with RRF when semantic_search.enabled.\n    10→\"\"\"\n    11→\n    12→from __future__ import annotations\n    13→\n    14→from concurrent.futures import ThreadPoolExecutor, as_completed\n    15→from datetime import UTC, datetime\n    16→from typing import TYPE_CHECKING\n    17→\n    18→import structlog\n    19→from pydantic import BaseModel, Field\n    20→\n    21→from tapps_brain.bm25 import BM25Scorer\n    22→from tapps_brain.decay import DecayConfig, calculate_decayed_confidence, is_stale\n    23→from tapps_brain.models import MemoryEntry, MemorySource  # noqa: TC001\n    24→from tapps_brain.reranker import RERANKER_TOP_CANDIDATES, Reranker\n    25→\n    26→if TYPE_CHECKING:\n    27→    from tapps_brain.store import MemoryStore\n    28→\n    29→logger = structlog.get_logger(__name__)\n    30→\n    31→# ---------------------------------------------------------------------------\n    32→# Models\n    33→# ---------------------------------------------------------------------------\n    34→\n    35→_MAX_RESULTS = 50\n    36→_DEFAULT_RESULTS = 10\n    37→_MIN_CONFIDENCE_FLOOR = 0.1\n    38→\n    39→# BM25 relevance normalization constant: score / (score + K)\n    40→# Chosen so that a BM25 score of 5.0 maps to ~0.5 normalized.\n    41→_BM25_NORM_K = 5.0\n    42→\n    43→\n    44→class ScoredMemory(BaseModel):\n    45→    \"\"\"A memory entry with retrieval scoring metadata.\"\"\"\n    46→\n    47→    entry: MemoryEntry\n    48→    score: float = Field(ge=0.0, description=\"Composite retrieval score.\")\n    49→    effective_confidence: float = Field(ge=0.0, le=1.0, description=\"Time-decayed confidence.\")\n    50→    bm25_relevance: float = Field(ge=0.0, description=\"Normalized text relevance.\")\n    51→    stale: bool = Field(default=False, description=\"Whether the memory is stale.\")\n    52→\n    53→\n    54→# ---------------------------------------------------------------------------\n    55→# Scoring weights\n    56→# ---------------------------------------------------------------------------\n    57→\n    58→_W_RELEVANCE = 0.40\n    59→_W_CONFIDENCE = 0.30\n    60→_W_RECENCY = 0.15\n    61→_W_FREQUENCY = 0.15\n    62→\n    63→_FREQUENCY_CAP = 20.0\n    64→\n    65→# Per-source trust multipliers applied to composite score (M2).\n    66→# These are post-composite multipliers, not additive weights.\n    67→_DEFAULT_SOURCE_TRUST: dict[str, float] = {\n    68→    \"human\": 1.0,\n    69→    \"system\": 0.9,\n    70→    \"agent\": 0.7,\n    71→    \"inferred\": 0.5,\n    72→}\n    73→\n    74→# Marker text for consolidated source entries\n    75→_CONSOLIDATED_MARKER = \"consolidated into\"\n    76→\n    77→\n    78→def _is_consolidated_source(entry: MemoryEntry) -> bool:\n    79→    \"\"\"Check if an entry is a source of a consolidated entry.\n    80→\n    81→    Source entries are marked with contradicted=True and a\n    82→    contradiction_reason containing \"consolidated into\".\n    83→\n    84→    Args:\n    85→        entry: The memory entry to check.\n    86→\n    87→    Returns:\n    88→        True if this entry was consolidated into another entry.\n    89→    \"\"\"\n    90→    if not entry.contradicted:\n    91→        return False\n    92→    reason = entry.contradiction_reason or \"\"\n    93→    return _CONSOLIDATED_MARKER in reason.lower()\n    94→\n    95→\n    96→# ---------------------------------------------------------------------------\n    97→# MemoryRetriever\n    98→# ---------------------------------------------------------------------------\n    99→\n   100→\n   101→class MemoryRetriever:\n   102→    \"\"\"Ranked retrieval engine for memory entries.\"\"\"\n   103→\n   104→    def __init__(\n   105→        self,\n   106→        config: DecayConfig | None = None,\n   107→        *,\n   108→        scoring_config: object | None = None,  # ScoringConfig from profile (EPIC-010)\n   109→        semantic_enabled: bool = False,\n   110→        hybrid_config: object = None,\n   111→        reranker: Reranker | None = None,\n   112→        reranker_enabled: bool = False,\n   113→        retrieval_policy: object | None = None,\n   114→        relations_enabled: bool = False,\n   115→        expand_queries: bool = True,\n   116→    ) -> None:\n   117→        self._config = config or DecayConfig()\n   118→        self._bm25 = BM25Scorer()\n   119→        self._bm25_entries: list[MemoryEntry] = []\n   120→        self._bm25_corpus_size: int = 0\n   121→        self._bm25_fingerprint: int = 0\n   122→        self._semantic_enabled = semantic_enabled\n   123→        self._hybrid_config = hybrid_config\n   124→        self._reranker = reranker\n   125→        self._reranker_enabled = reranker_enabled\n   126→        self._retrieval_policy = retrieval_policy\n   127→        self._relations_enabled = relations_enabled\n   128→        self._expand_queries = expand_queries\n   129→\n   130→        # EPIC-010: use configurable scoring weights if provided\n   131→        self._scoring_config = scoring_config\n   132→        if scoring_config is not None:\n   133→            self._w_relevance = getattr(scoring_config, \"relevance\", _W_RELEVANCE)\n   134→            self._w_confidence = getattr(scoring_config, \"confidence\", _W_CONFIDENCE)\n   135→            self._w_recency = getattr(scoring_config, \"recency\", _W_RECENCY)\n   136→            self._w_frequency = getattr(scoring_config, \"frequency\", _W_FREQUENCY)\n   137→            self._frequency_cap = float(getattr(scoring_config, \"frequency_cap\", _FREQUENCY_CAP))\n   138→            self._bm25_norm_k = float(getattr(scoring_config, \"bm25_norm_k\", _BM25_NORM_K))\n   139→            raw_trust = getattr(scoring_config, \"source_trust\", None)\n   140→            self._source_trust: dict[str, float] = (\n   141→                dict(raw_trust) if isinstance(raw_trust, dict) else dict(_DEFAULT_SOURCE_TRUST)\n   142→            )\n   143→        else:\n   144→            self._w_relevance = _W_RELEVANCE\n   145→            self._w_confidence = _W_CONFIDENCE\n   146→            self._w_recency = _W_RECENCY\n   147→            self._w_frequency = _W_FREQUENCY\n   148→            self._frequency_cap = _FREQUENCY_CAP\n   149→            self._bm25_norm_k = _BM25_NORM_K\n   150→            self._source_trust = dict(_DEFAULT_SOURCE_TRUST)\n   151→\n   152→    def search(\n   153→        self,\n   154→        query: str,\n   155→        store: MemoryStore,\n   156→        *,\n   157→        limit: int = _DEFAULT_RESULTS,\n   158→        include_contradicted: bool = False,\n   159→        include_sources: bool = False,\n   160→        min_confidence: float = _MIN_CONFIDENCE_FLOOR,\n   161→        as_of: str | None = None,\n   162→        include_superseded: bool = False,\n   163→    ) -> list[ScoredMemory]:\n   164→        \"\"\"Search memories with ranked scoring.\n   165→\n   166→        Uses the store's FTS5-backed search for candidate retrieval,\n   167→        then applies composite scoring with confidence, recency, and\n   168→        frequency signals.\n   169→\n   170→        Args:\n   171→            query: Search query string.\n   172→            store: Memory store to search.\n   173→            limit: Max results (default 10, max 50).\n   174→            include_contradicted: Include contradicted memories.\n   175→            include_sources: Include source entries of consolidated memories\n   176→                (Epic 58, Story 58.5). When False (default), entries that were\n   177→                consolidated into other entries are filtered out. When True,\n   178→                source entries are included alongside consolidated entries.\n   179→            min_confidence: Minimum confidence filter.\n   180→            as_of: ISO-8601 timestamp for point-in-time queries. When set,\n   181→                only entries valid at that time are returned.\n   182→            include_superseded: When True, include temporally invalid entries\n   183→                (marked with ``stale=True`` and a 0.5x relevance penalty).\n   184→\n   185→        Returns:\n   186→            Scored memories sorted by composite score (descending).\n   187→        \"\"\"\n   188→        if not query or not query.strip():\n   189→            return []\n   190→\n   191→        limit = max(1, min(limit, _MAX_RESULTS))\n   192→        now = datetime.now(tz=UTC)\n   193→\n   194→        # Epic 65.13: expand query via relations when enabled\n   195→        effective_query = query\n   196→        if self._relations_enabled and self._expand_queries:\n   197→            effective_query = self._expand_query_via_relations(query, store)\n   198→\n   199→        # Epic 65.8: hybrid path when semantic enabled\n   200→        if self._semantic_enabled:\n   201→            candidates = self._get_hybrid_candidates(effective_query, store)\n   202→        else:\n   203→            candidates = self._get_candidates(effective_query, store)\n   204→\n   205→        # Score and filter\n   206→        scored: list[ScoredMemory] = []\n   207→        for entry, relevance_raw in candidates:\n   208→            # Filter source entries of consolidated memories (Epic 58.5)\n   209→            if not include_sources and _is_consolidated_source(entry):\n   210→                continue\n   211→\n   212→            # Filter contradicted entries (sources already handled above)\n   213→            is_included_source = include_sources and _is_consolidated_source(entry)\n   214→            if entry.contradicted and not include_contradicted and not is_included_source:\n   215→                continue\n   216→\n   217→            # Temporal filtering (EPIC-004)\n   218→            temporally_valid = entry.is_temporally_valid(as_of)\n   219→            if not temporally_valid and not include_superseded:\n   220→                continue\n   221→\n   222→            # Calculate effective confidence\n   223→            eff_conf = calculate_decayed_confidence(entry, self._config, now=now)\n   224→\n   225→            # Filter low confidence\n   226→            if eff_conf < min_confidence:\n   227→                continue\n   228→\n   229→            stale_flag = is_stale(entry, self._config, now=now)\n   230→            # Mark temporally invalid entries as stale (EPIC-004)\n   231→            if not temporally_valid:\n   232→                stale_flag = True\n   233→\n   234→            # Compute composite score\n   235→            relevance_norm = self._normalize_relevance(relevance_raw)\n   236→            recency = self._recency_score(entry, now)\n   237→            frequency = self._frequency_score(entry)\n   238→\n   239→            composite = (\n   240→                self._w_relevance * relevance_norm\n   241→                + self._w_confidence * eff_conf\n   242→                + self._w_recency * recency\n   243→                + self._w_frequency * frequency\n   244→            )\n   245→\n   246→            # M2: Apply per-source trust multiplier\n   247→            source_key = (\n   248→                entry.source.value\n   249→                if isinstance(entry.source, MemorySource)\n   250→                else str(entry.source)\n   251→            )\n   252→            trust = self._source_trust.get(source_key, 1.0)\n   253→            composite *= trust\n   254→\n   255→            # Penalty for superseded entries included via include_superseded\n   256→            if not temporally_valid:\n   257→                composite *= 0.5\n   258→\n   259→            # Bonus for exact key match\n   260→            if entry.key == query.lower().replace(\" \", \"-\"):\n   261→                composite += 0.1\n   262→\n   263→            scored.append(\n   264→                ScoredMemory(\n   265→                    entry=entry,\n   266→                    score=round(composite, 4),\n   267→                    effective_confidence=round(eff_conf, 4),\n   268→                    bm25_relevance=round(relevance_norm, 4),\n   269→                    stale=stale_flag,\n   270→                )\n   271→            )\n   272→\n   273→        # Epic 65.14: Apply retrieval policy tag filtering\n   274→        if self._retrieval_policy is not None:\n   275→            blocked_tags = set(getattr(self._retrieval_policy, \"block_sensitive_tags\", []))\n   276→            if blocked_tags:\n   277→                scored = [s for s in scored if not blocked_tags.intersection(s.entry.tags)]\n   278→\n   279→        # Sort by score descending\n   280→        scored.sort(key=lambda s: s.score, reverse=True)\n   281→\n   282→        # Epic 65.9: optional reranking of top-20 -> top_k\n   283→        if self._reranker_enabled and self._reranker is not None and scored:\n   284→            scored = self._apply_reranker(query, scored, limit)\n   285→\n   286→        return scored[:limit]\n   287→\n   288→    def _apply_reranker(\n   289→        self,\n   290→        query: str,\n   291→        scored: list[ScoredMemory],\n   292→        limit: int,\n   293→    ) -> list[ScoredMemory]:\n   294→        \"\"\"Apply reranker to top candidates; fallback to original order on failure.\"\"\"\n   295→        assert self._reranker is not None  # caller checks before calling\n   296→        top_candidates = scored[:RERANKER_TOP_CANDIDATES]\n   297→        candidates = [(sm.entry.key, sm.entry.value) for sm in top_candidates]\n   298→        effective_top_k = min(limit, len(candidates))\n   299→\n   300→        try:\n   301→            reranked = self._reranker.rerank(query, candidates, top_k=effective_top_k)\n   302→        except Exception as e:\n   303→            logger.warning(\n   304→                \"reranker_failed_fallback_to_original\",\n   305→                reason=str(e),\n   306→            )\n   307→            return scored\n   308→\n   309→        if not reranked:\n   310→            return scored\n   311→\n   312→        key_to_scored = {sm.entry.key: sm for sm in scored}\n   313→        result: list[ScoredMemory] = []\n   314→        for key, rerank_score in reranked:\n   315→            sm = key_to_scored.get(key)\n   316→            if sm is not None:\n   317→                # Use reranker score as primary relevance; preserve other fields\n   318→                result.append(\n   319→                    ScoredMemory(\n   320→                        entry=sm.entry,\n   321→                        score=round(rerank_score, 4),\n   322→                        effective_confidence=sm.effective_confidence,\n   323→                        bm25_relevance=sm.bm25_relevance,\n   324→                        stale=sm.stale,\n   325→                    )\n   326→                )\n   327→        # Append any from original not in reranker result (e.g. API dropped some)\n   328→        seen = {sm.entry.key for sm in result}\n   329→        for sm in scored:\n   330→            if sm.entry.key not in seen:\n   331→                result.append(sm)\n   332→                if len(result) >= limit:\n   333→                    break\n   334→        return result[:limit]\n   335→\n   336→    # -----------------------------------------------------------------------\n   337→    # Relation expansion (Epic 65.13)\n   338→    # -----------------------------------------------------------------------\n   339→\n   340→    def _expand_query_via_relations(\n   341→        self,\n   342→        query: str,\n   343→        store: MemoryStore,\n   344→    ) -> str:\n   345→        \"\"\"Expand a query using entity/relationship graph traversal.\n   346→\n   347→        If the query matches a relationship pattern (e.g. \"who handles API\"),\n   348→        load relations from the persistence layer and expand with connected\n   349→        entities. Falls back to the original query on any error.\n   350→        \"\"\"\n   351→        try:\n   352→            from tapps_brain.relations import (\n   353→                RelationEntry,\n   354→                expand_via_relations,\n   355→            )\n   356→        except ImportError:\n   357→            return query\n   358→\n   359→        # Load relations from persistence if available\n   360→        try:\n   361→            persistence = getattr(store, \"_persistence\", None)\n   362→            if persistence is None:\n   363→                return query\n   364→            raw_relations = persistence.list_relations()\n   365→            if not raw_relations:\n   366→                return query\n   367→\n   368→            relations = [\n   369→                RelationEntry(\n   370→                    subject=r[\"subject\"],\n   371→                    predicate=r[\"predicate\"],\n   372→                    object_entity=r[\"object_entity\"],\n   373→                    source_entry_keys=r.get(\"source_entry_keys\", []),\n   374→                    confidence=r.get(\"confidence\", 0.8),\n   375→                )\n   376→                for r in raw_relations\n   377→            ]\n   378→\n   379→            expanded_terms = expand_via_relations(query, relations)\n   380→            if expanded_terms:\n   381→                expanded_query = f\"{query} {' '.join(expanded_terms)}\"\n   382→                logger.debug(\n   383→                    \"query_expanded_via_relations\",\n   384→                    original=query,\n   385→                    expanded=expanded_query,\n   386→                    terms_added=len(expanded_terms),\n   387→                )\n   388→                return expanded_query\n   389→        except Exception:\n   390→            logger.debug(\"relation_expansion_failed\", query=query)\n   391→\n   392→        return query\n   393→\n   394→    # -----------------------------------------------------------------------\n   395→    # BM25 index management\n   396→    # -----------------------------------------------------------------------\n   397→\n   398→    @staticmethod\n   399→    def _entry_to_document(entry: MemoryEntry) -> str:\n   400→        \"\"\"Convert a memory entry to a BM25-indexable document string.\"\"\"\n   401→        return f\"{entry.key} {entry.value} {' '.join(entry.tags)}\"\n   402→\n   403→    @staticmethod\n   404→    def _corpus_fingerprint(entries: list[MemoryEntry]) -> int:\n   405→        \"\"\"Compute a fingerprint that changes when any entry is added, removed, or updated.\"\"\"\n   406→        return hash(tuple((e.key, e.updated_at if e.updated_at else \"\") for e in entries))\n   407→\n   408→    def _ensure_bm25_index(self, entries: list[MemoryEntry]) -> None:\n   409→        \"\"\"Build or rebuild the BM25 index when the corpus changes.\"\"\"\n   410→        fingerprint = self._corpus_fingerprint(entries)\n   411→        if len(entries) == self._bm25_corpus_size and fingerprint == self._bm25_fingerprint:\n   412→            return\n   413→        documents = [self._entry_to_document(e) for e in entries]\n   414→        self._bm25.build_index(documents)\n   415→        self._bm25_entries = list(entries)\n   416→        self._bm25_corpus_size = len(entries)\n   417→        self._bm25_fingerprint = fingerprint\n   418→        logger.debug(\"bm25_index_rebuilt\", corpus_size=self._bm25_corpus_size)\n   419→\n   420→    # -----------------------------------------------------------------------\n   421→    # Candidate retrieval\n   422→    # -----------------------------------------------------------------------\n   423→\n   424→    def _get_candidates(\n   425→        self,\n   426→        query: str,\n   427→        store: MemoryStore,\n   428→    ) -> list[tuple[MemoryEntry, float]]:\n   429→        \"\"\"Retrieve candidate entries and compute BM25 relevance scores.\n   430→\n   431→        Tries the store's FTS5-backed search first for candidate\n   432→        filtering, then scores them using BM25. Falls back to full\n   433→        in-memory BM25 scan if FTS5 returns no results, and to word\n   434→        overlap if BM25 scoring fails entirely.\n   435→        \"\"\"\n   436→        # Try FTS5 via store.search() for candidate filtering\n   437→        try:\n   438→            fts_results = store.search(query)\n   439→            if fts_results:\n   440→                return self._bm25_score_entries(query, fts_results, store)\n   441→        except Exception:\n   442→            logger.debug(\"fts5_search_failed\", query=query)\n   443→\n   444→        # Fallback: full corpus BM25 scan\n   445→        return self._bm25_full_scan(query, store)\n   446→\n   447→    def _get_hybrid_candidates(\n   448→        self,\n   449→        query: str,\n   450→        store: MemoryStore,\n   451→    ) -> list[tuple[MemoryEntry, float]]:\n   452→        \"\"\"Epic 65.8: Run BM25 + vector search in parallel, merge with RRF.\"\"\"\n   453→        top_bm25 = 20\n   454→        top_vector = 20\n   455→        rrf_k = 60\n   456→        if self._hybrid_config is not None:\n   457→            top_bm25 = getattr(self._hybrid_config, \"top_bm25\", 20)\n   458→            top_vector = getattr(self._hybrid_config, \"top_vector\", 20)\n   459→            rrf_k = getattr(self._hybrid_config, \"rrf_k\", 60)\n   460→\n   461→        bm25_keys: list[str] = []\n   462→        vector_keys: list[str] = []\n   463→\n   464→        def run_bm25() -> None:\n   465→            nonlocal bm25_keys\n   466→            candidates = self._get_candidates(query, store)\n   467→            # Take top top_bm25 by score\n   468→            sorted_cands = sorted(\n   469→                candidates,\n   470→                key=lambda x: x[1],\n   471→                reverse=True,\n   472→            )[:top_bm25]\n   473→            bm25_keys = [e.key for e, _ in sorted_cands]\n   474→\n   475→        def run_vector() -> None:\n   476→            nonlocal vector_keys\n   477→            vector_results = self._vector_search(query, store, limit=top_vector)\n   478→            vector_keys = [k for k, _ in vector_results]\n   479→\n   480→        with ThreadPoolExecutor(max_workers=2) as ex:\n   481→            f1 = ex.submit(run_bm25)\n   482→            f2 = ex.submit(run_vector)\n   483→            for f in as_completed([f1, f2]):\n   484→                f.result()\n   485→\n   486→        from tapps_brain.fusion import reciprocal_rank_fusion\n   487→\n   488→        fused = reciprocal_rank_fusion(bm25_keys, vector_keys, k=rrf_k)\n   489→\n   490→        if not fused:\n   491→            return self._get_candidates(query, store)\n   492→\n   493→        entry_by_key = {e.key: e for e in store.list_all()}\n   494→        max_rrf = fused[0][1] if fused else 1.0\n   495→\n   496→        results: list[tuple[MemoryEntry, float]] = []\n   497→        for key, rrf_score in fused:\n   498→            entry = entry_by_key.get(key)\n   499→            if entry is None:\n   500→                continue\n   501→            relevance_raw = rrf_score / max_rrf if max_rrf > 0 else 0.0\n   502→            results.append((entry, relevance_raw))\n   503→\n   504→        return results\n   505→\n   506→    def _vector_search(\n   507→        self,\n   508→        query: str,\n   509→        store: MemoryStore,\n   510→        limit: int = 20,\n   511→    ) -> list[tuple[str, float]]:\n   512→        \"\"\"Epic 65.8: Embed query, cosine similarity with entry embeddings.\n   513→\n   514→        Uses on-the-fly embedding when stored embeddings are unavailable.\n   515→        Returns [(entry_key, score), ...] sorted by score descending.\n   516→        \"\"\"\n   517→        empty: list[tuple[str, float]] = []\n   518→\n   519→        try:\n   520→            from tapps_brain.embeddings import get_embedding_provider\n   521→\n   522→            embedder = get_embedding_provider(semantic_search_enabled=True)\n   523→        except ImportError:\n   524→            logger.debug(\"vector_search_embedder_unavailable\")\n   525→            return empty\n   526→        if embedder is None or not (all_entries := store.list_all()):\n   527→            return empty\n   528→\n   529→        texts = [self._entry_to_document(e) for e in all_entries]\n   530→        try:\n   531→            q = embedder.embed(query)\n   532→            entry_embs = embedder.embed_batch(texts)\n   533→        except Exception as e:\n   534→            logger.debug(\"vector_search_embed_failed\", error=str(e))\n   535→            return empty\n   536→\n   537→        if not q or len(entry_embs) != len(all_entries):\n   538→            return empty\n   539→        scored: list[tuple[str, float]] = []\n   540→        for i, entry in enumerate(all_entries):\n   541→            if i >= len(entry_embs):\n   542→                break\n   543→            emb = entry_embs[i]\n   544→            if len(emb) == len(q):\n   545→                sim = sum(a * b for a, b in zip(q, emb, strict=True))\n   546→                scored.append((entry.key, max(0.0, sim)))\n   547→        scored.sort(key=lambda x: x[1], reverse=True)\n   548→        return scored[:limit]\n   549→\n   550→    def _bm25_score_entries(\n   551→        self,\n   552→        query: str,\n   553→        entries: list[MemoryEntry],\n   554→        store: MemoryStore,\n   555→    ) -> list[tuple[MemoryEntry, float]]:\n   556→        \"\"\"Score a set of entries using BM25.\n   557→\n   558→        Builds the BM25 index over the full corpus (for proper IDF),\n   559→        then looks up scores for the given entries.\n   560→        \"\"\"\n   561→        try:\n   562→            all_entries = store.list_all()\n   563→            self._ensure_bm25_index(all_entries)\n   564→\n   565→            # Build a lookup: entry key -> index in corpus\n   566→            key_to_idx = {e.key: i for i, e in enumerate(self._bm25_entries)}\n   567→            all_scores = self._bm25.score(query)\n   568→\n   569→            results: list[tuple[MemoryEntry, float]] = []\n   570→            for entry in entries:\n   571→                idx = key_to_idx.get(entry.key)\n   572→                if idx is not None and idx < len(all_scores):\n   573→                    results.append((entry, all_scores[idx]))\n   574→                else:\n   575→                    # Entry not in index (new entry?), use word overlap\n   576→                    results.append((entry, self._word_overlap_score(query, entry)))\n   577→            return results\n   578→        except Exception:\n   579→            logger.debug(\"bm25_scoring_failed_using_word_overlap\", query=query)\n   580→            return [(entry, self._word_overlap_score(query, entry)) for entry in entries]\n   581→\n   582→    def _bm25_full_scan(\n   583→        self,\n   584→        query: str,\n   585→        store: MemoryStore,\n   586→    ) -> list[tuple[MemoryEntry, float]]:\n   587→        \"\"\"Full corpus BM25 scan as fallback.\n   588→\n   589→        Falls back to word overlap if BM25 fails.\n   590→        \"\"\"\n   591→        all_entries = store.list_all()\n   592→        if not all_entries:\n   593→            return []\n   594→\n   595→        try:\n   596→            self._ensure_bm25_index(all_entries)\n   597→            scores = self._bm25.score(query)\n   598→            return [\n   599→                (entry, score)\n   600→                for entry, score in zip(all_entries, scores, strict=True)\n   601→                if score > 0\n   602→            ]\n   603→        except Exception:\n   604→            logger.debug(\"bm25_full_scan_failed_using_word_overlap\", query=query)\n   605→            return self._like_search(query, store)\n   606→\n   607→    def _like_search(\n   608→        self,\n   609→        query: str,\n   610→        store: MemoryStore,\n   611→    ) -> list[tuple[MemoryEntry, float]]:\n   612→        \"\"\"Fallback LIKE-based search with simple word overlap scoring.\"\"\"\n   613→        query_words = set(query.lower().split())\n   614→        if not query_words:\n   615→            return []\n   616→\n   617→        all_entries = store.list_all()\n   618→        results: list[tuple[MemoryEntry, float]] = []\n   619→\n   620→        for entry in all_entries:\n   621→            relevance = self._word_overlap_score(query, entry)\n   622→            if relevance > 0:\n   623→                results.append((entry, relevance))\n   624→\n   625→        return results\n   626→\n   627→    # -----------------------------------------------------------------------\n   628→    # Scoring helpers\n   629→    # -----------------------------------------------------------------------\n   630→\n   631→    @staticmethod\n   632→    def _word_overlap_score(query: str, entry: MemoryEntry) -> float:\n   633→        \"\"\"Compute word overlap between query and entry text.\"\"\"\n   634→        query_words = set(query.lower().split())\n   635→        if not query_words:\n   636→            return 0.0\n   637→        entry_text = f\"{entry.key} {entry.value} {' '.join(entry.tags)}\".lower()\n   638→        entry_words = set(entry_text.split())\n   639→        overlap = len(query_words & entry_words)\n   640→        return overlap / len(query_words)\n   641→\n   642→    def _normalize_relevance(self, raw_score: float) -> float:\n   643→        \"\"\"Normalize relevance score to 0.0-1.0 range.\n   644→\n   645→        Uses sigmoid normalization: ``score / (score + K)`` where\n   646→        K defaults to 5.0, tuned for BM25 scores (typical range 0-15+).\n   647→        A BM25 score of K maps to 0.5 normalized. K is configurable\n   648→        via ``scoring_config.bm25_norm_k`` (EPIC-010).\n   649→        \"\"\"\n   650→        if raw_score <= 0:\n   651→            return 0.0\n   652→        return raw_score / (raw_score + self._bm25_norm_k)\n   653→\n   654→    @staticmethod\n   655→    def _recency_score(entry: MemoryEntry, now: datetime) -> float:\n   656→        \"\"\"Compute recency score: ``1.0 / (1.0 + days_since_updated)``.\"\"\"\n   657→        try:\n   658→            updated = datetime.fromisoformat(entry.updated_at)\n   659→            if updated.tzinfo is None:\n   660→                updated = updated.replace(tzinfo=UTC)\n   661→        except (ValueError, TypeError):\n   662→            return 0.5\n   663→        days = max((now - updated).total_seconds() / 86400.0, 0.0)\n   664→        return 1.0 / (1.0 + days)\n   665→\n   666→    def _frequency_score(self, entry: MemoryEntry) -> float:\n   667→        \"\"\"Compute access frequency score: ``min(1.0, access_count / cap)``.\n   668→\n   669→        The frequency cap defaults to 20.0 and is configurable via\n   670→        ``scoring_config.frequency_cap`` (EPIC-010).\n   671→        \"\"\"\n   672→        return min(1.0, entry.access_count / self._frequency_cap)\n   673→"}]},"parent_tool_use_id":"toolu_01GMYqRL7Arce5h4vZrADgHe","session_id":"4c2bbd2a-1a06-4e1e-9000-d7a8b9bf3b8b","uuid":"a39264c5-ef84-47db-9d82-9bb3e22a417d","timestamp":"2026-03-22T22:47:00.191Z"}
