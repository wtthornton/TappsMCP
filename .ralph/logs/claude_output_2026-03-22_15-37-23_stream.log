{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015RjtuBLKFKhWgfH38DbKkq","type":"tool_result","content":"  1000→\n  1001→        Must be called while holding ``self._lock``.\n  1002→        \"\"\"\n  1003→        count = 0\n  1004→        for k in self._entries:\n  1005→            if k == key or k.startswith(f\"{key}.v\"):\n  1006→                count += 1\n  1007→        return count\n  1008→\n  1009→    # ------------------------------------------------------------------\n  1010→    # Auto-recall (EPIC-003)\n  1011→    # ------------------------------------------------------------------\n  1012→\n  1013→    def recall(self, message: str, **kwargs: Any) -> Any:  # noqa: ANN401\n  1014→        \"\"\"Search for relevant memories and return injection-ready context.\n  1015→\n  1016→        Convenience wrapper around ``RecallOrchestrator.recall()``. The\n  1017→        orchestrator is created lazily on first call and reused after.\n  1018→\n  1019→        Args:\n  1020→            message: The user's incoming message to match against.\n  1021→            **kwargs: Override ``RecallConfig`` fields for this call.\n  1022→\n  1023→        Returns:\n  1024→            ``RecallResult`` with formatted memory section, metadata,\n  1025→            and timing information.\n  1026→        \"\"\"\n  1027→        from tapps_brain.recall import RecallOrchestrator\n  1028→\n  1029→        self._metrics.increment(\"store.recall\")\n  1030→        with self._lock:\n  1031→            if not hasattr(self, \"_recall_orchestrator\"):\n  1032→                # Wire Hive store and profile for hive-aware recall (EPIC-011)\n  1033→                hive_weight = 0.8\n  1034→                agent_profile = \"repo-brain\"\n  1035→                if self._profile is not None:\n  1036→                    hive_cfg = getattr(self._profile, \"hive\", None)\n  1037→                    if hive_cfg is not None:\n  1038→                        hive_weight = hive_cfg.recall_weight\n  1039→                    agent_profile = getattr(self._profile, \"name\", \"repo-brain\")\n  1040→                self._recall_orchestrator = RecallOrchestrator(\n  1041→                    self,\n  1042→                    hive_store=self._hive_store,\n  1043→                    hive_recall_weight=hive_weight,\n  1044→                    hive_agent_profile=agent_profile,\n  1045→                )\n  1046→\n  1047→        with MetricsTimer(self._metrics, \"store.recall_ms\"):\n  1048→            return self._recall_orchestrator.recall(message, **kwargs)\n  1049→\n  1050→    def health(self) -> StoreHealthReport:\n  1051→        \"\"\"Return a structured health report for this store.\"\"\"\n  1052→        from datetime import UTC, datetime\n  1053→\n  1054→        from tapps_brain.federation import load_federation_config\n  1055→        from tapps_brain.gc import MemoryGarbageCollector\n  1056→        from tapps_brain.similarity import find_consolidation_groups\n  1057→\n  1058→        with self._lock:\n  1059→            entries = list(self._entries.values())\n  1060→\n  1061→        tier_counts: dict[str, int] = {}\n  1062→        for entry in entries:\n  1063→            tier_val = entry.tier.value if isinstance(entry.tier, MemoryTier) else str(entry.tier)\n  1064→            tier_counts[tier_val] = tier_counts.get(tier_val, 0) + 1\n  1065→\n  1066→        schema_ver = self._persistence.get_schema_version()\n  1067→\n  1068→        oldest_age = 0.0\n  1069→        now = datetime.now(tz=UTC)\n  1070→        for entry in entries:\n  1071→            try:\n  1072→                raw = entry.created_at.replace(\"Z\", \"+00:00\")\n  1073→                created = datetime.fromisoformat(raw)\n  1074→                if created.tzinfo is None:\n  1075→                    created = created.replace(tzinfo=UTC)\n  1076→                days = (now - created).total_seconds() / 86400.0\n  1077→                oldest_age = max(oldest_age, days)\n  1078→            except (ValueError, TypeError, AttributeError):\n  1079→                continue\n  1080→\n  1081→        gc = MemoryGarbageCollector()\n  1082→        gc_candidates = gc.identify_candidates(entries)\n  1083→\n  1084→        groups = find_consolidation_groups(\n  1085→            entries,\n  1086→            threshold=self._consolidation_config.threshold,\n  1087→        )\n  1088→        consolidation_candidates = sum(len(g) for g in groups)\n  1089→\n  1090→        fed = load_federation_config()\n  1091→        federation_project_count = len(fed.projects)\n  1092→\n  1093→        # Integrity verification (H4c)\n  1094→        integrity = self.verify_integrity()\n  1095→\n  1096→        # Rate limiter anomaly counts (H6c)\n  1097→        rl_stats = self._rate_limiter.stats\n  1098→\n  1099→        return StoreHealthReport(\n  1100→            store_path=str(self._project_root),\n  1101→            entry_count=len(entries),\n  1102→            max_entries=_MAX_ENTRIES,\n  1103→            schema_version=schema_ver,\n  1104→            tier_distribution=tier_counts,\n  1105→            oldest_entry_age_days=oldest_age,\n  1106→            consolidation_candidates=consolidation_candidates,\n  1107→            gc_candidates=len(gc_candidates),\n  1108→            federation_enabled=federation_project_count > 0,\n  1109→            federation_project_count=federation_project_count,\n  1110→            integrity_verified=integrity[\"verified\"],\n  1111→            integrity_tampered=integrity[\"tampered\"],\n  1112→            integrity_no_hash=integrity[\"no_hash\"],\n  1113→            integrity_tampered_keys=integrity[\"tampered_keys\"][:20],\n  1114→            rate_limit_minute_anomalies=rl_stats.minute_anomalies,\n  1115→            rate_limit_session_anomalies=rl_stats.session_anomalies,\n  1116→            rate_limit_total_writes=rl_stats.total_writes,\n  1117→            rate_limit_exempt_writes=rl_stats.exempt_writes,\n  1118→        )\n  1119→\n  1120→    def gc(self, *, dry_run: bool = False) -> Any:  # noqa: ANN401\n  1121→        \"\"\"Run garbage collection on the store.\n  1122→\n  1123→        Args:\n  1124→            dry_run: If True, only identify candidates without archiving.\n  1125→\n  1126→        Returns:\n  1127→            ``GCResult`` with archived count and keys.\n  1128→        \"\"\"\n  1129→        from tapps_brain.gc import GCResult, MemoryGarbageCollector\n  1130→\n  1131→        self._metrics.increment(\"store.gc\")\n  1132→        gc_collector = MemoryGarbageCollector()\n  1133→        with self._lock:\n  1134→            entries = list(self._entries.values())\n  1135→        candidates = gc_collector.identify_candidates(entries)\n  1136→        candidate_keys = [c.key for c in candidates]\n  1137→\n  1138→        if dry_run:\n  1139→            return GCResult(\n  1140→                archived_count=0,\n  1141→                remaining_count=len(entries),\n  1142→                archived_keys=candidate_keys,\n  1143→            )\n  1144→\n  1145→        # Archive to JSONL and delete from store\n  1146→        archive_path = self._persistence._store_dir / \"gc_archive.jsonl\"\n  1147→        MemoryGarbageCollector.append_to_archive(candidates, archive_path)\n  1148→        for key in candidate_keys:\n  1149→            self.delete(key)\n  1150→\n  1151→        self._metrics.increment(\"store.gc.archived\", len(candidate_keys))\n  1152→        return GCResult(\n  1153→            archived_count=len(candidate_keys),\n  1154→            remaining_count=len(entries) - len(candidate_keys),\n  1155→            archived_keys=candidate_keys,\n  1156→        )\n  1157→\n  1158→    def audit(\n  1159→        self,\n  1160→        *,\n  1161→        key: str | None = None,\n  1162→        event_type: str | None = None,\n  1163→        since: str | None = None,\n  1164→        until: str | None = None,\n  1165→        limit: int = 100,\n  1166→    ) -> list[Any]:\n  1167→        \"\"\"Query the JSONL audit trail.\n  1168→\n  1169→        Convenience wrapper around ``AuditReader.query()``.\n  1170→\n  1171→        Args:\n  1172→            key: Filter by memory entry key.\n  1173→            event_type: Filter by event type (save, delete, etc.).\n  1174→            since: ISO-8601 lower bound (inclusive).\n  1175→            until: ISO-8601 upper bound (inclusive).\n  1176→            limit: Maximum number of entries to return.\n  1177→\n  1178→        Returns:\n  1179→            List of ``AuditEntry`` objects matching the filters.\n  1180→        \"\"\"\n  1181→        from tapps_brain.audit import AuditReader\n  1182→\n  1183→        reader = AuditReader(self._persistence._audit_path)\n  1184→        return reader.query(\n  1185→            key=key,\n  1186→            event_type=event_type,\n  1187→            since=since,\n  1188→            until=until,\n  1189→            limit=limit,\n  1190→        )\n  1191→\n  1192→    def get_metrics(self) -> MetricsSnapshot:\n  1193→        \"\"\"Return a snapshot of in-process operation metrics.\"\"\"\n  1194→        return self._metrics.snapshot()\n  1195→\n  1196→    # ------------------------------------------------------------------\n  1197→    # Relations (EPIC-006)\n  1198→    # ------------------------------------------------------------------\n  1199→\n  1200→    def get_relations(self, key: str) -> list[dict[str, Any]]:\n  1201→        \"\"\"Return all relations associated with a memory entry key.\n  1202→\n  1203→        Args:\n  1204→            key: The memory entry key.\n  1205→\n  1206→        Returns:\n  1207→            List of relation dicts with subject, predicate, object_entity,\n  1208→            source_entry_keys, confidence, and created_at.\n  1209→        \"\"\"\n  1210→        return list(self._relations.get(key, []))\n  1211→\n  1212→    def find_related(\n  1213→        self,\n  1214→        key: str,\n  1215→        *,\n  1216→        max_hops: int = 2,\n  1217→    ) -> list[tuple[str, int]]:\n  1218→        \"\"\"Find entries related to *key* via BFS traversal of the relation graph.\n  1219→\n  1220→        Two entries are considered connected when they share an entity\n  1221→        (subject or object_entity) in their extracted relations.\n  1222→\n  1223→        Args:\n  1224→            key: Starting entry key.\n  1225→            max_hops: Maximum traversal depth (default 2).\n  1226→\n  1227→        Returns:\n  1228→            List of ``(entry_key, hop_distance)`` tuples, ordered by hop\n  1229→            distance (ascending) then key name.  The starting key is\n  1230→            **not** included in the results.\n  1231→\n  1232→        Raises:\n  1233→            KeyError: If *key* does not exist in the store.\n  1234→        \"\"\"\n  1235→        with self._lock:\n  1236→            if key not in self._entries:\n  1237→                raise KeyError(key)\n  1238→\n  1239→            # Build entity -> set[entry_key] index from all relations\n  1240→            entity_to_keys: dict[str, set[str]] = {}\n  1241→            for entry_key, rels in self._relations.items():\n  1242→                for rel in rels:\n  1243→                    for entity in (rel[\"subject\"].lower(), rel[\"object_entity\"].lower()):\n  1244→                        entity_to_keys.setdefault(entity, set()).add(entry_key)\n  1245→\n  1246→            # BFS\n  1247→            visited: set[str] = {key}\n  1248→            result: list[tuple[str, int]] = []\n  1249→            frontier: set[str] = {key}\n  1250→\n  1251→            for hop in range(1, max_hops + 1):\n  1252→                next_frontier: set[str] = set()\n  1253→                for current_key in frontier:\n  1254→                    # Collect entities from current_key's relations\n  1255→                    for rel in self._relations.get(current_key, []):\n  1256→                        for entity in (rel[\"subject\"].lower(), rel[\"object_entity\"].lower()):\n  1257→                            for neighbor_key in entity_to_keys.get(entity, set()):\n  1258→                                if neighbor_key not in visited:\n  1259→                                    visited.add(neighbor_key)\n  1260→                                    result.append((neighbor_key, hop))\n  1261→                                    next_frontier.add(neighbor_key)\n  1262→                frontier = next_frontier\n  1263→\n  1264→        # Sort by hop distance, then key name for determinism\n  1265→        result.sort(key=lambda t: (t[1], t[0]))\n  1266→        return result\n  1267→\n  1268→    def query_relations(\n  1269→        self,\n  1270→        *,\n  1271→        subject: str | None = None,\n  1272→        predicate: str | None = None,\n  1273→        object_entity: str | None = None,\n  1274→    ) -> list[dict[str, Any]]:\n  1275→        \"\"\"Filter relations by subject, predicate, and/or object_entity.\n  1276→\n  1277→        All filters use case-insensitive matching.  When multiple filters are\n  1278→        provided they are combined with AND logic.  Passing no filters returns\n  1279→        all relations.\n  1280→\n  1281→        Args:\n  1282→            subject: Filter by subject entity.\n  1283→            predicate: Filter by predicate/relationship type.\n  1284→            object_entity: Filter by object entity.\n  1285→\n  1286→        Returns:\n  1287→            List of matching relation dicts.\n  1288→        \"\"\"\n  1289→        with self._lock:\n  1290→            matches: list[dict[str, Any]] = []\n  1291→            for rels in self._relations.values():\n  1292→                for rel in rels:\n  1293→                    if subject is not None and rel[\"subject\"].lower() != subject.lower():\n  1294→                        continue\n  1295→                    if predicate is not None and rel[\"predicate\"].lower() != predicate.lower():\n  1296→                        continue\n  1297→                    if (\n  1298→                        object_entity is not None\n  1299→                        and rel[\"object_entity\"].lower() != object_entity.lower()\n  1300→                    ):\n  1301→                        continue\n  1302→                    matches.append(dict(rel))\n  1303→            # Deduplicate by (subject, predicate, object_entity) triple\n  1304→            seen: set[tuple[str, str, str]] = set()\n  1305→            deduped: list[dict[str, Any]] = []\n  1306→            for m in matches:\n  1307→                triple = (m[\"subject\"].lower(), m[\"predicate\"].lower(), m[\"object_entity\"].lower())\n  1308→                if triple not in seen:\n  1309→                    seen.add(triple)\n  1310→                    deduped.append(m)\n  1311→        return deduped\n  1312→\n  1313→    # ------------------------------------------------------------------\n  1314→    # Tag management (EPIC-015)\n  1315→    # ------------------------------------------------------------------\n  1316→\n  1317→    def list_tags(self) -> dict[str, int]:\n  1318→        \"\"\"Return all unique tags across all entries with their usage counts.\n  1319→\n  1320→        Returns:\n  1321→            Dict mapping tag → count of entries that carry that tag.\n  1322→        \"\"\"\n  1323→        with self._lock:\n  1324→            entries = list(self._entries.values())\n  1325→        counts: dict[str, int] = {}\n  1326→        for entry in entries:\n  1327→            for tag in entry.tags:\n  1328→                counts[tag] = counts.get(tag, 0) + 1\n  1329→        return counts\n  1330→\n  1331→    def update_tags(\n  1332→        self,\n  1333→        key: str,\n  1334→        *,\n  1335→        add: list[str] | None = None,\n  1336→        remove: list[str] | None = None,\n  1337→    ) -> MemoryEntry | dict[str, str]:\n  1338→        \"\"\"Atomically add and/or remove tags on an existing entry.\n  1339→\n  1340→        Args:\n  1341→            key: The memory entry key.\n  1342→            add: Tags to add (ignored when already present).\n  1343→            remove: Tags to remove (ignored when not present).\n  1344→\n  1345→        Returns:\n  1346→            The updated ``MemoryEntry`` on success, or a dict with\n  1347→            ``\"error\"`` and ``\"message\"`` keys on failure.\n  1348→        \"\"\"\n  1349→        from tapps_brain.models import MAX_TAGS\n  1350→\n  1351→        add_set = set(add or [])\n  1352→        remove_set = set(remove or [])\n  1353→\n  1354→        with self._lock:\n  1355→            entry = self._entries.get(key)\n  1356→            if entry is None:\n  1357→                return {\"error\": \"not_found\", \"message\": f\"Entry '{key}' not found.\"}\n  1358→\n  1359→            current = list(entry.tags)\n  1360→            # Remove first, then add (preserves existing order)\n  1361→            updated_tags = [t for t in current if t not in remove_set]\n  1362→            for tag in add_set:\n  1363→                if tag not in updated_tags:\n  1364→                    updated_tags.append(tag)\n  1365→\n  1366→            if len(updated_tags) > MAX_TAGS:\n  1367→                return {\n  1368→                    \"error\": \"too_many_tags\",\n  1369→                    \"message\": (\n  1370→                        f\"Cannot have more than {MAX_TAGS} tags ({len(updated_tags)} would result).\"\n  1371→                    ),\n  1372→                }\n  1373→\n  1374→            from tapps_brain.models import _utc_now_iso\n  1375→\n  1376→            updated = entry.model_copy(update={\"tags\": updated_tags, \"updated_at\": _utc_now_iso()})\n  1377→            self._entries[key] = updated\n  1378→\n  1379→        self._persistence.save(updated)\n  1380→        return updated\n  1381→\n  1382→    def entries_by_tag(\n  1383→        self,\n  1384→        tag: str,\n  1385→        *,\n  1386→        tier: str | None = None,\n  1387→    ) -> list[MemoryEntry]:\n  1388→        \"\"\"Return all entries that carry a specific tag.\n  1389→\n  1390→        Args:\n  1391→            tag: The tag to filter by.\n  1392→            tier: Optional tier filter.\n  1393→\n  1394→        Returns:\n  1395→            List of matching ``MemoryEntry`` objects.\n  1396→        \"\"\"\n  1397→        return self.list_all(tags=[tag], tier=tier)\n  1398→\n  1399→    # ------------------------------------------------------------------\n  1400→    # Integrity verification (H4b)\n  1401→    # ------------------------------------------------------------------\n  1402→\n  1403→    def verify_integrity(self) -> dict[str, Any]:\n  1404→        \"\"\"Scan all entries and verify their HMAC integrity hashes.\n  1405→\n  1406→        For each entry that has a stored ``integrity_hash``, recomputes the\n  1407→        HMAC-SHA256 and checks for a match. Entries without a stored hash\n  1408→        (pre-v8 or NULL) are reported separately.\n  1409→\n  1410→        Returns:\n  1411→            Dict with ``total``, ``verified``, ``tampered``, ``no_hash``,\n  1412→            ``tampered_keys``, ``missing_hash_keys``, ``tampered_details``.\n  1413→        \"\"\"\n  1414→        from tapps_brain.integrity import compute_integrity_hash, verify_integrity_hash\n  1415→\n  1416→        self._metrics.increment(\"store.verify_integrity\")\n  1417→\n  1418→        with self._lock:\n  1419→            entries = list(self._entries.values())\n  1420→\n  1421→        total = len(entries)\n  1422→        verified = 0\n  1423→        tampered: list[str] = []\n  1424→        tampered_details: list[dict[str, str]] = []\n  1425→        missing_hash_keys: list[str] = []\n  1426→\n  1427→        for entry in entries:\n  1428→            stored_hash = getattr(entry, \"integrity_hash\", None)\n  1429→            if not stored_hash:\n  1430→                missing_hash_keys.append(entry.key)\n  1431→                continue\n  1432→\n  1433→            tier_str = entry.tier.value if hasattr(entry.tier, \"value\") else str(entry.tier)\n  1434→            source_str = (\n  1435→                entry.source.value if hasattr(entry.source, \"value\") else str(entry.source)\n  1436→            )\n  1437→            if verify_integrity_hash(\n  1438→                entry.key, entry.value, tier_str, source_str, stored_hash\n  1439→            ):\n  1440→                verified += 1\n  1441→            else:\n  1442→                tampered.append(entry.key)\n  1443→                expected = compute_integrity_hash(entry.key, entry.value, tier_str, source_str)\n  1444→                tampered_details.append(\n  1445→                    {\n  1446→                        \"key\": entry.key,\n  1447→                        \"stored_hash\": stored_hash,\n  1448→                        \"expected_hash\": expected,\n  1449→                    }\n  1450→                )\n  1451→                logger.warning(\n  1452→                    \"integrity_verification_failed\",\n  1453→                    key=entry.key,\n  1454→                    tier=tier_str,\n  1455→                )\n  1456→\n  1457→        return {\n  1458→            \"total\": total,\n  1459→            \"verified\": verified,\n  1460→            \"tampered\": len(tampered),\n  1461→            \"no_hash\": len(missing_hash_keys),\n  1462→            \"tampered_keys\": tampered,\n  1463→            \"missing_hash_keys\": missing_hash_keys,\n  1464→            \"tampered_details\": tampered_details,\n  1465→        }\n  1466→\n  1467→    def close(self) -> None:\n  1468→        \"\"\"Close the underlying persistence layer.\"\"\"\n  1469→        self._persistence.close()\n  1470→\n  1471→    # ------------------------------------------------------------------\n  1472→    # Private helpers\n  1473→    # ------------------------------------------------------------------\n  1474→\n  1475→    def _evict_lowest_confidence(self) -> None:\n  1476→        \"\"\"Evict the entry with the lowest confidence to make room.\n  1477→\n  1478→        Must be called while holding ``self._lock``.\n  1479→        \"\"\"\n  1480→        if not self._entries:\n  1481→            return\n  1482→\n  1483→        lowest_key = min(self._entries, key=lambda k: self._entries[k].confidence)\n  1484→        del self._entries[lowest_key]\n  1485→        self._persistence.delete(lowest_key)\n  1486→        logger.info(\"memory_evicted\", key=lowest_key, reason=\"max_entries\")\n  1487→\n  1488→    def _resolve_scope(self, key: str, scope: str, branch: str) -> MemoryEntry | None:\n  1489→        \"\"\"Resolve scope precedence: session > branch > project.\n  1490→\n  1491→        Must be called while holding ``self._lock``.\n  1492→        \"\"\"\n  1493→        # Try most specific first\n  1494→        for try_scope in [MemoryScope.session, MemoryScope.branch, MemoryScope.project]:\n  1495→            if try_scope.value == scope or _scope_rank(try_scope) >= _scope_rank(\n  1496→                MemoryScope(scope)\n  1497→            ):\n  1498→                for entry in self._entries.values():\n  1499→                    if entry.key == key and entry.scope == try_scope:"}]},"parent_tool_use_id":"toolu_01KJomf8MxPhmjTE3TX6wPks","session_id":"327621aa-924c-4bfb-b348-3a4acf890b54","uuid":"d0581b57-16b9-4f45-8d70-3429c8853202","timestamp":"2026-03-22T22:38:17.404Z"}
