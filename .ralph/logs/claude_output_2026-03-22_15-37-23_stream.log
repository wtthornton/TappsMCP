 Any]:\n   695→    \"\"\"Handle the reinforce action.\"\"\"\n   696→    if not p.key:\n   697→        return {\"error\": \"missing_key\", \"message\": \"Key is required for reinforce.\"}\n   698→\n   699→    entry = store.get(p.key)\n   700→    if entry is None:\n   701→        return {\n   702→            \"action\": \"reinforce\",\n   703→            \"found\": False,\n   704→            \"key\": p.key,\n   705→            \"store_metadata\": _store_metadata(store),\n   706→        }\n   707→\n   708→    old_confidence = entry.confidence\n   709→    old_tier = entry.tier if isinstance(entry.tier, str) else entry.tier.value\n   710→\n   711→    from tapps_core.memory.decay import DecayConfig\n   712→    from tapps_core.memory.reinforcement import reinforce\n   713→\n   714→    config = DecayConfig()\n   715→    updates = reinforce(entry, config)\n   716→    updated_entry = store.update_fields(p.key, **updates)\n   717→\n   718→    # Epic M2.6: Check for promotion after reinforcement\n   719→    promoted_to: str | None = None\n   720→    try:\n   721→        profile = store.profile\n   722→        if profile is not None:\n   723→            from tapps_brain.promotion import PromotionEngine\n   724→\n   725→            engine = PromotionEngine(config)\n   726→            target_entry = updated_entry if updated_entry else entry\n   727→            promoted_to = engine.check_promotion(target_entry, profile)\n   728→            if promoted_to:\n   729→                store.update_fields(p.key, tier=promoted_to)\n   730→    except Exception:\n   731→        pass  # Non-fatal -- promotion check is best-effort\n   732→\n   733→    result: dict[str, Any] = {\n   734→        \"action\": \"reinforce\",\n   735→        \"found\": True,\n   736→        \"old_confidence\": old_confidence,\n   737→        \"new_confidence\": updates[\"confidence\"],\n   738→        \"reinforce_count\": updates[\"reinforce_count\"],\n   739→        \"entry\": updated_entry.model_dump() if updated_entry else entry.model_dump(),\n   740→        \"store_metadata\": _store_metadata(store),\n   741→    }\n   742→    if promoted_to:\n   743→        result[\"promoted\"] = f\"{old_tier} -> {promoted_to}\"\n   744→    return result\n   745→\n   746→\n   747→def _handle_gc(store: MemoryStore, _p: _Params) -> dict[str, Any]:\n   748→    \"\"\"Handle the gc (garbage collection) action.\"\"\"\n   749→    from tapps_core.memory.decay import DecayConfig\n   750→    from tapps_core.memory.gc import MemoryGarbageCollector\n   751→\n   752→    config = DecayConfig()\n   753→    gc_runner = MemoryGarbageCollector(config)\n   754→\n   755→    snap = store.snapshot()\n   756→    candidates = gc_runner.identify_candidates(snap.entries)\n   757→\n   758→    archived_keys: list[str] = []\n   759→    for candidate in candidates:\n   760→        deleted = store.delete(candidate.key)\n   761→        if deleted:\n   762→            archived_keys.append(candidate.key)\n   763→\n   764→    return {\n   765→        \"action\": \"gc\",\n   766→        \"archived_count\": len(archived_keys),\n   767→        \"archived_keys\": archived_keys,"}]},"parent_tool_use_id":null,"session_id":"327621aa-924c-4bfb-b348-3a4acf890b54","uuid":"cca81d64-5185-4e04-a9f2-e5966b57d48d","timestamp":"2026-03-22T22:39:00.176Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\cursor\\TappMCP\\packages\\tapps-mcp\\src\\tapps_mcp\\server_memory_tools.py","content":"def _handle_search(store: MemoryStore, p: _Params) -> dict[str, Any]:\n    \"\"\"Handle the search action with optional ranked BM25 scoring.\"\"\"\n    if not p.query and not p.tag_list:\n        return {\n            \"error\": \"missing_query\",\n            \"message\": \"Query or tags required for search.\",\n        }\n\n    effective_limit = p.limit if p.limit > 0 else _SEARCH_DEFAULT_LIMIT\n\n    if p.ranked and p.query:\n        return _ranked_search(\n            store,\n            p.query,\n            effective_limit,\n            p.include_summary,\n            p.include_sources,\n            p.include_session_index,\n        )\n\n    # Unranked (legacy FTS5-only) search\n    results = store.search(\n        query=p.query,\n        tags=p.tag_list or None,\n        tier=p.tier if p.tier != \"pattern\" else None,\n        scope=p.scope if p.scope != \"project\" else None,\n    )\n\n    # Filter source entries of consolidated memories (Epic 58.5)\n    if not p.include_sources:\n        results = _filter_consolidated_sources(results)\n\n    truncated = results[:effective_limit]\n    result_entries = _build_entry_list(truncated, p.include_summary)\n\n    return {\n        \"action\": \"search\",\n        \"ranked\": False,\n        \"results\": result_entries,\n        \"total_count\": len(results),\n        \"returned_count\": len(result_entries),\n        \"query\": p.query,\n        \"store_metadata\": _store_metadata(store),\n    }\n\n\ndef _handle_reinforce(store: MemoryStore, p: _Params) -> dict[str, Any]:\n    \"\"\"Handle the reinforce action.\"\"\"\n    if not p.key:\n        return {\"error\": \"missing_key\", \"message\": \"Key is required for reinforce.\"}\n\n    entry = store.get(p.key)\n    if entry is None:\n        return {\n            \"action\": \"reinforce\",\n            \"found\": False,\n            \"key\": p.key,\n            \"store_metadata\": _store_metadata(store),\n        }\n\n    old_confidence = entry.confidence\n    old_tier = entry.tier if isinstance(entry.tier, str) else entry.tier.value\n\n    from tapps_core.memory.decay import DecayConfig\n    from tapps_core.memory.reinforcement import reinforce\n\n    config = DecayConfig()\n    updates = reinforce(entry, config)\n    updated_entry = store.update_fields(p.key, **updates)\n\n    # Epic M2.6: Check for promotion after reinforcement\n    promoted_to: str | None = None\n    try:\n        profile = store.profile\n        if profile is not None:\n            from tapps_brain.promotion import PromotionEngine\n\n            engine = PromotionEngine(config)\n            target_entry = updated_entry if updated_entry else entry\n            promoted_to = engine.check_promotion(target_entry, profile)\n            if promoted_to:\n                store.update_fields(p.key, tier=promoted_to)\n    except Exception:\n        pass  # Non-fatal -- promotion check is best-effort\n\n    result: dict[str, Any] = {\n        \"action\": \"reinforce\",\n        \"found\": True,\n        \"old_confidence\": old_confidence,\n        \"new_confidence\": updates[\"confidence\"],\n        \"reinforce_count\": updates[\"reinforce_count\"],\n        \"entry\": updated_entry.model_dump() if updated_entry else entry.model_dump(),\n        \"store_metadata\": _store_metadata(store),\n    }\n    if promoted_to:\n        result[\"promoted\"] = f\"{old_tier} -> {promoted_to}\"\n    return result\n\n\ndef _handle_gc(store: MemoryStore, _p: _Params) -> dict[str, Any]:\n    \"\"\"Handle the gc (garbage collection) action.\"\"\"\n    from tapps_core.memory.decay import DecayConfig\n    from tapps_core.memory.gc import MemoryGarbageCollector\n\n    config = DecayConfig()\n    gc_runner = MemoryGarbageCollector(config)\n\n    snap = store.snapshot()\n    candidates = gc_runner.identify_candidates(snap.entries)\n\n    archived_keys: list[str] = []\n    for candidate in candidates:\n        deleted = store.delete(candidate.key)\n        if deleted:\n            archived_keys.append(candidate.key)\n\n    return {\n        \"action\": \"gc\",\n        \"archived_count\": len(archived_keys),\n        \"archived_keys\": archived_keys,","numLines":120,"startLine":648,"totalLines":2201}}}
