{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G8s1cksCQ2zWZ7Zgjsq3qo","type":"tool_result","content":"    95→    def recall(self, message: str, **kwargs: object) -> RecallResult:\n    96→        \"\"\"Search the store and return injection-ready context.\n    97→\n    98→        Args:\n    99→            message: The user's incoming message to match against.\n   100→            **kwargs: Override ``RecallConfig`` fields for this call.\n   101→\n   102→        Returns:\n   103→            ``RecallResult`` with formatted memory section, metadata,\n   104→            and timing. Returns an empty result (not an error) when\n   105→            no relevant memories are found.\n   106→        \"\"\"\n   107→        start = time.perf_counter()\n   108→        cfg = self._effective_config(kwargs)\n   109→\n   110→        # Delegate to inject_memories for search + format + safety + budget\n   111→        injection_config = InjectionConfig(\n   112→            injection_max_tokens=cfg.max_tokens,\n   113→        )\n   114→        result = inject_memories(\n   115→            message,\n   116→            self._store,\n   117→            engagement_level=cfg.engagement_level,\n   118→            decay_config=self._decay_config,\n   119→            config=injection_config,\n   120→        )\n   121→\n   122→        # Graph boost: boost scores of entries connected via relation graph\n   123→        memories = result.get(\"memories\", [])\n   124→        memory_section: str = result.get(\"memory_section\", \"\")\n   125→\n   126→        if cfg.use_graph_boost and memories:\n   127→            memories = self._apply_graph_boost(memories, cfg.graph_boost_factor)\n   128→\n   129→        # Hive recall: merge local + Hive results (EPIC-011)\n   130→        hive_count = 0\n   131→        if self._hive_store is not None:\n   132→            hive_memories, hive_count = self._search_hive(message, memories)\n   133→            if hive_memories:\n   134→                memories = self._merge_hive_results(memories, hive_memories)\n   135→                # Rebuild section to include Hive results\n   136→                memory_section = self._rebuild_section(memories)\n   137→\n   138→        # Post-filter: scope, tier, branch, dedupe\n   139→\n   140→        if memories and self._needs_post_filter(cfg):\n   141→            memories, memory_section = self._apply_post_filters(memories, cfg, message)\n   142→\n   143→        elapsed_ms = (time.perf_counter() - start) * 1000.0\n   144→\n   145→        return RecallResult(\n   146→            memory_section=memory_section,\n   147→            memories=memories,\n   148→            token_count=result.get(\"injected_tokens\", 0),\n   149→            recall_time_ms=round(elapsed_ms, 2),\n   150→            truncated=result.get(\"truncated\", False),\n   151→            memory_count=len(memories),\n   152→            hive_memory_count=hive_count,\n   153→        )\n   154→\n   155→    # ------------------------------------------------------------------\n   156→    # Capture\n   157→    # ------------------------------------------------------------------\n   158→\n   159→    def capture(\n   160→        self,\n   161→        response: str,\n   162→        *,\n   163→        source: str = \"agent\",\n   164→        agent_scope: str = \"private\",\n   165→        **kwargs: object,\n   166→    ) -> list[str]:\n   167→        \"\"\"Extract and persist new facts from an agent response.\n   168→\n   169→        Delegates to ``store.ingest_context()`` for rule-based extraction\n   170→        and deduplication.\n   171→\n   172→        Args:\n   173→            response: The agent's response text to scan for facts.\n   174→            source: Source attribution for created entries.\n   175→            agent_scope: Hive propagation scope for captured facts —\n   176→                ``'private'`` (default), ``'domain'``, or ``'hive'``.\n   177→\n   178→        Returns:\n   179→            List of keys for newly created memory entries.\n   180→        \"\"\"\n   181→        if not response or not response.strip():\n   182→            return []\n   183→\n   184→        return self._store.ingest_context(\n   185→            response, source=source, agent_scope=agent_scope\n   186→        )\n   187→\n   188→    # ------------------------------------------------------------------\n   189→    # Internal helpers\n   190→    # ------------------------------------------------------------------\n   191→\n   192→    # ------------------------------------------------------------------\n   193→    # Hive recall helpers (EPIC-011)\n   194→    # ------------------------------------------------------------------"}]},"parent_tool_use_id":null,"session_id":"327621aa-924c-4bfb-b348-3a4acf890b54","uuid":"506a615b-dc28-4ab4-a26e-ccb1fc470996","timestamp":"2026-03-22T22:39:12.739Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\cursor\\tapps-brain\\src\\tapps_brain\\recall.py","content":"    def recall(self, message: str, **kwargs: object) -> RecallResult:\n        \"\"\"Search the store and return injection-ready context.\n\n        Args:\n            message: The user's incoming message to match against.\n            **kwargs: Override ``RecallConfig`` fields for this call.\n\n        Returns:\n            ``RecallResult`` with formatted memory section, metadata,\n            and timing. Returns an empty result (not an error) when\n            no relevant memories are found.\n        \"\"\"\n        start = time.perf_counter()\n        cfg = self._effective_config(kwargs)\n\n        # Delegate to inject_memories for search + format + safety + budget\n        injection_config = InjectionConfig(\n            injection_max_tokens=cfg.max_tokens,\n        )\n        result = inject_memories(\n            message,\n            self._store,\n            engagement_level=cfg.engagement_level,\n            decay_config=self._decay_config,\n            config=injection_config,\n        )\n\n        # Graph boost: boost scores of entries connected via relation graph\n        memories = result.get(\"memories\", [])\n        memory_section: str = result.get(\"memory_section\", \"\")\n\n        if cfg.use_graph_boost and memories:\n            memories = self._apply_graph_boost(memories, cfg.graph_boost_factor)\n\n        # Hive recall: merge local + Hive results (EPIC-011)\n        hive_count = 0\n        if self._hive_store is not None:\n            hive_memories, hive_count = self._search_hive(message, memories)\n            if hive_memories:\n                memories = self._merge_hive_results(memories, hive_memories)\n                # Rebuild section to include Hive results\n                memory_section = self._rebuild_section(memories)\n\n        # Post-filter: scope, tier, branch, dedupe\n\n        if memories and self._needs_post_filter(cfg):\n            memories, memory_section = self._apply_post_filters(memories, cfg, message)\n\n        elapsed_ms = (time.perf_counter() - start) * 1000.0\n\n        return RecallResult(\n            memory_section=memory_section,\n            memories=memories,\n            token_count=result.get(\"injected_tokens\", 0),\n            recall_time_ms=round(elapsed_ms, 2),\n            truncated=result.get(\"truncated\", False),\n            memory_count=len(memories),\n            hive_memory_count=hive_count,\n        )\n\n    # ------------------------------------------------------------------\n    # Capture\n    # ------------------------------------------------------------------\n\n    def capture(\n        self,\n        response: str,\n        *,\n        source: str = \"agent\",\n        agent_scope: str = \"private\",\n        **kwargs: object,\n    ) -> list[str]:\n        \"\"\"Extract and persist new facts from an agent response.\n\n        Delegates to ``store.ingest_context()`` for rule-based extraction\n        and deduplication.\n\n        Args:\n            response: The agent's response text to scan for facts.\n            source: Source attribution for created entries.\n            agent_scope: Hive propagation scope for captured facts —\n                ``'private'`` (default), ``'domain'``, or ``'hive'``.\n\n        Returns:\n            List of keys for newly created memory entries.\n        \"\"\"\n        if not response or not response.strip():\n            return []\n\n        return self._store.ingest_context(\n            response, source=source, agent_scope=agent_scope\n        )\n\n    # ------------------------------------------------------------------\n    # Internal helpers\n    # ------------------------------------------------------------------\n\n    # ------------------------------------------------------------------\n    # Hive recall helpers (EPIC-011)\n    # ------------------------------------------------------------------","numLines":100,"startLine":95,"totalLines":412}}}
