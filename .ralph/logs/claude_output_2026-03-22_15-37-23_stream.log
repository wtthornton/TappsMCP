{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GFPm3LBLDToMBhotjnCkSW","type":"tool_result","content":"     1→\"\"\"Auto-recall orchestrator for pre-prompt memory injection (EPIC-003).\n     2→\n     3→Provides a ``RecallOrchestrator`` that accepts an incoming user message,\n     4→searches the memory store for relevant entries, and returns injection-ready\n     5→context. Delegates formatting, safety, and token budget enforcement to\n     6→``inject_memories()``.\n     7→\n     8→The orchestrator adds quality gates on top of injection:\n     9→- Scope / tier / branch filtering\n    10→- Deduplication against already-in-context memories\n    11→- Minimum confidence threshold\n    12→- Timing measurement\n    13→\n    14→Thread-safe: multiple concurrent ``recall()`` calls are safe.\n    15→\"\"\"\n    16→\n    17→from __future__ import annotations\n    18→\n    19→import time\n    20→from dataclasses import dataclass, field\n    21→from typing import TYPE_CHECKING\n    22→\n    23→import structlog\n    24→\n    25→from tapps_brain.injection import InjectionConfig, inject_memories\n    26→from tapps_brain.models import MemoryScope, MemoryTier, RecallResult\n    27→\n    28→if TYPE_CHECKING:\n    29→    from tapps_brain.decay import DecayConfig\n    30→    from tapps_brain.hive import HiveStore\n    31→    from tapps_brain.retrieval import MemoryRetriever\n    32→    from tapps_brain.store import MemoryStore\n    33→\n    34→logger = structlog.get_logger(__name__)\n    35→\n    36→\n    37→# ---------------------------------------------------------------------------\n    38→# Configuration\n    39→# ---------------------------------------------------------------------------\n    40→\n    41→\n    42→@dataclass\n    43→class RecallConfig:\n    44→    \"\"\"Configuration for the recall orchestrator.\"\"\"\n    45→\n    46→    engagement_level: str = \"high\"\n    47→    max_tokens: int = 2000\n    48→    min_score: float = 0.3\n    49→    min_confidence: float = 0.1\n    50→    scope_filter: MemoryScope | None = None\n    51→    tier_filter: MemoryTier | None = None\n    52→    branch: str | None = None\n    53→    dedupe_window: list[str] = field(default_factory=list)\n    54→    use_graph_boost: bool = False\n    55→    graph_boost_factor: float = 0.15\n    56→\n    57→\n    58→# ---------------------------------------------------------------------------\n    59→# RecallOrchestrator\n    60→# ---------------------------------------------------------------------------\n    61→\n    62→\n    63→class RecallOrchestrator:\n    64→    \"\"\"Orchestrates auto-recall: search → filter → inject → return.\n    65→\n    66→    Delegates formatting/safety/budget to ``inject_memories()`` and adds\n    67→    quality gates (scope, tier, branch, deduplication, timing).\n    68→\n    69→    Thread-safe: all mutable state access is guarded by the store lock.\n    70→    \"\"\"\n    71→\n    72→    def __init__(\n    73→        self,\n    74→        store: MemoryStore,\n    75→        *,\n    76→        retriever: MemoryRetriever | None = None,\n    77→        config: RecallConfig | None = None,\n    78→        decay_config: DecayConfig | None = None,\n    79→        hive_store: HiveStore | None = None,\n    80→        hive_recall_weight: float = 0.8,\n    81→        hive_agent_profile: str = \"repo-brain\",\n    82→    ) -> None:\n    83→        self._store = store\n    84→        self._retriever = retriever\n    85→        self._config = config or RecallConfig()\n    86→        self._decay_config = decay_config\n    87→        self._hive_store = hive_store\n    88→        self._hive_recall_weight = hive_recall_weight\n    89→        self._hive_agent_profile = hive_agent_profile\n    90→\n    91→    # ------------------------------------------------------------------\n    92→    # Recall\n    93→    # ------------------------------------------------------------------\n    94→\n    95→    def recall(self, message: str, **kwargs: object) -> RecallResult:\n    96→        \"\"\"Search the store and return injection-ready context.\n    97→\n    98→        Args:\n    99→            message: The user's incoming message to match against.\n   100→            **kwargs: Override ``RecallConfig`` fields for this call.\n   101→\n   102→        Returns:\n   103→            ``RecallResult`` with formatted memory section, metadata,\n   104→            and timing. Returns an empty result (not an error) when\n   105→            no relevant memories are found.\n   106→        \"\"\"\n   107→        start = time.perf_counter()\n   108→        cfg = self._effective_config(kwargs)\n   109→\n   110→        # Delegate to inject_memories for search + format + safety + budget\n   111→        injection_config = InjectionConfig(\n   112→            injection_max_tokens=cfg.max_tokens,\n   113→        )\n   114→        result = inject_memories(\n   115→            message,\n   116→            self._store,\n   117→            engagement_level=cfg.engagement_level,\n   118→            decay_config=self._decay_config,\n   119→            config=injection_config,\n   120→        )\n   121→\n   122→        # Graph boost: boost scores of entries connected via relation graph\n   123→        memories = result.get(\"memories\", [])\n   124→        memory_section: str = result.get(\"memory_section\", \"\")\n   125→\n   126→        if cfg.use_graph_boost and memories:\n   127→            memories = self._apply_graph_boost(memories, cfg.graph_boost_factor)\n   128→\n   129→        # Hive recall: merge local + Hive results (EPIC-011)\n   130→        hive_count = 0\n   131→        if self._hive_store is not None:\n   132→            hive_memories, hive_count = self._search_hive(message, memories)\n   133→            if hive_memories:\n   134→                memories = self._merge_hive_results(memories, hive_memories)\n   135→                # Rebuild section to include Hive results\n   136→                memory_section = self._rebuild_section(memories)\n   137→\n   138→        # Post-filter: scope, tier, branch, dedupe\n   139→\n   140→        if memories and self._needs_post_filter(cfg):\n   141→            memories, memory_section = self._apply_post_filters(memories, cfg, message)\n   142→\n   143→        elapsed_ms = (time.perf_counter() - start) * 1000.0\n   144→\n   145→        return RecallResult(\n   146→            memory_section=memory_section,\n   147→            memories=memories,\n   148→            token_count=result.get(\"injected_tokens\", 0),\n   149→            recall_time_ms=round(elapsed_ms, 2),\n   150→            truncated=result.get(\"truncated\", False),\n   151→            memory_count=len(memories),\n   152→            hive_memory_count=hive_count,\n   153→        )\n   154→\n   155→    # ------------------------------------------------------------------\n   156→    # Capture\n   157→    # ------------------------------------------------------------------\n   158→\n   159→    def capture(\n   160→        self,\n   161→        response: str,\n   162→        *,\n   163→        source: str = \"agent\",\n   164→        agent_scope: str = \"private\",\n   165→        **kwargs: object,\n   166→    ) -> list[str]:\n   167→        \"\"\"Extract and persist new facts from an agent response.\n   168→\n   169→        Delegates to ``store.ingest_context()`` for rule-based extraction\n   170→        and deduplication.\n   171→\n   172→        Args:\n   173→            response: The agent's response text to scan for facts.\n   174→            source: Source attribution for created entries.\n   175→            agent_scope: Hive propagation scope for captured facts —\n   176→                ``'private'`` (default), ``'domain'``, or ``'hive'``.\n   177→\n   178→        Returns:\n   179→            List of keys for newly created memory entries.\n   180→        \"\"\"\n   181→        if not response or not response.strip():\n   182→            return []\n   183→\n   184→        return self._store.ingest_context(\n   185→            response, source=source, agent_scope=agent_scope\n   186→        )\n   187→\n   188→    # ------------------------------------------------------------------\n   189→    # Internal helpers\n   190→    # ------------------------------------------------------------------\n   191→\n   192→    # ------------------------------------------------------------------\n   193→    # Hive recall helpers (EPIC-011)\n   194→    # ------------------------------------------------------------------\n   195→\n   196→    def _search_hive(\n   197→        self,\n   198→        message: str,\n   199→        local_memories: list[dict[str, object]],\n   200→    ) -> tuple[list[dict[str, object]], int]:\n   201→        \"\"\"Search the Hive for relevant memories not already in local results.\n   202→\n   203→        Returns (hive_memories, count).\n   204→        \"\"\"\n   205→        if self._hive_store is None:\n   206→            return [], 0\n   207→\n   208→        local_keys = {str(m.get(\"key\", \"\")) for m in local_memories}\n   209→\n   210→        # Search universal + agent's domain namespace\n   211→        namespaces = [\"universal\", self._hive_agent_profile]\n   212→        try:\n   213→            hive_results = self._hive_store.search(\n   214→                message,\n   215→                namespaces=namespaces,\n   216→                min_confidence=self._config.min_confidence,\n   217→                limit=20,\n   218→            )\n   219→        except Exception:\n   220→            logger.debug(\"hive_recall_search_failed\", exc_info=True)\n   221→            return [], 0\n   222→\n   223→        hive_memories: list[dict[str, object]] = []\n   224→        for entry in hive_results:\n   225→            key = str(entry.get(\"key\", \"\"))\n   226→            if key in local_keys:\n   227→                continue  # Deduplicate — local wins\n   228→\n   229→            # Apply hive weight to confidence\n   230→            raw_conf = entry.get(\"confidence\", 0.6)\n   231→            conf = float(raw_conf) if isinstance(raw_conf, (int, float)) else 0.6\n   232→            hive_memories.append(\n   233→                {\n   234→                    \"key\": key,\n   235→                    \"confidence\": round(conf * self._hive_recall_weight, 4),\n   236→                    \"tier\": entry.get(\"tier\", \"pattern\"),\n   237→                    \"score\": round(conf * self._hive_recall_weight, 4),\n   238→                    \"source\": \"hive\",\n   239→                    \"namespace\": entry.get(\"namespace\", \"universal\"),\n   240→                    \"value\": entry.get(\"value\", \"\"),\n   241→                }\n   242→            )\n   243→\n   244→        return hive_memories, len(hive_memories)\n   245→\n   246→    @staticmethod\n   247→    def _merge_hive_results(\n   248→        local: list[dict[str, object]],\n   249→        hive: list[dict[str, object]],\n   250→    ) -> list[dict[str, object]]:\n   251→        \"\"\"Merge local and Hive results, sorted by score descending.\"\"\"\n   252→        merged = [*local, *hive]\n   253→\n   254→        def _score(m: dict[str, object]) -> float:\n   255→            raw = m.get(\"score\", 0.0)\n   256→            return float(raw) if isinstance(raw, (int, float)) else 0.0\n   257→\n   258→        merged.sort(key=_score, reverse=True)\n   259→        return merged\n   260→\n   261→    @staticmethod\n   262→    def _rebuild_section(memories: list[dict[str, object]]) -> str:\n   263→        \"\"\"Rebuild the formatted memory section from merged results.\"\"\"\n   264→        if not memories:\n   265→            return \"\"\n   266→        lines = [\"### Project Memory\"]\n   267→        for mem in memories:\n   268→            key = str(mem.get(\"key\", \"\"))\n   269→            raw_conf = mem.get(\"confidence\", 0.0)\n   270→            conf = float(raw_conf) if isinstance(raw_conf, (int, float)) else 0.0\n   271→            tier = str(mem.get(\"tier\", \"pattern\"))\n   272→            value = str(mem.get(\"value\", key))\n   273→            src = str(mem.get(\"source\", \"local\"))\n   274→            origin = f\" [hive:{mem.get('namespace', '')}]\" if src == \"hive\" else \"\"\n   275→            lines.append(f\"- **{key}** (confidence: {conf:.2f}, tier: {tier}{origin}): {value}\")\n   276→        return \"\\n\".join(lines)\n   277→\n   278→    def _apply_graph_boost(\n   279→        self,\n   280→        memories: list[dict[str, object]],\n   281→        boost_factor: float,\n   282→    ) -> list[dict[str, object]]:\n   283→        \"\"\"Boost scores of memories connected via the relation graph.\n   284→\n   285→        For each memory in the result set, find graph-connected entries.\n   286→        If a connected entry is also in the result set, boost its score\n   287→        by *boost_factor* (additive, capped at 1.0).  The boosted list\n   288→        is re-sorted by descending score.\n   289→        \"\"\"\n   290→        result_keys = {str(m.get(\"key\", \"\")) for m in memories}\n   291→        # Collect all graph-connected keys and their hop distances\n   292→        connected: dict[str, int] = {}\n   293→        for mem in memories:\n   294→            key = str(mem.get(\"key\", \"\"))\n   295→            if not key:\n   296→                continue\n   297→            try:\n   298→                related = self._store.find_related(key, max_hops=2)\n   299→            except KeyError:\n   300→                continue\n   301→            for rel_key, hop in related:\n   302→                if rel_key in result_keys and (\n   303→                    rel_key not in connected or hop < connected[rel_key]\n   304→                ):\n   305→                    connected[rel_key] = hop\n   306→\n   307→        if not connected:\n   308→            return memories\n   309→\n   310→        # Apply boost: closer hops get more boost\n   311→        boosted: list[dict[str, object]] = []\n   312→        for mem in memories:\n   313→            key = str(mem.get(\"key\", \"\"))\n   314→            if key in connected:\n   315→                hop = connected[key]\n   316→                # Boost inversely proportional to hop distance\n   317→                hop_boost = boost_factor / hop\n   318→                raw_score = mem.get(\"score\", 0.0)\n   319→                score = float(raw_score) if isinstance(raw_score, (int, float)) else 0.0\n   320→                new_score = min(score + hop_boost, 1.0)\n   321→                mem = {**mem, \"score\": new_score, \"graph_boosted\": True}\n   322→            boosted.append(mem)\n   323→\n   324→        # Re-sort by score descending\n   325→        def _score(m: dict[str, object]) -> float:\n   326→            raw = m.get(\"score\", 0.0)\n   327→            return float(raw) if isinstance(raw, (int, float)) else 0.0\n   328→\n   329→        boosted.sort(key=_score, reverse=True)\n   330→        return boosted\n   331→\n   332→    def _effective_config(self, overrides: dict[str, object]) -> RecallConfig:\n   333→        \"\"\"Build effective config by merging base config with per-call overrides.\"\"\"\n   334→        if not overrides:\n   335→            return self._config\n   336→\n   337→        vals: dict[str, object] = {\n   338→            \"engagement_level\": self._config.engagement_level,\n   339→            \"max_tokens\": self._config.max_tokens,\n   340→            \"min_score\": self._config.min_score,\n   341→            \"min_confidence\": self._config.min_confidence,\n   342→            \"scope_filter\": self._config.scope_filter,\n   343→            \"tier_filter\": self._config.tier_filter,\n   344→            \"branch\": self._config.branch,\n   345→            \"dedupe_window\": list(self._config.dedupe_window),\n   346→            \"use_graph_boost\": self._config.use_graph_boost,\n   347→            \"graph_boost_factor\": self._config.graph_boost_factor,\n   348→        }\n   349→        for k, v in overrides.items():\n   350→            if k in vals:\n   351→                vals[k] = v\n   352→        return RecallConfig(**vals)  # type: ignore[arg-type]\n   353→\n   354→    def _needs_post_filter(self, cfg: RecallConfig) -> bool:\n   355→        \"\"\"Check whether any post-filter is active.\"\"\"\n   356→        return bool(cfg.scope_filter or cfg.tier_filter or cfg.branch or cfg.dedupe_window)\n   357→\n   358→    def _apply_post_filters(\n   359→        self,\n   360→        memories: list[dict[str, object]],\n   361→        cfg: RecallConfig,\n   362→        message: str,\n   363→    ) -> tuple[list[dict[str, object]], str]:\n   364→        \"\"\"Filter memories by scope/tier/branch/dedupe and rebuild the section.\n   365→\n   366→        When post-filters remove memories, the formatted section is rebuilt\n   367→        from the remaining entries to keep them in sync.\n   368→        \"\"\"\n   369→        dedupe_set = set(cfg.dedupe_window)\n   370→        filtered: list[dict[str, object]] = []\n   371→\n   372→        for mem in memories:\n   373→            key = str(mem.get(\"key\", \"\"))\n   374→\n   375→            # Dedupe\n   376→            if key in dedupe_set:\n   377→                continue\n   378→\n   379→            # Scope filter: look up entry in store\n   380→            if cfg.scope_filter or cfg.tier_filter or cfg.branch:\n   381→                entry = self._store.get(key) if key else None\n   382→                if entry is None:\n   383→                    # Entry not found — keep the memory (defensive)\n   384→                    filtered.append(mem)\n   385→                    continue\n   386→\n   387→                if cfg.scope_filter and entry.scope != cfg.scope_filter:\n   388→                    continue\n   389→                if cfg.tier_filter and entry.tier != cfg.tier_filter:\n   390→                    continue\n   391→                if cfg.branch and entry.scope == MemoryScope.branch and entry.branch != cfg.branch:\n   392→                    continue\n   393→\n   394→            filtered.append(mem)\n   395→\n   396→        # Rebuild section from filtered memories\n   397→        if not filtered:\n   398→            return [], \"\"\n   399→\n   400→        lines = [\"### Project Memory\"]\n   401→        for mem in filtered:\n   402→            key = str(mem.get(\"key\", \"\"))\n   403→            raw_conf = mem.get(\"confidence\", 0.0)\n   404→            conf = float(raw_conf) if isinstance(raw_conf, (int, float, str)) else 0.0\n   405→            tier = str(mem.get(\"tier\", \"pattern\"))\n   406→            # Look up value from store for the section\n   407→            entry = self._store.get(str(key)) if key else None\n   408→            value = entry.value if entry else str(key)\n   409→            lines.append(f\"- **{key}** (confidence: {conf:.2f}, tier: {tier}): {value}\")\n   410→\n   411→        return filtered, \"\\n\".join(lines)\n   412→"}]},"parent_tool_use_id":"toolu_01KJomf8MxPhmjTE3TX6wPks","session_id":"327621aa-924c-4bfb-b348-3a4acf890b54","uuid":"23938282-1d1e-435e-ac85-f8119096b838","timestamp":"2026-03-22T22:37:59.504Z"}
