{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XipfxesQVEGtR5cRLDizew","type":"tool_result","content":"     1→\"\"\"Tests for auto-recall protocols and models (EPIC-003).\"\"\"\n     2→\n     3→from __future__ import annotations\n     4→\n     5→import threading\n     6→from typing import Any\n     7→\n     8→import pytest\n     9→\n    10→from tapps_brain._protocols import CaptureHookLike, RecallHookLike\n    11→from tapps_brain.models import MemoryScope, MemoryTier, RecallResult\n    12→from tapps_brain.recall import RecallConfig, RecallOrchestrator\n    13→from tapps_brain.store import MemoryStore\n    14→\n    15→# ---------------------------------------------------------------------------\n    16→# STORY-003.1: Protocol and model tests\n    17→# ---------------------------------------------------------------------------\n    18→\n    19→\n    20→class TestRecallResult:\n    21→    \"\"\"Tests for RecallResult model.\"\"\"\n    22→\n    23→    def test_empty_result(self) -> None:\n    24→        result = RecallResult()\n    25→        assert result.memory_section == \"\"\n    26→        assert result.memories == []\n    27→        assert result.token_count == 0\n    28→        assert result.recall_time_ms == 0.0\n    29→        assert result.truncated is False\n    30→        assert result.memory_count == 0\n    31→\n    32→    def test_populated_result(self) -> None:\n    33→        memories = [\n    34→            {\n    35→                \"key\": \"tech-stack\",\n    36→                \"confidence\": 0.9,\n    37→                \"tier\": \"architectural\",\n    38→                \"score\": 0.8,\n    39→                \"stale\": False,\n    40→            }\n    41→        ]\n    42→        result = RecallResult(\n    43→            memory_section=\"### Project Memory\\n- **tech-stack**: We use Python\",\n    44→            memories=memories,\n    45→            token_count=42,\n    46→            recall_time_ms=3.5,\n    47→            truncated=False,\n    48→            memory_count=1,\n    49→        )\n    50→        assert result.memory_section.startswith(\"### Project Memory\")\n    51→        assert len(result.memories) == 1\n    52→        assert result.token_count == 42\n    53→        assert result.recall_time_ms == 3.5\n    54→        assert result.memory_count == 1\n    55→\n    56→    def test_serialization_round_trip(self) -> None:\n    57→        result = RecallResult(\n    58→            memory_section=\"test\",\n    59→            memories=[{\"key\": \"k1\"}],\n    60→            token_count=10,\n    61→            recall_time_ms=1.0,\n    62→            memory_count=1,\n    63→        )\n    64→        data = result.model_dump()\n    65→        restored = RecallResult.model_validate(data)\n    66→        assert restored == result\n    67→\n    68→\n    69→class _StubRecallHook:\n    70→    \"\"\"Minimal stub that satisfies RecallHookLike.\"\"\"\n    71→\n    72→    def recall(self, message: str, **kwargs: Any) -> RecallResult:\n    73→        return RecallResult(memory_section=f\"recalled: {message}\", memory_count=0)\n    74→\n    75→\n    76→class _StubCaptureHook:\n    77→    \"\"\"Minimal stub that satisfies CaptureHookLike.\"\"\"\n    78→\n    79→    def capture(self, response: str, **kwargs: Any) -> list[str]:\n    80→        return [\"key-1\"]\n    81→\n    82→\n    83→class TestRecallHookProtocol:\n    84→    \"\"\"Tests for RecallHookLike protocol structural subtyping.\"\"\"\n    85→\n    86→    def test_stub_satisfies_protocol(self) -> None:\n    87→        hook = _StubRecallHook()\n    88→        assert isinstance(hook, RecallHookLike)\n    89→\n    90→    def test_stub_is_callable(self) -> None:\n    91→        hook = _StubRecallHook()\n    92→        result = hook.recall(\"hello\")\n    93→        assert isinstance(result, RecallResult)\n    94→        assert result.memory_section == \"recalled: hello\"\n    95→\n    96→\n    97→class TestCaptureHookProtocol:\n    98→    \"\"\"Tests for CaptureHookLike protocol structural subtyping.\"\"\"\n    99→\n   100→    def test_stub_satisfies_protocol(self) -> None:\n   101→        hook = _StubCaptureHook()\n   102→        assert isinstance(hook, CaptureHookLike)\n   103→\n   104→    def test_stub_is_callable(self) -> None:\n   105→        hook = _StubCaptureHook()\n   106→        keys = hook.capture(\"some response\")\n   107→        assert keys == [\"key-1\"]\n   108→\n   109→    def test_non_conforming_object_rejected(self) -> None:\n   110→        class _Bad:\n   111→            pass\n   112→\n   113→        assert not isinstance(_Bad(), RecallHookLike)\n   114→        assert not isinstance(_Bad(), CaptureHookLike)\n   115→\n   116→\n   117→# ---------------------------------------------------------------------------\n   118→# STORY-003.2: RecallOrchestrator tests\n   119→# ---------------------------------------------------------------------------\n   120→\n   121→\n   122→@pytest.fixture()\n   123→def store(tmp_path):\n   124→    \"\"\"Create a MemoryStore with sample entries.\"\"\"\n   125→    s = MemoryStore(tmp_path)\n   126→    s.save(\n   127→        key=\"tech-stack\",\n   128→        value=\"We use Python 3.12 with FastAPI\",\n   129→        tier=\"architectural\",\n   130→        source=\"human\",\n   131→    )\n   132→    s.save(\n   133→        key=\"test-framework\", value=\"We use pytest for all testing\", tier=\"pattern\", source=\"human\"\n   134→    )\n   135→    s.save(\n   136→        key=\"deploy-target\",\n   137→        value=\"We deploy to AWS ECS Fargate\",\n   138→        tier=\"architectural\",\n   139→        source=\"agent\",\n   140→    )\n   141→    s.save(\n   142→        key=\"session-note\",\n   143→        value=\"Discussed refactoring the auth module\",\n   144→        tier=\"context\",\n   145→        source=\"agent\",\n   146→        scope=\"session\",\n   147→    )\n   148→    s.save(\n   149→        key=\"branch-feature\",\n   150→        value=\"Working on feature-x branch auth rewrite\",\n   151→        tier=\"context\",\n   152→        source=\"agent\",\n   153→        scope=\"branch\",\n   154→        branch=\"feature-x\",\n   155→    )\n   156→    return s\n   157→\n   158→\n   159→class TestRecallOrchestrator:\n   160→    \"\"\"Tests for RecallOrchestrator.recall().\"\"\"\n   161→\n   162→    def test_recall_returns_result(self, store):\n   163→        orch = RecallOrchestrator(store)\n   164→        result = orch.recall(\"what is our tech stack?\")\n   165→        assert isinstance(result, RecallResult)\n   166→        assert result.recall_time_ms > 0\n   167→\n   168→    def test_recall_finds_relevant_memories(self, store):\n   169→        orch = RecallOrchestrator(store)\n   170→        result = orch.recall(\"python tech stack\")\n   171→        assert result.memory_count > 0\n   172→        assert result.memory_section != \"\"\n   173→\n   174→    def test_recall_empty_message_returns_empty(self, store):\n   175→        orch = RecallOrchestrator(store)\n   176→        result = orch.recall(\"\")\n   177→        assert result.memory_count == 0\n   178→        assert result.memory_section == \"\"\n   179→\n   180→    def test_recall_no_matches_returns_empty(self, store):\n   181→        orch = RecallOrchestrator(store)\n   182→        result = orch.recall(\"quantum computing blockchain\")\n   183→        assert result.memory_count == 0\n   184→\n   185→    def test_recall_low_engagement_returns_empty(self, store):\n   186→        cfg = RecallConfig(engagement_level=\"low\")\n   187→        orch = RecallOrchestrator(store, config=cfg)\n   188→        result = orch.recall(\"tech stack\")\n   189→        assert result.memory_count == 0\n   190→\n   191→    def test_recall_respects_dedupe_window(self, store):\n   192→        cfg = RecallConfig(dedupe_window=[\"tech-stack\"])\n   193→        orch = RecallOrchestrator(store, config=cfg)\n   194→        result = orch.recall(\"python tech stack\")\n   195→        keys = [m.get(\"key\") for m in result.memories]\n   196→        assert \"tech-stack\" not in keys\n   197→\n   198→    def test_recall_respects_scope_filter(self, store):\n   199→        cfg = RecallConfig(scope_filter=MemoryScope.project)\n   200→        orch = RecallOrchestrator(store, config=cfg)\n   201→        result = orch.recall(\"auth module refactoring session\")\n   202→        keys = [m.get(\"key\") for m in result.memories]\n   203→        assert \"session-note\" not in keys\n   204→\n   205→    def test_recall_respects_tier_filter(self, store):\n   206→        cfg = RecallConfig(tier_filter=MemoryTier.architectural)\n   207→        orch = RecallOrchestrator(store, config=cfg)\n   208→        result = orch.recall(\"python testing deploy\")\n   209→        keys = [m.get(\"key\") for m in result.memories]\n   210→        # Only architectural entries should remain\n   211→        for key in keys:\n   212→            entry = store.get(key)\n   213→            if entry:\n   214→                assert entry.tier == MemoryTier.architectural\n   215→\n   216→    def test_recall_respects_branch_filter(self, store):\n   217→        cfg = RecallConfig(branch=\"feature-x\")\n   218→        orch = RecallOrchestrator(store, config=cfg)\n   219→        result = orch.recall(\"auth rewrite branch feature\")\n   220→        # branch-scoped entries for other branches should be excluded\n   221→        keys = [m.get(\"key\") for m in result.memories]\n   222→        for key in keys:\n   223→            entry = store.get(key)\n   224→            if entry and entry.scope == MemoryScope.branch:\n   225→                assert entry.branch == \"feature-x\"\n   226→\n   227→    def test_recall_token_budget_enforced(self, store):\n   228→        cfg = RecallConfig(max_tokens=10)  # Very small budget\n   229→        orch = RecallOrchestrator(store, config=cfg)\n   230→        result = orch.recall(\"python tech stack testing deploy\")\n   231→        # With a 10-token budget, at most 1 entry can fit\n   232→        assert result.memory_count <= 1\n   233→\n   234→    def test_recall_per_call_override(self, store):\n   235→        orch = RecallOrchestrator(store)\n   236→        result = orch.recall(\"tech stack\", engagement_level=\"low\")\n   237→        assert result.memory_count == 0\n   238→\n   239→    def test_recall_thread_safety(self, store):\n   240→        orch = RecallOrchestrator(store)\n   241→        results = []\n   242→        errors = []\n   243→\n   244→        def do_recall(msg):\n   245→            try:\n   246→                r = orch.recall(msg)\n   247→                results.append(r)\n   248→            except Exception as e:\n   249→                errors.append(e)\n   250→\n   251→        threads = [threading.Thread(target=do_recall, args=(f\"query {i}\",)) for i in range(5)]\n   252→        for t in threads:\n   253→            t.start()\n   254→        for t in threads:\n   255→            t.join()\n   256→\n   257→        assert len(errors) == 0\n   258→        assert len(results) == 5\n   259→        for r in results:\n   260→            assert isinstance(r, RecallResult)\n   261→\n   262→    def test_orchestrator_satisfies_recall_hook_protocol(self, store):\n   263→        orch = RecallOrchestrator(store)\n   264→        assert isinstance(orch, RecallHookLike)\n   265→\n   266→\n   267→# ---------------------------------------------------------------------------\n   268→# STORY-003.3: Capture pipeline tests\n   269→# ---------------------------------------------------------------------------\n   270→\n   271→\n   272→class TestCapturePipeline:\n   273→    \"\"\"Tests for RecallOrchestrator.capture().\"\"\"\n   274→\n   275→    def test_capture_extracts_facts(self, store):\n   276→        orch = RecallOrchestrator(store)\n   277→        response = (\n   278→            \"We decided to use PostgreSQL for the database layer.\"\n   279→            \" Key decision: all APIs must be versioned.\"\n   280→        )\n   281→        keys = orch.capture(response)\n   282→        assert len(keys) > 0\n   283→        # Verify entries exist in store\n   284→        for key in keys:\n   285→            entry = store.get(key)\n   286→            assert entry is not None\n   287→\n   288→    def test_capture_empty_response(self, store):\n   289→        orch = RecallOrchestrator(store)\n   290→        keys = orch.capture(\"\")\n   291→        assert keys == []\n   292→\n   293→    def test_capture_whitespace_response(self, store):\n   294→        orch = RecallOrchestrator(store)\n   295→        keys = orch.capture(\"   \\n  \")\n   296→        assert keys == []\n   297→\n   298→    def test_capture_no_duplicates(self, store):\n   299→        orch = RecallOrchestrator(store)\n   300→        response = \"We decided to use Redis for caching.\""}]},"parent_tool_use_id":"toolu_01KJomf8MxPhmjTE3TX6wPks","session_id":"327621aa-924c-4bfb-b348-3a4acf890b54","uuid":"c40637ee-1ada-48ba-8f84-1b0235b3000b","timestamp":"2026-03-22T22:38:20.356Z"}
