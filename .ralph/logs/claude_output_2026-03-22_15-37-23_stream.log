{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NH68Jn3gyNS9sFURZ4h977","type":"tool_result","content":"     1→\"\"\"Integration tests for knowledge graph lifecycle (EPIC-006, STORY-006.6).\n     2→\n     3→All tests use a real MemoryStore + SQLite (no mocks). Covers:\n     4→- Save entries with relations, close/reopen, verify persistence\n     5→- find_related traversal across reopened store\n     6→- Relation transfer on supersede\n     7→- Graph-based recall boost ranking\n     8→\"\"\"\n     9→\n    10→from __future__ import annotations\n    11→\n    12→import pytest\n    13→\n    14→from tapps_brain.models import RecallResult\n    15→from tapps_brain.recall import RecallConfig, RecallOrchestrator\n    16→from tapps_brain.store import MemoryStore\n    17→\n    18→\n    19→@pytest.fixture()\n    20→def graph_store(tmp_path):\n    21→    \"\"\"Create a store with relation-rich entries on real SQLite.\"\"\"\n    22→    store = MemoryStore(tmp_path)\n    23→    # \"X uses/manages Y\" patterns produce relations via extract_relations\n    24→    store.save(key=\"svc-auth\", value=\"AuthService uses TokenStore\", tier=\"architectural\")\n    25→    store.save(key=\"svc-api\", value=\"ApiGateway uses AuthService\", tier=\"architectural\")\n    26→    store.save(key=\"svc-cache\", value=\"CacheLayer manages TokenStore\", tier=\"pattern\")\n    27→    store.save(key=\"svc-db\", value=\"DatabaseLayer manages DataStore\", tier=\"architectural\")\n    28→    store.save(key=\"plain-note\", value=\"Remember to update docs\", tier=\"context\")\n    29→    return store\n    30→\n    31→\n    32→class TestGraphPersistenceRoundTrip:\n    33→    \"\"\"Relations survive close/reopen on real SQLite.\"\"\"\n    34→\n    35→    def test_relations_persist_across_restart(self, tmp_path):\n    36→        store1 = MemoryStore(tmp_path)\n    37→        store1.save(key=\"a\", value=\"ServiceA uses ServiceB\", tier=\"architectural\")\n    38→        rels_before = store1.get_relations(\"a\")\n    39→        assert len(rels_before) >= 1\n    40→        store1.close()\n    41→\n    42→        store2 = MemoryStore(tmp_path)\n    43→        rels_after = store2.get_relations(\"a\")\n    44→        assert len(rels_after) >= 1\n    45→        assert rels_after[0][\"subject\"].lower() == rels_before[0][\"subject\"].lower()\n    46→        store2.close()\n    47→\n    48→    def test_find_related_after_restart(self, tmp_path):\n    49→        store1 = MemoryStore(tmp_path)\n    50→        store1.save(key=\"x\", value=\"ServiceX uses ServiceY\")\n    51→        store1.save(key=\"y\", value=\"ServiceY manages DataStore\")\n    52→        related_before = store1.find_related(\"x\")\n    53→        assert len(related_before) >= 1\n    54→        store1.close()\n    55→\n    56→        store2 = MemoryStore(tmp_path)\n    57→        related_after = store2.find_related(\"x\")\n    58→        keys_after = [k for k, _h in related_after]\n    59→        assert \"y\" in keys_after\n    60→        store2.close()\n    61→\n    62→    def test_query_relations_after_restart(self, tmp_path):\n    63→        store1 = MemoryStore(tmp_path)\n    64→        store1.save(key=\"m\", value=\"ModuleA uses ModuleB\")\n    65→        qr_before = store1.query_relations(predicate=\"uses\")\n    66→        assert len(qr_before) >= 1\n    67→        store1.close()\n    68→\n    69→        store2 = MemoryStore(tmp_path)\n    70→        qr_after = store2.query_relations(predicate=\"uses\")\n    71→        assert len(qr_after) >= 1\n    72→        store2.close()\n    73→\n    74→\n    75→class TestGraphTraversal:\n    76→    \"\"\"BFS traversal works correctly on real SQLite data.\"\"\"\n    77→\n    78→    def test_multi_hop_traversal(self, graph_store):\n    79→        \"\"\"AuthService -> TokenStore -> CacheLayer is a 2-hop chain.\"\"\"\n    80→        related = graph_store.find_related(\"svc-auth\")\n    81→        hop_map = dict(related)\n    82→        # svc-api shares \"AuthService\" -> hop 1\n    83→        assert hop_map.get(\"svc-api\") == 1\n    84→        # svc-cache shares \"TokenStore\" -> hop 1 or 2\n    85→        assert \"svc-cache\" in hop_map\n    86→\n    87→    def test_plain_entry_not_connected(self, graph_store):\n    88→        \"\"\"Entry without relations is not connected to others.\"\"\"\n    89→        related = graph_store.find_related(\"plain-note\")\n    90→        assert related == []\n    91→\n    92→    def test_query_relations_filters(self, graph_store):\n    93→        \"\"\"query_relations filters by predicate correctly.\"\"\"\n    94→        uses_rels = graph_store.query_relations(predicate=\"uses\")\n    95→        manages_rels = graph_store.query_relations(predicate=\"manages\")\n    96→        assert len(uses_rels) >= 2  # auth->token, api->auth\n    97→        assert len(manages_rels) >= 1  # cache->token or db->datastore\n    98→\n    99→\n   100→class TestSupersedeRelationTransfer:\n   101→    \"\"\"Supersede transfers relations on real SQLite.\"\"\"\n   102→\n   103→    def test_supersede_carries_relations(self, graph_store):\n   104→        old_rels = graph_store.get_relations(\"svc-auth\")\n   105→        assert len(old_rels) >= 1\n   106→\n   107→        new_entry = graph_store.supersede(\"svc-auth\", \"AuthService v2 uses TokenStore\")\n   108→        new_rels = graph_store.get_relations(new_entry.key)\n   109→        # New entry should have at least the old relations\n   110→        old_subjects = {r[\"subject\"].lower() for r in old_rels}\n   111→        new_subjects = {r[\"subject\"].lower() for r in new_rels}\n   112→        assert old_subjects.issubset(new_subjects)\n   113→\n   114→    def test_supersede_relations_persist_after_restart(self, tmp_path):\n   115→        store1 = MemoryStore(tmp_path)\n   116→        store1.save(key=\"fact-1\", value=\"ServiceP uses ServiceQ\", tier=\"architectural\")\n   117→        new = store1.supersede(\"fact-1\", \"ServiceP v2 uses ServiceQ\", key=\"fact-1.v2\")\n   118→        rels = store1.get_relations(new.key)\n   119→        assert len(rels) >= 1\n   120→        store1.close()\n   121→\n   122→        store2 = MemoryStore(tmp_path)\n   123→        rels_after = store2.get_relations(\"fact-1.v2\")\n   124→        assert len(rels_after) >= 1\n   125→        store2.close()\n   126→\n   127→    def test_find_related_follows_superseded_entry(self, tmp_path):\n   128→        \"\"\"After supersede, the new entry is reachable via graph.\"\"\"\n   129→        store = MemoryStore(tmp_path)\n   130→        store.save(key=\"comp-a\", value=\"ComponentA uses ComponentB\")\n   131→        store.save(key=\"comp-b\", value=\"ComponentB manages DataLayer\")\n   132→        new = store.supersede(\"comp-a\", \"ComponentA v2 uses ComponentB\", key=\"comp-a-v2\")\n   133→\n   134→        related = store.find_related(new.key)\n   135→        keys = [k for k, _h in related]\n   136→        assert \"comp-b\" in keys\n   137→        store.close()\n   138→\n   139→\n   140→class TestRecallGraphBoost:\n   141→    \"\"\"Graph boost affects ranking in real recall flow.\"\"\"\n   142→\n   143→    def test_graph_boost_returns_result(self, graph_store):\n   144→        cfg = RecallConfig(use_graph_boost=True, graph_boost_factor=0.2)\n   145→        orch = RecallOrchestrator(graph_store, config=cfg)\n   146→        result = orch.recall(\"AuthService TokenStore\")\n   147→        assert isinstance(result, RecallResult)\n   148→\n   149→    def test_graph_boost_does_not_crash_on_empty(self, tmp_path):\n   150→        \"\"\"Graph boost on empty store returns empty result.\"\"\"\n   151→        store = MemoryStore(tmp_path)\n   152→        cfg = RecallConfig(use_graph_boost=True)\n   153→        orch = RecallOrchestrator(store, config=cfg)\n   154→        result = orch.recall(\"anything\")\n   155→        assert isinstance(result, RecallResult)\n   156→        assert result.memory_count == 0\n   157→        store.close()\n   158→\n   159→    def test_boosted_scores_gte_unboosted(self, graph_store):\n   160→        \"\"\"With graph boost, connected entries have scores >= unboosted.\"\"\"\n   161→        orch_plain = RecallOrchestrator(graph_store)\n   162→        result_plain = orch_plain.recall(\"AuthService TokenStore ApiGateway\")\n   163→\n   164→        cfg = RecallConfig(use_graph_boost=True, graph_boost_factor=0.2)\n   165→        orch_boost = RecallOrchestrator(graph_store, config=cfg)\n   166→        result_boost = orch_boost.recall(\"AuthService TokenStore ApiGateway\")\n   167→\n   168→        scores_plain = {\n   169→            str(m.get(\"key\", \"\")): float(m.get(\"score\", 0)) for m in result_plain.memories\n   170→        }\n   171→        for mem in result_boost.memories:\n   172→            key = str(mem.get(\"key\", \"\"))\n   173→            if mem.get(\"graph_boosted\") and key in scores_plain:\n   174→                assert float(mem.get(\"score\", 0)) >= scores_plain[key]\n   175→"}]},"parent_tool_use_id":"toolu_01KJomf8MxPhmjTE3TX6wPks","session_id":"327621aa-924c-4bfb-b348-3a4acf890b54","uuid":"f1a42133-8701-4c22-96d8-25637b675d3a","timestamp":"2026-03-22T22:38:03.245Z"}
