{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JizByGdvS7Pe2WnBc1caUX","type":"tool_result","content":"     1→\"\"\"Entity/Relationship extraction from memory entries (Epic 65.12).\n     2→\n     3→Rule-based, deterministic extraction of subject-predicate-object triples\n     4→from memory entry values. No LLM calls -- uses regex patterns to identify\n     5→common relationship verbs and their arguments.\n     6→\"\"\"\n     7→\n     8→from __future__ import annotations\n     9→\n    10→import re\n    11→from datetime import UTC, datetime\n    12→from typing import TYPE_CHECKING, ClassVar\n    13→\n    14→import structlog\n    15→from pydantic import BaseModel, Field\n    16→\n    17→if TYPE_CHECKING:\n    18→    from tapps_brain.models import MemoryEntry\n    19→\n    20→logger = structlog.get_logger()\n    21→\n    22→# ---------------------------------------------------------------------------\n    23→# Helpers\n    24→# ---------------------------------------------------------------------------\n    25→\n    26→\n    27→def _utc_now_iso() -> str:\n    28→    \"\"\"Return the current UTC time as an ISO-8601 string.\"\"\"\n    29→    return datetime.now(tz=UTC).isoformat()\n    30→\n    31→\n    32→# ---------------------------------------------------------------------------\n    33→# Model\n    34→# ---------------------------------------------------------------------------\n    35→\n    36→\n    37→class RelationEntry(BaseModel):\n    38→    \"\"\"A subject-predicate-object triple extracted from memory content.\"\"\"\n    39→\n    40→    subject: str = Field(description=\"The entity performing the action.\")\n    41→    predicate: str = Field(description=\"The relationship verb.\")\n    42→    object_entity: str = Field(\n    43→        description=\"The entity being acted upon (named to avoid Python keyword).\"\n    44→    )\n    45→    source_entry_keys: list[str] = Field(\n    46→        default_factory=list,\n    47→        description=\"Memory entry keys this relation was extracted from.\",\n    48→    )\n    49→    confidence: float = Field(default=0.8, ge=0.0, le=1.0, description=\"Extraction confidence.\")\n    50→    created_at: str = Field(default_factory=_utc_now_iso, description=\"ISO-8601 UTC creation time.\")\n    51→\n    52→    # -- Constants ----------------------------------------------------------\n    53→    MAX_RELATIONS_PER_ENTRY: ClassVar[int] = 5\n    54→    MIN_ENTITY_LENGTH: ClassVar[int] = 2\n    55→\n    56→\n    57→# ---------------------------------------------------------------------------\n    58→# Regex patterns for relationship extraction\n    59→# ---------------------------------------------------------------------------\n    60→\n    61→# Each pattern captures (subject, predicate_label, object_entity).\n    62→# Group 1 = subject (greedy, up to the verb), Group 2 = object (up to\n    63→# sentence boundary).  The predicate is the label string.\n    64→#\n    65→# Subject: 1-6 words before the verb.\n    66→# Object: 1-8 words after the verb, stopping at sentence punctuation.\n    67→# Words are alpha-start tokens of 1+ word chars (letters, digits, underscore).\n    68→# Dots/slashes excluded so sentence boundaries terminate matches naturally.\n    69→_WORD = r\"[A-Za-z]\\w*\"\n    70→_SUBJ = r\"((?:\" + _WORD + r\"\\s+){0,5}\" + _WORD + r\")\"\n    71→_OBJ = r\"(\" + _WORD + r\"(?:\\s+\" + _WORD + r\"){0,7})\"\n    72→\n    73→_RELATION_PATTERNS: list[tuple[re.Pattern[str], str]] = [\n    74→    (re.compile(_SUBJ + r\"\\s+manages\\s+\" + _OBJ, re.I), \"manages\"),\n    75→    (re.compile(_SUBJ + r\"\\s+owns\\s+\" + _OBJ, re.I), \"owns\"),\n    76→    (re.compile(_SUBJ + r\"\\s+handles\\s+\" + _OBJ, re.I), \"handles\"),\n    77→    (re.compile(_SUBJ + r\"\\s+uses\\s+\" + _OBJ, re.I), \"uses\"),\n    78→    (re.compile(_SUBJ + r\"\\s+depends\\s+on\\s+\" + _OBJ, re.I), \"depends on\"),\n    79→    (re.compile(_SUBJ + r\"\\s+creates\\s+\" + _OBJ, re.I), \"creates\"),\n    80→    (re.compile(_SUBJ + r\"\\s+provides\\s+\" + _OBJ, re.I), \"provides\"),\n    81→]\n    82→\n    83→# Query patterns that indicate relationship lookups\n    84→_QUERY_PATTERNS: list[tuple[re.Pattern[str], str | None]] = [\n    85→    (re.compile(r\"(?:who|what)\\s+handles\\s+(.+)\", re.I), \"handles\"),\n    86→    (re.compile(r\"(?:who|what)\\s+manages\\s+(.+)\", re.I), \"manages\"),\n    87→    (re.compile(r\"(?:who|what)\\s+owns\\s+(.+)\", re.I), \"owns\"),\n    88→    (re.compile(r\"(?:who|what)\\s+uses\\s+(.+)\", re.I), \"uses\"),\n    89→    (re.compile(r\"(?:who|what)\\s+creates\\s+(.+)\", re.I), \"creates\"),\n    90→    (re.compile(r\"(?:who|what)\\s+provides\\s+(.+)\", re.I), \"provides\"),\n    91→    (re.compile(r\"(?:who|what)\\s+depends\\s+on\\s+(.+)\", re.I), \"depends on\"),\n    92→]\n    93→\n    94→# Max hops for relationship traversal\n    95→_MAX_HOPS: int = 2\n    96→\n    97→\n    98→# ---------------------------------------------------------------------------\n    99→# Extraction helpers\n   100→# ---------------------------------------------------------------------------\n   101→\n   102→\n   103→def _clean_entity(raw: str) -> str:\n   104→    \"\"\"Normalize an extracted entity string.\"\"\"\n   105→    # Strip leading/trailing whitespace and common noise\n   106→    cleaned = raw.strip().strip(\".,;:!?\\\"'\")\n   107→    # Collapse internal whitespace\n   108→    cleaned = re.sub(r\"\\s+\", \" \", cleaned)\n   109→    return cleaned\n   110→\n   111→\n   112→# ---------------------------------------------------------------------------\n   113→# Public API\n   114→# ---------------------------------------------------------------------------\n   115→\n   116→\n   117→def extract_relations(entry_key: str, value: str) -> list[RelationEntry]:\n   118→    \"\"\"Extract entity-relationship triples from a single memory value.\n   119→\n   120→    Uses rule-based regex patterns to find subject-predicate-object triples.\n   121→    Returns at most ``RelationEntry.MAX_RELATIONS_PER_ENTRY`` relations.\n   122→\n   123→    Args:\n   124→        entry_key: The memory entry key (for provenance tracking).\n   125→        value: The text content to extract relations from.\n   126→\n   127→    Returns:\n   128→        List of ``RelationEntry`` objects (max 5).\n   129→    \"\"\"\n   130→    if not value or not value.strip():\n   131→        return []\n   132→\n   133→    results: list[RelationEntry] = []\n   134→    seen_triples: set[tuple[str, str, str]] = set()\n   135→\n   136→    for pattern, predicate in _RELATION_PATTERNS:\n   137→        for match in pattern.finditer(value):\n   138→            subject = _clean_entity(match.group(1))\n   139→            obj = _clean_entity(match.group(2))\n   140→\n   141→            # Skip empty or trivially short entities\n   142→            if (\n   143→                len(subject) < RelationEntry.MIN_ENTITY_LENGTH\n   144→                or len(obj) < RelationEntry.MIN_ENTITY_LENGTH\n   145→            ):\n   146→                continue\n   147→\n   148→            triple_key = (subject.lower(), predicate.lower(), obj.lower())\n   149→            if triple_key in seen_triples:\n   150→                continue\n   151→            seen_triples.add(triple_key)\n   152→\n   153→            results.append(\n   154→                RelationEntry(\n   155→                    subject=subject,\n   156→                    predicate=predicate,\n   157→                    object_entity=obj,\n   158→                    source_entry_keys=[entry_key],\n   159→                    confidence=0.8,\n   160→                )\n   161→            )\n   162→\n   163→            if len(results) >= RelationEntry.MAX_RELATIONS_PER_ENTRY:\n   164→                break\n   165→\n   166→        if len(results) >= RelationEntry.MAX_RELATIONS_PER_ENTRY:\n   167→            break\n   168→\n   169→    logger.debug(\n   170→        \"relations.extracted\",\n   171→        entry_key=entry_key,\n   172→        count=len(results),\n   173→    )\n   174→    return results\n   175→\n   176→\n   177→def extract_relations_from_entries(\n   178→    entries: list[MemoryEntry],\n   179→) -> list[RelationEntry]:\n   180→    \"\"\"Extract and deduplicate relations from multiple memory entries.\n   181→\n   182→    Calls :func:`extract_relations` for each entry and deduplicates by\n   183→    the ``(subject, predicate, object_entity)`` triple, merging\n   184→    ``source_entry_keys`` when duplicates are found.\n   185→\n   186→    Args:\n   187→        entries: List of memory entries to process.\n   188→\n   189→    Returns:\n   190→        Deduplicated list of ``RelationEntry`` objects.\n   191→    \"\"\"\n   192→    # Map triple -> RelationEntry for dedup + provenance merge\n   193→    seen: dict[tuple[str, str, str], RelationEntry] = {}\n   194→\n   195→    for entry in entries:\n   196→        relations = extract_relations(entry.key, entry.value)\n   197→        for rel in relations:\n   198→            triple_key = (\n   199→                rel.subject.lower(),\n   200→                rel.predicate.lower(),\n   201→                rel.object_entity.lower(),\n   202→            )\n   203→            if triple_key in seen:\n   204→                existing = seen[triple_key]\n   205→                # Merge source keys (deduplicated)\n   206→                merged_keys = list(\n   207→                    dict.fromkeys(existing.source_entry_keys + rel.source_entry_keys)\n   208→                )\n   209→                seen[triple_key] = existing.model_copy(update={\"source_entry_keys\": merged_keys})\n   210→            else:\n   211→                seen[triple_key] = rel\n   212→\n   213→    result = list(seen.values())\n   214→    logger.debug(\n   215→        \"relations.extracted_from_entries\",\n   216→        entry_count=len(entries),\n   217→        relation_count=len(result),\n   218→    )\n   219→    return result\n   220→\n   221→\n   222→def expand_via_relations(\n   223→    query: str,\n   224→    relations: list[RelationEntry],\n   225→) -> list[str]:\n   226→    \"\"\"Expand a query using relationship graph traversal.\n   227→\n   228→    For queries like \"who handles X\" or \"what manages Y\", performs 1-hop\n   229→    and 2-hop traversal of the relation graph to find connected entities.\n   230→\n   231→    Args:\n   232→        query: The search query string.\n   233→        relations: Available relations to traverse.\n   234→\n   235→    Returns:\n   236→        List of additional query terms discovered via relations.\n   237→        Returns empty list if query doesn't match a relationship pattern.\n   238→    \"\"\"\n   239→    if not query or not relations:\n   240→        return []\n   241→\n   242→    # Try to match a relationship query pattern\n   243→    target_entity: str | None = None\n   244→    target_predicate: str | None = None\n   245→\n   246→    for pattern, predicate in _QUERY_PATTERNS:\n   247→        match = pattern.search(query)\n   248→        if match:\n   249→            target_entity = _clean_entity(match.group(1))\n   250→            target_predicate = predicate\n   251→            break\n   252→\n   253→    if target_entity is None:\n   254→        return []\n   255→\n   256→    target_lower = target_entity.lower()\n   257→    expanded: list[str] = []\n   258→    seen: set[str] = set()\n   259→\n   260→    # --- Hop 1: direct matches -------------------------------------------------\n   261→    hop1_subjects: list[str] = []\n   262→    for rel in relations:\n   263→        # Match predicate if we identified one, otherwise match any\n   264→        if target_predicate and rel.predicate.lower() != target_predicate:\n   265→            continue\n   266→\n   267→        # Object matches target -> subject is the answer\n   268→        if rel.object_entity.lower() == target_lower:\n   269→            subj = rel.subject\n   270→            if subj.lower() not in seen:\n   271→                seen.add(subj.lower())\n   272→                expanded.append(subj)\n   273→                hop1_subjects.append(subj)\n   274→\n   275→        # Subject matches target -> object is related\n   276→        if rel.subject.lower() == target_lower:\n   277→            obj = rel.object_entity\n   278→            if obj.lower() not in seen:\n   279→                seen.add(obj.lower())\n   280→                expanded.append(obj)\n   281→\n   282→    # --- Hop 2: entities related to hop-1 results ------------------------------\n   283→    for hop1_entity in hop1_subjects:\n   284→        hop1_lower = hop1_entity.lower()\n   285→        for rel in relations:\n   286→            # Find what hop1 entities are also connected to\n   287→            if rel.subject.lower() == hop1_lower:\n   288→                obj = rel.object_entity\n   289→                if obj.lower() not in seen and obj.lower() != target_lower:\n   290→                    seen.add(obj.lower())\n   291→                    expanded.append(obj)\n   292→            if rel.object_entity.lower() == hop1_lower:\n   293→                subj = rel.subject\n   294→                if subj.lower() not in seen and subj.lower() != target_lower:\n   295→                    seen.add(subj.lower())\n   296→                    expanded.append(subj)\n   297→\n   298→    logger.debug(\n   299→        \"relations.expanded_query\",\n   300→        query=query,\n   301→        target_entity=target_entity,\n   302→        target_predicate=target_predicate,\n   303→        expanded_count=len(expanded),\n   304→    )\n   305→    return expanded\n   306→"}]},"parent_tool_use_id":"toolu_01KJomf8MxPhmjTE3TX6wPks","session_id":"327621aa-924c-4bfb-b348-3a4acf890b54","uuid":"b2208c3f-e7d5-47be-88e2-e192ec373c1d","timestamp":"2026-03-22T22:37:59.298Z"}
