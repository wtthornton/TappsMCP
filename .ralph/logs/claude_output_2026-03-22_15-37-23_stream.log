{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M63YMB6pmCufuupUSbhYVs","type":"tool_result","content":"     1→\"\"\"Auto-recall orchestrator for pre-prompt memory injection (EPIC-003).\n     2→\n     3→Provides a ``RecallOrchestrator`` that accepts an incoming user message,\n     4→searches the memory store for relevant entries, and returns injection-ready\n     5→context. Delegates formatting, safety, and token budget enforcement to\n     6→``inject_memories()``.\n     7→\n     8→The orchestrator adds quality gates on top of injection:\n     9→- Scope / tier / branch filtering\n    10→- Deduplication against already-in-context memories\n    11→- Minimum confidence threshold\n    12→- Timing measurement\n    13→\n    14→Thread-safe: multiple concurrent ``recall()`` calls are safe.\n    15→\"\"\"\n    16→\n    17→from __future__ import annotations\n    18→\n    19→import time\n    20→from dataclasses import dataclass, field\n    21→from typing import TYPE_CHECKING\n    22→\n    23→import structlog\n    24→\n    25→from tapps_brain.injection import InjectionConfig, inject_memories\n    26→from tapps_brain.models import MemoryScope, MemoryTier, RecallResult\n    27→\n    28→if TYPE_CHECKING:\n    29→    from tapps_brain.decay import DecayConfig\n    30→    from tapps_brain.hive import HiveStore\n    31→    from tapps_brain.retrieval import MemoryRetriever\n    32→    from tapps_brain.store import MemoryStore\n    33→\n    34→logger = structlog.get_logger(__name__)\n    35→\n    36→\n    37→# ---------------------------------------------------------------------------\n    38→# Configuration\n    39→# ---------------------------------------------------------------------------\n    40→\n    41→\n    42→@dataclass\n    43→class RecallConfig:\n    44→    \"\"\"Configuration for the recall orchestrator.\"\"\"\n    45→\n    46→    engagement_level: str = \"high\"\n    47→    max_tokens: int = 2000\n    48→    min_score: float = 0.3\n    49→    min_confidence: float = 0.1\n    50→    scope_filter: MemoryScope | None = None\n    51→    tier_filter: MemoryTier | None = None\n    52→    branch: str | None = None\n    53→    dedupe_window: list[str] = field(default_factory=list)\n    54→    use_graph_boost: bool = False\n    55→    graph_boost_factor: float = 0.15\n    56→\n    57→\n    58→# ---------------------------------------------------------------------------\n    59→# RecallOrchestrator\n    60→# ---------------------------------------------------------------------------\n    61→\n    62→\n    63→class RecallOrchestrator:\n    64→    \"\"\"Orchestrates auto-recall: search → filter → inject → return.\n    65→\n    66→    Delegates formatting/safety/budget to ``inject_memories()`` and adds\n    67→    quality gates (scope, tier, branch, deduplication, timing).\n    68→\n    69→    Thread-safe: all mutable state access is guarded by the store lock.\n    70→    \"\"\"\n    71→\n    72→    def __init__(\n    73→        self,\n    74→        store: MemoryStore,\n    75→        *,\n    76→        retriever: MemoryRetriever | None = None,\n    77→        config: RecallConfig | None = None,\n    78→        decay_config: DecayConfig | None = None,\n    79→        hive_store: HiveStore | None = None,\n    80→        hive_recall_weight: float = 0.8,"}]},"parent_tool_use_id":null,"session_id":"327621aa-924c-4bfb-b348-3a4acf890b54","uuid":"f2d5cccf-c891-42db-9f99-0471d7cd2f90","timestamp":"2026-03-22T22:39:01.853Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\cursor\\tapps-brain\\src\\tapps_brain\\recall.py","content":"\"\"\"Auto-recall orchestrator for pre-prompt memory injection (EPIC-003).\n\nProvides a ``RecallOrchestrator`` that accepts an incoming user message,\nsearches the memory store for relevant entries, and returns injection-ready\ncontext. Delegates formatting, safety, and token budget enforcement to\n``inject_memories()``.\n\nThe orchestrator adds quality gates on top of injection:\n- Scope / tier / branch filtering\n- Deduplication against already-in-context memories\n- Minimum confidence threshold\n- Timing measurement\n\nThread-safe: multiple concurrent ``recall()`` calls are safe.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport time\nfrom dataclasses import dataclass, field\nfrom typing import TYPE_CHECKING\n\nimport structlog\n\nfrom tapps_brain.injection import InjectionConfig, inject_memories\nfrom tapps_brain.models import MemoryScope, MemoryTier, RecallResult\n\nif TYPE_CHECKING:\n    from tapps_brain.decay import DecayConfig\n    from tapps_brain.hive import HiveStore\n    from tapps_brain.retrieval import MemoryRetriever\n    from tapps_brain.store import MemoryStore\n\nlogger = structlog.get_logger(__name__)\n\n\n# ---------------------------------------------------------------------------\n# Configuration\n# ---------------------------------------------------------------------------\n\n\n@dataclass\nclass RecallConfig:\n    \"\"\"Configuration for the recall orchestrator.\"\"\"\n\n    engagement_level: str = \"high\"\n    max_tokens: int = 2000\n    min_score: float = 0.3\n    min_confidence: float = 0.1\n    scope_filter: MemoryScope | None = None\n    tier_filter: MemoryTier | None = None\n    branch: str | None = None\n    dedupe_window: list[str] = field(default_factory=list)\n    use_graph_boost: bool = False\n    graph_boost_factor: float = 0.15\n\n\n# ---------------------------------------------------------------------------\n# RecallOrchestrator\n# ---------------------------------------------------------------------------\n\n\nclass RecallOrchestrator:\n    \"\"\"Orchestrates auto-recall: search → filter → inject → return.\n\n    Delegates formatting/safety/budget to ``inject_memories()`` and adds\n    quality gates (scope, tier, branch, deduplication, timing).\n\n    Thread-safe: all mutable state access is guarded by the store lock.\n    \"\"\"\n\n    def __init__(\n        self,\n        store: MemoryStore,\n        *,\n        retriever: MemoryRetriever | None = None,\n        config: RecallConfig | None = None,\n        decay_config: DecayConfig | None = None,\n        hive_store: HiveStore | None = None,\n        hive_recall_weight: float = 0.8,","numLines":80,"startLine":1,"totalLines":412}}}
