{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01BiYzS3xx7VHypUZy2Ts76X","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01RvZwCEozji2f5ffHbaX6hb","name":"Read","input":{"file_path":"/c/cursor/tapps-brain/src/tapps_brain/store.py","limit":500,"offset":500},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":4,"cache_creation_input_tokens":6670,"cache_read_input_tokens":74467,"cache_creation":{"ephemeral_5m_input_tokens":6670,"ephemeral_1h_input_tokens":0},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01KJomf8MxPhmjTE3TX6wPks","session_id":"327621aa-924c-4bfb-b348-3a4acf890b54","uuid":"f62cacee-d45e-4c2d-9fd2-798a413973f2"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RvZwCEozji2f5ffHbaX6hb","type":"tool_result","content":"   500→            with self._lock:\n   501→                if scope is not None and branch is not None:\n   502→                    entry = self._resolve_scope(key, scope, branch)\n   503→                else:\n   504→                    entry = self._entries.get(key)\n   505→\n   506→                if entry is None:\n   507→                    self._metrics.increment(\"store.get.miss\")\n   508→                    return None\n   509→\n   510→                # Update access metadata\n   511→                now = _utc_now_iso()\n   512→                updated = entry.model_copy(\n   513→                    update={\n   514→                        \"last_accessed\": now,\n   515→                        \"access_count\": entry.access_count + 1,\n   516→                    }\n   517→                )\n   518→                self._entries[updated.key] = updated\n   519→\n   520→            self._metrics.increment(\"store.get.hit\")\n   521→            self._persistence.save(updated)\n   522→            return updated\n   523→\n   524→    def list_all(\n   525→        self,\n   526→        tier: str | None = None,\n   527→        scope: str | None = None,\n   528→        tags: list[str] | None = None,\n   529→        include_superseded: bool = True,\n   530→    ) -> list[MemoryEntry]:\n   531→        \"\"\"List entries with optional filters.\n   532→\n   533→        Args:\n   534→            tier: Filter by tier.\n   535→            scope: Filter by scope.\n   536→            tags: Filter by tags.\n   537→            include_superseded: When ``False``, exclude temporally invalid\n   538→                (superseded/expired) entries. Default ``True`` for backward\n   539→                compatibility.\n   540→        \"\"\"\n   541→        with self._lock:\n   542→            entries = list(self._entries.values())\n   543→\n   544→        if tier is not None:\n   545→            entries = [e for e in entries if e.tier == tier]\n   546→        if scope is not None:\n   547→            entries = [e for e in entries if e.scope == scope]\n   548→        if tags:\n   549→            tag_set = set(tags)\n   550→            entries = [e for e in entries if tag_set.intersection(e.tags)]\n   551→        if not include_superseded:\n   552→            entries = [e for e in entries if e.is_temporally_valid()]\n   553→\n   554→        return entries\n   555→\n   556→    def delete(self, key: str) -> bool:\n   557→        \"\"\"Delete a memory entry by key. Returns True if deleted.\"\"\"\n   558→        with self._lock:\n   559→            if key not in self._entries:\n   560→                return False\n   561→            del self._entries[key]\n   562→\n   563→        self._persistence.delete(key)\n   564→        return True\n   565→\n   566→    def search(\n   567→        self,\n   568→        query: str,\n   569→        tags: list[str] | None = None,\n   570→        tier: str | None = None,\n   571→        scope: str | None = None,\n   572→        as_of: str | None = None,\n   573→    ) -> list[MemoryEntry]:\n   574→        \"\"\"Search via FTS5, with optional post-filters.\n   575→\n   576→        Args:\n   577→            query: Search query string.\n   578→            tags: Filter by tags.\n   579→            tier: Filter by tier.\n   580→            scope: Filter by scope.\n   581→            as_of: ISO-8601 timestamp for point-in-time temporal filtering.\n   582→                When set, only entries valid at that time are returned.\n   583→                When ``None`` (default), temporally invalid entries are excluded\n   584→                using the current time.\n   585→        \"\"\"\n   586→        self._metrics.increment(\"store.search\")\n   587→        with MetricsTimer(self._metrics, \"store.search_ms\"):\n   588→            results = self._persistence.search(query)\n   589→\n   590→            if tier is not None:\n   591→                results = [r for r in results if r.tier == tier]\n   592→            if scope is not None:\n   593→                results = [r for r in results if r.scope == scope]\n   594→            if tags:\n   595→                tag_set = set(tags)\n   596→                results = [r for r in results if tag_set.intersection(r.tags)]\n   597→\n   598→            # Temporal filtering (EPIC-004)\n   599→            results = [r for r in results if r.is_temporally_valid(as_of)]\n   600→\n   601→            self._metrics.increment(\"store.search.results\", len(results))\n   602→            return results\n   603→\n   604→    def update_fields(self, key: str, **fields: Any) -> MemoryEntry | None:  # noqa: ANN401\n   605→        \"\"\"Partial update of specific fields on an existing entry.\n   606→\n   607→        Preserves immutable fields like ``created_at``. Used by Epic 24\n   608→        decay/contradiction/reinforcement systems.\n   609→        \"\"\"\n   610→        with self._lock:\n   611→            entry = self._entries.get(key)\n   612→            if entry is None:\n   613→                return None\n   614→\n   615→            fields[\"updated_at\"] = _utc_now_iso()\n   616→            updated = entry.model_copy(update=fields)\n   617→            self._entries[key] = updated\n   618→\n   619→        self._persistence.save(updated)\n   620→        return updated\n   621→\n   622→    def count(self) -> int:\n   623→        \"\"\"Return the total number of memory entries.\"\"\"\n   624→        with self._lock:\n   625→            return len(self._entries)\n   626→\n   627→    def snapshot(self) -> MemorySnapshot:\n   628→        \"\"\"Return a serializable snapshot of the full memory state.\"\"\"\n   629→        with self._lock:\n   630→            entries = list(self._entries.values())\n   631→\n   632→        tier_counts: dict[str, int] = {}\n   633→        for entry in entries:\n   634→            tier_val = entry.tier.value if isinstance(entry.tier, MemoryTier) else str(entry.tier)\n   635→            tier_counts[tier_val] = tier_counts.get(tier_val, 0) + 1\n   636→\n   637→        return MemorySnapshot(\n   638→            project_root=str(self._project_root),\n   639→            entries=entries,\n   640→            total_count=len(entries),\n   641→            tier_counts=tier_counts,\n   642→        )\n   643→\n   644→    # ------------------------------------------------------------------\n   645→    # Reinforcement (Story 002.2)\n   646→    # ------------------------------------------------------------------\n   647→\n   648→    def reinforce(self, key: str, *, confidence_boost: float = 0.0) -> MemoryEntry:\n   649→        \"\"\"Reinforce a memory entry, resetting its decay clock atomically.\n   650→\n   651→        Args:\n   652→            key: The memory entry key to reinforce.\n   653→            confidence_boost: Optional confidence increase (0.0-0.2).\n   654→\n   655→        Returns:\n   656→            The updated ``MemoryEntry``.\n   657→\n   658→        Raises:\n   659→            KeyError: If the entry does not exist.\n   660→        \"\"\"\n   661→        from tapps_brain.reinforcement import reinforce as _reinforce\n   662→\n   663→        decay_cfg = self._get_decay_config()\n   664→\n   665→        with self._lock:\n   666→            entry = self._entries.get(key)\n   667→            if entry is None:\n   668→                raise KeyError(key)\n   669→\n   670→            updates = _reinforce(entry, decay_cfg, confidence_boost=confidence_boost)\n   671→            updated = entry.model_copy(update=updates)\n   672→            self._entries[key] = updated\n   673→\n   674→        self._persistence.save(updated)\n   675→\n   676→        # EPIC-010: Check promotion after reinforcement\n   677→        if self._profile is not None:\n   678→            try:\n   679→                from tapps_brain.promotion import PromotionEngine\n   680→\n   681→                engine = PromotionEngine(decay_cfg)\n   682→                target_tier = engine.check_promotion(updated, self._profile)\n   683→                if target_tier is not None:\n   684→                    old_tier = str(updated.tier)\n   685→                    promoted = updated.model_copy(\n   686→                        update={\"tier\": target_tier, \"updated_at\": _utc_now_iso()}\n   687→                    )\n   688→                    with self._lock:\n   689→                        self._entries[key] = promoted\n   690→                    self._persistence.save(promoted)\n   691→                    self._persistence.append_audit(\n   692→                        action=\"promote\",\n   693→                        key=key,\n   694→                        extra={\n   695→                            \"from_tier\": old_tier,\n   696→                            \"to_tier\": target_tier,\n   697→                            \"access_count\": updated.access_count,\n   698→                            \"reinforce_count\": updated.reinforce_count,\n   699→                        },\n   700→                    )\n   701→                    logger.info(\n   702→                        \"memory_promoted\",\n   703→                        key=key,\n   704→                        from_tier=old_tier,\n   705→                        to_tier=target_tier,\n   706→                    )\n   707→                    return promoted\n   708→            except Exception:\n   709→                logger.debug(\"promotion_check_failed\", key=key, exc_info=True)\n   710→\n   711→        return updated\n   712→\n   713→    # ------------------------------------------------------------------\n   714→    # Extraction ingestion (Story 002.3)\n   715→    # ------------------------------------------------------------------\n   716→\n   717→    def ingest_context(\n   718→        self,\n   719→        context: str,\n   720→        *,\n   721→        source: str = \"agent\",\n   722→        capture_prompt: str = \"\",\n   723→        agent_scope: str = \"private\",\n   724→    ) -> list[str]:\n   725→        \"\"\"Extract durable facts from context and save new entries.\n   726→\n   727→        Uses rule-based pattern matching to find decision-like statements\n   728→        and saves them as memory entries. Existing keys are skipped.\n   729→\n   730→        Args:\n   731→            context: Raw session/transcript text to scan.\n   732→            source: Source attribution for created entries.\n   733→            capture_prompt: Optional guidance for extraction.\n   734→            agent_scope: Hive propagation scope for captured facts —\n   735→                ``'private'`` (default), ``'domain'``, or ``'hive'``.\n   736→\n   737→        Returns:\n   738→            List of keys for newly created entries.\n   739→        \"\"\"\n   740→        from tapps_brain.extraction import extract_durable_facts\n   741→\n   742→        facts = extract_durable_facts(context, capture_prompt)\n   743→        created_keys: list[str] = []\n   744→\n   745→        for fact in facts:\n   746→            key = fact[\"key\"]\n   747→            # Skip if already exists\n   748→            with self._lock:\n   749→                if key in self._entries:\n   750→                    continue\n   751→\n   752→            result = self.save(\n   753→                key=key,\n   754→                value=fact[\"value\"],\n   755→                tier=fact[\"tier\"],\n   756→                source=source,\n   757→                agent_scope=agent_scope,\n   758→            )\n   759→            if isinstance(result, MemoryEntry):\n   760→                created_keys.append(key)\n   761→\n   762→        return created_keys\n   763→\n   764→    # ------------------------------------------------------------------\n   765→    # Session indexing (Story 002.4)\n   766→    # ------------------------------------------------------------------\n   767→\n   768→    def index_session(self, session_id: str, chunks: list[str]) -> int:\n   769→        \"\"\"Index session chunks for later search.\n   770→\n   771→        Args:\n   772→            session_id: Session identifier.\n   773→            chunks: List of text chunks to index.\n   774→\n   775→        Returns:\n   776→            Number of chunks stored.\n   777→        \"\"\"\n   778→        from tapps_brain.session_index import index_session as _index_session\n   779→\n   780→        try:\n   781→            return _index_session(self._project_root, session_id, chunks)\n   782→        except Exception:\n   783→            logger.debug(\"session_index_failed\", session_id=session_id, exc_info=True)\n   784→            return 0\n   785→\n   786→    def search_sessions(self, query: str, *, limit: int = 10) -> list[dict[str, Any]]:\n   787→        \"\"\"Search session index by query.\n   788→\n   789→        Returns list of dicts with keys: session_id, chunk_index, content, created_at.\n   790→        \"\"\"\n   791→        from tapps_brain.session_index import search_session_index\n   792→\n   793→        try:\n   794→            return search_session_index(self._project_root, query, limit=limit)\n   795→        except Exception:\n   796→            logger.debug(\"session_search_failed\", query=query, exc_info=True)\n   797→            return []\n   798→\n   799→    def cleanup_sessions(self, *, ttl_days: int = 90) -> int:\n   800→        \"\"\"Delete session chunks older than ttl_days.\n   801→\n   802→        Returns:\n   803→            Count of deleted chunks.\n   804→        \"\"\"\n   805→        from tapps_brain.session_index import delete_expired_sessions\n   806→\n   807→        try:\n   808→            return delete_expired_sessions(self._project_root, ttl_days)\n   809→        except Exception:\n   810→            logger.debug(\"session_cleanup_failed\", exc_info=True)\n   811→            return 0\n   812→\n   813→    # ------------------------------------------------------------------\n   814→    # Doc validation (Story 002.1)\n   815→    # ------------------------------------------------------------------\n   816→\n   817→    def validate_entries(\n   818→        self,\n   819→        *,\n   820→        keys: list[str] | None = None,\n   821→    ) -> Any:  # noqa: ANN401\n   822→        \"\"\"Validate memory entries against authoritative documentation.\n   823→\n   824→        Requires a lookup engine to be configured at construction time.\n   825→        When no lookup engine is set, returns an empty ``ValidationReport``.\n   826→\n   827→        Args:\n   828→            keys: Optional list of entry keys to validate. If None,\n   829→                validates all entries.\n   830→\n   831→        Returns:\n   832→            A ``ValidationReport`` with per-entry results. Changes are\n   833→            applied back to the store automatically.\n   834→        \"\"\"\n   835→        import asyncio\n   836→\n   837→        from tapps_brain.doc_validation import MemoryDocValidator, ValidationReport\n   838→\n   839→        if self._lookup_engine is None:\n   840→            return ValidationReport()\n   841→\n   842→        validator = MemoryDocValidator(self._lookup_engine)\n   843→\n   844→        # Collect entries to validate\n   845→        with self._lock:\n   846→            if keys is not None:\n   847→                entries = [self._entries[k] for k in keys if k in self._entries]\n   848→            else:\n   849→                entries = list(self._entries.values())\n   850→\n   851→        # Run async validation synchronously (store is sync by design)\n   852→        report = asyncio.run(validator.validate_batch(entries))\n   853→\n   854→        # Apply results back to the store\n   855→        asyncio.run(validator.apply_results(report, self))\n   856→\n   857→        return report\n   858→\n   859→    # ------------------------------------------------------------------\n   860→    # Bi-temporal versioning (EPIC-004)\n   861→    # ------------------------------------------------------------------\n   862→\n   863→    def supersede(self, old_key: str, new_value: str, **kwargs: Any) -> MemoryEntry:  # noqa: ANN401\n   864→        \"\"\"Atomically supersede an existing entry with a new one.\n   865→\n   866→        Sets ``invalid_at`` and ``superseded_by`` on the old entry and\n   867→        creates a new entry with ``valid_at`` set to now.\n   868→\n   869→        Args:\n   870→            old_key: Key of the entry to supersede.\n   871→            new_value: Value for the replacement entry.\n   872→            **kwargs: Additional fields for the new entry (tier, tags, etc.).\n   873→\n   874→        Returns:\n   875→            The newly created ``MemoryEntry``.\n   876→\n   877→        Raises:\n   878→            KeyError: If *old_key* does not exist.\n   879→            ValueError: If *old_key* is already superseded.\n   880→        \"\"\"\n   881→        self._metrics.increment(\"store.supersede\")\n   882→        now = _utc_now_iso()\n   883→\n   884→        with self._lock:\n   885→            old_entry = self._entries.get(old_key)\n   886→            if old_entry is None:\n   887→                raise KeyError(old_key)\n   888→\n   889→            if old_entry.invalid_at is not None:\n   890→                msg = (\n   891→                    f\"Entry '{old_key}' is already superseded (invalid_at={old_entry.invalid_at}).\"\n   892→                )\n   893→                raise ValueError(msg)\n   894→\n   895→            # Derive new key from old key or kwargs\n   896→            new_key = kwargs.pop(\"key\", f\"{old_key}.v{self._version_count(old_key) + 1}\")\n   897→\n   898→            # Invalidate the old entry\n   899→            invalidated = old_entry.model_copy(\n   900→                update={\n   901→                    \"invalid_at\": now,\n   902→                    \"superseded_by\": new_key,\n   903→                    \"updated_at\": now,\n   904→                }\n   905→            )\n   906→            self._entries[old_key] = invalidated\n   907→\n   908→        # Persist the invalidated entry\n   909→        self._persistence.save(invalidated)\n   910→\n   911→        # Create the new entry\n   912→        new_kwargs: dict[str, Any] = {\n   913→            \"tier\": str(old_entry.tier),\n   914→            \"source\": old_entry.source.value,\n   915→            \"source_agent\": old_entry.source_agent,\n   916→            \"scope\": old_entry.scope.value,\n   917→            \"tags\": list(old_entry.tags),\n   918→            \"branch\": old_entry.branch,\n   919→            \"confidence\": old_entry.confidence,\n   920→        }\n   921→        new_kwargs.update(kwargs)\n   922→\n   923→        new_entry = self.save(key=new_key, value=new_value, **new_kwargs)\n   924→        if isinstance(new_entry, dict):\n   925→            msg = f\"Failed to create superseding entry: {new_entry.get('message', '')}\"\n   926→            raise ValueError(msg)\n   927→\n   928→        # Set valid_at on the new entry\n   929→        with self._lock:\n   930→            updated_new = new_entry.model_copy(update={\"valid_at\": now})\n   931→            self._entries[new_key] = updated_new\n   932→        self._persistence.save(updated_new)\n   933→\n   934→        # Transfer relations from old entry to new entry\n   935→        old_relations = self.get_relations(old_key)\n   936→        if old_relations:\n   937→            transferred = [\n   938→                RelationEntry(\n   939→                    subject=r[\"subject\"],\n   940→                    predicate=r[\"predicate\"],\n   941→                    object_entity=r[\"object_entity\"],\n   942→                    source_entry_keys=[new_key],\n   943→                    confidence=float(r.get(\"confidence\", 0.8)),\n   944→                )\n   945→                for r in old_relations\n   946→            ]\n   947→            self._persistence.save_relations(new_key, transferred)\n   948→            with self._lock:\n   949→                self._relations[new_key] = self._persistence.load_relations(new_key)\n   950→\n   951→        return updated_new\n   952→\n   953→    def history(self, key: str) -> list[MemoryEntry]:\n   954→        \"\"\"Return the full temporal chain for a key, ordered by ``valid_at``.\n   955→\n   956→        Follows the ``superseded_by`` chain forward from the given key\n   957→        to find all successors, and backward to find all predecessors.\n   958→\n   959→        Args:\n   960→            key: Any key in the version chain.\n   961→\n   962→        Returns:\n   963→            All entries in the chain, ordered by ``valid_at`` ascending\n   964→            (entries without ``valid_at`` sort first).\n   965→\n   966→        Raises:\n   967→            KeyError: If *key* does not exist.\n   968→        \"\"\"\n   969→        with self._lock:\n   970→            if key not in self._entries:\n   971→                raise KeyError(key)\n   972→\n   973→            # Build reverse index: superseded_by -> source key\n   974→            reverse: dict[str, str] = {}\n   975→            for e in self._entries.values():\n   976→                if e.superseded_by:\n   977→                    reverse[e.superseded_by] = e.key\n   978→\n   979→            # Walk backward to the root\n   980→            root = key\n   981→            while root in reverse:\n   982→                root = reverse[root]\n   983→\n   984→            # Walk forward from root collecting the chain\n   985→            chain: list[MemoryEntry] = []\n   986→            current: str | None = root\n   987→            while current is not None:\n   988→                entry = self._entries.get(current)\n   989→                if entry is None:\n   990→                    break\n   991→                chain.append(entry)\n   992→                current = entry.superseded_by\n   993→\n   994→        # Sort by valid_at (None sorts first)\n   995→        chain.sort(key=lambda e: e.valid_at or \"\")\n   996→        return chain\n   997→\n   998→    def _version_count(self, key: str) -> int:\n   999→        \"\"\"Count how many versions of a key exist (for generating version suffixes)."}]},"parent_tool_use_id":"toolu_01KJomf8MxPhmjTE3TX6wPks","session_id":"327621aa-924c-4bfb-b348-3a4acf890b54","uuid":"6e2e545d-bbd4-4d5e-8010-430bc7d7b1db","timestamp":"2026-03-22T22:38:14.388Z"}
