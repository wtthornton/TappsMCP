{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016uaYLRG1PpwSuPbnwETVks","type":"tool_result","content":"  1996→def _ranked_search(\n  1997→    store: MemoryStore,\n  1998→    query: str,\n  1999→    limit: int,\n  2000→    include_summary: bool,\n  2001→    include_sources: bool = False,\n  2002→    include_session_index: bool = False,\n  2003→) -> dict[str, Any]:\n  2004→    \"\"\"Execute ranked BM25 search via MemoryRetriever (hybrid + reranker when enabled).\n  2005→\n  2006→    When include_session_index and memory.session_index.enabled, merges session\n  2007→    index hits with memory results (Epic 65.10).\n  2008→    \"\"\"\n  2009→    from tapps_core.config.settings import load_settings\n  2010→    from tapps_core.memory.reranker import get_reranker\n  2011→    from tapps_core.memory.retrieval import MemoryRetriever\n  2012→\n  2013→    settings = load_settings()\n  2014→    rr = settings.memory.reranker\n  2015→    reranker = (\n  2016→        get_reranker(\n  2017→            enabled=rr.enabled,\n  2018→            provider=rr.provider,\n  2019→            top_k=rr.top_k,\n  2020→            api_key=rr.api_key,\n  2021→        )\n  2022→        if rr.enabled\n  2023→        else None\n  2024→    )\n  2025→    retriever = MemoryRetriever(\n  2026→        semantic_enabled=settings.memory.semantic_search.enabled,\n  2027→        hybrid_config=settings.memory.hybrid,\n  2028→        reranker=reranker,\n  2029→        reranker_enabled=rr.enabled,\n  2030→        relations_enabled=settings.memory.relations.enabled,\n  2031→        expand_queries=settings.memory.relations.expand_queries,\n  2032→    )\n  2033→    scored = retriever.search(query, store, limit=limit, include_sources=include_sources)\n  2034→\n  2035→    result_entries: list[dict[str, Any]] = []\n  2036→    for i, sm in enumerate(scored):\n  2037→        entry_data = (\n  2038→            _summarize_entry(sm.entry)\n  2039→            if include_summary and i >= _FULL_VALUE_THRESHOLD\n  2040→            else sm.entry.model_dump()\n  2041→        )\n  2042→        result_entries.append(\n  2043→            {\n  2044→                \"entry\": entry_data,\n  2045→                \"score\": sm.score,\n  2046→                \"effective_confidence\": sm.effective_confidence,\n  2047→                \"stale\": sm.stale,\n  2048→                \"source\": \"memory\",\n  2049→            }\n  2050→        )\n  2051→\n  2052→    # Epic 65.10: optionally include session index hits\n  2053→    if include_session_index and settings.memory.session_index.enabled:\n  2054→        from tapps_core.memory.session_index import search_session_index\n  2055→\n  2056→        sess_limit = min(limit, 5)\n  2057→        sess_hits = search_session_index(store.project_root, query, limit=sess_limit)\n  2058→        for i, hit in enumerate(sess_hits):\n  2059→            score = 0.7 - (i * 0.05)\n  2060→            result_entries.append(\n  2061→                {\n  2062→                    \"session_chunk\": {\n  2063→                        \"session_id\": hit[\"session_id\"],\n  2064→                        \"chunk_index\": hit[\"chunk_index\"],\n  2065→                        \"content\": hit[\"content\"][:200] + (\"...\" if len(hit[\"content\"]) > 200 else \"\"),\n  2066→                        \"created_at\": hit[\"created_at\"],\n  2067→                    },\n  2068→                    \"score\": max(0.4, score),\n  2069→                    \"effective_confidence\": 0.5,\n  2070→                    \"stale\": False,\n  2071→                    \"source\": \"session_index\",\n  2072→                }\n  2073→            )\n  2074→        result_entries.sort(key=lambda x: x[\"score\"], reverse=True)\n  2075→        result_entries = result_entries[:limit]"}]},"parent_tool_use_id":null,"session_id":"327621aa-924c-4bfb-b348-3a4acf890b54","uuid":"7b2d6e41-255f-4f4a-a69d-201023bfe6df","timestamp":"2026-03-22T22:39:11.907Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\cursor\\TappMCP\\packages\\tapps-mcp\\src\\tapps_mcp\\server_memory_tools.py","content":"def _ranked_search(\n    store: MemoryStore,\n    query: str,\n    limit: int,\n    include_summary: bool,\n    include_sources: bool = False,\n    include_session_index: bool = False,\n) -> dict[str, Any]:\n    \"\"\"Execute ranked BM25 search via MemoryRetriever (hybrid + reranker when enabled).\n\n    When include_session_index and memory.session_index.enabled, merges session\n    index hits with memory results (Epic 65.10).\n    \"\"\"\n    from tapps_core.config.settings import load_settings\n    from tapps_core.memory.reranker import get_reranker\n    from tapps_core.memory.retrieval import MemoryRetriever\n\n    settings = load_settings()\n    rr = settings.memory.reranker\n    reranker = (\n        get_reranker(\n            enabled=rr.enabled,\n            provider=rr.provider,\n            top_k=rr.top_k,\n            api_key=rr.api_key,\n        )\n        if rr.enabled\n        else None\n    )\n    retriever = MemoryRetriever(\n        semantic_enabled=settings.memory.semantic_search.enabled,\n        hybrid_config=settings.memory.hybrid,\n        reranker=reranker,\n        reranker_enabled=rr.enabled,\n        relations_enabled=settings.memory.relations.enabled,\n        expand_queries=settings.memory.relations.expand_queries,\n    )\n    scored = retriever.search(query, store, limit=limit, include_sources=include_sources)\n\n    result_entries: list[dict[str, Any]] = []\n    for i, sm in enumerate(scored):\n        entry_data = (\n            _summarize_entry(sm.entry)\n            if include_summary and i >= _FULL_VALUE_THRESHOLD\n            else sm.entry.model_dump()\n        )\n        result_entries.append(\n            {\n                \"entry\": entry_data,\n                \"score\": sm.score,\n                \"effective_confidence\": sm.effective_confidence,\n                \"stale\": sm.stale,\n                \"source\": \"memory\",\n            }\n        )\n\n    # Epic 65.10: optionally include session index hits\n    if include_session_index and settings.memory.session_index.enabled:\n        from tapps_core.memory.session_index import search_session_index\n\n        sess_limit = min(limit, 5)\n        sess_hits = search_session_index(store.project_root, query, limit=sess_limit)\n        for i, hit in enumerate(sess_hits):\n            score = 0.7 - (i * 0.05)\n            result_entries.append(\n                {\n                    \"session_chunk\": {\n                        \"session_id\": hit[\"session_id\"],\n                        \"chunk_index\": hit[\"chunk_index\"],\n                        \"content\": hit[\"content\"][:200] + (\"...\" if len(hit[\"content\"]) > 200 else \"\"),\n                        \"created_at\": hit[\"created_at\"],\n                    },\n                    \"score\": max(0.4, score),\n                    \"effective_confidence\": 0.5,\n                    \"stale\": False,\n                    \"source\": \"session_index\",\n                }\n            )\n        result_entries.sort(key=lambda x: x[\"score\"], reverse=True)\n        result_entries = result_entries[:limit]","numLines":80,"startLine":1996,"totalLines":2201}}}
