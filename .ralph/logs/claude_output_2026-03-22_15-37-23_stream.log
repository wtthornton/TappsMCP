{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AQqnmNtyoatLo1rxyqbzkW","type":"tool_result","content":"     1→\"\"\"Ranked memory retrieval with composite scoring.\n     2→\n     3→Upgrades memory search from simple keyword matching to scored,\n     4→ranked retrieval combining text relevance with memory-specific\n     5→signals (confidence, recency, access frequency).\n     6→\n     7→Uses BM25 (Okapi) for text relevance scoring with automatic\n     8→index building and invalidation. Epic 65.8: hybrid BM25 + vector\n     9→search with RRF when semantic_search.enabled.\n    10→\"\"\"\n    11→\n    12→from __future__ import annotations\n    13→\n    14→from concurrent.futures import ThreadPoolExecutor, as_completed\n    15→from datetime import UTC, datetime\n    16→from typing import TYPE_CHECKING\n    17→\n    18→import structlog\n    19→from pydantic import BaseModel, Field\n    20→\n    21→from tapps_brain.bm25 import BM25Scorer\n    22→from tapps_brain.decay import DecayConfig, calculate_decayed_confidence, is_stale\n    23→from tapps_brain.models import MemoryEntry  # noqa: TC001\n    24→from tapps_brain.reranker import RERANKER_TOP_CANDIDATES, Reranker\n    25→\n    26→if TYPE_CHECKING:\n    27→    from tapps_brain.store import MemoryStore\n    28→\n    29→logger = structlog.get_logger(__name__)\n    30→\n    31→# ---------------------------------------------------------------------------\n    32→# Models\n    33→# ---------------------------------------------------------------------------\n    34→\n    35→_MAX_RESULTS = 50\n    36→_DEFAULT_RESULTS = 10\n    37→_MIN_CONFIDENCE_FLOOR = 0.1\n    38→\n    39→# BM25 relevance normalization constant: score / (score + K)\n    40→# Chosen so that a BM25 score of 5.0 maps to ~0.5 normalized.\n    41→_BM25_NORM_K = 5.0\n    42→\n    43→\n    44→class ScoredMemory(BaseModel):\n    45→    \"\"\"A memory entry with retrieval scoring metadata.\"\"\"\n    46→\n    47→    entry: MemoryEntry\n    48→    score: float = Field(ge=0.0, description=\"Composite retrieval score.\")\n    49→    effective_confidence: float = Field(ge=0.0, le=1.0, description=\"Time-decayed confidence.\")\n    50→    bm25_relevance: float = Field(ge=0.0, description=\"Normalized text relevance.\")\n    51→    stale: bool = Field(default=False, description=\"Whether the memory is stale.\")\n    52→\n    53→\n    54→# ---------------------------------------------------------------------------\n    55→# Scoring weights\n    56→# ---------------------------------------------------------------------------\n    57→\n    58→_W_RELEVANCE = 0.40\n    59→_W_CONFIDENCE = 0.30\n    60→_W_RECENCY = 0.15\n    61→_W_FREQUENCY = 0.15\n    62→\n    63→_FREQUENCY_CAP = 20.0\n    64→\n    65→# Marker text for consolidated source entries\n    66→_CONSOLIDATED_MARKER = \"consolidated into\"\n    67→\n    68→\n    69→def _is_consolidated_source(entry: MemoryEntry) -> bool:\n    70→    \"\"\"Check if an entry is a source of a consolidated entry.\n    71→\n    72→    Source entries are marked with contradicted=True and a\n    73→    contradiction_reason containing \"consolidated into\".\n    74→\n    75→    Args:\n    76→        entry: The memory entry to check.\n    77→\n    78→    Returns:\n    79→        True if this entry was consolidated into another entry.\n    80→    \"\"\"\n    81→    if not entry.contradicted:\n    82→        return False\n    83→    reason = entry.contradiction_reason or \"\"\n    84→    return _CONSOLIDATED_MARKER in reason.lower()\n    85→\n    86→\n    87→# ---------------------------------------------------------------------------\n    88→# MemoryRetriever\n    89→# ---------------------------------------------------------------------------\n    90→\n    91→\n    92→class MemoryRetriever:\n    93→    \"\"\"Ranked retrieval engine for memory entries.\"\"\"\n    94→\n    95→    def __init__(\n    96→        self,\n    97→        config: DecayConfig | None = None,\n    98→        *,\n    99→        scoring_config: object | None = None,  # ScoringConfig from profile (EPIC-010)\n   100→        semantic_enabled: bool = False,\n   101→        hybrid_config: object = None,\n   102→        reranker: Reranker | None = None,\n   103→        reranker_enabled: bool = False,\n   104→        retrieval_policy: object | None = None,\n   105→        relations_enabled: bool = False,\n   106→        expand_queries: bool = True,\n   107→    ) -> None:\n   108→        self._config = config or DecayConfig()\n   109→        self._bm25 = BM25Scorer()\n   110→        self._bm25_entries: list[MemoryEntry] = []\n   111→        self._bm25_corpus_size: int = 0\n   112→        self._bm25_fingerprint: int = 0\n   113→        self._semantic_enabled = semantic_enabled\n   114→        self._hybrid_config = hybrid_config\n   115→        self._reranker = reranker\n   116→        self._reranker_enabled = reranker_enabled\n   117→        self._retrieval_policy = retrieval_policy\n   118→        self._relations_enabled = relations_enabled\n   119→        self._expand_queries = expand_queries\n   120→\n   121→        # EPIC-010: use configurable scoring weights if provided\n   122→        self._scoring_config = scoring_config\n   123→        if scoring_config is not None:\n   124→            self._w_relevance = getattr(scoring_config, \"relevance\", _W_RELEVANCE)\n   125→            self._w_confidence = getattr(scoring_config, \"confidence\", _W_CONFIDENCE)\n   126→            self._w_recency = getattr(scoring_config, \"recency\", _W_RECENCY)\n   127→            self._w_frequency = getattr(scoring_config, \"frequency\", _W_FREQUENCY)\n   128→            self._frequency_cap = float(getattr(scoring_config, \"frequency_cap\", _FREQUENCY_CAP))\n   129→            self._bm25_norm_k = float(getattr(scoring_config, \"bm25_norm_k\", _BM25_NORM_K))\n   130→        else:\n   131→            self._w_relevance = _W_RELEVANCE\n   132→            self._w_confidence = _W_CONFIDENCE\n   133→            self._w_recency = _W_RECENCY\n   134→            self._w_frequency = _W_FREQUENCY\n   135→            self._frequency_cap = _FREQUENCY_CAP\n   136→            self._bm25_norm_k = _BM25_NORM_K\n   137→\n   138→    def search(\n   139→        self,\n   140→        query: str,\n   141→        store: MemoryStore,\n   142→        *,\n   143→        limit: int = _DEFAULT_RESULTS,\n   144→        include_contradicted: bool = False,\n   145→        include_sources: bool = False,\n   146→        min_confidence: float = _MIN_CONFIDENCE_FLOOR,\n   147→        as_of: str | None = None,\n   148→        include_superseded: bool = False,\n   149→    ) -> list[ScoredMemory]:\n   150→        \"\"\"Search memories with ranked scoring.\n   151→\n   152→        Uses the store's FTS5-backed search for candidate retrieval,\n   153→        then applies composite scoring with confidence, recency, and\n   154→        frequency signals.\n   155→\n   156→        Args:\n   157→            query: Search query string.\n   158→            store: Memory store to search.\n   159→            limit: Max results (default 10, max 50).\n   160→            include_contradicted: Include contradicted memories.\n   161→            include_sources: Include source entries of consolidated memories\n   162→                (Epic 58, Story 58.5). When False (default), entries that were\n   163→                consolidated into other entries are filtered out. When True,\n   164→                source entries are included alongside consolidated entries.\n   165→            min_confidence: Minimum confidence filter.\n   166→            as_of: ISO-8601 timestamp for point-in-time queries. When set,\n   167→                only entries valid at that time are returned.\n   168→            include_superseded: When True, include temporally invalid entries\n   169→                (marked with ``stale=True`` and a 0.5x relevance penalty).\n   170→\n   171→        Returns:\n   172→            Scored memories sorted by composite score (descending).\n   173→        \"\"\"\n   174→        if not query or not query.strip():\n   175→            return []\n   176→\n   177→        limit = max(1, min(limit, _MAX_RESULTS))\n   178→        now = datetime.now(tz=UTC)\n   179→\n   180→        # Epic 65.13: expand query via relations when enabled\n   181→        effective_query = query\n   182→        if self._relations_enabled and self._expand_queries:\n   183→            effective_query = self._expand_query_via_relations(query, store)\n   184→\n   185→        # Epic 65.8: hybrid path when semantic enabled\n   186→        if self._semantic_enabled:\n   187→            candidates = self._get_hybrid_candidates(effective_query, store)\n   188→        else:\n   189→            candidates = self._get_candidates(effective_query, store)\n   190→\n   191→        # Score and filter\n   192→        scored: list[ScoredMemory] = []\n   193→        for entry, relevance_raw in candidates:\n   194→            # Filter source entries of consolidated memories (Epic 58.5)\n   195→            if not include_sources and _is_consolidated_source(entry):\n   196→                continue\n   197→\n   198→            # Filter contradicted entries (sources already handled above)\n   199→            is_included_source = include_sources and _is_consolidated_source(entry)\n   200→            if entry.contradicted and not include_contradicted and not is_included_source:\n   201→                continue\n   202→\n   203→            # Temporal filtering (EPIC-004)\n   204→            temporally_valid = entry.is_temporally_valid(as_of)\n   205→            if not temporally_valid and not include_superseded:\n   206→                continue\n   207→\n   208→            # Calculate effective confidence\n   209→            eff_conf = calculate_decayed_confidence(entry, self._config, now=now)\n   210→\n   211→            # Filter low confidence\n   212→            if eff_conf < min_confidence:\n   213→                continue\n   214→\n   215→            stale_flag = is_stale(entry, self._config, now=now)\n   216→            # Mark temporally invalid entries as stale (EPIC-004)\n   217→            if not temporally_valid:\n   218→                stale_flag = True\n   219→\n   220→            # Compute composite score\n   221→            relevance_norm = self._normalize_relevance(relevance_raw)\n   222→            recency = self._recency_score(entry, now)\n   223→            frequency = self._frequency_score(entry)\n   224→\n   225→            composite = (\n   226→                self._w_relevance * relevance_norm\n   227→                + self._w_confidence * eff_conf\n   228→                + self._w_recency * recency\n   229→                + self._w_frequency * frequency\n   230→            )\n   231→\n   232→            # Penalty for superseded entries included via include_superseded\n   233→            if not temporally_valid:\n   234→                composite *= 0.5\n   235→\n   236→            # Bonus for exact key match\n   237→            if entry.key == query.lower().replace(\" \", \"-\"):\n   238→                composite += 0.1\n   239→\n   240→            scored.append(\n   241→                ScoredMemory(\n   242→                    entry=entry,\n   243→                    score=round(composite, 4),\n   244→                    effective_confidence=round(eff_conf, 4),\n   245→                    bm25_relevance=round(relevance_norm, 4),\n   246→                    stale=stale_flag,\n   247→                )\n   248→            )\n   249→\n   250→        # Epic 65.14: Apply retrieval policy tag filtering\n   251→        if self._retrieval_policy is not None:\n   252→            blocked_tags = set(getattr(self._retrieval_policy, \"block_sensitive_tags\", []))\n   253→            if blocked_tags:\n   254→                scored = [s for s in scored if not blocked_tags.intersection(s.entry.tags)]\n   255→\n   256→        # Sort by score descending\n   257→        scored.sort(key=lambda s: s.score, reverse=True)\n   258→\n   259→        # Epic 65.9: optional reranking of top-20 -> top_k\n   260→        if self._reranker_enabled and self._reranker is not None and scored:\n   261→            scored = self._apply_reranker(query, scored, limit)\n   262→\n   263→        return scored[:limit]\n   264→\n   265→    def _apply_reranker(\n   266→        self,\n   267→        query: str,\n   268→        scored: list[ScoredMemory],\n   269→        limit: int,\n   270→    ) -> list[ScoredMemory]:\n   271→        \"\"\"Apply reranker to top candidates; fallback to original order on failure.\"\"\"\n   272→        assert self._reranker is not None  # caller checks before calling\n   273→        top_candidates = scored[:RERANKER_TOP_CANDIDATES]\n   274→        candidates = [(sm.entry.key, sm.entry.value) for sm in top_candidates]\n   275→        effective_top_k = min(limit, len(candidates))\n   276→\n   277→        try:\n   278→            reranked = self._reranker.rerank(query, candidates, top_k=effective_top_k)\n   279→        except Exception as e:\n   280→            logger.warning(\n   281→                \"reranker_failed_fallback_to_original\",\n   282→                reason=str(e),\n   283→            )\n   284→            return scored\n   285→\n   286→        if not reranked:\n   287→            return scored\n   288→\n   289→        key_to_scored = {sm.entry.key: sm for sm in scored}\n   290→        result: list[ScoredMemory] = []\n   291→        for key, rerank_score in reranked:\n   292→            sm = key_to_scored.get(key)\n   293→            if sm is not None:\n   294→                # Use reranker score as primary relevance; preserve other fields\n   295→                result.append(\n   296→                    ScoredMemory(\n   297→                        entry=sm.entry,\n   298→                        score=round(rerank_score, 4),\n   299→                        effective_confidence=sm.effective_confidence,\n   300→                        bm25_relevance=sm.bm25_relevance,\n   301→                        stale=sm.stale,\n   302→                    )\n   303→                )\n   304→        # Append any from original not in reranker result (e.g. API dropped some)\n   305→        seen = {sm.entry.key for sm in result}\n   306→        for sm in scored:\n   307→            if sm.entry.key not in seen:\n   308→                result.append(sm)\n   309→                if len(result) >= limit:\n   310→                    break\n   311→        return result[:limit]\n   312→\n   313→    # -----------------------------------------------------------------------\n   314→    # Relation expansion (Epic 65.13)\n   315→    # -----------------------------------------------------------------------\n   316→\n   317→    def _expand_query_via_relations(\n   318→        self,\n   319→        query: str,\n   320→        store: MemoryStore,\n   321→    ) -> str:\n   322→        \"\"\"Expand a query using entity/relationship graph traversal.\n   323→\n   324→        If the query matches a relationship pattern (e.g. \"who handles API\"),\n   325→        load relations from the persistence layer and expand with connected\n   326→        entities. Falls back to the original query on any error.\n   327→        \"\"\"\n   328→        try:\n   329→            from tapps_brain.relations import (\n   330→                RelationEntry,\n   331→                expand_via_relations,\n   332→            )\n   333→        except ImportError:\n   334→            return query\n   335→\n   336→        # Load relations from persistence if available\n   337→        try:\n   338→            persistence = getattr(store, \"_persistence\", None)\n   339→            if persistence is None:\n   340→                return query\n   341→            raw_relations = persistence.list_relations()\n   342→            if not raw_relations:\n   343→                return query\n   344→\n   345→            relations = [\n   346→                RelationEntry(\n   347→                    subject=r[\"subject\"],\n   348→                    predicate=r[\"predicate\"],\n   349→                    object_entity=r[\"object_entity\"],\n   350→                    source_entry_keys=r.get(\"source_entry_keys\", []),\n   351→                    confidence=r.get(\"confidence\", 0.8),\n   352→                )\n   353→                for r in raw_relations\n   354→            ]\n   355→\n   356→            expanded_terms = expand_via_relations(query, relations)\n   357→            if expanded_terms:\n   358→                expanded_query = f\"{query} {' '.join(expanded_terms)}\"\n   359→                logger.debug(\n   360→                    \"query_expanded_via_relations\",\n   361→                    original=query,\n   362→                    expanded=expanded_query,\n   363→                    terms_added=len(expanded_terms),\n   364→                )\n   365→                return expanded_query\n   366→        except Exception:\n   367→            logger.debug(\"relation_expansion_failed\", query=query)\n   368→\n   369→        return query\n   370→\n   371→    # -----------------------------------------------------------------------\n   372→    # BM25 index management\n   373→    # -----------------------------------------------------------------------\n   374→\n   375→    @staticmethod\n   376→    def _entry_to_document(entry: MemoryEntry) -> str:\n   377→        \"\"\"Convert a memory entry to a BM25-indexable document string.\"\"\"\n   378→        return f\"{entry.key} {entry.value} {' '.join(entry.tags)}\"\n   379→\n   380→    @staticmethod\n   381→    def _corpus_fingerprint(entries: list[MemoryEntry]) -> int:\n   382→        \"\"\"Compute a fingerprint that changes when any entry is added, removed, or updated.\"\"\"\n   383→        return hash(tuple((e.key, e.updated_at if e.updated_at else \"\") for e in entries))\n   384→\n   385→    def _ensure_bm25_index(self, entries: list[MemoryEntry]) -> None:\n   386→        \"\"\"Build or rebuild the BM25 index when the corpus changes.\"\"\"\n   387→        fingerprint = self._corpus_fingerprint(entries)\n   388→        if len(entries) == self._bm25_corpus_size and fingerprint == self._bm25_fingerprint:\n   389→            return\n   390→        documents = [self._entry_to_document(e) for e in entries]\n   391→        self._bm25.build_index(documents)\n   392→        self._bm25_entries = list(entries)\n   393→        self._bm25_corpus_size = len(entries)\n   394→        self._bm25_fingerprint = fingerprint\n   395→        logger.debug(\"bm25_index_rebuilt\", corpus_size=self._bm25_corpus_size)\n   396→\n   397→    # -----------------------------------------------------------------------\n   398→    # Candidate retrieval\n   399→    # -----------------------------------------------------------------------\n   400→\n   401→    def _get_candidates(\n   402→        self,\n   403→        query: str,\n   404→        store: MemoryStore,\n   405→    ) -> list[tuple[MemoryEntry, float]]:\n   406→        \"\"\"Retrieve candidate entries and compute BM25 relevance scores.\n   407→\n   408→        Tries the store's FTS5-backed search first for candidate\n   409→        filtering, then scores them using BM25. Falls back to full\n   410→        in-memory BM25 scan if FTS5 returns no results, and to word\n   411→        overlap if BM25 scoring fails entirely.\n   412→        \"\"\"\n   413→        # Try FTS5 via store.search() for candidate filtering\n   414→        try:\n   415→            fts_results = store.search(query)\n   416→            if fts_results:\n   417→                return self._bm25_score_entries(query, fts_results, store)\n   418→        except Exception:\n   419→            logger.debug(\"fts5_search_failed\", query=query)\n   420→\n   421→        # Fallback: full corpus BM25 scan\n   422→        return self._bm25_full_scan(query, store)\n   423→\n   424→    def _get_hybrid_candidates(\n   425→        self,\n   426→        query: str,\n   427→        store: MemoryStore,\n   428→    ) -> list[tuple[MemoryEntry, float]]:\n   429→        \"\"\"Epic 65.8: Run BM25 + vector search in parallel, merge with RRF.\"\"\"\n   430→        top_bm25 = 20\n   431→        top_vector = 20\n   432→        rrf_k = 60\n   433→        if self._hybrid_config is not None:\n   434→            top_bm25 = getattr(self._hybrid_config, \"top_bm25\", 20)\n   435→            top_vector = getattr(self._hybrid_config, \"top_vector\", 20)\n   436→            rrf_k = getattr(self._hybrid_config, \"rrf_k\", 60)\n   437→\n   438→        bm25_keys: list[str] = []\n   439→        vector_keys: list[str] = []\n   440→\n   441→        def run_bm25() -> None:\n   442→            nonlocal bm25_keys\n   443→            candidates = self._get_candidates(query, store)\n   444→            # Take top top_bm25 by score\n   445→            sorted_cands = sorted(\n   446→                candidates,\n   447→                key=lambda x: x[1],\n   448→                reverse=True,\n   449→            )[:top_bm25]\n   450→            bm25_keys = [e.key for e, _ in sorted_cands]\n   451→\n   452→        def run_vector() -> None:\n   453→            nonlocal vector_keys\n   454→            vector_results = self._vector_search(query, store, limit=top_vector)\n   455→            vector_keys = [k for k, _ in vector_results]\n   456→\n   457→        with ThreadPoolExecutor(max_workers=2) as ex:\n   458→            f1 = ex.submit(run_bm25)\n   459→            f2 = ex.submit(run_vector)\n   460→            for f in as_completed([f1, f2]):\n   461→                f.result()\n   462→\n   463→        from tapps_brain.fusion import reciprocal_rank_fusion\n   464→\n   465→        fused = reciprocal_rank_fusion(bm25_keys, vector_keys, k=rrf_k)\n   466→\n   467→        if not fused:\n   468→            return self._get_candidates(query, store)\n   469→\n   470→        entry_by_key = {e.key: e for e in store.list_all()}\n   471→        max_rrf = fused[0][1] if fused else 1.0\n   472→\n   473→        results: list[tuple[MemoryEntry, float]] = []\n   474→        for key, rrf_score in fused:\n   475→            entry = entry_by_key.get(key)\n   476→            if entry is None:\n   477→                continue\n   478→            relevance_raw = rrf_score / max_rrf if max_rrf > 0 else 0.0\n   479→            results.append((entry, relevance_raw))\n   480→\n   481→        return results\n   482→\n   483→    def _vector_search(\n   484→        self,\n   485→        query: str,\n   486→        store: MemoryStore,\n   487→        limit: int = 20,\n   488→    ) -> list[tuple[str, float]]:\n   489→        \"\"\"Epic 65.8: Embed query, cosine similarity with entry embeddings.\n   490→\n   491→        Uses on-the-fly embedding when stored embeddings are unavailable.\n   492→        Returns [(entry_key, score), ...] sorted by score descending.\n   493→        \"\"\"\n   494→        empty: list[tuple[str, float]] = []\n   495→\n   496→        try:\n   497→            from tapps_brain.embeddings import get_embedding_provider\n   498→\n   499→            embedder = get_embedding_provider(semantic_search_enabled=True)\n   500→        except ImportError:\n   501→            logger.debug(\"vector_search_embedder_unavailable\")\n   502→            return empty\n   503→        if embedder is None or not (all_entries := store.list_all()):\n   504→            return empty\n   505→\n   506→        texts = [self._entry_to_document(e) for e in all_entries]\n   507→        try:\n   508→            q = embedder.embed(query)\n   509→            entry_embs = embedder.embed_batch(texts)\n   510→        except Exception as e:\n   511→            logger.debug(\"vector_search_embed_failed\", error=str(e))\n   512→            return empty\n   513→\n   514→        if not q or len(entry_embs) != len(all_entries):\n   515→            return empty\n   516→        scored: list[tuple[str, float]] = []\n   517→        for i, entry in enumerate(all_entries):\n   518→            if i >= len(entry_embs):\n   519→                break\n   520→            emb = entry_embs[i]\n   521→            if len(emb) == len(q):\n   522→                sim = sum(a * b for a, b in zip(q, emb, strict=True))\n   523→                scored.append((entry.key, max(0.0, sim)))\n   524→        scored.sort(key=lambda x: x[1], reverse=True)\n   525→        return scored[:limit]\n   526→\n   527→    def _bm25_score_entries(\n   528→        self,\n   529→        query: str,\n   530→        entries: list[MemoryEntry],\n   531→        store: MemoryStore,\n   532→    ) -> list[tuple[MemoryEntry, float]]:\n   533→        \"\"\"Score a set of entries using BM25.\n   534→\n   535→        Builds the BM25 index over the full corpus (for proper IDF),\n   536→        then looks up scores for the given entries.\n   537→        \"\"\"\n   538→        try:\n   539→            all_entries = store.list_all()\n   540→            self._ensure_bm25_index(all_entries)\n   541→\n   542→            # Build a lookup: entry key -> index in corpus\n   543→            key_to_idx = {e.key: i for i, e in enumerate(self._bm25_entries)}\n   544→            all_scores = self._bm25.score(query)\n   545→\n   546→            results: list[tuple[MemoryEntry, float]] = []\n   547→            for entry in entries:\n   548→                idx = key_to_idx.get(entry.key)\n   549→                if idx is not None and idx < len(all_scores):\n   550→                    results.append((entry, all_scores[idx]))\n   551→                else:\n   552→                    # Entry not in index (new entry?), use word overlap\n   553→                    results.append((entry, self._word_overlap_score(query, entry)))\n   554→            return results\n   555→        except Exception:\n   556→            logger.debug(\"bm25_scoring_failed_using_word_overlap\", query=query)\n   557→            return [(entry, self._word_overlap_score(query, entry)) for entry in entries]\n   558→\n   559→    def _bm25_full_scan(\n   560→        self,\n   561→        query: str,\n   562→        store: MemoryStore,\n   563→    ) -> list[tuple[MemoryEntry, float]]:\n   564→        \"\"\"Full corpus BM25 scan as fallback.\n   565→\n   566→        Falls back to word overlap if BM25 fails.\n   567→        \"\"\"\n   568→        all_entries = store.list_all()\n   569→        if not all_entries:\n   570→            return []\n   571→\n   572→        try:\n   573→            self._ensure_bm25_index(all_entries)\n   574→            scores = self._bm25.score(query)\n   575→            return [\n   576→                (entry, score)\n   577→                for entry, score in zip(all_entries, scores, strict=True)\n   578→                if score > 0\n   579→            ]\n   580→        except Exception:\n   581→            logger.debug(\"bm25_full_scan_failed_using_word_overlap\", query=query)\n   582→            return self._like_search(query, store)\n   583→\n   584→    def _like_search(\n   585→        self,\n   586→        query: str,\n   587→        store: MemoryStore,\n   588→    ) -> list[tuple[MemoryEntry, float]]:\n   589→        \"\"\"Fallback LIKE-based search with simple word overlap scoring.\"\"\"\n   590→        query_words = set(query.lower().split())\n   591→        if not query_words:\n   592→            return []\n   593→\n   594→        all_entries = store.list_all()\n   595→        results: list[tuple[MemoryEntry, float]] = []\n   596→\n   597→        for entry in all_entries:\n   598→            relevance = self._word_overlap_score(query, entry)\n   599→            if relevance > 0:\n   600→                results.append((entry, relevance))\n   601→\n   602→        return results\n   603→\n   604→    # -----------------------------------------------------------------------\n   605→    # Scoring helpers\n   606→    # -----------------------------------------------------------------------\n   607→\n   608→    @staticmethod\n   609→    def _word_overlap_score(query: str, entry: MemoryEntry) -> float:\n   610→        \"\"\"Compute word overlap between query and entry text.\"\"\"\n   611→        query_words = set(query.lower().split())\n   612→        if not query_words:\n   613→            return 0.0\n   614→        entry_text = f\"{entry.key} {entry.value} {' '.join(entry.tags)}\".lower()\n   615→        entry_words = set(entry_text.split())\n   616→        overlap = len(query_words & entry_words)\n   617→        return overlap / len(query_words)\n   618→\n   619→    def _normalize_relevance(self, raw_score: float) -> float:\n   620→        \"\"\"Normalize relevance score to 0.0-1.0 range.\n   621→\n   622→        Uses sigmoid normalization: ``score / (score + K)`` where\n   623→        K defaults to 5.0, tuned for BM25 scores (typical range 0-15+).\n   624→        A BM25 score of K maps to 0.5 normalized. K is configurable\n   625→        via ``scoring_config.bm25_norm_k`` (EPIC-010).\n   626→        \"\"\"\n   627→        if raw_score <= 0:\n   628→            return 0.0\n   629→        return raw_score / (raw_score + self._bm25_norm_k)\n   630→\n   631→    @staticmethod\n   632→    def _recency_score(entry: MemoryEntry, now: datetime) -> float:\n   633→        \"\"\"Compute recency score: ``1.0 / (1.0 + days_since_updated)``.\"\"\"\n   634→        try:\n   635→            updated = datetime.fromisoformat(entry.updated_at)\n   636→            if updated.tzinfo is None:\n   637→                updated = updated.replace(tzinfo=UTC)\n   638→        except (ValueError, TypeError):\n   639→            return 0.5\n   640→        days = max((now - updated).total_seconds() / 86400.0, 0.0)\n   641→        return 1.0 / (1.0 + days)\n   642→\n   643→    def _frequency_score(self, entry: MemoryEntry) -> float:\n   644→        \"\"\"Compute access frequency score: ``min(1.0, access_count / cap)``.\n   645→\n   646→        The frequency cap defaults to 20.0 and is configurable via\n   647→        ``scoring_config.frequency_cap`` (EPIC-010).\n   648→        \"\"\"\n   649→        return min(1.0, entry.access_count / self._frequency_cap)\n   650→"}]},"parent_tool_use_id":"toolu_01KJomf8MxPhmjTE3TX6wPks","session_id":"327621aa-924c-4bfb-b348-3a4acf890b54","uuid":"ba1eef75-9480-4315-bfce-ecfe5e1ea880","timestamp":"2026-03-22T22:37:59.695Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018qYY8DpQtA1QxiFXabF3xN","type":"tool_result","content":"     1→\"\"\"SQLite-backed persistence layer for the shared memory subsystem.\n     2→\n     3→Uses WAL journal mode for concurrent reads during writes, FTS5 for\n     4→full-text search, and schema versioning with forward migrations.\n     5→A JSONL audit log is maintained for debugging/compliance (append-only).\n     6→\"\"\"\n     7→\n     8→from __future__ import annotations\n     9→\n    10→import json\n    11→import logging\n    12→import sqlite3\n    13→import threading\n    14→from datetime import UTC, datetime\n    15→from typing import TYPE_CHECKING, Any\n    16→\n    17→import structlog\n    18→\n    19→if TYPE_CHECKING:\n    20→    from pathlib import Path\n    21→\n    22→    from tapps_brain.relations import RelationEntry\n    23→\n    24→from tapps_brain.models import MemoryEntry\n    25→\n    26→logger = structlog.get_logger(__name__)\n    27→\n    28→# Current schema version - bump when adding migrations.\n    29→_SCHEMA_VERSION = 8\n    30→\n    31→# Previous schema versions for migration checks.\n    32→_SCHEMA_V2 = 2\n    33→_SCHEMA_V3 = 3\n    34→_SCHEMA_V4 = 4\n    35→_SCHEMA_V5 = 5\n    36→_SCHEMA_V6 = 6\n    37→_SCHEMA_V7 = 7\n    38→_SCHEMA_V8 = 8\n    39→\n    40→# Maximum JSONL audit log lines before truncation.\n    41→_MAX_AUDIT_LINES = 10_000\n    42→\n    43→\n    44→class MemoryPersistence:\n    45→    \"\"\"SQLite-backed persistence for memory entries.\n    46→\n    47→    Storage directory: ``{project_root}/{store_dir}/memory/``\n    48→\n    49→    Default store_dir is ``.tapps-brain`` for standalone use.\n    50→    TappsMCP passes ``.tapps-mcp`` for backward compatibility.\n    51→\n    52→    Files:\n    53→    - ``memory.db`` -- SQLite database (WAL mode, FTS5)\n    54→    - ``memory_log.jsonl`` -- append-only audit log\n    55→    \"\"\"\n    56→\n    57→    def __init__(self, project_root: Path, *, store_dir: str = \".tapps-brain\") -> None:\n    58→        self._store_dir = project_root / store_dir / \"memory\"\n    59→        self._store_dir.mkdir(parents=True, exist_ok=True)\n    60→        self._db_path = self._store_dir / \"memory.db\"\n    61→        self._audit_path = self._store_dir / \"memory_log.jsonl\"\n    62→        self._lock = threading.Lock()\n    63→\n    64→        try:\n    65→            self._conn = self._connect()\n    66→            self._ensure_schema()\n    67→        except sqlite3.DatabaseError as exc:\n    68→            _msg = f\"Database corrupt: {self._db_path}. Back up and delete to recover.\"\n    69→            # Emit via stdlib logging so pytest caplog can capture it in tests\n    70→            logging.getLogger(__name__).error(\"database_corrupt: %s\", _msg, exc_info=exc)\n    71→            logger.error(\n    72→                \"database_corrupt\",\n    73→                path=str(self._db_path),\n    74→                message=_msg,\n    75→            )\n    76→            raise\n    77→\n    78→    # ------------------------------------------------------------------\n    79→    # Connection and schema\n    80→    # ------------------------------------------------------------------\n    81→\n    82→    def _connect(self) -> sqlite3.Connection:\n    83→        \"\"\"Open a SQLite connection with recommended pragmas.\"\"\"\n    84→        conn = sqlite3.connect(\n    85→            str(self._db_path),\n    86→            check_same_thread=False,\n    87→        )\n    88→        conn.row_factory = sqlite3.Row\n    89→        conn.execute(\"PRAGMA journal_mode=WAL\")\n    90→        conn.execute(\"PRAGMA busy_timeout=5000\")\n    91→        conn.execute(\"PRAGMA foreign_keys=ON\")\n    92→        return conn\n    93→\n    94→    def _ensure_schema(self) -> None:\n    95→        \"\"\"Create tables if absent and apply forward migrations.\"\"\"\n    96→        with self._lock:\n    97→            cur = self._conn.cursor()\n    98→\n    99→            # Schema version table\n   100→            cur.execute(\n   101→                \"CREATE TABLE IF NOT EXISTS schema_version \"\n   102→                \"(version INTEGER NOT NULL, migrated_at TEXT NOT NULL)\"\n   103→            )\n   104→\n   105→            # Check current version\n   106→            row = cur.execute(\"SELECT MAX(version) FROM schema_version\").fetchone()\n   107→            current_version: int = row[0] if row[0] is not None else 0\n   108→\n   109→            if current_version < 1:\n   110→                self._create_v1_schema(cur)\n   111→\n   112→            if current_version < _SCHEMA_V2:\n   113→                self._migrate_v1_to_v2(cur)\n   114→            if current_version < _SCHEMA_V3:\n   115→                self._migrate_v2_to_v3(cur)\n   116→            if current_version < _SCHEMA_V4:\n   117→                self._migrate_v3_to_v4(cur)\n   118→            if current_version < _SCHEMA_V5:\n   119→                self._migrate_v4_to_v5(cur)\n   120→            if current_version < _SCHEMA_V6:\n   121→                self._migrate_v5_to_v6(cur)\n   122→            if current_version < _SCHEMA_V7:\n   123→                self._migrate_v6_to_v7(cur)\n   124→            if current_version < _SCHEMA_V8:\n   125→                self._migrate_v7_to_v8(cur)\n   126→\n   127→            self._conn.commit()\n   128→\n   129→    def _create_v1_schema(self, cur: sqlite3.Cursor) -> None:\n   130→        \"\"\"Create the initial v1 schema.\"\"\"\n   131→        # Main memories table\n   132→        cur.execute(\"\"\"\n   133→            CREATE TABLE IF NOT EXISTS memories (\n   134→                key TEXT NOT NULL,\n   135→                value TEXT NOT NULL,\n   136→                tier TEXT NOT NULL DEFAULT 'pattern',\n   137→                confidence REAL NOT NULL DEFAULT 0.6,\n   138→                source TEXT NOT NULL DEFAULT 'agent',\n   139→                source_agent TEXT NOT NULL DEFAULT 'unknown',\n   140→                scope TEXT NOT NULL DEFAULT 'project',\n   141→                tags TEXT NOT NULL DEFAULT '[]',\n   142→                created_at TEXT NOT NULL,\n   143→                updated_at TEXT NOT NULL,\n   144→                last_accessed TEXT NOT NULL,\n   145→                access_count INTEGER NOT NULL DEFAULT 0,\n   146→                branch TEXT,\n   147→                last_reinforced TEXT,\n   148→                reinforce_count INTEGER NOT NULL DEFAULT 0,\n   149→                contradicted INTEGER NOT NULL DEFAULT 0,\n   150→                contradiction_reason TEXT,\n   151→                seeded_from TEXT,\n   152→                PRIMARY KEY (key)\n   153→            )\n   154→        \"\"\")\n   155→\n   156→        # Indexes for common queries\n   157→        cur.execute(\"CREATE INDEX IF NOT EXISTS idx_memories_tier ON memories(tier)\")\n   158→        cur.execute(\"CREATE INDEX IF NOT EXISTS idx_memories_scope ON memories(scope)\")\n   159→        cur.execute(\"CREATE INDEX IF NOT EXISTS idx_memories_confidence ON memories(confidence)\")\n   160→\n   161→        # FTS5 full-text search index\n   162→        cur.execute(\"\"\"\n   163→            CREATE VIRTUAL TABLE IF NOT EXISTS memories_fts\n   164→            USING fts5(key, value, tags, content=memories, content_rowid=rowid)\n   165→        \"\"\")\n   166→\n   167→        # Triggers to keep FTS in sync\n   168→        cur.execute(\"\"\"\n   169→            CREATE TRIGGER IF NOT EXISTS memories_ai AFTER INSERT ON memories BEGIN\n   170→                INSERT INTO memories_fts(rowid, key, value, tags)\n   171→                VALUES (new.rowid, new.key, new.value, new.tags);\n   172→            END\n   173→        \"\"\")\n   174→        cur.execute(\"\"\"\n   175→            CREATE TRIGGER IF NOT EXISTS memories_ad AFTER DELETE ON memories BEGIN\n   176→                INSERT INTO memories_fts(memories_fts, rowid, key, value, tags)\n   177→                VALUES ('delete', old.rowid, old.key, old.value, old.tags);\n   178→            END\n   179→        \"\"\")\n   180→        cur.execute(\"\"\"\n   181→            CREATE TRIGGER IF NOT EXISTS memories_au AFTER UPDATE ON memories BEGIN\n   182→                INSERT INTO memories_fts(memories_fts, rowid, key, value, tags)\n   183→                VALUES ('delete', old.rowid, old.key, old.value, old.tags);\n   184→                INSERT INTO memories_fts(rowid, key, value, tags)\n   185→                VALUES (new.rowid, new.key, new.value, new.tags);\n   186→            END\n   187→        \"\"\")\n   188→\n   189→        # Reserved for Epic 24 GC\n   190→        cur.execute(\"\"\"\n   191→            CREATE TABLE IF NOT EXISTS archived_memories (\n   192→                key TEXT NOT NULL,\n   193→                value TEXT NOT NULL,\n   194→                tier TEXT NOT NULL,\n   195→                confidence REAL NOT NULL,\n   196→                source TEXT NOT NULL,\n   197→                source_agent TEXT NOT NULL,\n   198→                scope TEXT NOT NULL,\n   199→                tags TEXT NOT NULL DEFAULT '[]',\n   200→                created_at TEXT NOT NULL,\n   201→                updated_at TEXT NOT NULL,\n   202→                last_accessed TEXT NOT NULL,\n   203→                access_count INTEGER NOT NULL DEFAULT 0,\n   204→                branch TEXT,\n   205→                last_reinforced TEXT,\n   206→                reinforce_count INTEGER NOT NULL DEFAULT 0,\n   207→                contradicted INTEGER NOT NULL DEFAULT 0,\n   208→                contradiction_reason TEXT,\n   209→                seeded_from TEXT,\n   210→                archived_at TEXT NOT NULL\n   211→            )\n   212→        \"\"\")\n   213→\n   214→        # Record schema version\n   215→        cur.execute(\n   216→            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n   217→            (1, datetime.now(tz=UTC).isoformat()),\n   218→        )\n   219→\n   220→    def _migrate_v1_to_v2(self, cur: sqlite3.Cursor) -> None:\n   221→        \"\"\"Add optional embedding column for semantic search (Epic 65.7).\n   222→\n   223→        Stores JSON array of floats. Existing rows get NULL.\n   224→        \"\"\"\n   225→        try:\n   226→            cur.execute(\"ALTER TABLE memories ADD COLUMN embedding TEXT\")\n   227→        except sqlite3.OperationalError as e:\n   228→            if \"duplicate column name\" in str(e).lower():\n   229→                pass  # Column already exists\n   230→            else:\n   231→                raise\n   232→\n   233→        cur.execute(\n   234→            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n   235→            (2, datetime.now(tz=UTC).isoformat()),\n   236→        )\n   237→\n   238→    def _migrate_v2_to_v3(self, cur: sqlite3.Cursor) -> None:\n   239→        \"\"\"Add session_index table for searchable session chunks (Epic 65.10).\"\"\"\n   240→        cur.execute(\"\"\"\n   241→            CREATE TABLE IF NOT EXISTS session_index (\n   242→                session_id TEXT NOT NULL,\n   243→                chunk_index INTEGER NOT NULL,\n   244→                content TEXT NOT NULL,\n   245→                created_at TEXT NOT NULL,\n   246→                PRIMARY KEY (session_id, chunk_index)\n   247→            )\n   248→        \"\"\")\n   249→        cur.execute(\n   250→            \"CREATE INDEX IF NOT EXISTS idx_session_index_session ON session_index(session_id)\"\n   251→        )\n   252→        cur.execute(\"\"\"\n   253→            CREATE VIRTUAL TABLE IF NOT EXISTS session_index_fts\n   254→            USING fts5(session_id, content, content=session_index, content_rowid=rowid)\n   255→        \"\"\")\n   256→        cur.execute(\"\"\"\n   257→            CREATE TRIGGER IF NOT EXISTS session_index_ai AFTER INSERT ON session_index BEGIN\n   258→                INSERT INTO session_index_fts(rowid, session_id, content)\n   259→                VALUES (new.rowid, new.session_id, new.content);\n   260→            END\n   261→        \"\"\")\n   262→        cur.execute(\"\"\"\n   263→            CREATE TRIGGER IF NOT EXISTS session_index_ad AFTER DELETE ON session_index BEGIN\n   264→                INSERT INTO session_index_fts(session_index_fts, rowid, session_id, content)\n   265→                VALUES ('delete', old.rowid, old.session_id, old.content);\n   266→            END\n   267→        \"\"\")\n   268→        cur.execute(\"\"\"\n   269→            CREATE TRIGGER IF NOT EXISTS session_index_au AFTER UPDATE ON session_index BEGIN\n   270→                INSERT INTO session_index_fts(session_index_fts, rowid, session_id, content)\n   271→                VALUES ('delete', old.rowid, old.session_id, old.content);\n   272→                INSERT INTO session_index_fts(rowid, session_id, content)\n   273→                VALUES (new.rowid, new.session_id, new.content);\n   274→            END\n   275→        \"\"\")\n   276→        cur.execute(\n   277→            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n   278→            (3, datetime.now(tz=UTC).isoformat()),\n   279→        )\n   280→\n   281→    def _migrate_v3_to_v4(self, cur: sqlite3.Cursor) -> None:\n   282→        \"\"\"Add relations table for entity/relationship extraction (Epic 65.12).\"\"\"\n   283→        cur.execute(\"\"\"\n   284→            CREATE TABLE IF NOT EXISTS relations (\n   285→                subject TEXT NOT NULL,\n   286→                predicate TEXT NOT NULL,\n   287→                object_entity TEXT NOT NULL,\n   288→                source_entry_keys TEXT NOT NULL DEFAULT '[]',\n   289→                confidence REAL NOT NULL DEFAULT 0.8,\n   290→                created_at TEXT NOT NULL,\n   291→                PRIMARY KEY (subject, predicate, object_entity)\n   292→            )\n   293→        \"\"\")\n   294→        cur.execute(\"CREATE INDEX IF NOT EXISTS idx_relations_subject ON relations(subject)\")\n   295→        cur.execute(\"CREATE INDEX IF NOT EXISTS idx_relations_object ON relations(object_entity)\")\n   296→        cur.execute(\n   297→            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n   298→            (4, datetime.now(tz=UTC).isoformat()),\n   299→        )\n   300→\n   301→    def _migrate_v4_to_v5(self, cur: sqlite3.Cursor) -> None:\n   302→        \"\"\"Add bi-temporal columns for validity windows (EPIC-004).\n   303→\n   304→        Adds ``valid_at``, ``invalid_at``, ``superseded_by`` to memories\n   305→        and creates an index for temporal queries.\n   306→        \"\"\"\n   307→        for col in (\"valid_at\", \"invalid_at\", \"superseded_by\"):\n   308→            try:\n   309→                cur.execute(f\"ALTER TABLE memories ADD COLUMN {col} TEXT\")\n   310→            except sqlite3.OperationalError as e:\n   311→                if \"duplicate column name\" not in str(e).lower():\n   312→                    raise\n   313→\n   314→        cur.execute(\n   315→            \"CREATE INDEX IF NOT EXISTS idx_memories_temporal ON memories(valid_at, invalid_at)\"\n   316→        )\n   317→\n   318→        cur.execute(\n   319→            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n   320→            (5, datetime.now(tz=UTC).isoformat()),\n   321→        )\n   322→\n   323→    def _migrate_v5_to_v6(self, cur: sqlite3.Cursor) -> None:\n   324→        \"\"\"Schema v6 — observability hooks / version bump (EPIC-007).\n   325→\n   326→        No SQLite shape changes; bumps version so tooling can detect v6 stores.\n   327→        \"\"\"\n   328→        cur.execute(\n   329→            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n   330→            (6, datetime.now(tz=UTC).isoformat()),\n   331→        )\n   332→\n   333→    def _migrate_v6_to_v7(self, cur: sqlite3.Cursor) -> None:\n   334→        \"\"\"Add agent_scope column for Hive propagation (EPIC-011).\n   335→\n   336→        Adds ``agent_scope TEXT DEFAULT 'private'`` to memories table.\n   337→        Existing entries default to ``'private'`` (no Hive propagation).\n   338→        \"\"\"\n   339→        try:\n   340→            cur.execute(\"ALTER TABLE memories ADD COLUMN agent_scope TEXT DEFAULT 'private'\")\n   341→        except sqlite3.OperationalError as e:\n   342→            if \"duplicate column name\" not in str(e).lower():\n   343→                raise\n   344→\n   345→        cur.execute(\n   346→            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n   347→            (7, datetime.now(tz=UTC).isoformat()),\n   348→        )\n   349→\n   350→    def _migrate_v7_to_v8(self, cur: sqlite3.Cursor) -> None:\n   351→        \"\"\"Add integrity_hash column for tamper detection (H4a).\n   352→\n   353→        Stores HMAC-SHA256 hex digest computed over key|value|tier|source.\n   354→        Existing rows get NULL (hash computed on next save/update).\n   355→        \"\"\"\n   356→        try:\n   357→            cur.execute(\"ALTER TABLE memories ADD COLUMN integrity_hash TEXT\")\n   358→        except sqlite3.OperationalError as e:\n   359→            if \"duplicate column name\" not in str(e).lower():\n   360→                raise\n   361→\n   362→        cur.execute(\n   363→            \"INSERT INTO schema_version (version, migrated_at) VALUES (?, ?)\",\n   364→            (8, datetime.now(tz=UTC).isoformat()),\n   365→        )\n   366→\n   367→    def migrate_contradicted_to_temporal(self) -> int:\n   368→        \"\"\"Migrate ``contradicted`` entries with \"consolidated into\" to temporal fields.\n   369→\n   370→        For each entry where ``contradicted=1`` and ``contradiction_reason``\n   371→        matches ``consolidated into {key}``, sets ``invalid_at = updated_at``\n   372→        and ``superseded_by = {key}``.\n   373→\n   374→        Returns:\n   375→            Number of entries migrated.\n   376→        \"\"\"\n   377→        import re as _re\n   378→\n   379→        pattern = _re.compile(r\"consolidated into (\\S+)\", _re.IGNORECASE)\n   380→        count = 0\n   381→\n   382→        with self._lock:\n   383→            rows = self._conn.execute(\n   384→                \"SELECT key, updated_at, contradiction_reason, invalid_at \"\n   385→                \"FROM memories WHERE contradicted = 1 AND contradiction_reason IS NOT NULL\"\n   386→            ).fetchall()\n   387→\n   388→            for row in rows:\n   389→                # Skip if already migrated\n   390→                if row[\"invalid_at\"] is not None:\n   391→                    continue\n   392→                reason = row[\"contradiction_reason\"] or \"\"\n   393→                match = pattern.search(reason)\n   394→                if not match:\n   395→                    continue\n   396→                target_key = match.group(1)\n   397→                self._conn.execute(\n   398→                    \"UPDATE memories SET invalid_at = ?, superseded_by = ? WHERE key = ?\",\n   399→                    (row[\"updated_at\"], target_key, row[\"key\"]),\n   400→                )\n   401→                count += 1\n   402→\n   403→            if count > 0:\n   404→                self._conn.commit()\n   405→\n   406→        return count\n   407→\n   408→    # ------------------------------------------------------------------\n   409→    # CRUD operations\n   410→    # ------------------------------------------------------------------\n   411→\n   412→    def save(self, entry: MemoryEntry) -> None:\n   413→        \"\"\"Insert or replace a memory entry.\"\"\"\n   414→        tags_json = json.dumps(entry.tags, ensure_ascii=False)\n   415→        embedding_json: str | None = None\n   416→        if entry.embedding is not None:\n   417→            embedding_json = json.dumps(entry.embedding, ensure_ascii=False)\n   418→\n   419→        columns = [\n   420→            \"key\",\n   421→            \"value\",\n   422→            \"tier\",\n   423→            \"confidence\",\n   424→            \"source\",\n   425→            \"source_agent\",\n   426→            \"scope\",\n   427→            \"tags\",\n   428→            \"created_at\",\n   429→            \"updated_at\",\n   430→            \"last_accessed\",\n   431→            \"access_count\",\n   432→            \"branch\",\n   433→            \"last_reinforced\",\n   434→            \"reinforce_count\",\n   435→            \"contradicted\",\n   436→            \"contradiction_reason\",\n   437→            \"seeded_from\",\n   438→        ]\n   439→        placeholders = \", \".join(\"?\" * len(columns))\n   440→        values: tuple[Any, ...] = (\n   441→            entry.key,\n   442→            entry.value,\n   443→            entry.tier.value if hasattr(entry.tier, \"value\") else str(entry.tier),\n   444→            entry.confidence,\n   445→            entry.source.value,\n   446→            entry.source_agent,\n   447→            entry.scope.value,\n   448→            tags_json,\n   449→            entry.created_at,\n   450→            entry.updated_at,\n   451→            entry.last_accessed,\n   452→            entry.access_count,\n   453→            entry.branch,\n   454→            entry.last_reinforced,\n   455→            entry.reinforce_count,\n   456→            1 if entry.contradicted else 0,\n   457→            entry.contradiction_reason,\n   458→            entry.seeded_from,\n   459→        )\n   460→\n   461→        # Include embedding if schema supports it (v2+)\n   462→        schema_ver = self.get_schema_version()\n   463→        if schema_ver >= _SCHEMA_V4:\n   464→            columns.append(\"embedding\")\n   465→            values = (*values, embedding_json)\n   466→\n   467→        # Include temporal fields if schema supports it (v5+)\n   468→        if schema_ver >= _SCHEMA_V5:\n   469→            columns.extend([\"valid_at\", \"invalid_at\", \"superseded_by\"])\n   470→            values = (*values, entry.valid_at, entry.invalid_at, entry.superseded_by)\n   471→\n   472→        # Include agent_scope if schema supports it (v7+)\n   473→        if schema_ver >= _SCHEMA_V7:\n   474→            columns.append(\"agent_scope\")\n   475→            values = (*values, entry.agent_scope)\n   476→\n   477→        # Compute and include integrity hash if schema supports it (v8+)\n   478→        if schema_ver >= _SCHEMA_V8:\n   479→            from tapps_brain.integrity import compute_integrity_hash\n   480→\n   481→            tier_str = entry.tier.value if hasattr(entry.tier, \"value\") else str(entry.tier)\n   482→            source_str = entry.source.value if hasattr(entry.source, \"value\") else str(entry.source)\n   483→            integrity_hash = compute_integrity_hash(\n   484→                entry.key, entry.value, tier_str, source_str\n   485→            )\n   486→            columns.append(\"integrity_hash\")\n   487→            values = (*values, integrity_hash)\n   488→\n   489→        placeholders = \", \".join(\"?\" * len(columns))\n   490→\n   491→        cols = \", \".join(columns)\n   492→        with self._lock:\n   493→            self._conn.execute(\n   494→                f\"INSERT OR REPLACE INTO memories ({cols}) VALUES ({placeholders})\",\n   495→                values,\n   496→            )\n   497→            self._conn.commit()\n   498→        self._audit_log(\"save\", entry.key)\n   499→\n   500→    def get(self, key: str) -> MemoryEntry | None:\n   501→        \"\"\"Retrieve a single memory entry by key.\"\"\"\n   502→        with self._lock:\n   503→            row = self._conn.execute(\"SELECT * FROM memories WHERE key = ?\", (key,)).fetchone()\n   504→        if row is None:\n   505→            return None\n   506→        return self._row_to_entry(row)\n   507→\n   508→    def list_all(\n   509→        self,\n   510→        tier: str | None = None,\n   511→        scope: str | None = None,\n   512→        tags: list[str] | None = None,\n   513→    ) -> list[MemoryEntry]:\n   514→        \"\"\"List entries with optional filters.\"\"\"\n   515→        query = \"SELECT * FROM memories WHERE 1=1\"\n   516→        params: list[Any] = []\n   517→\n   518→        if tier is not None:\n   519→            query += \" AND tier = ?\"\n   520→            params.append(tier)\n   521→        if scope is not None:\n   522→            query += \" AND scope = ?\"\n   523→            params.append(scope)\n   524→\n   525→        with self._lock:\n   526→            rows = self._conn.execute(query, params).fetchall()\n   527→\n   528→        entries = [self._row_to_entry(r) for r in rows]\n   529→\n   530→        # Filter by tags in Python (tags stored as JSON array)\n   531→        if tags:\n   532→            tag_set = set(tags)\n   533→            entries = [e for e in entries if tag_set.intersection(e.tags)]\n   534→\n   535→        return entries\n   536→\n   537→    def delete(self, key: str) -> bool:\n   538→        \"\"\"Delete a memory entry by key. Returns True if deleted.\"\"\"\n   539→        with self._lock:\n   540→            cur = self._conn.execute(\"DELETE FROM memories WHERE key = ?\", (key,))\n   541→            self._conn.commit()\n   542→        deleted = cur.rowcount > 0\n   543→        if deleted:\n   544→            self._audit_log(\"delete\", key)\n   545→        return deleted\n   546→\n   547→    def search(self, query: str) -> list[MemoryEntry]:\n   548→        \"\"\"Full-text search via FTS5 across key, value, and tags.\"\"\"\n   549→        if not query.strip():\n   550→            return []\n   551→\n   552→        # Escape FTS5 special characters for safety\n   553→        safe_query = self._escape_fts_query(query)\n   554→        if not safe_query:\n   555→            return []\n   556→\n   557→        with self._lock:\n   558→            try:\n   559→                rows = self._conn.execute(\n   560→                    \"\"\"\n   561→                    SELECT m.* FROM memories m\n   562→                    JOIN memories_fts fts ON m.rowid = fts.rowid\n   563→                    WHERE memories_fts MATCH ?\n   564→                    \"\"\",\n   565→                    (safe_query,),\n   566→                ).fetchall()\n   567→            except sqlite3.OperationalError:\n   568→                logger.debug(\"fts_search_failed\", query=query)\n   569→                return []\n   570→\n   571→        return [self._row_to_entry(r) for r in rows]\n   572→\n   573→    def load_all(self) -> list[MemoryEntry]:\n   574→        \"\"\"Load all entries (for cold-start into in-memory cache).\"\"\"\n   575→        with self._lock:\n   576→            rows = self._conn.execute(\"SELECT * FROM memories\").fetchall()\n   577→        return [self._row_to_entry(r) for r in rows]\n   578→\n   579→    def count(self) -> int:\n   580→        \"\"\"Return the total number of memory entries.\"\"\"\n   581→        with self._lock:\n   582→            row = self._conn.execute(\"SELECT COUNT(*) FROM memories\").fetchone()\n   583→        return int(row[0]) if row else 0\n   584→\n   585→    def get_schema_version(self) -> int:\n   586→        \"\"\"Return the current schema version.\"\"\"\n   587→        with self._lock:\n   588→            row = self._conn.execute(\"SELECT MAX(version) FROM schema_version\").fetchone()\n   589→        return int(row[0]) if row and row[0] is not None else 0\n   590→\n   591→    def close(self) -> None:\n   592→        \"\"\"Close the database connection.\"\"\"\n   593→        with self._lock:\n   594→            self._conn.close()\n   595→\n   596→    # ------------------------------------------------------------------\n   597→    # Session index (Epic 65.10)\n   598→    # ------------------------------------------------------------------\n   599→\n   600→    def save_session_chunks(\n   601→        self,\n   602→        session_id: str,\n   603→        chunks: list[str],\n   604→        *,\n   605→        max_chunks: int = 50,\n   606→        max_chars_per_chunk: int = 500,\n   607→    ) -> int:\n   608→        \"\"\"Store session chunks for indexing. Returns count stored.\"\"\"\n   609→        if not chunks or not session_id.strip():\n   610→            return 0\n   611→        now = datetime.now(tz=UTC).isoformat()\n   612→        stored = 0\n   613→        with self._lock:\n   614→            for i, raw in enumerate(chunks[:max_chunks]):\n   615→                content = (raw or \"\")[:max_chars_per_chunk].strip()\n   616→                if not content:\n   617→                    continue\n   618→                try:\n   619→                    self._conn.execute(\n   620→                        \"\"\"\n   621→                        INSERT OR REPLACE INTO session_index\n   622→                        (session_id, chunk_index, content, created_at)\n   623→                        VALUES (?, ?, ?, ?)\n   624→                        \"\"\",\n   625→                        (session_id, i, content, now),\n   626→                    )\n   627→                    stored += 1\n   628→                except sqlite3.IntegrityError:\n   629→                    pass\n   630→            self._conn.commit()\n   631→        return stored\n   632→\n   633→    def search_session_index(self, query: str, limit: int = 10) -> list[dict[str, Any]]:\n   634→        \"\"\"Full-text search session index.\n   635→\n   636→        Returns list of {session_id, chunk_index, content, created_at}.\n   637→        \"\"\"\n   638→        if not query or not query.strip():\n   639→            return []\n   640→        safe = self._escape_fts_query(query)\n   641→        if not safe:\n   642→            return []\n   643→        with self._lock:\n   644→            try:\n   645→                rows = self._conn.execute(\n   646→                    \"\"\"\n   647→                    SELECT s.session_id, s.chunk_index, s.content, s.created_at\n   648→                    FROM session_index s\n   649→                    JOIN session_index_fts fts ON s.rowid = fts.rowid\n   650→                    WHERE session_index_fts MATCH ?\n   651→                    ORDER BY s.created_at DESC\n   652→                    LIMIT ?\n   653→                    \"\"\",\n   654→                    (safe, limit),\n   655→                ).fetchall()\n   656→            except sqlite3.OperationalError:\n   657→                logger.debug(\"session_index_fts_search_failed\", query=query)\n   658→                return []\n   659→        return [\n   660→            {\n   661→                \"session_id\": r[\"session_id\"],\n   662→                \"chunk_index\": r[\"chunk_index\"],\n   663→                \"content\": r[\"content\"],\n   664→                \"created_at\": r[\"created_at\"],\n   665→            }\n   666→            for r in rows\n   667→        ]\n   668→\n   669→    def delete_expired_session_chunks(self, ttl_days: int) -> int:\n   670→        \"\"\"Delete session chunks older than ttl_days. Returns count deleted.\"\"\"\n   671→        from datetime import timedelta\n   672→\n   673→        cutoff = (datetime.now(tz=UTC) - timedelta(days=ttl_days)).isoformat()\n   674→        with self._lock:\n   675→            cur = self._conn.execute(\"DELETE FROM session_index WHERE created_at < ?\", (cutoff,))\n   676→            self._conn.commit()\n   677→            return cur.rowcount\n   678→\n   679→    def count_session_chunks(self) -> int:\n   680→        \"\"\"Return total session index chunk count.\"\"\"\n   681→        with self._lock:\n   682→            row = self._conn.execute(\"SELECT COUNT(*) FROM session_index\").fetchone()\n   683→        return int(row[0]) if row else 0\n   684→\n   685→    # ------------------------------------------------------------------\n   686→    # Relations (Epic 65.12)\n   687→    # ------------------------------------------------------------------\n   688→\n   689→    def save_relation(\n   690→        self,\n   691→        subject: str,\n   692→        predicate: str,\n   693→        object_entity: str,\n   694→        source_entry_keys: list[str],\n   695→        confidence: float = 0.8,\n   696→    ) -> None:\n   697→        \"\"\"Insert or replace a relation triple.\"\"\"\n   698→        keys_json = json.dumps(source_entry_keys, ensure_ascii=False)\n   699→        now = datetime.now(tz=UTC).isoformat()\n   700→        with self._lock:\n   701→            self._conn.execute(\n   702→                \"INSERT OR REPLACE INTO relations \"\n   703→                \"(subject, predicate, object_entity, source_entry_keys, confidence, created_at) \"\n   704→                \"VALUES (?, ?, ?, ?, ?, ?)\",\n   705→                (subject, predicate, object_entity, keys_json, confidence, now),\n   706→            )\n   707→            self._conn.commit()\n   708→\n   709→    def list_relations(self) -> list[dict[str, Any]]:\n   710→        \"\"\"Return all stored relations as dicts.\"\"\"\n   711→        with self._lock:\n   712→            rows = self._conn.execute(\"SELECT * FROM relations\").fetchall()\n   713→        results: list[dict[str, Any]] = []\n   714→        for r in rows:\n   715→            try:\n   716→                keys = json.loads(r[\"source_entry_keys\"])\n   717→            except (json.JSONDecodeError, TypeError):\n   718→                keys = []\n   719→            results.append(\n   720→                {\n   721→                    \"subject\": r[\"subject\"],\n   722→                    \"predicate\": r[\"predicate\"],\n   723→                    \"object_entity\": r[\"object_entity\"],\n   724→                    \"source_entry_keys\": keys,\n   725→                    \"confidence\": r[\"confidence\"],\n   726→                    \"created_at\": r[\"created_at\"],\n   727→                }\n   728→            )\n   729→        return results\n   730→\n   731→    def count_relations(self) -> int:\n   732→        \"\"\"Return the total number of stored relations.\"\"\"\n   733→        with self._lock:\n   734→            row = self._conn.execute(\"SELECT COUNT(*) FROM relations\").fetchone()\n   735→        return int(row[0]) if row else 0\n   736→\n   737→    def save_relations(self, key: str, relations: list[RelationEntry]) -> int:\n   738→        \"\"\"Batch-save relations linked to a memory entry key.\n   739→\n   740→        Each relation's ``source_entry_keys`` is ensured to contain *key*.\n   741→        Existing triples are updated (INSERT OR REPLACE).\n   742→\n   743→        Returns:\n   744→            Number of relations saved.\n   745→        \"\"\"\n   746→        if not relations:\n   747→            return 0\n   748→        now = datetime.now(tz=UTC).isoformat()\n   749→        count = 0\n   750→        with self._lock:\n   751→            for rel in relations:\n   752→                source_keys = list(dict.fromkeys([*rel.source_entry_keys, key]))\n   753→                keys_json = json.dumps(source_keys, ensure_ascii=False)\n   754→                self._conn.execute(\n   755→                    \"INSERT OR REPLACE INTO relations \"\n   756→                    \"(subject, predicate, object_entity, source_entry_keys, \"\n   757→                    \"confidence, created_at) VALUES (?, ?, ?, ?, ?, ?)\",\n   758→                    (\n   759→                        rel.subject,\n   760→                        rel.predicate,\n   761→                        rel.object_entity,\n   762→                        keys_json,\n   763→                        rel.confidence,\n   764→                        now,\n   765→                    ),\n   766→                )\n   767→                count += 1\n   768→            self._conn.commit()\n   769→        return count\n   770→\n   771→    def load_relations(self, key: str) -> list[dict[str, Any]]:\n   772→        \"\"\"Load all relations whose ``source_entry_keys`` contains *key*.\"\"\"\n   773→        all_relations = self.list_relations()\n   774→        return [r for r in all_relations if key in r[\"source_entry_keys\"]]\n   775→\n   776→    def delete_relations(self, key: str) -> int:\n   777→        \"\"\"Delete all relations whose ``source_entry_keys`` contains *key*.\n   778→\n   779→        Returns:\n   780→            Number of relations deleted.\n   781→        \"\"\"\n   782→        with self._lock:\n   783→            rows = self._conn.execute(\"SELECT * FROM relations\").fetchall()\n   784→            count = 0\n   785→            for r in rows:\n   786→                try:\n   787→                    keys = json.loads(r[\"source_entry_keys\"])\n   788→                except (json.JSONDecodeError, TypeError):\n   789→                    keys = []\n   790→                if key in keys:\n   791→                    self._conn.execute(\n   792→                        \"DELETE FROM relations \"\n   793→                        \"WHERE subject = ? AND predicate = ? AND object_entity = ?\",\n   794→                        (r[\"subject\"], r[\"predicate\"], r[\"object_entity\"]),\n   795→                    )\n   796→                    count += 1\n   797→            if count > 0:\n   798→                self._conn.commit()\n   799→        return count\n   800→\n   801→    # ------------------------------------------------------------------\n   802→    # Private helpers\n   803→    # ------------------------------------------------------------------\n   804→\n   805→    @staticmethod\n   806→    def _row_to_entry(row: sqlite3.Row) -> MemoryEntry:\n   807→        \"\"\"Convert a SQLite Row to a MemoryEntry.\"\"\"\n   808→        tags_raw = row[\"tags\"]\n   809→        try:\n   810→            tags = json.loads(tags_raw) if tags_raw else []\n   811→        except (json.JSONDecodeError, TypeError):\n   812→            tags = []\n   813→\n   814→        embedding: list[float] | None = None\n   815→        try:\n   816→            emb_raw = row[\"embedding\"]\n   817→        except (KeyError, IndexError):\n   818→            emb_raw = None\n   819→        if emb_raw:\n   820→            try:\n   821→                parsed = json.loads(str(emb_raw))\n   822→                if isinstance(parsed, list) and all(isinstance(x, (int, float)) for x in parsed):\n   823→                    embedding = [float(x) for x in parsed]\n   824→            except (json.JSONDecodeError, TypeError):\n   825→                pass\n   826→\n   827→        # Read temporal fields (v5+), gracefully handle missing columns\n   828→        valid_at: str | None = None\n   829→        invalid_at: str | None = None\n   830→        superseded_by: str | None = None\n   831→        try:\n   832→            valid_at = row[\"valid_at\"]\n   833→            invalid_at = row[\"invalid_at\"]\n   834→            superseded_by = row[\"superseded_by\"]\n   835→        except (KeyError, IndexError):\n   836→            pass\n   837→\n   838→        # Read agent_scope (v7+), gracefully handle missing column\n   839→        agent_scope: str = \"private\"\n   840→        try:\n   841→            val = row[\"agent_scope\"]\n   842→            if val is not None:\n   843→                agent_scope = val\n   844→        except (KeyError, IndexError):\n   845→            pass\n   846→\n   847→        # Read integrity_hash (v8+), gracefully handle missing column\n   848→        integrity_hash: str | None = None\n   849→        try:\n   850→            integrity_hash = row[\"integrity_hash\"]\n   851→        except (KeyError, IndexError):\n   852→            pass\n   853→\n   854→        return MemoryEntry(\n   855→            key=row[\"key\"],\n   856→            value=row[\"value\"],\n   857→            tier=row[\"tier\"],\n   858→            confidence=row[\"confidence\"],\n   859→            source=row[\"source\"],\n   860→            source_agent=row[\"source_agent\"],\n   861→            scope=row[\"scope\"],\n   862→            tags=tags,\n   863→            created_at=row[\"created_at\"],\n   864→            updated_at=row[\"updated_at\"],\n   865→            last_accessed=row[\"last_accessed\"],\n   866→            access_count=row[\"access_count\"],\n   867→            branch=row[\"branch\"],\n   868→            last_reinforced=row[\"last_reinforced\"],\n   869→            reinforce_count=row[\"reinforce_count\"],\n   870→            contradicted=bool(row[\"contradicted\"]),\n   871→            contradiction_reason=row[\"contradiction_reason\"],\n   872→            seeded_from=row[\"seeded_from\"],\n   873→            embedding=embedding,\n   874→            valid_at=valid_at,\n   875→            invalid_at=invalid_at,\n   876→            superseded_by=superseded_by,\n   877→            agent_scope=agent_scope,\n   878→            integrity_hash=integrity_hash,\n   879→        )\n   880→\n   881→    @staticmethod\n   882→    def _escape_fts_query(query: str) -> str:\n   883→        \"\"\"Escape an FTS5 query string for safe matching.\n   884→\n   885→        Wraps each token in double quotes to treat them as literals.\n   886→        \"\"\"\n   887→        tokens = query.strip().split()\n   888→        if not tokens:\n   889→            return \"\"\n   890→        return \" \".join(f'\"{t}\"' for t in tokens)\n   891→\n   892→    def append_audit(\n   893→        self,\n   894→        action: str,\n   895→        key: str,\n   896→        extra: dict[str, Any] | None = None,\n   897→    ) -> None:\n   898→        \"\"\"Append an entry to the JSONL audit log with optional extra fields (EPIC-010).\"\"\"\n   899→        record: dict[str, Any] = {\n   900→            \"action\": action,\n   901→            \"key\": key,\n   902→            \"timestamp\": datetime.now(tz=UTC).isoformat(),\n   903→        }\n   904→        if extra:\n   905→            record.update(extra)\n   906→        try:\n   907→            with self._audit_path.open(\"a\", encoding=\"utf-8\") as fh:\n   908→                fh.write(json.dumps(record, ensure_ascii=False) + \"\\n\")\n   909→            self._maybe_truncate_audit()\n   910→        except OSError:\n   911→            logger.debug(\"audit_log_write_failed\", key=key, action=action)\n   912→\n   913→    def _audit_log(self, action: str, key: str) -> None:\n   914→        \"\"\"Append an entry to the JSONL audit log.\"\"\"\n   915→        record = {\n   916→            \"action\": action,\n   917→            \"key\": key,\n   918→            \"timestamp\": datetime.now(tz=UTC).isoformat(),\n   919→        }\n   920→        try:\n   921→            with self._audit_path.open(\"a\", encoding=\"utf-8\") as fh:\n   922→                fh.write(json.dumps(record, ensure_ascii=False) + \"\\n\")\n   923→            self._maybe_truncate_audit()\n   924→        except OSError:\n   925→            logger.debug(\"audit_log_write_failed\", key=key, action=action)\n   926→\n   927→    def _maybe_truncate_audit(self) -> None:\n   928→        \"\"\"Truncate audit log if it exceeds the max line count.\"\"\"\n   929→        try:\n   930→            lines = self._audit_path.read_text(encoding=\"utf-8\").splitlines()\n   931→            if len(lines) > _MAX_AUDIT_LINES:\n   932→                # Keep the most recent entries\n   933→                keep = lines[-_MAX_AUDIT_LINES:]\n   934→                self._audit_path.write_text(\"\\n\".join(keep) + \"\\n\", encoding=\"utf-8\")\n   935→        except OSError:\n   936→            pass\n   937→"}]},"parent_tool_use_id":"toolu_01KJomf8MxPhmjTE3TX6wPks","session_id":"327621aa-924c-4bfb-b348-3a4acf890b54","uuid":"d0781d1e-2cc0-4650-87f4-668b1f99ead2","timestamp":"2026-03-22T22:37:59.795Z"}
