t_factor / hop\n   318→                raw_score = mem.get(\"score\", 0.0)\n   319→                score = float(raw_score) if isinstance(raw_score, (int, float)) else 0.0\n   320→                new_score = min(score + hop_boost, 1.0)\n   321→                mem = {**mem, \"score\": new_score, \"graph_boosted\": True}\n   322→            boosted.append(mem)\n   323→\n   324→        # Re-sort by score descending\n   325→        def _score(m: dict[str, object]) -> float:\n   326→            raw = m.get(\"score\", 0.0)\n   327→            return float(raw) if isinstance(raw, (int, float)) else 0.0\n   328→\n   329→        boosted.sort(key=_score, reverse=True)\n   330→        return boosted\n   331→\n   332→    def _effective_config(self, overrides: dict[str, object]) -> RecallConfig:\n   333→        \"\"\"Build effective config by merging base config with per-call overrides.\"\"\"\n   334→        if not overrides:\n   335→            return self._config\n   336→\n   337→        vals: dict[str, object] = {"}]},"parent_tool_use_id":null,"session_id":"327621aa-924c-4bfb-b348-3a4acf890b54","uuid":"41b2d865-f25c-42b8-86a0-e4408dd04328","timestamp":"2026-03-22T22:40:39.210Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\cursor\\tapps-brain\\src\\tapps_brain\\recall.py","content":"    def _apply_graph_boost(\n        self,\n        memories: list[dict[str, object]],\n        boost_factor: float,\n    ) -> list[dict[str, object]]:\n        \"\"\"Boost scores of memories connected via the relation graph.\n\n        For each memory in the result set, find graph-connected entries.\n        If a connected entry is also in the result set, boost its score\n        by *boost_factor* (additive, capped at 1.0).  The boosted list\n        is re-sorted by descending score.\n        \"\"\"\n        result_keys = {str(m.get(\"key\", \"\")) for m in memories}\n        # Collect all graph-connected keys and their hop distances\n        connected: dict[str, int] = {}\n        for mem in memories:\n            key = str(mem.get(\"key\", \"\"))\n            if not key:\n                continue\n            try:\n                related = self._store.find_related(key, max_hops=2)\n            except KeyError:\n                continue\n            for rel_key, hop in related:\n                if rel_key in result_keys and (\n                    rel_key not in connected or hop < connected[rel_key]\n                ):\n                    connected[rel_key] = hop\n\n        if not connected:\n            return memories\n\n        # Apply boost: closer hops get more boost\n        boosted: list[dict[str, object]] = []\n        for mem in memories:\n            key = str(mem.get(\"key\", \"\"))\n            if key in connected:\n                hop = connected[key]\n                # Boost inversely proportional to hop distance\n                hop_boost = boost_factor / hop\n                raw_score = mem.get(\"score\", 0.0)\n                score = float(raw_score) if isinstance(raw_score, (int, float)) else 0.0\n                new_score = min(score + hop_boost, 1.0)\n                mem = {**mem, \"score\": new_score, \"graph_boosted\": True}\n            boosted.append(mem)\n\n        # Re-sort by score descending\n        def _score(m: dict[str, object]) -> float:\n            raw = m.get(\"score\", 0.0)\n            return float(raw) if isinstance(raw, (int, float)) else 0.0\n\n        boosted.sort(key=_score, reverse=True)\n        return boosted\n\n    def _effective_config(self, overrides: dict[str, object]) -> RecallConfig:\n        \"\"\"Build effective config by merging base config with per-call overrides.\"\"\"\n        if not overrides:\n            return self._config\n\n        vals: dict[str, object] = {","numLines":60,"startLine":278,"totalLines":412}}}
