{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EfaddJRabJdFkNsAaZmb3G","type":"tool_result","content":"     1→\"\"\"Tests for the sliding window rate limiter (H6a/H6b).\"\"\"\n     2→\n     3→from __future__ import annotations\n     4→\n     5→import time\n     6→from unittest.mock import patch\n     7→\n     8→import pytest\n     9→\n    10→from tapps_brain.rate_limiter import (\n    11→    BATCH_EXEMPT_CONTEXTS,\n    12→    RateLimiterConfig,\n    13→    RateLimitResult,\n    14→    SlidingWindowRateLimiter,\n    15→)\n    16→\n    17→\n    18→class TestRateLimiterConfig:\n    19→    \"\"\"Test RateLimiterConfig defaults.\"\"\"\n    20→\n    21→    def test_defaults(self) -> None:\n    22→        cfg = RateLimiterConfig()\n    23→        assert cfg.writes_per_minute == 20\n    24→        assert cfg.writes_per_session == 100\n    25→        assert cfg.enabled is True\n    26→\n    27→    def test_custom_config(self) -> None:\n    28→        cfg = RateLimiterConfig(writes_per_minute=5, writes_per_session=50, enabled=False)\n    29→        assert cfg.writes_per_minute == 5\n    30→        assert cfg.writes_per_session == 50\n    31→        assert cfg.enabled is False\n    32→\n    33→\n    34→class TestRateLimitResult:\n    35→    \"\"\"Test RateLimitResult defaults.\"\"\"\n    36→\n    37→    def test_defaults(self) -> None:\n    38→        result = RateLimitResult()\n    39→        assert result.allowed is True\n    40→        assert result.minute_exceeded is False\n    41→        assert result.session_exceeded is False\n    42→        assert result.current_minute_count == 0\n    43→        assert result.current_session_count == 0\n    44→        assert result.message == \"\"\n    45→\n    46→\n    47→class TestSlidingWindowRateLimiter:\n    48→    \"\"\"Test the sliding window rate limiter.\"\"\"\n    49→\n    50→    def test_under_limit_allowed(self) -> None:\n    51→        \"\"\"Writes under the limit should not trigger warnings.\"\"\"\n    52→        limiter = SlidingWindowRateLimiter(RateLimiterConfig(writes_per_minute=5))\n    53→        for _ in range(5):\n    54→            result = limiter.check()\n    55→            assert result.allowed is True\n    56→            assert result.minute_exceeded is False\n    57→\n    58→    def test_over_minute_limit_warns(self) -> None:\n    59→        \"\"\"Exceeding per-minute limit should warn but still allow.\"\"\"\n    60→        limiter = SlidingWindowRateLimiter(\n    61→            RateLimiterConfig(writes_per_minute=3, writes_per_session=100)\n    62→        )\n    63→        # First 3 writes are fine\n    64→        for _ in range(3):\n    65→            result = limiter.check()\n    66→            assert result.minute_exceeded is False\n    67→\n    68→        # 4th write exceeds minute limit\n    69→        result = limiter.check()\n    70→        assert result.allowed is True  # Warn-only, never blocks\n    71→        assert result.minute_exceeded is True\n    72→        assert result.current_minute_count == 4\n    73→        assert \"Rate limit warning\" in result.message\n    74→\n    75→    def test_over_session_limit_warns(self) -> None:\n    76→        \"\"\"Exceeding per-session limit should warn but still allow.\"\"\"\n    77→        limiter = SlidingWindowRateLimiter(\n    78→            RateLimiterConfig(writes_per_minute=1000, writes_per_session=5)\n    79→        )\n    80→        for _ in range(5):\n    81→            result = limiter.check()\n    82→            assert result.session_exceeded is False\n    83→\n    84→        result = limiter.check()\n    85→        assert result.allowed is True\n    86→        assert result.session_exceeded is True\n    87→        assert result.current_session_count == 6\n    88→        assert \"session\" in result.message\n    89→\n    90→    def test_both_limits_exceeded(self) -> None:\n    91→        \"\"\"Both limits exceeded at once should produce combined message.\"\"\"\n    92→        limiter = SlidingWindowRateLimiter(\n    93→            RateLimiterConfig(writes_per_minute=2, writes_per_session=2)\n    94→        )\n    95→        limiter.check()\n    96→        limiter.check()\n    97→        result = limiter.check()\n    98→        assert result.minute_exceeded is True\n    99→        assert result.session_exceeded is True\n   100→        assert \"minute\" in result.message\n   101→        assert \"session\" in result.message\n   102→\n   103→    def test_disabled_limiter(self) -> None:\n   104→        \"\"\"Disabled limiter should always return default result.\"\"\"\n   105→        limiter = SlidingWindowRateLimiter(\n   106→            RateLimiterConfig(enabled=False, writes_per_minute=1)\n   107→        )\n   108→        for _ in range(10):\n   109→            result = limiter.check()\n   110→            assert result.allowed is True\n   111→            assert result.minute_exceeded is False\n   112→            assert result.session_exceeded is False\n   113→\n   114→    def test_sliding_window_expiry(self) -> None:\n   115→        \"\"\"Old timestamps should be pruned from the sliding window.\"\"\"\n   116→        limiter = SlidingWindowRateLimiter(\n   117→            RateLimiterConfig(writes_per_minute=3, writes_per_session=100)\n   118→        )\n   119→        # Simulate timestamps from 2 minutes ago by patching time.monotonic\n   120→        old_time = time.monotonic() - 120.0  # 2 minutes ago\n   121→\n   122→        with patch(\"tapps_brain.rate_limiter.time.monotonic\", return_value=old_time):\n   123→            limiter.check()\n   124→            limiter.check()\n   125→            limiter.check()\n   126→\n   127→        # Now check at current time — old entries should be pruned\n   128→        result = limiter.check()\n   129→        assert result.minute_exceeded is False\n   130→        assert result.current_minute_count == 1\n   131→        # Session count still accumulates\n   132→        assert result.current_session_count == 4\n   133→\n   134→    def test_batch_context_exempt(self) -> None:\n   135→        \"\"\"Batch context exemptions bypass rate limiting.\"\"\"\n   136→        limiter = SlidingWindowRateLimiter(\n   137→            RateLimiterConfig(writes_per_minute=1, writes_per_session=1)\n   138→        )\n   139→        # Use up the limit\n   140→        limiter.check()\n   141→\n   142→        # Exempt contexts should not trigger warnings\n   143→        for ctx in BATCH_EXEMPT_CONTEXTS:\n   144→            result = limiter.check(batch_context=ctx)\n   145→            assert result.allowed is True\n   146→            assert result.minute_exceeded is False\n   147→            assert result.session_exceeded is False\n   148→\n   149→    def test_batch_context_non_exempt(self) -> None:\n   150→        \"\"\"Non-exempt batch contexts are rate limited normally.\"\"\"\n   151→        limiter = SlidingWindowRateLimiter(\n   152→            RateLimiterConfig(writes_per_minute=1, writes_per_session=100)\n   153→        )\n   154→        limiter.check()  # Use the limit\n   155→\n   156→        result = limiter.check(batch_context=\"not_exempt\")\n   157→        assert result.minute_exceeded is True\n   158→\n   159→    def test_stats_tracking(self) -> None:\n   160→        \"\"\"Stats should accumulate correctly.\"\"\"\n   161→        limiter = SlidingWindowRateLimiter(\n   162→            RateLimiterConfig(writes_per_minute=2, writes_per_session=100)\n   163→        )\n   164→        limiter.check()\n   165→        limiter.check()\n   166→        limiter.check()  # exceeds minute limit\n   167→\n   168→        stats = limiter.stats\n   169→        assert stats.total_writes == 3\n   170→        assert stats.minute_anomalies == 1\n   171→        assert stats.session_anomalies == 0\n   172→        assert stats.exempt_writes == 0\n   173→\n   174→    def test_stats_exempt_tracking(self) -> None:\n   175→        \"\"\"Exempt writes should be tracked in stats.\"\"\"\n   176→        limiter = SlidingWindowRateLimiter(RateLimiterConfig())\n   177→        limiter.check(batch_context=\"seed\")\n   178→        limiter.check(batch_context=\"consolidate\")\n   179→\n   180→        stats = limiter.stats\n   181→        assert stats.exempt_writes == 2\n   182→        assert stats.total_writes == 2\n   183→\n   184→    def test_reset(self) -> None:\n   185→        \"\"\"Reset should clear all state.\"\"\"\n   186→        limiter = SlidingWindowRateLimiter(\n   187→            RateLimiterConfig(writes_per_minute=1, writes_per_session=1)\n   188→        )\n   189→        limiter.check()\n   190→        limiter.check()\n   191→\n   192→        limiter.reset()\n   193→\n   194→        stats = limiter.stats\n   195→        assert stats.total_writes == 0\n   196→        assert stats.minute_anomalies == 0\n   197→        assert stats.session_anomalies == 0\n   198→\n   199→        result = limiter.check()\n   200→        assert result.minute_exceeded is False\n   201→        assert result.session_exceeded is False\n   202→        assert result.current_session_count == 1\n   203→\n   204→    def test_config_property(self) -> None:\n   205→        \"\"\"Config property should return the active config.\"\"\"\n   206→        cfg = RateLimiterConfig(writes_per_minute=42)\n   207→        limiter = SlidingWindowRateLimiter(cfg)\n   208→        assert limiter.config is cfg\n   209→        assert limiter.config.writes_per_minute == 42\n   210→\n   211→\n   212→class TestBatchExemptContexts:\n   213→    \"\"\"Test batch exempt context constants.\"\"\"\n   214→\n   215→    def test_expected_contexts(self) -> None:\n   216→        assert \"import_markdown\" in BATCH_EXEMPT_CONTEXTS\n   217→        assert \"seed\" in BATCH_EXEMPT_CONTEXTS\n   218→        assert \"federation_sync\" in BATCH_EXEMPT_CONTEXTS\n   219→        assert \"consolidate\" in BATCH_EXEMPT_CONTEXTS\n   220→\n   221→    def test_is_frozenset(self) -> None:\n   222→        assert isinstance(BATCH_EXEMPT_CONTEXTS, frozenset)\n   223→"}]},"parent_tool_use_id":"toolu_01LbDdTJVatSJ29PCFJETdBX","session_id":"b8c12035-e8ed-4df0-b6e9-5090fcc99196","uuid":"912abda9-84a4-4457-ae2c-9d18c52ebb11","timestamp":"2026-03-22T22:31:26.707Z"}
