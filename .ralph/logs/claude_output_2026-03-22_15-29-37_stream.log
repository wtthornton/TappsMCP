{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016EcQNzhJgUMqSKBLMeqMN2","type":"tool_result","content":"     1→\"\"\"In-memory metrics collector for observability (EPIC-007).\n     2→\n     3→Provides lightweight counters and histograms with no external dependencies.\n     4→Thread-safe via ``threading.Lock``. Zero-cost when not read — just atomic\n     5→counter increments and reservoir sampling.\n     6→\"\"\"\n     7→\n     8→from __future__ import annotations\n     9→\n    10→import math\n    11→import random\n    12→import threading\n    13→import time\n    14→from typing import Any\n    15→\n    16→from pydantic import BaseModel, Field\n    17→\n    18→# ---------------------------------------------------------------------------\n    19→# Models\n    20→# ---------------------------------------------------------------------------\n    21→\n    22→\n    23→class HistogramStats(BaseModel):\n    24→    \"\"\"Computed statistics from a histogram.\"\"\"\n    25→\n    26→    count: int = 0\n    27→    min: float = 0.0\n    28→    max: float = 0.0\n    29→    mean: float = 0.0\n    30→    p50: float = 0.0\n    31→    p95: float = 0.0\n    32→    p99: float = 0.0\n    33→\n    34→\n    35→class MetricsSnapshot(BaseModel):\n    36→    \"\"\"Frozen snapshot of all counters and histograms.\"\"\"\n    37→\n    38→    counters: dict[str, int] = Field(default_factory=dict)\n    39→    histograms: dict[str, HistogramStats] = Field(default_factory=dict)\n    40→    captured_at: str = Field(default=\"\")\n    41→\n    42→    def to_dict(self) -> dict[str, Any]:\n    43→        \"\"\"Convert to a plain dict for JSON serialization.\"\"\"\n    44→        return self.model_dump(mode=\"json\")\n    45→\n    46→\n    47→class StoreHealthReport(BaseModel):\n    48→    \"\"\"Aggregate health view for a project memory store (EPIC-007).\"\"\"\n    49→\n    50→    store_path: str = Field(description=\"Project root path backing the store.\")\n    51→    entry_count: int = 0\n    52→    max_entries: int = 500\n    53→    schema_version: int = 0\n    54→    tier_distribution: dict[str, int] = Field(default_factory=dict)\n    55→    oldest_entry_age_days: float = 0.0\n    56→    consolidation_candidates: int = 0\n    57→    gc_candidates: int = 0\n    58→    federation_enabled: bool = False\n    59→    federation_project_count: int = 0\n    60→    # Integrity verification (H4c)\n    61→    integrity_verified: int = 0\n    62→    integrity_tampered: int = 0\n    63→    integrity_no_hash: int = 0\n    64→    integrity_tampered_keys: list[str] = Field(default_factory=list)\n    65→\n    66→\n    67→# ---------------------------------------------------------------------------\n    68→# Reservoir for histogram sampling\n    69→# ---------------------------------------------------------------------------\n    70→\n    71→_RESERVOIR_SIZE = 1024\n    72→\n    73→\n    74→class _Reservoir:\n    75→    \"\"\"Vitter's Algorithm R reservoir sampler for histogram data.\"\"\"\n    76→\n    77→    __slots__ = (\"_count\", \"_max\", \"_min\", \"_samples\", \"_sum\")\n    78→\n    79→    def __init__(self) -> None:\n    80→        self._samples: list[float] = []\n    81→        self._count: int = 0\n    82→        self._min: float = math.inf\n    83→        self._max: float = -math.inf\n    84→        self._sum: float = 0.0\n    85→\n    86→    def add(self, value: float) -> None:\n    87→        self._count += 1\n    88→        self._sum += value\n    89→        self._min = min(self._min, value)\n    90→        self._max = max(self._max, value)\n    91→\n    92→        if len(self._samples) < _RESERVOIR_SIZE:\n    93→            self._samples.append(value)\n    94→        else:\n    95→            j = random.randint(0, self._count - 1)\n    96→            if j < _RESERVOIR_SIZE:\n    97→                self._samples[j] = value\n    98→\n    99→    def stats(self) -> HistogramStats:\n   100→        if self._count == 0:\n   101→            return HistogramStats()\n   102→\n   103→        sorted_samples = sorted(self._samples)\n   104→        n = len(sorted_samples)\n   105→\n   106→        return HistogramStats(\n   107→            count=self._count,\n   108→            min=self._min,\n   109→            max=self._max,\n   110→            mean=self._sum / self._count,\n   111→            p50=sorted_samples[int(n * 0.5)] if n > 0 else 0.0,\n   112→            p95=sorted_samples[min(int(n * 0.95), n - 1)] if n > 0 else 0.0,\n   113→            p99=sorted_samples[min(int(n * 0.99), n - 1)] if n > 0 else 0.0,\n   114→        )\n   115→\n   116→\n   117→# ---------------------------------------------------------------------------\n   118→# Collector\n   119→# ---------------------------------------------------------------------------\n   120→\n   121→\n   122→class MetricsCollector:\n   123→    \"\"\"Thread-safe in-memory metrics collector.\n   124→\n   125→    Supports counters (increment) and histograms (observe) with no\n   126→    external dependencies. Use ``snapshot()`` to get a frozen copy.\n   127→    \"\"\"\n   128→\n   129→    def __init__(self) -> None:\n   130→        self._lock = threading.Lock()\n   131→        self._counters: dict[str, int] = {}\n   132→        self._histograms: dict[str, _Reservoir] = {}\n   133→\n   134→    def increment(self, name: str, value: int = 1, tags: dict[str, str] | None = None) -> None:\n   135→        \"\"\"Increment a counter by *value* (default 1).\"\"\"\n   136→        key = self._tagged_name(name, tags)\n   137→        with self._lock:\n   138→            self._counters[key] = self._counters.get(key, 0) + value\n   139→\n   140→    def observe(self, name: str, value: float, tags: dict[str, str] | None = None) -> None:\n   141→        \"\"\"Record a value in a histogram.\"\"\"\n   142→        key = self._tagged_name(name, tags)\n   143→        with self._lock:\n   144→            if key not in self._histograms:\n   145→                self._histograms[key] = _Reservoir()\n   146→            self._histograms[key].add(value)\n   147→\n   148→    def snapshot(self) -> MetricsSnapshot:\n   149→        \"\"\"Return a frozen copy of all counters and histograms.\"\"\"\n   150→        from datetime import UTC, datetime\n   151→\n   152→        with self._lock:\n   153→            counters = dict(self._counters)\n   154→            histograms = {k: v.stats() for k, v in self._histograms.items()}\n   155→\n   156→        return MetricsSnapshot(\n   157→            counters=counters,\n   158→            histograms=histograms,\n   159→            captured_at=datetime.now(tz=UTC).isoformat(),\n   160→        )\n   161→\n   162→    def reset(self) -> None:\n   163→        \"\"\"Clear all metrics (for testing).\"\"\"\n   164→        with self._lock:\n   165→            self._counters.clear()\n   166→            self._histograms.clear()\n   167→\n   168→    @staticmethod\n   169→    def _tagged_name(name: str, tags: dict[str, str] | None) -> str:\n   170→        \"\"\"Build a metric key from name and optional tags.\"\"\"\n   171→        if not tags:\n   172→            return name\n   173→        tag_str = \",\".join(f\"{k}={v}\" for k, v in sorted(tags.items()))\n   174→        return f\"{name}{{{tag_str}}}\"\n   175→\n   176→\n   177→# ---------------------------------------------------------------------------\n   178→# Timer context manager for latency measurement\n   179→# ---------------------------------------------------------------------------\n   180→\n   181→\n   182→class MetricsTimer:\n   183→    \"\"\"Context manager that records elapsed time to a histogram.\"\"\"\n   184→\n   185→    __slots__ = (\"_collector\", \"_name\", \"_start\", \"_tags\")\n   186→\n   187→    def __init__(\n   188→        self, collector: MetricsCollector, name: str, tags: dict[str, str] | None = None\n   189→    ) -> None:\n   190→        self._collector = collector\n   191→        self._name = name\n   192→        self._tags = tags\n   193→        self._start: float = 0.0\n   194→\n   195→    def __enter__(self) -> MetricsTimer:\n   196→        self._start = time.perf_counter()\n   197→        return self\n   198→\n   199→    def __exit__(self, *_: object) -> None:\n   200→        elapsed_ms = (time.perf_counter() - self._start) * 1000.0\n   201→        self._collector.observe(self._name, elapsed_ms, self._tags)\n   202→"}]},"parent_tool_use_id":null,"session_id":"b8c12035-e8ed-4df0-b6e9-5090fcc99196","uuid":"aa8a88eb-b6af-4464-b3fc-b75fba6584fc","timestamp":"2026-03-22T22:31:54.032Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\cursor\\tapps-brain\\src\\tapps_brain\\metrics.py","content":"\"\"\"In-memory metrics collector for observability (EPIC-007).\n\nProvides lightweight counters and histograms with no external dependencies.\nThread-safe via ``threading.Lock``. Zero-cost when not read — just atomic\ncounter increments and reservoir sampling.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport math\nimport random\nimport threading\nimport time\nfrom typing import Any\n\nfrom pydantic import BaseModel, Field\n\n# ---------------------------------------------------------------------------\n# Models\n# ---------------------------------------------------------------------------\n\n\nclass HistogramStats(BaseModel):\n    \"\"\"Computed statistics from a histogram.\"\"\"\n\n    count: int = 0\n    min: float = 0.0\n    max: float = 0.0\n    mean: float = 0.0\n    p50: float = 0.0\n    p95: float = 0.0\n    p99: float = 0.0\n\n\nclass MetricsSnapshot(BaseModel):\n    \"\"\"Frozen snapshot of all counters and histograms.\"\"\"\n\n    counters: dict[str, int] = Field(default_factory=dict)\n    histograms: dict[str, HistogramStats] = Field(default_factory=dict)\n    captured_at: str = Field(default=\"\")\n\n    def to_dict(self) -> dict[str, Any]:\n        \"\"\"Convert to a plain dict for JSON serialization.\"\"\"\n        return self.model_dump(mode=\"json\")\n\n\nclass StoreHealthReport(BaseModel):\n    \"\"\"Aggregate health view for a project memory store (EPIC-007).\"\"\"\n\n    store_path: str = Field(description=\"Project root path backing the store.\")\n    entry_count: int = 0\n    max_entries: int = 500\n    schema_version: int = 0\n    tier_distribution: dict[str, int] = Field(default_factory=dict)\n    oldest_entry_age_days: float = 0.0\n    consolidation_candidates: int = 0\n    gc_candidates: int = 0\n    federation_enabled: bool = False\n    federation_project_count: int = 0\n    # Integrity verification (H4c)\n    integrity_verified: int = 0\n    integrity_tampered: int = 0\n    integrity_no_hash: int = 0\n    integrity_tampered_keys: list[str] = Field(default_factory=list)\n\n\n# ---------------------------------------------------------------------------\n# Reservoir for histogram sampling\n# ---------------------------------------------------------------------------\n\n_RESERVOIR_SIZE = 1024\n\n\nclass _Reservoir:\n    \"\"\"Vitter's Algorithm R reservoir sampler for histogram data.\"\"\"\n\n    __slots__ = (\"_count\", \"_max\", \"_min\", \"_samples\", \"_sum\")\n\n    def __init__(self) -> None:\n        self._samples: list[float] = []\n        self._count: int = 0\n        self._min: float = math.inf\n        self._max: float = -math.inf\n        self._sum: float = 0.0\n\n    def add(self, value: float) -> None:\n        self._count += 1\n        self._sum += value\n        self._min = min(self._min, value)\n        self._max = max(self._max, value)\n\n        if len(self._samples) < _RESERVOIR_SIZE:\n            self._samples.append(value)\n        else:\n            j = random.randint(0, self._count - 1)\n            if j < _RESERVOIR_SIZE:\n                self._samples[j] = value\n\n    def stats(self) -> HistogramStats:\n        if self._count == 0:\n            return HistogramStats()\n\n        sorted_samples = sorted(self._samples)\n        n = len(sorted_samples)\n\n        return HistogramStats(\n            count=self._count,\n            min=self._min,\n            max=self._max,\n            mean=self._sum / self._count,\n            p50=sorted_samples[int(n * 0.5)] if n > 0 else 0.0,\n            p95=sorted_samples[min(int(n * 0.95), n - 1)] if n > 0 else 0.0,\n            p99=sorted_samples[min(int(n * 0.99), n - 1)] if n > 0 else 0.0,\n        )\n\n\n# ---------------------------------------------------------------------------\n# Collector\n# ---------------------------------------------------------------------------\n\n\nclass MetricsCollector:\n    \"\"\"Thread-safe in-memory metrics collector.\n\n    Supports counters (increment) and histograms (observe) with no\n    external dependencies. Use ``snapshot()`` to get a frozen copy.\n    \"\"\"\n\n    def __init__(self) -> None:\n        self._lock = threading.Lock()\n        self._counters: dict[str, int] = {}\n        self._histograms: dict[str, _Reservoir] = {}\n\n    def increment(self, name: str, value: int = 1, tags: dict[str, str] | None = None) -> None:\n        \"\"\"Increment a counter by *value* (default 1).\"\"\"\n        key = self._tagged_name(name, tags)\n        with self._lock:\n            self._counters[key] = self._counters.get(key, 0) + value\n\n    def observe(self, name: str, value: float, tags: dict[str, str] | None = None) -> None:\n        \"\"\"Record a value in a histogram.\"\"\"\n        key = self._tagged_name(name, tags)\n        with self._lock:\n            if key not in self._histograms:\n                self._histograms[key] = _Reservoir()\n            self._histograms[key].add(value)\n\n    def snapshot(self) -> MetricsSnapshot:\n        \"\"\"Return a frozen copy of all counters and histograms.\"\"\"\n        from datetime import UTC, datetime\n\n        with self._lock:\n            counters = dict(self._counters)\n            histograms = {k: v.stats() for k, v in self._histograms.items()}\n\n        return MetricsSnapshot(\n            counters=counters,\n            histograms=histograms,\n            captured_at=datetime.now(tz=UTC).isoformat(),\n        )\n\n    def reset(self) -> None:\n        \"\"\"Clear all metrics (for testing).\"\"\"\n        with self._lock:\n            self._counters.clear()\n            self._histograms.clear()\n\n    @staticmethod\n    def _tagged_name(name: str, tags: dict[str, str] | None) -> str:\n        \"\"\"Build a metric key from name and optional tags.\"\"\"\n        if not tags:\n            return name\n        tag_str = \",\".join(f\"{k}={v}\" for k, v in sorted(tags.items()))\n        return f\"{name}{{{tag_str}}}\"\n\n\n# ---------------------------------------------------------------------------\n# Timer context manager for latency measurement\n# ---------------------------------------------------------------------------\n\n\nclass MetricsTimer:\n    \"\"\"Context manager that records elapsed time to a histogram.\"\"\"\n\n    __slots__ = (\"_collector\", \"_name\", \"_start\", \"_tags\")\n\n    def __init__(\n        self, collector: MetricsCollector, name: str, tags: dict[str, str] | None = None\n    ) -> None:\n        self._collector = collector\n        self._name = name\n        self._tags = tags\n        self._start: float = 0.0\n\n    def __enter__(self) -> MetricsTimer:\n        self._start = time.perf_counter()\n        return self\n\n    def __exit__(self, *_: object) -> None:\n        elapsed_ms = (time.perf_counter() - self._start) * 1000.0\n        self._collector.observe(self._name, elapsed_ms, self._tags)\n","numLines":202,"startLine":1,"totalLines":202}}}
