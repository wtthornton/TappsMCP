{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LnXY8CvDfVa1AASdg2AJaV","type":"tool_result","content":"  1542→def _handle_health(store: MemoryStore, _p: _Params) -> dict[str, Any]:\n  1543→    \"\"\"Handle the health action -- aggregate health report with integrity status.\n  1544→\n  1545→    Delegates to ``store.health()`` when available (tapps-brain >= v1.1.0).\n  1546→    Falls back to a basic snapshot-based report for older versions.\n  1547→    \"\"\"\n  1548→    if hasattr(store, \"health\") and callable(store.health):\n  1549→        report = store.health()\n  1550→        return {\n  1551→            \"action\": \"health\",\n  1552→            \"store_path\": report.store_path,\n  1553→            \"entry_count\": report.entry_count,\n  1554→            \"max_entries\": report.max_entries,\n  1555→            \"schema_version\": report.schema_version,\n  1556→            \"tier_distribution\": report.tier_distribution,\n  1557→            \"oldest_entry_age_days\": round(report.oldest_entry_age_days, 1),\n  1558→            \"consolidation_candidates\": report.consolidation_candidates,\n  1559→            \"gc_candidates\": report.gc_candidates,\n  1560→            \"federation_enabled\": report.federation_enabled,\n  1561→            \"federation_project_count\": report.federation_project_count,\n  1562→            # Integrity (H4c)\n  1563→            \"integrity_verified\": report.integrity_verified,\n  1564→            \"integrity_tampered\": report.integrity_tampered,\n  1565→            \"integrity_no_hash\": report.integrity_no_hash,\n  1566→            \"integrity_tampered_keys\": report.integrity_tampered_keys[:20],\n  1567→            \"integrity_status\": (\n  1568→                \"clean\" if report.integrity_tampered == 0 else \"tampered\"\n  1569→            ),\n  1570→        }\n  1571→\n  1572→    # Fallback for older tapps-brain without store.health()\n  1573→    snap = store.snapshot()\n  1574→    return {\n  1575→        \"action\": \"health\",\n  1576→        \"entry_count\": snap.total_count,\n  1577→        \"tier_distribution\": snap.tier_counts,\n  1578→        \"integrity_status\": \"unavailable\",\n  1579→        \"degraded\": True,\n  1580→        \"message\": \"Full health report requires tapps-brain >= v1.1.0.\",\n  1581→    }\n  1582→\n  1583→\n  1584→# ---------------------------------------------------------------------------\n  1585→# Epic M1: Security surface handlers\n  1586→# ---------------------------------------------------------------------------\n  1587→\n  1588→\n  1589→def _handle_safety_check(store: MemoryStore, p: _Params) -> dict[str, Any]:\n  1590→    \"\"\"Handle the safety_check action -- pre-flight content safety validation.\"\"\"\n  1591→    if not p.value:\n  1592→        return {\"error\": \"missing_value\", \"message\": \"Value is required for safety_check.\"}\n  1593→\n  1594→    try:\n  1595→        from tapps_brain.safety import check_content_safety\n  1596→    except ImportError:\n  1597→        return {\n  1598→            \"action\": \"safety_check\",\n  1599→            \"error\": \"unsupported\",\n  1600→            \"degraded\": True,\n  1601→            \"message\": \"Safety module not available in installed tapps-brain version.\",\n  1602→        }\n  1603→\n  1604→    result = check_content_safety(p.value)\n  1605→    return {\n  1606→        \"action\": \"safety_check\",\n  1607→        \"safe\": result.safe,\n  1608→        \"flagged_patterns\": result.flagged_patterns,\n  1609→        \"match_count\": result.match_count,\n  1610→        \"warning\": result.warning,\n  1611→        \"sanitised_preview\": (\n  1612→            result.sanitised_content[:_VALUE_PREVIEW_LEN] + \"...\"\n  1613→            if result.sanitised_content and len(result.sanitised_content) > _VALUE_PREVIEW_LEN\n  1614→            else result.sanitised_content\n  1615→        ),\n  1616→    }\n  1617→\n  1618→\n  1619→def _handle_verify_integrity(store: MemoryStore, _p: _Params) -> dict[str, Any]:\n  1620→    \"\"\"Handle the verify_integrity action -- check memory entries for tampering.\n  1621→\n  1622→    Delegates to ``store.verify_integrity()`` for HMAC-SHA256 verification\n  1623→    when available. Falls back to a basic consistency check (entry round-trip)\n  1624→    for older tapps-brain versions.\n  1625→    \"\"\"\n  1626→    if hasattr(store, \"verify_integrity\") and callable(store.verify_integrity):\n  1627→        result = store.verify_integrity()\n  1628→        return {\n  1629→            \"action\": \"verify_integrity\",\n  1630→            \"total_entries\": result[\"total\"],\n  1631→            \"verified\": result[\"verified\"],\n  1632→            \"tampered\": result[\"tampered\"],\n  1633→            \"no_hash\": result[\"no_hash\"],\n  1634→            \"tampered_keys\": result[\"tampered_keys\"][:20],\n  1635→            \"missing_hash_keys\": result.get(\"missing_hash_keys\", [])[:20],\n  1636→            \"tampered_details\": result.get(\"tampered_details\", [])[:10],\n  1637→            \"integrity_method\": \"hmac_sha256\",\n  1638→            \"store_metadata\": _store_metadata(store),\n  1639→        }\n  1640→\n  1641→    # Fallback for older tapps-brain without verify_integrity()"}]},"parent_tool_use_id":"toolu_01LbDdTJVatSJ29PCFJETdBX","session_id":"b8c12035-e8ed-4df0-b6e9-5090fcc99196","uuid":"6407b1df-cdf5-4243-b0a3-6429ec223b9b","timestamp":"2026-03-22T22:30:55.076Z"}
