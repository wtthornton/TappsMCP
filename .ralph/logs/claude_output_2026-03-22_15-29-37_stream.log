   59→    exempt_writes: int = 0\n    60→\n    61→\n    62→class SlidingWindowRateLimiter:\n    63→    \"\"\"Sliding window rate limiter for memory writes.\n    64→\n    65→    Uses a deque-like list of timestamps for the per-minute window.\n    66→    Thread-safe via ``threading.Lock``.\n    67→\n    68→    In warn-only mode (default), writes are never blocked — the limiter\n    69→    logs warnings and tracks anomaly counts for ``memory_health()``.\n    70→    \"\"\"\n    71→\n    72→    def __init__(self, config: RateLimiterConfig | None = None) -> None:\n    73→        self._config = config or RateLimiterConfig()\n    74→        self._lock = threading.Lock()\n    75→        self._timestamps: list[float] = []\n    76→        self._session_count: int = 0\n    77→        self._stats = RateLimiterStats()\n    78→\n    79→    @property\n    80→    def config(self) -> RateLimiterConfig:\n    81→        \"\"\"Return the active configuration.\"\"\"\n    82→        return self._config\n    83→\n    84→    @property\n    85→    def stats(self) -> RateLimiterStats:\n    86→        \"\"\"Return accumulated anomaly statistics.\"\"\"\n    87→        with self._lock:\n    88→            return RateLimiterStats(\n    89→                minute_anomalies=self._stats.minute_anomalies,\n    90→                session_anomalies=self._stats.session_anomalies,\n    91→                total_writes=self._stats.total_writes,\n    92→                exempt_writes=self._stats.exempt_writes,\n    93→            )\n    94→\n    95→    def check(self, *, batch_context: str | None = None) -> RateLimitResult:\n    96→        \"\"\"Check rate limits and record the write.\n    97→\n    98→        Args:\n    99→            batch_context: If provided and in ``BATCH_EXEMPT_CONTEXTS``,\n   100→                the write is exempt from rate limiting.\n   101→\n   102→        Returns:\n   103→            ``RateLimitResult`` indicating whether limits were exceeded.\n   104→            In warn-only mode, ``allowed`` is always ``True``.\n   105→        \"\"\"\n   106→        if not self._config.enabled:\n   107→            return RateLimitResult()\n   108→\n   109→        # Batch context exemption (H6b)\n   110→        if batch_context is not None and batch_context in BATCH_EXEMPT_CONTEXTS:\n   111→            with self._lock:\n   112→                self._stats.exempt_writes += 1\n   113→                self._stats.total_writes += 1\n   114→            return RateLimitResult()\n   115→\n   116→        now = time.monotonic()\n   117→        window_start = now - 60.0\n   118→\n   119→        with self._lock:\n   120→            # Prune timestamps older than 1 minute\n   121→            self._timestamps = [t for t in self._timestamps if t > window_start]\n   122→\n   123→            # Record this write\n   124→            self._timestamps.append(now)\n   125→            self._session_count += 1\n   126→            self._stats.total_writes += 1\n   127→\n   128→            minute_count = len(self._timestamps)\n   129→            session_count = self._session_count\n   130→\n   131→            minute_exceeded = minute_count > self._config.writes_per_minute\n   132→            session_exceeded = session_count > self._config.writes_per_session\n   133→\n   134→            if minute_exceeded:\n   135→                self._stats.minute_anomalies += 1\n   136→            if session_exceeded:\n   137→                self._stats.session_anomalies += 1\n   138→\n   139→        # Build result\n   140→        result = RateLimitResult(\n   141→            allowed=True,  # Warn-only: never block\n   142→            minute_exceeded=minute_exceeded,\n   143→            session_exceeded=session_exceeded,\n   144→            current_minute_count=minute_count,\n   145→            current_session_count=session_count,\n   146→        )\n   147→\n   148→        # Log warnings for exceeded limits\n   149→        if minute_exceeded:\n   150→            result.message = (\n   151→                f\"Rate limit warning: {minute_count} writes in last minute \"\n   152→                f\"(limit: {self._config.writes_per_minute})\"\n   153→            )\n   154→            logger.warning(\n   155→                \"rate_limit_minute_exceeded\",\n   156→                current=minute_count,\n   157→                limit=self._config.writes_per_minute,\n   158→            )\n   159→\n   160→        if session_exceeded:\n   161→            msg = (\n   162→                f\"Rate limit warning: {session_count} writes this session \"\n   163→                f\"(limit: {self._config.writes_per_session})\"\n   164→            )\n   165→            if result.message:\n   166→                result.message += f\"; {msg}\"\n   167→            else:\n   168→                result.message = msg\n   169→            logger.warning(\n   170→                \"rate_limit_session_exceeded\",\n   171→                current=session_count,\n   172→                limit=self._config.writes_per_session,\n   173→            )\n   174→\n   175→        return result\n   176→\n   177→    def reset(self) -> None:\n   178→        \"\"\"Reset all counters and timestamps (useful for testing).\"\"\"\n   179→        with self._lock:\n   180→            self._timestamps.clear()\n   181→            self._session_count = 0\n   182→            self._stats = RateLimiterStats()\n   183→"}]},"parent_tool_use_id":null,"session_id":"b8c12035-e8ed-4df0-b6e9-5090fcc99196","uuid":"76335cd9-1465-4d3c-99e5-c6699ea70af3","timestamp":"2026-03-22T22:31:55.918Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\cursor\\tapps-brain\\src\\tapps_brain\\rate_limiter.py","content":"\"\"\"Sliding window rate limiter for memory write operations.\n\nProvides warn-only rate limiting to detect anomalous write bursts\nwithout blocking legitimate operations. Configurable per-minute and\nper-session limits with batch context exemptions.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport threading\nimport time\nfrom dataclasses import dataclass, field\n\nimport structlog\n\nlogger = structlog.get_logger(__name__)\n\n# Default limits\n_DEFAULT_WRITES_PER_MINUTE = 20\n_DEFAULT_WRITES_PER_SESSION = 100\n\n# Batch contexts exempt from rate limiting (H6b)\nBATCH_EXEMPT_CONTEXTS: frozenset[str] = frozenset({\n    \"import_markdown\",\n    \"seed\",\n    \"federation_sync\",\n    \"consolidate\",\n})\n\n\n@dataclass\nclass RateLimiterConfig:\n    \"\"\"Configuration for the sliding window rate limiter.\"\"\"\n\n    writes_per_minute: int = _DEFAULT_WRITES_PER_MINUTE\n    writes_per_session: int = _DEFAULT_WRITES_PER_SESSION\n    enabled: bool = True\n\n\n@dataclass\nclass RateLimitResult:\n    \"\"\"Result of a rate limit check.\"\"\"\n\n    allowed: bool = True\n    minute_exceeded: bool = False\n    session_exceeded: bool = False\n    current_minute_count: int = 0\n    current_session_count: int = 0\n    message: str = \"\"\n\n\n@dataclass\nclass RateLimiterStats:\n    \"\"\"Accumulated anomaly statistics for health reporting.\"\"\"\n\n    minute_anomalies: int = 0\n    session_anomalies: int = 0\n    total_writes: int = 0\n    exempt_writes: int = 0\n\n\nclass SlidingWindowRateLimiter:\n    \"\"\"Sliding window rate limiter for memory writes.\n\n    Uses a deque-like list of timestamps for the per-minute window.\n    Thread-safe via ``threading.Lock``.\n\n    In warn-only mode (default), writes are never blocked — the limiter\n    logs warnings and tracks anomaly counts for ``memory_health()``.\n    \"\"\"\n\n    def __init__(self, config: RateLimiterConfig | None = None) -> None:\n        self._config = config or RateLimiterConfig()\n        self._lock = threading.Lock()\n        self._timestamps: list[float] = []\n        self._session_count: int = 0\n        self._stats = RateLimiterStats()\n\n    @property\n    def config(self) -> RateLimiterConfig:\n        \"\"\"Return the active configuration.\"\"\"\n        return self._config\n\n    @property\n    def stats(self) -> RateLimiterStats:\n        \"\"\"Return accumulated anomaly statistics.\"\"\"\n        with self._lock:\n            return RateLimiterStats(\n                minute_anomalies=self._stats.minute_anomalies,\n                session_anomalies=self._stats.session_anomalies,\n                total_writes=self._stats.total_writes,\n                exempt_writes=self._stats.exempt_writes,\n            )\n\n    def check(self, *, batch_context: str | None = None) -> RateLimitResult:\n        \"\"\"Check rate limits and record the write.\n\n        Args:\n            batch_context: If provided and in ``BATCH_EXEMPT_CONTEXTS``,\n                the write is exempt from rate limiting.\n\n        Returns:\n            ``RateLimitResult`` indicating whether limits were exceeded.\n            In warn-only mode, ``allowed`` is always ``True``.\n        \"\"\"\n        if not self._config.enabled:\n            return RateLimitResult()\n\n        # Batch context exemption (H6b)\n        if batch_context is not None and batch_context in BATCH_EXEMPT_CONTEXTS:\n            with self._lock:\n                self._stats.exempt_writes += 1\n                self._stats.total_writes += 1\n            return RateLimitResult()\n\n        now = time.monotonic()\n        window_start = now - 60.0\n\n        with self._lock:\n            # Prune timestamps older than 1 minute\n            self._timestamps = [t for t in self._timestamps if t > window_start]\n\n            # Record this write\n            self._timestamps.append(now)\n            self._session_count += 1\n            self._stats.total_writes += 1\n\n            minute_count = len(self._timestamps)\n            session_count = self._session_count\n\n            minute_exceeded = minute_count > self._config.writes_per_minute\n            session_exceeded = session_count > self._config.writes_per_session\n\n            if minute_exceeded:\n                self._stats.minute_anomalies += 1\n            if session_exceeded:\n                self._stats.session_anomalies += 1\n\n        # Build result\n        result = RateLimitResult(\n            allowed=True,  # Warn-only: never block\n            minute_exceeded=minute_exceeded,\n            session_exceeded=session_exceeded,\n            current_minute_count=minute_count,\n            current_session_count=session_count,\n        )\n\n        # Log warnings for exceeded limits\n        if minute_exceeded:\n            result.message = (\n                f\"Rate limit warning: {minute_count} writes in last minute \"\n                f\"(limit: {self._config.writes_per_minute})\"\n            )\n            logger.warning(\n                \"rate_limit_minute_exceeded\",\n                current=minute_count,\n                limit=self._config.writes_per_minute,\n            )\n\n        if session_exceeded:\n            msg = (\n                f\"Rate limit warning: {session_count} writes this session \"\n                f\"(limit: {self._config.writes_per_session})\"\n            )\n            if result.message:\n                result.message += f\"; {msg}\"\n            else:\n                result.message = msg\n            logger.warning(\n                \"rate_limit_session_exceeded\",\n                current=session_count,\n                limit=self._config.writes_per_session,\n            )\n\n        return result\n\n    def reset(self) -> None:\n        \"\"\"Reset all counters and timestamps (useful for testing).\"\"\"\n        with self._lock:\n            self._timestamps.clear()\n            self._session_count = 0\n            self._stats = RateLimiterStats()\n","numLines":183,"startLine":1,"totalLines":183}}}
