{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Mb7umxyTjUPFFBmvTMLHf4","type":"tool_result","content":"  1050→    def health(self) -> StoreHealthReport:\n  1051→        \"\"\"Return a structured health report for this store.\"\"\"\n  1052→        from datetime import UTC, datetime\n  1053→\n  1054→        from tapps_brain.federation import load_federation_config\n  1055→        from tapps_brain.gc import MemoryGarbageCollector\n  1056→        from tapps_brain.similarity import find_consolidation_groups\n  1057→\n  1058→        with self._lock:\n  1059→            entries = list(self._entries.values())\n  1060→\n  1061→        tier_counts: dict[str, int] = {}\n  1062→        for entry in entries:\n  1063→            tier_val = entry.tier.value if isinstance(entry.tier, MemoryTier) else str(entry.tier)\n  1064→            tier_counts[tier_val] = tier_counts.get(tier_val, 0) + 1\n  1065→\n  1066→        schema_ver = self._persistence.get_schema_version()\n  1067→\n  1068→        oldest_age = 0.0\n  1069→        now = datetime.now(tz=UTC)\n  1070→        for entry in entries:\n  1071→            try:\n  1072→                raw = entry.created_at.replace(\"Z\", \"+00:00\")\n  1073→                created = datetime.fromisoformat(raw)\n  1074→                if created.tzinfo is None:\n  1075→                    created = created.replace(tzinfo=UTC)\n  1076→                days = (now - created).total_seconds() / 86400.0\n  1077→                oldest_age = max(oldest_age, days)\n  1078→            except (ValueError, TypeError, AttributeError):\n  1079→                continue\n  1080→\n  1081→        gc = MemoryGarbageCollector()\n  1082→        gc_candidates = gc.identify_candidates(entries)\n  1083→\n  1084→        groups = find_consolidation_groups(\n  1085→            entries,\n  1086→            threshold=self._consolidation_config.threshold,\n  1087→        )\n  1088→        consolidation_candidates = sum(len(g) for g in groups)\n  1089→\n  1090→        fed = load_federation_config()\n  1091→        federation_project_count = len(fed.projects)\n  1092→\n  1093→        # Integrity verification (H4c)\n  1094→        integrity = self.verify_integrity()\n  1095→\n  1096→        return StoreHealthReport(\n  1097→            store_path=str(self._project_root),\n  1098→            entry_count=len(entries),\n  1099→            max_entries=_MAX_ENTRIES,\n  1100→            schema_version=schema_ver,\n  1101→            tier_distribution=tier_counts,\n  1102→            oldest_entry_age_days=oldest_age,\n  1103→            consolidation_candidates=consolidation_candidates,\n  1104→            gc_candidates=len(gc_candidates),\n  1105→            federation_enabled=federation_project_count > 0,\n  1106→            federation_project_count=federation_project_count,\n  1107→            integrity_verified=integrity[\"verified\"],\n  1108→            integrity_tampered=integrity[\"tampered\"],\n  1109→            integrity_no_hash=integrity[\"no_hash\"],\n  1110→            integrity_tampered_keys=integrity[\"tampered_keys\"][:20],\n  1111→        )\n  1112→\n  1113→    def gc(self, *, dry_run: bool = False) -> Any:  # noqa: ANN401\n  1114→        \"\"\"Run garbage collection on the store.\n  1115→\n  1116→        Args:\n  1117→            dry_run: If True, only identify candidates without archiving.\n  1118→\n  1119→        Returns:\n  1120→            ``GCResult`` with archived count and keys.\n  1121→        \"\"\"\n  1122→        from tapps_brain.gc import GCResult, MemoryGarbageCollector\n  1123→\n  1124→        self._metrics.increment(\"store.gc\")\n  1125→        gc_collector = MemoryGarbageCollector()\n  1126→        with self._lock:\n  1127→            entries = list(self._entries.values())\n  1128→        candidates = gc_collector.identify_candidates(entries)\n  1129→        candidate_keys = [c.key for c in candidates]\n  1130→\n  1131→        if dry_run:\n  1132→            return GCResult(\n  1133→                archived_count=0,\n  1134→                remaining_count=len(entries),\n  1135→                archived_keys=candidate_keys,\n  1136→            )\n  1137→\n  1138→        # Archive to JSONL and delete from store\n  1139→        archive_path = self._persistence._store_dir / \"gc_archive.jsonl\"\n  1140→        MemoryGarbageCollector.append_to_archive(candidates, archive_path)\n  1141→        for key in candidate_keys:\n  1142→            self.delete(key)\n  1143→\n  1144→        self._metrics.increment(\"store.gc.archived\", len(candidate_keys))\n  1145→        return GCResult(\n  1146→            archived_count=len(candidate_keys),\n  1147→            remaining_count=len(entries) - len(candidate_keys),\n  1148→            archived_keys=candidate_keys,\n  1149→        )\n  1150→\n  1151→    def audit(\n  1152→        self,\n  1153→        *,\n  1154→        key: str | None = None,\n  1155→        event_type: str | None = None,\n  1156→        since: str | None = None,\n  1157→        until: str | None = None,\n  1158→        limit: int = 100,\n  1159→    ) -> list[Any]:\n  1160→        \"\"\"Query the JSONL audit trail.\n  1161→\n  1162→        Convenience wrapper around ``AuditReader.query()``.\n  1163→\n  1164→        Args:\n  1165→            key: Filter by memory entry key.\n  1166→            event_type: Filter by event type (save, delete, etc.).\n  1167→            since: ISO-8601 lower bound (inclusive).\n  1168→            until: ISO-8601 upper bound (inclusive).\n  1169→            limit: Maximum number of entries to return.\n  1170→\n  1171→        Returns:\n  1172→            List of ``AuditEntry`` objects matching the filters.\n  1173→        \"\"\"\n  1174→        from tapps_brain.audit import AuditReader\n  1175→\n  1176→        reader = AuditReader(self._persistence._audit_path)\n  1177→        return reader.query(\n  1178→            key=key,\n  1179→            event_type=event_type,\n  1180→            since=since,\n  1181→            until=until,\n  1182→            limit=limit,\n  1183→        )\n  1184→\n  1185→    def get_metrics(self) -> MetricsSnapshot:\n  1186→        \"\"\"Return a snapshot of in-process operation metrics.\"\"\"\n  1187→        return self._metrics.snapshot()\n  1188→\n  1189→    # ------------------------------------------------------------------\n  1190→    # Relations (EPIC-006)\n  1191→    # ------------------------------------------------------------------\n  1192→\n  1193→    def get_relations(self, key: str) -> list[dict[str, Any]]:\n  1194→        \"\"\"Return all relations associated with a memory entry key.\n  1195→\n  1196→        Args:\n  1197→            key: The memory entry key.\n  1198→\n  1199→        Returns:\n  1200→            List of relation dicts with subject, predicate, object_entity,\n  1201→            source_entry_keys, confidence, and created_at.\n  1202→        \"\"\"\n  1203→        return list(self._relations.get(key, []))\n  1204→\n  1205→    def find_related(\n  1206→        self,\n  1207→        key: str,\n  1208→        *,\n  1209→        max_hops: int = 2,\n  1210→    ) -> list[tuple[str, int]]:\n  1211→        \"\"\"Find entries related to *key* via BFS traversal of the relation graph.\n  1212→\n  1213→        Two entries are considered connected when they share an entity\n  1214→        (subject or object_entity) in their extracted relations.\n  1215→\n  1216→        Args:\n  1217→            key: Starting entry key.\n  1218→            max_hops: Maximum traversal depth (default 2).\n  1219→\n  1220→        Returns:\n  1221→            List of ``(entry_key, hop_distance)`` tuples, ordered by hop\n  1222→            distance (ascending) then key name.  The starting key is\n  1223→            **not** included in the results.\n  1224→\n  1225→        Raises:\n  1226→            KeyError: If *key* does not exist in the store.\n  1227→        \"\"\"\n  1228→        with self._lock:\n  1229→            if key not in self._entries:\n  1230→                raise KeyError(key)\n  1231→\n  1232→            # Build entity -> set[entry_key] index from all relations\n  1233→            entity_to_keys: dict[str, set[str]] = {}\n  1234→            for entry_key, rels in self._relations.items():\n  1235→                for rel in rels:\n  1236→                    for entity in (rel[\"subject\"].lower(), rel[\"object_entity\"].lower()):\n  1237→                        entity_to_keys.setdefault(entity, set()).add(entry_key)\n  1238→\n  1239→            # BFS\n  1240→            visited: set[str] = {key}\n  1241→            result: list[tuple[str, int]] = []\n  1242→            frontier: set[str] = {key}\n  1243→\n  1244→            for hop in range(1, max_hops + 1):\n  1245→                next_frontier: set[str] = set()\n  1246→                for current_key in frontier:\n  1247→                    # Collect entities from current_key's relations\n  1248→                    for rel in self._relations.get(current_key, []):\n  1249→                        for entity in (rel[\"subject\"].lower(), rel[\"object_entity\"].lower()):"}]},"parent_tool_use_id":"toolu_01LbDdTJVatSJ29PCFJETdBX","session_id":"b8c12035-e8ed-4df0-b6e9-5090fcc99196","uuid":"0954e95a-18c9-413f-9a24-bccccfb8fb57","timestamp":"2026-03-22T22:30:44.855Z"}
