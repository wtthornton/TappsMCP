tent_safety(p.value)\n  1618→    return {\n  1619→        \"action\": \"safety_check\",\n  1620→        \"safe\": result.safe,\n  1621→        \"flagged_patterns\": result.flagged_patterns,\n  1622→        \"match_count\": result.match_count,\n  1623→        \"warning\": result.warning,\n  1624→        \"sanitised_preview\": (\n  1625→            result.sanitised_content[:_VALUE_PREVIEW_LEN] + \"...\"\n  1626→            if result.sanitised_content and len(result.sanitised_content) > _VALUE_PREVIEW_LEN\n  1627→            else result.sanitised_content\n  1628→        ),\n  1629→    }\n  1630→\n  1631→\n  1632→def _handle_verify_integrity(store: MemoryStore, _p: _Params) -> dict[str, Any]:\n  1633→    \"\"\"Handle the verify_integrity action -- check memory entries for tampering.\n  1634→\n  1635→    Delegates to ``store.verify_integrity()`` for HMAC-SHA256 verification\n  1636→    when available. Falls back to a basic consistency check (entry round-trip)\n  1637→    for older tapps-brain versions.\n  1638→    \"\"\"\n  1639→    if hasattr(store, \"verify_integrity\") and callable(store.verify_integrity):\n  1640→        result = store.verify_integrity()\n  1641→        return {"}]},"parent_tool_use_id":"toolu_01RJAcJZz7Cn5wtgAByaGREC","session_id":"7d2ed658-450a-4244-b41e-ec52ea2ad30e","uuid":"66ec35b4-2ab8-4f5f-ace6-bddf9e3f085f","timestamp":"2026-03-22T22:32:55.852Z"}
