{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LgnL37TMMpt7Pd2Zr6cEmr","type":"tool_result","content":"  1485→        \"hub_stats\": stats,\n  1486→    }\n  1487→\n  1488→\n  1489→def _handle_maintain(store: MemoryStore, _p: _Params) -> dict[str, Any]:\n  1490→    \"\"\"Run memory maintenance: GC + consolidation + deduplication (Epic 65.15).\"\"\"\n  1491→    gc_archived = 0\n  1492→    consolidated = 0\n  1493→    deduplicated = 0\n  1494→\n  1495→    # Run GC (same approach as _handle_gc)\n  1496→    try:\n  1497→        from tapps_core.memory.decay import DecayConfig\n  1498→        from tapps_core.memory.gc import MemoryGarbageCollector\n  1499→\n  1500→        config = DecayConfig()\n  1501→        gc_runner = MemoryGarbageCollector(config)\n  1502→        snap = store.snapshot()\n  1503→        candidates = gc_runner.identify_candidates(snap.entries)\n  1504→        for candidate in candidates:\n  1505→            if store.delete(candidate.key):\n  1506→                gc_archived += 1\n  1507→    except Exception:\n  1508→        pass\n  1509→\n  1510→    # Run consolidation scan\n  1511→    try:\n  1512→        from tapps_core.memory.auto_consolidation import run_periodic_consolidation_scan\n  1513→\n  1514→        consol_result = run_periodic_consolidation_scan(store)\n  1515→        consolidated = getattr(consol_result, \"groups_formed\", 0) if consol_result else 0\n  1516→    except Exception:\n  1517→        pass\n  1518→\n  1519→    # Deduplication: find exact duplicate values and merge\n  1520→    try:\n  1521→        snapshot = store.snapshot()\n  1522→        seen_values: dict[str, str] = {}  # value hash -> first key\n  1523→        for entry in snapshot.entries:\n  1524→            val_hash = entry.value.strip().lower()\n  1525→            if val_hash in seen_values and seen_values[val_hash] != entry.key:\n  1526→                store.delete(entry.key)\n  1527→                deduplicated += 1\n  1528→            else:\n  1529→                seen_values[val_hash] = entry.key\n  1530→    except Exception:\n  1531→        pass\n  1532→\n  1533→    return {\n  1534→        \"action\": \"maintain\",\n  1535→        \"gc_archived\": gc_archived,\n  1536→        \"consolidated\": consolidated,\n  1537→        \"deduplicated\": deduplicated,\n  1538→        \"store_metadata\": _store_metadata(store),\n  1539→    }\n  1540→\n  1541→\n  1542→def _handle_health(store: MemoryStore, _p: _Params) -> dict[str, Any]:\n  1543→    \"\"\"Handle the health action -- aggregate health report with integrity status.\n  1544→\n  1545→    Delegates to ``store.health()`` when available (tapps-brain >= v1.1.0).\n  1546→    Falls back to a basic snapshot-based report for older versions.\n  1547→    \"\"\"\n  1548→    if hasattr(store, \"health\") and callable(store.health):\n  1549→        report = store.health()\n  1550→        return {\n  1551→            \"action\": \"health\",\n  1552→            \"store_path\": report.store_path,\n  1553→            \"entry_count\": report.entry_count,\n  1554→            \"max_entries\": report.max_entries,\n  1555→            \"schema_version\": report.schema_version,\n  1556→            \"tier_distribution\": report.tier_distribution,\n  1557→            \"oldest_entry_age_days\": round(report.oldest_entry_age_days, 1),\n  1558→            \"consolidation_candidates\": report.consolidation_candidates,\n  1559→            \"gc_candidates\": report.gc_candidates,\n  1560→            \"federation_enabled\": report.federation_enabled,\n  1561→            \"federation_project_count\": report.federation_project_count,\n  1562→            # Integrity (H4c)\n  1563→            \"integrity_verified\": report.integrity_verified,\n  1564→            \"integrity_tampered\": report.integrity_tampered,\n  1565→            \"integrity_no_hash\": report.integrity_no_hash,\n  1566→            \"integrity_tampered_keys\": report.integrity_tampered_keys[:20],\n  1567→            \"integrity_status\": (\n  1568→                \"clean\" if report.integrity_tampered == 0 else \"tampered\"\n  1569→            ),\n  1570→            # Rate limiter anomaly counts (H6c)\n  1571→            \"rate_limit_minute_anomalies\": getattr(\n  1572→                report, \"rate_limit_minute_anomalies\", 0\n  1573→            ),\n  1574→            \"rate_limit_session_anomalies\": getattr(\n  1575→                report, \"rate_limit_session_anomalies\", 0\n  1576→            ),\n  1577→            \"rate_limit_total_writes\": getattr(\n  1578→                report, \"rate_limit_total_writes\", 0\n  1579→            ),\n  1580→            \"rate_limit_exempt_writes\": getattr(\n  1581→                report, \"rate_limit_exempt_writes\", 0\n  1582→            ),\n  1583→        }\n  1584→\n  1585→    # Fallback for older tapps-brain without store.health()\n  1586→    snap = store.snapshot()\n  1587→    return {\n  1588→        \"action\": \"health\",\n  1589→        \"entry_count\": snap.total_count,\n  1590→        \"tier_distribution\": snap.tier_counts,\n  1591→        \"integrity_status\": \"unavailable\",\n  1592→        \"degraded\": True,\n  1593→        \"message\": \"Full health report requires tapps-brain >= v1.1.0.\",\n  1594→    }\n  1595→\n  1596→\n  1597→# ---------------------------------------------------------------------------\n  1598→# Epic M1: Security surface handlers\n  1599→# ---------------------------------------------------------------------------\n  1600→\n  1601→\n  1602→def _handle_safety_check(store: MemoryStore, p: _Params) -> dict[str, Any]:\n  1603→    \"\"\"Handle the safety_check action -- pre-flight content safety validation.\"\"\"\n  1604→    if not p.value:"}]},"parent_tool_use_id":"toolu_01RJAcJZz7Cn5wtgAByaGREC","session_id":"7d2ed658-450a-4244-b41e-ec52ea2ad30e","uuid":"e7ac7ea2-ec9f-4490-9a6d-ababc59a55d8","timestamp":"2026-03-22T22:38:52.266Z"}
