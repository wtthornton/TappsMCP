{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013U7V87XWGncXET5ReaG9CD","type":"tool_result","content":"     1→\"\"\"Memory tool handlers for TappsMCP.\n     2→\n     3→Functions are defined at module level (importable for tests) and\n     4→registered on the ``mcp`` instance via :func:`register`.\n     5→\"\"\"\n     6→\n     7→from __future__ import annotations\n     8→\n     9→import dataclasses\n    10→import json\n    11→import time\n    12→from pathlib import Path\n    13→from typing import TYPE_CHECKING, Any\n    14→\n    15→import structlog\n    16→\n    17→from tapps_mcp.server_helpers import (\n    18→    _get_memory_store,\n    19→    ensure_session_initialized,\n    20→    error_response,\n    21→    success_response,\n    22→)\n    23→\n    24→if TYPE_CHECKING:\n    25→    from collections.abc import Callable\n    26→\n    27→    from mcp.server.fastmcp import FastMCP\n    28→\n    29→    from tapps_core.memory.models import MemoryEntry\n    30→    from tapps_core.memory.store import MemoryStore\n    31→\n    32→from mcp.types import ToolAnnotations\n    33→\n    34→_ANNOTATIONS_MEMORY = ToolAnnotations(\n    35→    readOnlyHint=False,\n    36→    destructiveHint=False,\n    37→    idempotentHint=False,\n    38→    openWorldHint=False,\n    39→)\n    40→\n    41→_VALUE_PREVIEW_LEN = 200\n    42→\n    43→logger = structlog.get_logger(__name__)\n    44→\n    45→_VALID_ACTIONS = {\n    46→    \"save\",\n    47→    \"save_bulk\",\n    48→    \"get\",\n    49→    \"list\",\n    50→    \"delete\",\n    51→    \"search\",\n    52→    \"reinforce\",\n    53→    \"gc\",\n    54→    \"contradictions\",\n    55→    \"reseed\",\n    56→    \"import\",\n    57→    \"export\",\n    58→    \"consolidate\",\n    59→    \"unconsolidate\",\n    60→    \"federate_register\",\n    61→    \"federate_publish\",\n    62→    \"federate_subscribe\",\n    63→    \"federate_sync\",\n    64→    \"federate_search\",\n    65→    \"federate_status\",\n    66→    \"index_session\",\n    67→    \"validate\",\n    68→    \"maintain\",\n    69→    # Epic M1: Security surface\n    70→    \"safety_check\",\n    71→    \"verify_integrity\",\n    72→    # Epic M2: Profile & lifecycle management\n    73→    \"profile_info\",\n    74→    \"profile_list\",\n    75→    \"profile_switch\",\n    76→    # Health / diagnostics\n    77→    \"health\",\n    78→}\n    79→\n    80→# Async actions require special dispatch (doc lookups are async)\n    81→_ASYNC_ACTIONS = {\"validate\"}\n    82→\n    83→_BULK_SAVE_MAX_ENTRIES = 50\n    84→\n    85→# Curated response limits\n    86→_SEARCH_DEFAULT_LIMIT = 10\n    87→_LIST_DEFAULT_LIMIT = 50\n    88→_FULL_VALUE_THRESHOLD = 5\n    89→_SUMMARY_MAX_LEN = 80\n    90→\n    91→\n    92→# ---------------------------------------------------------------------------\n    93→# Typed parameter bag — eliminates **kwargs: Any in dispatch\n    94→# ---------------------------------------------------------------------------\n    95→\n    96→\n    97→@dataclasses.dataclass(frozen=True, slots=True)\n    98→class _Params:\n    99→    \"\"\"Immutable bag of parsed tool parameters passed to action handlers.\"\"\"\n   100→\n   101→    key: str\n   102→    value: str\n   103→    tier: str\n   104→    source: str\n   105→    source_agent: str\n   106→    scope: str\n   107→    tag_list: list[str]\n   108→    branch: str\n   109→    query: str\n   110→    confidence: float\n   111→    ranked: bool\n   112→    limit: int\n   113→    include_summary: bool\n   114→    file_path: str\n   115→    overwrite: bool\n   116→    entries: str\n   117→    # Consolidation parameters (Epic 58, Story 58.4)\n   118→    entry_ids: list[str]\n   119→    dry_run: bool\n   120→    # Retrieval deduplication (Epic 58, Story 58.5)\n   121→    include_sources: bool\n   122→    # Federation parameters (Epic 64)\n   123→    project_id: str = \"\"\n   124→    sources: list[str] = dataclasses.field(default_factory=list)\n   125→    min_confidence: float = 0.5\n   126→    include_hub: bool = True\n   127→    # Validation parameters (Epic 62)\n   128→    stale_only: bool = False\n   129→    max_entries: int = 10\n   130→    # Export format parameters (Epic 65.2)\n   131→    export_format: str = \"json\"\n   132→    include_frontmatter: bool = True\n   133→    export_group_by: str = \"tier\"\n   134→    # Session index (Epic 65.10)\n   135→    include_session_index: bool = False\n   136→    session_id: str = \"\"\n   137→    chunks: str = \"\"\n   138→    # Safety bypass (H3c)\n   139→    safety_bypass: bool = False\n   140→\n   141→\n   142→# ---------------------------------------------------------------------------\n   143→# Public MCP tool\n   144→# ---------------------------------------------------------------------------\n   145→\n   146→\n   147→async def tapps_memory(\n   148→    action: str,\n   149→    key: str = \"\",\n   150→    value: str = \"\",\n   151→    tier: str = \"pattern\",\n   152→    source: str = \"agent\",\n   153→    source_agent: str = \"unknown\",\n   154→    scope: str = \"project\",\n   155→    tags: str = \"\",\n   156→    branch: str = \"\",\n   157→    query: str = \"\",\n   158→    confidence: float = -1.0,\n   159→    ranked: bool = True,\n   160→    limit: int = 0,\n   161→    include_summary: bool = True,\n   162→    file_path: str = \"\",\n   163→    overwrite: bool = False,\n   164→    entries: str = \"\",\n   165→    entry_ids: str = \"\",\n   166→    dry_run: bool = False,\n   167→    include_sources: bool = False,\n   168→    project_id: str = \"\",\n   169→    sources: str = \"\",\n   170→    min_confidence: float = 0.5,\n   171→    include_hub: bool = True,\n   172→    stale_only: bool = False,\n   173→    max_entries: int = 10,\n   174→    format: str = \"json\",  # noqa: A002\n   175→    include_frontmatter: bool = True,\n   176→    group_by: str = \"tier\",\n   177→    include_session_index: bool = False,\n   178→    session_id: str = \"\",\n   179→    chunks: str = \"\",\n   180→    safety_bypass: bool = False,\n   181→) -> dict[str, Any]:\n   182→    \"\"\"Persist and retrieve project memories across sessions.\n   183→\n   184→    Side effects: save/delete/reinforce/gc/consolidate write to SQLite at\n   185→    .tapps-mcp/memory/. get/list/search are read-only.\n   186→\n   187→    Memories are typed by tier (architectural, pattern, context), carry\n   188→    confidence scores and metadata, and persist in SQLite. Use this tool\n   189→    to save decisions, patterns, and context that should survive across\n   190→    sessions and be available to all MCP-connected agents.\n   191→\n   192→    Args:\n   193→        action: One of \"save\", \"save_bulk\", \"get\", \"list\", \"delete\", \"search\",\n   194→            \"reinforce\", \"gc\", \"contradictions\", \"reseed\", \"import\", \"export\",\n   195→            \"consolidate\", \"unconsolidate\", \"safety_check\", \"verify_integrity\",\n   196→            \"profile_info\", \"profile_list\", \"profile_switch\".\n   197→        key: Memory key (required for save/get/delete/reinforce). Lowercase slug.\n   198→        value: Memory content (required for save). Max 4096 chars.\n   199→        tier: \"architectural\", \"pattern\", or \"context\" (default: \"pattern\").\n   200→        source: \"human\", \"agent\", \"inferred\", or \"system\" (default: \"agent\")."}]},"parent_tool_use_id":"toolu_01RJAcJZz7Cn5wtgAByaGREC","session_id":"7d2ed658-450a-4244-b41e-ec52ea2ad30e","uuid":"e390c90a-d0e1-4bfe-8f55-27a6c92b14c7","timestamp":"2026-03-22T22:35:24.921Z"}
