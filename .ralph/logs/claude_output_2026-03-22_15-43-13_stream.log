{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017qZGbyx4JywKz7Z1RwqP1g","type":"tool_result","content":"     1→\"\"\"Configurable memory profiles — pluggable layers and scoring (EPIC-010).\n     2→\n     3→Defines the ``MemoryProfile`` data model and loading/resolution functions.\n     4→Profiles are YAML files that configure layer definitions (tiers), decay\n     5→parameters, scoring weights, GC thresholds, and recall defaults.\n     6→\n     7→The default ``repo-brain`` profile reproduces current hardcoded behavior\n     8→exactly, ensuring zero behavior change for existing users.\n     9→\"\"\"\n    10→\n    11→from __future__ import annotations\n    12→\n    13→import importlib.resources\n    14→from pathlib import Path\n    15→from typing import Literal\n    16→\n    17→import yaml\n    18→from pydantic import BaseModel, Field, model_validator\n    19→\n    20→# ---------------------------------------------------------------------------\n    21→# Sub-models\n    22→# ---------------------------------------------------------------------------\n    23→\n    24→\n    25→class PromotionThreshold(BaseModel):\n    26→    \"\"\"Criteria for promoting a memory to a higher layer.\"\"\"\n    27→\n    28→    min_access_count: int = Field(default=5, ge=1)\n    29→    min_age_days: int = Field(default=7, ge=1)\n    30→    min_confidence: float = Field(default=0.5, ge=0.0, le=1.0)\n    31→\n    32→\n    33→class LayerDefinition(BaseModel):\n    34→    \"\"\"A single memory layer (tier) definition within a profile.\"\"\"\n    35→\n    36→    name: str\n    37→    description: str = \"\"\n    38→    half_life_days: int = Field(ge=1)\n    39→    decay_model: Literal[\"exponential\", \"power_law\"] = \"exponential\"\n    40→    decay_exponent: float = Field(default=1.0, ge=0.1, le=5.0)\n    41→    confidence_floor: float = Field(default=0.1, ge=0.0, le=1.0)\n    42→    importance_tags: dict[str, float] = Field(default_factory=dict)\n    43→    promotion_to: str | None = None\n    44→    promotion_threshold: PromotionThreshold | None = None\n    45→    demotion_to: str | None = None\n    46→\n    47→\n    48→class ScoringConfig(BaseModel):\n    49→    \"\"\"Composite scoring weight configuration.\"\"\"\n    50→\n    51→    relevance: float = Field(default=0.40, ge=0.0, le=1.0)\n    52→    confidence: float = Field(default=0.30, ge=0.0, le=1.0)\n    53→    recency: float = Field(default=0.15, ge=0.0, le=1.0)\n    54→    frequency: float = Field(default=0.15, ge=0.0, le=1.0)\n    55→    bm25_norm_k: float = Field(default=5.0, ge=0.1)\n    56→    frequency_cap: int = Field(default=20, ge=1)\n    57→\n    58→    _WEIGHT_SUM_LO: float = 0.95\n    59→    _WEIGHT_SUM_HI: float = 1.05\n    60→\n    61→    @model_validator(mode=\"after\")\n    62→    def _weights_sum_check(self) -> ScoringConfig:\n    63→        total = self.relevance + self.confidence + self.recency + self.frequency\n    64→        if not (self._WEIGHT_SUM_LO <= total <= self._WEIGHT_SUM_HI):\n    65→            msg = (\n    66→                f\"Scoring weights must sum to ~1.0 (got {total:.3f}). \"\n    67→                f\"relevance={self.relevance}, confidence={self.confidence}, \"\n    68→                f\"recency={self.recency}, frequency={self.frequency}\"\n    69→            )\n    70→            raise ValueError(msg)\n    71→        return self\n    72→\n    73→\n    74→class GCConfig(BaseModel):\n    75→    \"\"\"Garbage collection configuration.\"\"\"\n    76→\n    77→    floor_retention_days: int = Field(default=30, ge=1)\n    78→    session_expiry_days: int = Field(default=7, ge=1)\n    79→    contradicted_threshold: float = Field(default=0.2, ge=0.0, le=1.0)\n    80→    stale_threshold: float = Field(default=0.3, ge=0.0, le=1.0)\n    81→\n    82→\n    83→class RecallProfileConfig(BaseModel):\n    84→    \"\"\"Recall / injection defaults.\"\"\"\n    85→\n    86→    default_token_budget: int = Field(default=2000, ge=100)\n    87→    default_engagement: Literal[\"low\", \"medium\", \"high\"] = \"high\"\n    88→    min_score: float = Field(default=0.3, ge=0.0, le=1.0)\n    89→    min_confidence: float = Field(default=0.1, ge=0.0, le=1.0)\n    90→\n    91→\n    92→class LimitsConfig(BaseModel):\n    93→    \"\"\"Store limits configuration.\"\"\"\n    94→\n    95→    max_entries: int = Field(default=500, ge=1)\n    96→    max_key_length: int = Field(default=128, ge=1)\n    97→    max_value_length: int = Field(default=4096, ge=1)\n    98→    max_tags: int = Field(default=10, ge=1)\n    99→\n   100→\n   101→class HiveConfig(BaseModel):\n   102→    \"\"\"Hive propagation configuration (EPIC-011).\n   103→\n   104→    Controls how memories flow between the local store and the Hive.\n   105→    When absent or all defaults, Hive is effectively disabled.\n   106→    \"\"\"\n   107→\n   108→    auto_propagate_tiers: list[str] = Field(\n   109→        default_factory=list,\n   110→        description=\"Tiers that auto-propagate to the Hive (e.g. ['architectural']).\",\n   111→    )\n   112→    private_tiers: list[str] = Field(\n   113→        default_factory=list,\n   114→        description=\"Tiers that never propagate (e.g. ['context']).\",\n   115→    )\n   116→    conflict_policy: str = Field(\n   117→        default=\"supersede\",\n   118→        description=(\n   119→            \"Conflict resolution: 'supersede' | 'source_authority'\"\n   120→            \" | 'confidence_max' | 'last_write_wins'.\"\n   121→        ),\n   122→    )\n   123→    recall_weight: float = Field(\n   124→        default=0.8,\n   125→        ge=0.0,\n   126→        le=1.0,\n   127→        description=\"Weight multiplier for Hive results in recall (0.0-1.0).\",\n   128→    )\n   129→\n   130→\n   131→# ---------------------------------------------------------------------------\n   132→# Main profile model\n   133→# ---------------------------------------------------------------------------\n   134→\n   135→_DEFAULT_SOURCE_CONFIDENCE: dict[str, float] = {\n   136→    \"human\": 0.95,\n   137→    \"agent\": 0.60,\n   138→    \"inferred\": 0.40,\n   139→    \"system\": 0.90,\n   140→}\n   141→\n   142→_DEFAULT_SOURCE_CEILINGS: dict[str, float] = {\n   143→    \"human\": 0.95,\n   144→    \"agent\": 0.85,\n   145→    \"inferred\": 0.70,\n   146→    \"system\": 0.95,\n   147→}\n   148→\n   149→\n   150→class MemoryProfile(BaseModel):\n   151→    \"\"\"A complete memory profile configuration.\n   152→\n   153→    Loaded from YAML at ``MemoryStore`` init time. The default\n   154→    ``repo-brain`` profile reproduces current hardcoded behavior exactly.\n   155→    \"\"\"\n   156→\n   157→    name: str\n   158→    version: str = \"1.0\"\n   159→    extends: str | None = None\n   160→    description: str = \"\"\n   161→    layers: list[LayerDefinition]\n   162→    scoring: ScoringConfig = Field(default_factory=ScoringConfig)\n   163→    source_confidence: dict[str, float] = Field(\n   164→        default_factory=lambda: dict(_DEFAULT_SOURCE_CONFIDENCE)\n   165→    )\n   166→    source_ceilings: dict[str, float] = Field(\n   167→        default_factory=lambda: dict(_DEFAULT_SOURCE_CEILINGS)\n   168→    )\n   169→    gc: GCConfig = Field(default_factory=GCConfig)\n   170→    recall: RecallProfileConfig = Field(default_factory=RecallProfileConfig)\n   171→    limits: LimitsConfig = Field(default_factory=LimitsConfig)\n   172→    hive: HiveConfig = Field(default_factory=HiveConfig)\n   173→\n   174→    @model_validator(mode=\"after\")\n   175→    def _validate_layers(self) -> MemoryProfile:\n   176→        names = [layer.name for layer in self.layers]\n   177→        if len(names) != len(set(names)):\n   178→            seen: set[str] = set()\n   179→            dupes = [n for n in names if n in seen or seen.add(n)]  # type: ignore[func-returns-value]\n   180→            msg = f\"Layer names must be unique. Duplicates: {dupes}\"\n   181→            raise ValueError(msg)\n   182→\n   183→        # Validate promotion/demotion targets reference existing layers\n   184→        name_set = set(names)\n   185→        for layer in self.layers:\n   186→            if layer.promotion_to and layer.promotion_to not in name_set:\n   187→                msg = (\n   188→                    f\"Layer '{layer.name}' has promotion_to='{layer.promotion_to}' \"\n   189→                    f\"which is not a defined layer.\"\n   190→                )\n   191→                raise ValueError(msg)\n   192→            if layer.demotion_to and layer.demotion_to not in name_set:\n   193→                msg = (\n   194→                    f\"Layer '{layer.name}' has demotion_to='{layer.demotion_to}' \"\n   195→                    f\"which is not a defined layer.\"\n   196→                )\n   197→                raise ValueError(msg)\n   198→        return self\n   199→\n   200→    def get_layer(self, name: str) -> LayerDefinition | None:\n   201→        \"\"\"Return the layer definition for *name*, or ``None``.\"\"\"\n   202→        for layer in self.layers:\n   203→            if layer.name == name:\n   204→                return layer\n   205→        return None\n   206→\n   207→    def get_layer_or_default(self, name: str) -> LayerDefinition:\n   208→        \"\"\"Return the layer for *name*, falling back to the shortest half-life layer.\"\"\"\n   209→        layer = self.get_layer(name)\n   210→        if layer is not None:\n   211→            return layer\n   212→        # Fallback: shortest half-life layer\n   213→        return min(self.layers, key=lambda la: la.half_life_days)\n   214→\n   215→    @property\n   216→    def layer_names(self) -> list[str]:\n   217→        \"\"\"Return the ordered list of layer names.\"\"\"\n   218→        return [layer.name for layer in self.layers]\n   219→\n   220→\n   221→# ---------------------------------------------------------------------------\n   222→# Profile loading\n   223→# ---------------------------------------------------------------------------\n   224→\n   225→_MAX_INHERITANCE_DEPTH = 3\n   226→\n   227→\n   228→def load_profile(path: Path) -> MemoryProfile:\n   229→    \"\"\"Load and validate a profile from a YAML file.\n   230→\n   231→    The YAML is expected to have a top-level ``profile`` key.\n   232→\n   233→    Raises:\n   234→        FileNotFoundError: If *path* does not exist.\n   235→        ValueError: If the YAML is invalid or fails validation.\n   236→    \"\"\"\n   237→    text = path.read_text(encoding=\"utf-8\")\n   238→    data = yaml.safe_load(text)\n   239→    if not isinstance(data, dict):\n   240→        msg = f\"Profile YAML must be a mapping, got {type(data).__name__}\"\n   241→        raise ValueError(msg)\n   242→\n   243→    profile_data = data.get(\"profile\", data)\n   244→    return MemoryProfile.model_validate(profile_data)\n   245→\n   246→\n   247→def _builtin_profiles_dir() -> Path:\n   248→    \"\"\"Return the path to the built-in profiles directory.\"\"\"\n   249→    ref = importlib.resources.files(\"tapps_brain\") / \"profiles\"\n   250→    # files() returns a Traversable; for our purposes it's always a Path"}]},"parent_tool_use_id":"toolu_018L5tqxjjasB32i2EQmYvDy","session_id":"1dfeb66a-ec06-46ac-b5f4-422c4dae48e2","uuid":"2a2dbf51-2810-462d-bdaf-f5360a185441","timestamp":"2026-03-22T22:44:05.298Z"}
