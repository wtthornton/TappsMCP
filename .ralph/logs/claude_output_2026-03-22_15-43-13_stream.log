{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UXhsgdoveJzEVaMhn1p9d2","type":"tool_result","content":"     1→\"\"\"Shared test factories for tapps-brain.\n     2→\n     3→Provides a single ``make_entry`` helper that covers all parameter\n     4→variants previously scattered across per-file ``_make_entry`` helpers.\n     5→\"\"\"\n     6→\n     7→from __future__ import annotations\n     8→\n     9→from datetime import UTC, datetime\n    10→\n    11→from tapps_brain.models import (\n    12→    MemoryEntry,\n    13→    MemoryScope,\n    14→    MemorySource,\n    15→    MemoryTier,\n    16→)\n    17→\n    18→\n    19→def make_entry(\n    20→    key: str = \"test-key\",\n    21→    value: str = \"test value\",\n    22→    *,\n    23→    tier: MemoryTier = MemoryTier.pattern,\n    24→    confidence: float = -1.0,\n    25→    source: MemorySource | str = MemorySource.agent,\n    26→    source_agent: str = \"test\",\n    27→    scope: MemoryScope = MemoryScope.project,\n    28→    tags: list[str] | None = None,\n    29→    branch: str | None = None,\n    30→    created_at: str | None = None,\n    31→    updated_at: str | None = None,\n    32→    last_accessed: str | None = None,\n    33→    access_count: int = 0,\n    34→    last_reinforced: str | None = None,\n    35→    reinforce_count: int = 0,\n    36→    contradicted: bool = False,\n    37→    contradiction_reason: str | None = None,\n    38→    seeded_from: str | None = None,\n    39→    valid_at: str | None = None,\n    40→    invalid_at: str | None = None,\n    41→    superseded_by: str | None = None,\n    42→) -> MemoryEntry:\n    43→    \"\"\"Create a ``MemoryEntry`` with sensible test defaults.\n    44→\n    45→    Every parameter accepted by ``MemoryEntry`` can be overridden.\n    46→    Timestamp fields default to *now* when not supplied.\n    47→\n    48→    The ``confidence`` default of ``-1.0`` triggers the model's\n    49→    source-based default (0.95 for human, 0.6 for agent, etc.).\n    50→    Pass an explicit float to override.\n    51→    \"\"\"\n    52→    now_iso = datetime.now(tz=UTC).isoformat()\n    53→\n    54→    kwargs: dict[str, object] = {\n    55→        \"key\": key,\n    56→        \"value\": value,\n    57→        \"tier\": tier,\n    58→        \"source\": source,\n    59→        \"source_agent\": source_agent,\n    60→        \"scope\": scope,\n    61→        \"tags\": tags or [],\n    62→        \"branch\": branch,\n    63→        \"created_at\": created_at or now_iso,\n    64→        \"updated_at\": updated_at or now_iso,\n    65→        \"last_accessed\": last_accessed or now_iso,\n    66→        \"access_count\": access_count,\n    67→        \"last_reinforced\": last_reinforced,\n    68→        \"reinforce_count\": reinforce_count,\n    69→        \"contradicted\": contradicted,\n    70→        \"contradiction_reason\": contradiction_reason,\n    71→        \"seeded_from\": seeded_from,\n    72→        \"valid_at\": valid_at,\n    73→        \"invalid_at\": invalid_at,\n    74→        \"superseded_by\": superseded_by,\n    75→    }\n    76→\n    77→    if confidence != -1.0:\n    78→        kwargs[\"confidence\"] = confidence\n    79→\n    80→    return MemoryEntry(**kwargs)  # type: ignore[arg-type]\n    81→"}]},"parent_tool_use_id":null,"session_id":"1dfeb66a-ec06-46ac-b5f4-422c4dae48e2","uuid":"9465cd66-b632-4346-b9fa-bcf50d10a836","timestamp":"2026-03-22T22:45:13.748Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\cursor\\tapps-brain\\tests\\factories.py","content":"\"\"\"Shared test factories for tapps-brain.\n\nProvides a single ``make_entry`` helper that covers all parameter\nvariants previously scattered across per-file ``_make_entry`` helpers.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom datetime import UTC, datetime\n\nfrom tapps_brain.models import (\n    MemoryEntry,\n    MemoryScope,\n    MemorySource,\n    MemoryTier,\n)\n\n\ndef make_entry(\n    key: str = \"test-key\",\n    value: str = \"test value\",\n    *,\n    tier: MemoryTier = MemoryTier.pattern,\n    confidence: float = -1.0,\n    source: MemorySource | str = MemorySource.agent,\n    source_agent: str = \"test\",\n    scope: MemoryScope = MemoryScope.project,\n    tags: list[str] | None = None,\n    branch: str | None = None,\n    created_at: str | None = None,\n    updated_at: str | None = None,\n    last_accessed: str | None = None,\n    access_count: int = 0,\n    last_reinforced: str | None = None,\n    reinforce_count: int = 0,\n    contradicted: bool = False,\n    contradiction_reason: str | None = None,\n    seeded_from: str | None = None,\n    valid_at: str | None = None,\n    invalid_at: str | None = None,\n    superseded_by: str | None = None,\n) -> MemoryEntry:\n    \"\"\"Create a ``MemoryEntry`` with sensible test defaults.\n\n    Every parameter accepted by ``MemoryEntry`` can be overridden.\n    Timestamp fields default to *now* when not supplied.\n\n    The ``confidence`` default of ``-1.0`` triggers the model's\n    source-based default (0.95 for human, 0.6 for agent, etc.).\n    Pass an explicit float to override.\n    \"\"\"\n    now_iso = datetime.now(tz=UTC).isoformat()\n\n    kwargs: dict[str, object] = {\n        \"key\": key,\n        \"value\": value,\n        \"tier\": tier,\n        \"source\": source,\n        \"source_agent\": source_agent,\n        \"scope\": scope,\n        \"tags\": tags or [],\n        \"branch\": branch,\n        \"created_at\": created_at or now_iso,\n        \"updated_at\": updated_at or now_iso,\n        \"last_accessed\": last_accessed or now_iso,\n        \"access_count\": access_count,\n        \"last_reinforced\": last_reinforced,\n        \"reinforce_count\": reinforce_count,\n        \"contradicted\": contradicted,\n        \"contradiction_reason\": contradiction_reason,\n        \"seeded_from\": seeded_from,\n        \"valid_at\": valid_at,\n        \"invalid_at\": invalid_at,\n        \"superseded_by\": superseded_by,\n    }\n\n    if confidence != -1.0:\n        kwargs[\"confidence\"] = confidence\n\n    return MemoryEntry(**kwargs)  # type: ignore[arg-type]\n","numLines":81,"startLine":1,"totalLines":81}}}
