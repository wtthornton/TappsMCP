{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HBiGiUTRNQRr411Ban7Rf6","type":"tool_result","content":"24-# ---------------------------------------------------------------------------\n25-# Configuration\n26-# ---------------------------------------------------------------------------\n27-\n28-\n29:class DecayConfig(BaseModel):\n30-    \"\"\"Configuration for memory confidence decay.\"\"\"\n31-\n32-    # Tier-specific half-lives (days)\n33-    architectural_half_life_days: int = Field(default=180, ge=1)\n34-    pattern_half_life_days: int = Field(default=60, ge=1)\n--\n176-    if entry.last_reinforced:\n177-        return entry.last_reinforced\n178-    return entry.updated_at\n179-\n180-\n181:def calculate_decayed_confidence(\n182-    entry: MemoryEntry,\n183-    config: DecayConfig,\n184-    *,\n185-    now: datetime | None = None,\n186-) -> float:\n--\n226-\n227-    # Clamp to [floor, ceiling]\n228-    return max(floor, min(ceiling, decayed))\n229-\n230-\n231:def is_stale(\n232-    entry: MemoryEntry,\n233-    config: DecayConfig,\n234-    threshold: float = _DEFAULT_STALE_THRESHOLD,\n235-    *,\n236-    now: datetime | None = None,"}]},"parent_tool_use_id":"toolu_018L5tqxjjasB32i2EQmYvDy","session_id":"1dfeb66a-ec06-46ac-b5f4-422c4dae48e2","uuid":"d9f74b8e-d115-4ac5-90d4-6ec9015a065d","timestamp":"2026-03-22T22:43:58.708Z"}
