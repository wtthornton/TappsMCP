{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01Q9otBvqJNJYFPsNUtBngGN","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_013LgeUoMLjXNh4gUbGUCMgS","name":"Read","input":{"file_path":"C:/cursor/tapps-brain/src/tapps_brain/store.py","offset":566,"limit":220},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":6,"cache_creation_input_tokens":2250,"cache_read_input_tokens":54011,"cache_creation":{"ephemeral_5m_input_tokens":2250,"ephemeral_1h_input_tokens":0},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_018L5tqxjjasB32i2EQmYvDy","session_id":"1dfeb66a-ec06-46ac-b5f4-422c4dae48e2","uuid":"1435b930-d560-475e-9f63-69e1f5a99d77"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013LgeUoMLjXNh4gUbGUCMgS","type":"tool_result","content":"   566→    def search(\n   567→        self,\n   568→        query: str,\n   569→        tags: list[str] | None = None,\n   570→        tier: str | None = None,\n   571→        scope: str | None = None,\n   572→        as_of: str | None = None,\n   573→    ) -> list[MemoryEntry]:\n   574→        \"\"\"Search via FTS5, with optional post-filters.\n   575→\n   576→        Args:\n   577→            query: Search query string.\n   578→            tags: Filter by tags.\n   579→            tier: Filter by tier.\n   580→            scope: Filter by scope.\n   581→            as_of: ISO-8601 timestamp for point-in-time temporal filtering.\n   582→                When set, only entries valid at that time are returned.\n   583→                When ``None`` (default), temporally invalid entries are excluded\n   584→                using the current time.\n   585→        \"\"\"\n   586→        self._metrics.increment(\"store.search\")\n   587→        with MetricsTimer(self._metrics, \"store.search_ms\"):\n   588→            results = self._persistence.search(query)\n   589→\n   590→            if tier is not None:\n   591→                results = [r for r in results if r.tier == tier]\n   592→            if scope is not None:\n   593→                results = [r for r in results if r.scope == scope]\n   594→            if tags:\n   595→                tag_set = set(tags)\n   596→                results = [r for r in results if tag_set.intersection(r.tags)]\n   597→\n   598→            # Temporal filtering (EPIC-004)\n   599→            results = [r for r in results if r.is_temporally_valid(as_of)]\n   600→\n   601→            self._metrics.increment(\"store.search.results\", len(results))\n   602→            return results\n   603→\n   604→    def update_fields(self, key: str, **fields: Any) -> MemoryEntry | None:  # noqa: ANN401\n   605→        \"\"\"Partial update of specific fields on an existing entry.\n   606→\n   607→        Preserves immutable fields like ``created_at``. Used by Epic 24\n   608→        decay/contradiction/reinforcement systems.\n   609→        \"\"\"\n   610→        with self._lock:\n   611→            entry = self._entries.get(key)\n   612→            if entry is None:\n   613→                return None\n   614→\n   615→            fields[\"updated_at\"] = _utc_now_iso()\n   616→            updated = entry.model_copy(update=fields)\n   617→            self._entries[key] = updated\n   618→\n   619→        self._persistence.save(updated)\n   620→        return updated\n   621→\n   622→    def count(self) -> int:\n   623→        \"\"\"Return the total number of memory entries.\"\"\"\n   624→        with self._lock:\n   625→            return len(self._entries)\n   626→\n   627→    def snapshot(self) -> MemorySnapshot:\n   628→        \"\"\"Return a serializable snapshot of the full memory state.\"\"\"\n   629→        with self._lock:\n   630→            entries = list(self._entries.values())\n   631→\n   632→        tier_counts: dict[str, int] = {}\n   633→        for entry in entries:\n   634→            tier_val = entry.tier.value if isinstance(entry.tier, MemoryTier) else str(entry.tier)\n   635→            tier_counts[tier_val] = tier_counts.get(tier_val, 0) + 1\n   636→\n   637→        return MemorySnapshot(\n   638→            project_root=str(self._project_root),\n   639→            entries=entries,\n   640→            total_count=len(entries),\n   641→            tier_counts=tier_counts,\n   642→        )\n   643→\n   644→    # ------------------------------------------------------------------\n   645→    # Reinforcement (Story 002.2)\n   646→    # ------------------------------------------------------------------\n   647→\n   648→    def reinforce(self, key: str, *, confidence_boost: float = 0.0) -> MemoryEntry:\n   649→        \"\"\"Reinforce a memory entry, resetting its decay clock atomically.\n   650→\n   651→        Args:\n   652→            key: The memory entry key to reinforce.\n   653→            confidence_boost: Optional confidence increase (0.0-0.2).\n   654→\n   655→        Returns:\n   656→            The updated ``MemoryEntry``.\n   657→\n   658→        Raises:\n   659→            KeyError: If the entry does not exist.\n   660→        \"\"\"\n   661→        from tapps_brain.reinforcement import reinforce as _reinforce\n   662→\n   663→        decay_cfg = self._get_decay_config()\n   664→\n   665→        with self._lock:\n   666→            entry = self._entries.get(key)\n   667→            if entry is None:\n   668→                raise KeyError(key)\n   669→\n   670→            updates = _reinforce(entry, decay_cfg, confidence_boost=confidence_boost)\n   671→            updated = entry.model_copy(update=updates)\n   672→            self._entries[key] = updated\n   673→\n   674→        self._persistence.save(updated)\n   675→\n   676→        # EPIC-010: Check promotion after reinforcement\n   677→        if self._profile is not None:\n   678→            try:\n   679→                from tapps_brain.promotion import PromotionEngine\n   680→\n   681→                engine = PromotionEngine(decay_cfg)\n   682→                target_tier = engine.check_promotion(updated, self._profile)\n   683→                if target_tier is not None:\n   684→                    old_tier = str(updated.tier)\n   685→                    promoted = updated.model_copy(\n   686→                        update={\"tier\": target_tier, \"updated_at\": _utc_now_iso()}\n   687→                    )\n   688→                    with self._lock:\n   689→                        self._entries[key] = promoted\n   690→                    self._persistence.save(promoted)\n   691→                    self._persistence.append_audit(\n   692→                        action=\"promote\",\n   693→                        key=key,\n   694→                        extra={\n   695→                            \"from_tier\": old_tier,\n   696→                            \"to_tier\": target_tier,\n   697→                            \"access_count\": updated.access_count,\n   698→                            \"reinforce_count\": updated.reinforce_count,\n   699→                        },\n   700→                    )\n   701→                    logger.info(\n   702→                        \"memory_promoted\",\n   703→                        key=key,\n   704→                        from_tier=old_tier,\n   705→                        to_tier=target_tier,\n   706→                    )\n   707→                    return promoted\n   708→            except Exception:\n   709→                logger.debug(\"promotion_check_failed\", key=key, exc_info=True)\n   710→\n   711→        return updated\n   712→\n   713→    # ------------------------------------------------------------------\n   714→    # Extraction ingestion (Story 002.3)\n   715→    # ------------------------------------------------------------------\n   716→\n   717→    def ingest_context(\n   718→        self,\n   719→        context: str,\n   720→        *,\n   721→        source: str = \"agent\",\n   722→        capture_prompt: str = \"\",\n   723→        agent_scope: str = \"private\",\n   724→    ) -> list[str]:\n   725→        \"\"\"Extract durable facts from context and save new entries.\n   726→\n   727→        Uses rule-based pattern matching to find decision-like statements\n   728→        and saves them as memory entries. Existing keys are skipped.\n   729→\n   730→        Args:\n   731→            context: Raw session/transcript text to scan.\n   732→            source: Source attribution for created entries.\n   733→            capture_prompt: Optional guidance for extraction.\n   734→            agent_scope: Hive propagation scope for captured facts —\n   735→                ``'private'`` (default), ``'domain'``, or ``'hive'``.\n   736→\n   737→        Returns:\n   738→            List of keys for newly created entries.\n   739→        \"\"\"\n   740→        from tapps_brain.extraction import extract_durable_facts\n   741→\n   742→        facts = extract_durable_facts(context, capture_prompt)\n   743→        created_keys: list[str] = []\n   744→\n   745→        for fact in facts:\n   746→            key = fact[\"key\"]\n   747→            # Skip if already exists\n   748→            with self._lock:\n   749→                if key in self._entries:\n   750→                    continue\n   751→\n   752→            result = self.save(\n   753→                key=key,\n   754→                value=fact[\"value\"],\n   755→                tier=fact[\"tier\"],\n   756→                source=source,\n   757→                agent_scope=agent_scope,\n   758→            )\n   759→            if isinstance(result, MemoryEntry):\n   760→                created_keys.append(key)\n   761→\n   762→        return created_keys\n   763→\n   764→    # ------------------------------------------------------------------\n   765→    # Session indexing (Story 002.4)\n   766→    # ------------------------------------------------------------------\n   767→\n   768→    def index_session(self, session_id: str, chunks: list[str]) -> int:\n   769→        \"\"\"Index session chunks for later search.\n   770→\n   771→        Args:\n   772→            session_id: Session identifier.\n   773→            chunks: List of text chunks to index.\n   774→\n   775→        Returns:\n   776→            Number of chunks stored.\n   777→        \"\"\"\n   778→        from tapps_brain.session_index import index_session as _index_session\n   779→\n   780→        try:\n   781→            return _index_session(self._project_root, session_id, chunks)\n   782→        except Exception:\n   783→            logger.debug(\"session_index_failed\", session_id=session_id, exc_info=True)\n   784→            return 0\n   785→"}]},"parent_tool_use_id":"toolu_018L5tqxjjasB32i2EQmYvDy","session_id":"1dfeb66a-ec06-46ac-b5f4-422c4dae48e2","uuid":"7415dc1c-5191-4276-986d-37dec5a2cdfd","timestamp":"2026-03-22T22:43:55.857Z"}
