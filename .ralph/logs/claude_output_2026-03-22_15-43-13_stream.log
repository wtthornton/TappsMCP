{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WF4aMv8hLy9gTQN1GzvNh8","type":"tool_result","content":"     1→\"\"\"Pydantic v2 models for the shared memory subsystem.\"\"\"\n     2→\n     3→from __future__ import annotations\n     4→\n     5→import re\n     6→from datetime import UTC, datetime\n     7→from enum import StrEnum\n     8→from typing import Any, ClassVar\n     9→\n    10→from pydantic import BaseModel, Field, field_validator, model_validator\n    11→\n    12→\n    13→def _utc_now_iso() -> str:\n    14→    \"\"\"Return the current UTC time as an ISO-8601 string.\"\"\"\n    15→    return datetime.now(tz=UTC).isoformat()\n    16→\n    17→\n    18→# ---------------------------------------------------------------------------\n    19→# Enums\n    20→# ---------------------------------------------------------------------------\n    21→\n    22→_KEY_SLUG_PATTERN = re.compile(r\"^[a-z0-9][a-z0-9._-]{0,127}$\")\n    23→\n    24→\n    25→class MemoryTier(StrEnum):\n    26→    \"\"\"Decay classification for memory entries.\"\"\"\n    27→\n    28→    architectural = \"architectural\"  # slow decay - project structure, key decisions\n    29→    pattern = \"pattern\"  # medium decay - coding patterns, conventions\n    30→    procedural = \"procedural\"  # medium decay - how to do (workflows, steps); Epic 65.11\n    31→    context = \"context\"  # fast decay - session-specific context\n    32→\n    33→\n    34→class MemorySource(StrEnum):\n    35→    \"\"\"Origin of a memory entry.\"\"\"\n    36→\n    37→    human = \"human\"  # explicitly set by a developer\n    38→    agent = \"agent\"  # created by an AI agent\n    39→    inferred = \"inferred\"  # derived from analysis\n    40→    system = \"system\"  # created by TappsMCP internals\n    41→\n    42→\n    43→class MemoryScope(StrEnum):\n    44→    \"\"\"Visibility scope of a memory entry.\"\"\"\n    45→\n    46→    project = \"project\"  # visible across the entire project\n    47→    branch = \"branch\"  # scoped to a git branch\n    48→    session = \"session\"  # ephemeral, current session only\n    49→    shared = \"shared\"  # eligible for cross-project federation\n    50→\n    51→\n    52→# ---------------------------------------------------------------------------\n    53→# Source-based confidence defaults\n    54→# ---------------------------------------------------------------------------\n    55→\n    56→_SOURCE_CONFIDENCE_DEFAULTS: dict[MemorySource, float] = {\n    57→    MemorySource.human: 0.95,\n    58→    MemorySource.agent: 0.6,\n    59→    MemorySource.inferred: 0.4,\n    60→    MemorySource.system: 0.9,\n    61→}\n    62→\n    63→# ---------------------------------------------------------------------------\n    64→# Limits\n    65→# ---------------------------------------------------------------------------\n    66→\n    67→MAX_KEY_LENGTH: int = 128\n    68→MAX_VALUE_LENGTH: int = 4096\n    69→MAX_TAGS: int = 10\n    70→\n    71→\n    72→def tier_str(tier: MemoryTier | str) -> str:\n    73→    \"\"\"Return the string value of a tier, handling both MemoryTier enum and str.\"\"\"\n    74→    return tier.value if isinstance(tier, MemoryTier) else str(tier)\n    75→\n    76→\n    77→# ---------------------------------------------------------------------------\n    78→# Models\n    79→# ---------------------------------------------------------------------------\n    80→\n    81→\n    82→class MemoryEntry(BaseModel):\n    83→    \"\"\"A single memory entry in the shared memory store.\"\"\"\n    84→\n    85→    key: str = Field(description=\"Unique slug identifier (max 128 chars).\")\n    86→    value: str = Field(description=\"Memory content (max 4096 chars).\")\n    87→    tier: MemoryTier | str = Field(default=MemoryTier.pattern, description=\"Decay classification.\")\n    88→    confidence: float = Field(\n    89→        default=-1.0,\n    90→        ge=-1.0,\n    91→        le=1.0,\n    92→        description=\"Confidence score 0.0-1.0. -1.0 means use source default.\",\n    93→    )\n    94→    source: MemorySource = Field(default=MemorySource.agent, description=\"Who created this memory.\")\n    95→    source_agent: str = Field(\n    96→        default=\"unknown\", description=\"Agent identifier (e.g. 'claude-code').\"\n    97→    )\n    98→    scope: MemoryScope = Field(default=MemoryScope.project, description=\"Visibility scope.\")\n    99→    tags: list[str] = Field(default_factory=list, description=\"Free-form tags for search (max 10).\")\n   100→    created_at: str = Field(default_factory=_utc_now_iso, description=\"ISO-8601 UTC creation time.\")\n   101→    updated_at: str = Field(\n   102→        default_factory=_utc_now_iso, description=\"ISO-8601 UTC last update time.\"\n   103→    )\n   104→    last_accessed: str = Field(\n   105→        default_factory=_utc_now_iso, description=\"ISO-8601 UTC last access time.\"\n   106→    )\n   107→    access_count: int = Field(default=0, ge=0, description=\"Read access count.\")\n   108→    branch: str | None = Field(default=None, description=\"Git branch (required when scope=branch).\")\n   109→\n   110→    # Reserved for Epic 24 (Memory Intelligence)\n   111→    last_reinforced: str | None = Field(\n   112→        default=None, description=\"ISO-8601 UTC, set by reinforce action.\"\n   113→    )\n   114→    reinforce_count: int = Field(default=0, ge=0, description=\"Total reinforcements.\")\n   115→    contradicted: bool = Field(default=False, description=\"Set by contradiction detection.\")\n   116→    contradiction_reason: str | None = Field(default=None, description=\"Reason for contradiction.\")\n   117→\n   118→    # Reserved for Epic 25 (Memory Retrieval & Integration)\n   119→    seeded_from: str | None = Field(default=None, description=\"Populated by profile seeding.\")\n   120→\n   121→    # Optional embedding for semantic search (Epic 65.7)\n   122→    embedding: list[float] | None = Field(\n   123→        default=None,\n   124→        description=\"Vector embedding for semantic search when enabled.\",\n   125→    )\n   126→\n   127→    # Hive agent scope (EPIC-011)\n   128→    agent_scope: str = Field(\n   129→        default=\"private\",\n   130→        description=\"Hive propagation scope: 'private' | 'domain' | 'hive'.\",\n   131→    )\n   132→\n   133→    # Bi-temporal versioning (EPIC-004)\n   134→    valid_at: str | None = Field(\n   135→        default=None,\n   136→        description=\"ISO-8601 UTC: when this fact became true in the real world.\",\n   137→    )\n   138→    invalid_at: str | None = Field(\n   139→        default=None,\n   140→        description=\"ISO-8601 UTC: when this fact stopped being true.\",\n   141→    )\n   142→    superseded_by: str | None = Field(\n   143→        default=None,\n   144→        description=\"Key of the entry that replaced this one.\",\n   145→    )\n   146→\n   147→    # Integrity hash for tamper detection (H4a)\n   148→    integrity_hash: str | None = Field(\n   149→        default=None,\n   150→        description=\"HMAC-SHA256 hex digest computed over key|value|tier|source.\",\n   151→    )\n   152→\n   153→    # Class-level constants (not serialised)\n   154→    _KEY_PATTERN: ClassVar[re.Pattern[str]] = _KEY_SLUG_PATTERN\n   155→\n   156→    @field_validator(\"key\")\n   157→    @classmethod\n   158→    def _validate_key(cls, v: str) -> str:\n   159→        if not _KEY_SLUG_PATTERN.match(v):\n   160→            msg = (\n   161→                f\"Key must be a lowercase slug (letters, digits, dots, hyphens, \"\n   162→                f\"underscores), 1-{MAX_KEY_LENGTH} chars, starting with alphanumeric. \"\n   163→                f\"Got: {v!r}\"\n   164→            )\n   165→            raise ValueError(msg)\n   166→        return v\n   167→\n   168→    @field_validator(\"value\")\n   169→    @classmethod\n   170→    def _validate_value(cls, v: str) -> str:\n   171→        if len(v) > MAX_VALUE_LENGTH:\n   172→            msg = f\"Value exceeds max length ({len(v)} > {MAX_VALUE_LENGTH}).\"\n   173→            raise ValueError(msg)\n   174→        if not v.strip():\n   175→            msg = \"Value must not be empty or whitespace-only.\"\n   176→            raise ValueError(msg)\n   177→        return v\n   178→\n   179→    @field_validator(\"tags\")\n   180→    @classmethod\n   181→    def _validate_tags(cls, v: list[str]) -> list[str]:\n   182→        if len(v) > MAX_TAGS:\n   183→            msg = f\"Too many tags ({len(v)} > {MAX_TAGS}).\"\n   184→            raise ValueError(msg)\n   185→        return v\n   186→\n   187→    @model_validator(mode=\"after\")\n   188→    def _apply_defaults_and_validate(self) -> MemoryEntry:\n   189→        # Apply source-based confidence default\n   190→        if self.confidence < 0:\n   191→            object.__setattr__(\n   192→                self,\n   193→                \"confidence\",\n   194→                _SOURCE_CONFIDENCE_DEFAULTS.get(self.source, 0.5),\n   195→            )\n   196→\n   197→        # Branch required when scope=branch\n   198→        if self.scope == MemoryScope.branch and not self.branch:\n   199→            msg = \"Branch name is required when scope is 'branch'.\"\n   200→            raise ValueError(msg)\n   201→\n   202→        # Temporal validation: invalid_at must be after valid_at\n   203→        if (\n   204→            self.valid_at is not None\n   205→            and self.invalid_at is not None\n   206→            and self.invalid_at <= self.valid_at\n   207→        ):\n   208→            msg = \"invalid_at must be after valid_at.\"\n   209→            raise ValueError(msg)\n   210→\n   211→        return self\n   212→\n   213→    def is_temporally_valid(self, as_of: str | None = None) -> bool:\n   214→        \"\"\"Check whether this entry is valid at the given point in time.\n   215→\n   216→        If *as_of* is ``None``, uses the current UTC time. An entry with\n   217→        both ``valid_at`` and ``invalid_at`` set to ``None`` is always valid.\n   218→\n   219→        The window is ``[valid_at, invalid_at)`` — inclusive start, exclusive end.\n   220→        \"\"\"\n   221→        ts = as_of or _utc_now_iso()\n   222→        if self.valid_at is not None and ts < self.valid_at:\n   223→            return False\n   224→        return not (self.invalid_at is not None and ts >= self.invalid_at)\n   225→\n   226→    @property\n   227→    def is_superseded(self) -> bool:\n   228→        \"\"\"Return ``True`` if this entry has been superseded (invalid_at in the past).\"\"\"\n   229→        if self.invalid_at is None:\n   230→            return False\n   231→        return _utc_now_iso() >= self.invalid_at\n   232→\n   233→\n   234→# ---------------------------------------------------------------------------\n   235→# Auto-recall models (Epic 003)\n   236→# ---------------------------------------------------------------------------\n   237→\n   238→\n   239→class RecallResult(BaseModel):\n   240→    \"\"\"Result of an auto-recall operation.\n   241→\n   242→    Returned by ``RecallOrchestrator.recall()`` and the ``RecallHookLike``\n   243→    protocol. Contains the formatted memory section ready for injection,\n   244→    metadata about which memories were selected, and timing information.\n   245→    \"\"\"\n   246→\n   247→    memory_section: str = Field(\n   248→        default=\"\",\n   249→        description=\"Formatted markdown section for injection into the prompt.\",\n   250→    )\n   251→    memories: list[dict[str, Any]] = Field(\n   252→        default_factory=list,\n   253→        description=\"List of injected memory summaries (key, confidence, tier, score, stale).\",\n   254→    )\n   255→    token_count: int = Field(\n   256→        default=0,\n   257→        ge=0,\n   258→        description=\"Estimated token count of the injected memory section.\",\n   259→    )\n   260→    recall_time_ms: float = Field(\n   261→        default=0.0,\n   262→        ge=0.0,\n   263→        description=\"Time taken for the recall operation in milliseconds.\",\n   264→    )\n   265→    truncated: bool = Field(\n   266→        default=False,\n   267→        description=\"Whether the results were truncated due to token budget.\",\n   268→    )\n   269→    memory_count: int = Field(\n   270→        default=0,\n   271→        ge=0,\n   272→        description=\"Number of memories injected.\",\n   273→    )\n   274→    hive_memory_count: int = Field(\n   275→        default=0,\n   276→        ge=0,\n   277→        description=\"Number of memories from the Hive (EPIC-011).\",\n   278→    )\n   279→\n   280→\n   281→class MemorySnapshot(BaseModel):\n   282→    \"\"\"Full-state snapshot of the memory store for export/serialization.\"\"\"\n   283→\n   284→    project_root: str = Field(description=\"Project root path.\")\n   285→    entries: list[MemoryEntry] = Field(default_factory=list, description=\"All memory entries.\")\n   286→    total_count: int = Field(default=0, ge=0, description=\"Total entry count.\")\n   287→    tier_counts: dict[str, int] = Field(default_factory=dict, description=\"Count per tier.\")\n   288→    exported_at: str = Field(default_factory=_utc_now_iso, description=\"ISO-8601 UTC export time.\")\n   289→\n   290→\n   291→# ---------------------------------------------------------------------------\n   292→# Consolidation models (Epic 58)\n   293→# ---------------------------------------------------------------------------\n   294→\n   295→\n   296→class ConsolidationReason(StrEnum):\n   297→    \"\"\"Why entries were consolidated.\"\"\"\n   298→\n   299→    similarity = \"similarity\"  # Jaccard + TF-IDF similarity above threshold\n   300→    same_topic = \"same_topic\"  # Same tier + overlapping tags\n   301→    supersession = \"supersession\"  # Newer entry references older entry\n   302→    manual = \"manual\"  # User-triggered consolidation\n   303→\n   304→\n   305→class ConsolidatedEntry(MemoryEntry):\n   306→    \"\"\"A memory entry that consolidates multiple source entries.\n   307→\n   308→    Inherits all MemoryEntry fields and adds provenance tracking.\n   309→    Source entries are marked as `consolidated: true` but retained.\n   310→    \"\"\"\n   311→\n   312→    source_ids: list[str] = Field(\n   313→        default_factory=list,\n   314→        description=\"Keys of entries that were consolidated into this one.\",\n   315→    )\n   316→    consolidated_at: str = Field(\n   317→        default_factory=_utc_now_iso,\n   318→        description=\"ISO-8601 UTC timestamp when consolidation occurred.\",\n   319→    )\n   320→    consolidation_reason: ConsolidationReason = Field(\n   321→        default=ConsolidationReason.similarity,\n   322→        description=\"Why the entries were consolidated.\",\n   323→    )\n   324→    is_consolidated: bool = Field(\n   325→        default=True,\n   326→        description=\"Always True for ConsolidatedEntry.\",\n   327→    )\n   328→"}]},"parent_tool_use_id":null,"session_id":"1dfeb66a-ec06-46ac-b5f4-422c4dae48e2","uuid":"2d586c0c-504a-4fe8-b4f0-293aa969f2e0","timestamp":"2026-03-22T22:44:58.740Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\cursor\\tapps-brain\\src\\tapps_brain\\models.py","content":"\"\"\"Pydantic v2 models for the shared memory subsystem.\"\"\"\n\nfrom __future__ import annotations\n\nimport re\nfrom datetime import UTC, datetime\nfrom enum import StrEnum\nfrom typing import Any, ClassVar\n\nfrom pydantic import BaseModel, Field, field_validator, model_validator\n\n\ndef _utc_now_iso() -> str:\n    \"\"\"Return the current UTC time as an ISO-8601 string.\"\"\"\n    return datetime.now(tz=UTC).isoformat()\n\n\n# ---------------------------------------------------------------------------\n# Enums\n# ---------------------------------------------------------------------------\n\n_KEY_SLUG_PATTERN = re.compile(r\"^[a-z0-9][a-z0-9._-]{0,127}$\")\n\n\nclass MemoryTier(StrEnum):\n    \"\"\"Decay classification for memory entries.\"\"\"\n\n    architectural = \"architectural\"  # slow decay - project structure, key decisions\n    pattern = \"pattern\"  # medium decay - coding patterns, conventions\n    procedural = \"procedural\"  # medium decay - how to do (workflows, steps); Epic 65.11\n    context = \"context\"  # fast decay - session-specific context\n\n\nclass MemorySource(StrEnum):\n    \"\"\"Origin of a memory entry.\"\"\"\n\n    human = \"human\"  # explicitly set by a developer\n    agent = \"agent\"  # created by an AI agent\n    inferred = \"inferred\"  # derived from analysis\n    system = \"system\"  # created by TappsMCP internals\n\n\nclass MemoryScope(StrEnum):\n    \"\"\"Visibility scope of a memory entry.\"\"\"\n\n    project = \"project\"  # visible across the entire project\n    branch = \"branch\"  # scoped to a git branch\n    session = \"session\"  # ephemeral, current session only\n    shared = \"shared\"  # eligible for cross-project federation\n\n\n# ---------------------------------------------------------------------------\n# Source-based confidence defaults\n# ---------------------------------------------------------------------------\n\n_SOURCE_CONFIDENCE_DEFAULTS: dict[MemorySource, float] = {\n    MemorySource.human: 0.95,\n    MemorySource.agent: 0.6,\n    MemorySource.inferred: 0.4,\n    MemorySource.system: 0.9,\n}\n\n# ---------------------------------------------------------------------------\n# Limits\n# ---------------------------------------------------------------------------\n\nMAX_KEY_LENGTH: int = 128\nMAX_VALUE_LENGTH: int = 4096\nMAX_TAGS: int = 10\n\n\ndef tier_str(tier: MemoryTier | str) -> str:\n    \"\"\"Return the string value of a tier, handling both MemoryTier enum and str.\"\"\"\n    return tier.value if isinstance(tier, MemoryTier) else str(tier)\n\n\n# ---------------------------------------------------------------------------\n# Models\n# ---------------------------------------------------------------------------\n\n\nclass MemoryEntry(BaseModel):\n    \"\"\"A single memory entry in the shared memory store.\"\"\"\n\n    key: str = Field(description=\"Unique slug identifier (max 128 chars).\")\n    value: str = Field(description=\"Memory content (max 4096 chars).\")\n    tier: MemoryTier | str = Field(default=MemoryTier.pattern, description=\"Decay classification.\")\n    confidence: float = Field(\n        default=-1.0,\n        ge=-1.0,\n        le=1.0,\n        description=\"Confidence score 0.0-1.0. -1.0 means use source default.\",\n    )\n    source: MemorySource = Field(default=MemorySource.agent, description=\"Who created this memory.\")\n    source_agent: str = Field(\n        default=\"unknown\", description=\"Agent identifier (e.g. 'claude-code').\"\n    )\n    scope: MemoryScope = Field(default=MemoryScope.project, description=\"Visibility scope.\")\n    tags: list[str] = Field(default_factory=list, description=\"Free-form tags for search (max 10).\")\n    created_at: str = Field(default_factory=_utc_now_iso, description=\"ISO-8601 UTC creation time.\")\n    updated_at: str = Field(\n        default_factory=_utc_now_iso, description=\"ISO-8601 UTC last update time.\"\n    )\n    last_accessed: str = Field(\n        default_factory=_utc_now_iso, description=\"ISO-8601 UTC last access time.\"\n    )\n    access_count: int = Field(default=0, ge=0, description=\"Read access count.\")\n    branch: str | None = Field(default=None, description=\"Git branch (required when scope=branch).\")\n\n    # Reserved for Epic 24 (Memory Intelligence)\n    last_reinforced: str | None = Field(\n        default=None, description=\"ISO-8601 UTC, set by reinforce action.\"\n    )\n    reinforce_count: int = Field(default=0, ge=0, description=\"Total reinforcements.\")\n    contradicted: bool = Field(default=False, description=\"Set by contradiction detection.\")\n    contradiction_reason: str | None = Field(default=None, description=\"Reason for contradiction.\")\n\n    # Reserved for Epic 25 (Memory Retrieval & Integration)\n    seeded_from: str | None = Field(default=None, description=\"Populated by profile seeding.\")\n\n    # Optional embedding for semantic search (Epic 65.7)\n    embedding: list[float] | None = Field(\n        default=None,\n        description=\"Vector embedding for semantic search when enabled.\",\n    )\n\n    # Hive agent scope (EPIC-011)\n    agent_scope: str = Field(\n        default=\"private\",\n        description=\"Hive propagation scope: 'private' | 'domain' | 'hive'.\",\n    )\n\n    # Bi-temporal versioning (EPIC-004)\n    valid_at: str | None = Field(\n        default=None,\n        description=\"ISO-8601 UTC: when this fact became true in the real world.\",\n    )\n    invalid_at: str | None = Field(\n        default=None,\n        description=\"ISO-8601 UTC: when this fact stopped being true.\",\n    )\n    superseded_by: str | None = Field(\n        default=None,\n        description=\"Key of the entry that replaced this one.\",\n    )\n\n    # Integrity hash for tamper detection (H4a)\n    integrity_hash: str | None = Field(\n        default=None,\n        description=\"HMAC-SHA256 hex digest computed over key|value|tier|source.\",\n    )\n\n    # Class-level constants (not serialised)\n    _KEY_PATTERN: ClassVar[re.Pattern[str]] = _KEY_SLUG_PATTERN\n\n    @field_validator(\"key\")\n    @classmethod\n    def _validate_key(cls, v: str) -> str:\n        if not _KEY_SLUG_PATTERN.match(v):\n            msg = (\n                f\"Key must be a lowercase slug (letters, digits, dots, hyphens, \"\n                f\"underscores), 1-{MAX_KEY_LENGTH} chars, starting with alphanumeric. \"\n                f\"Got: {v!r}\"\n            )\n            raise ValueError(msg)\n        return v\n\n    @field_validator(\"value\")\n    @classmethod\n    def _validate_value(cls, v: str) -> str:\n        if len(v) > MAX_VALUE_LENGTH:\n            msg = f\"Value exceeds max length ({len(v)} > {MAX_VALUE_LENGTH}).\"\n            raise ValueError(msg)\n        if not v.strip():\n            msg = \"Value must not be empty or whitespace-only.\"\n            raise ValueError(msg)\n        return v\n\n    @field_validator(\"tags\")\n    @classmethod\n    def _validate_tags(cls, v: list[str]) -> list[str]:\n        if len(v) > MAX_TAGS:\n            msg = f\"Too many tags ({len(v)} > {MAX_TAGS}).\"\n            raise ValueError(msg)\n        return v\n\n    @model_validator(mode=\"after\")\n    def _apply_defaults_and_validate(self) -> MemoryEntry:\n        # Apply source-based confidence default\n        if self.confidence < 0:\n            object.__setattr__(\n                self,\n                \"confidence\",\n                _SOURCE_CONFIDENCE_DEFAULTS.get(self.source, 0.5),\n            )\n\n        # Branch required when scope=branch\n        if self.scope == MemoryScope.branch and not self.branch:\n            msg = \"Branch name is required when scope is 'branch'.\"\n            raise ValueError(msg)\n\n        # Temporal validation: invalid_at must be after valid_at\n        if (\n            self.valid_at is not None\n            and self.invalid_at is not None\n            and self.invalid_at <= self.valid_at\n        ):\n            msg = \"invalid_at must be after valid_at.\"\n            raise ValueError(msg)\n\n        return self\n\n    def is_temporally_valid(self, as_of: str | None = None) -> bool:\n        \"\"\"Check whether this entry is valid at the given point in time.\n\n        If *as_of* is ``None``, uses the current UTC time. An entry with\n        both ``valid_at`` and ``invalid_at`` set to ``None`` is always valid.\n\n        The window is ``[valid_at, invalid_at)`` — inclusive start, exclusive end.\n        \"\"\"\n        ts = as_of or _utc_now_iso()\n        if self.valid_at is not None and ts < self.valid_at:\n            return False\n        return not (self.invalid_at is not None and ts >= self.invalid_at)\n\n    @property\n    def is_superseded(self) -> bool:\n        \"\"\"Return ``True`` if this entry has been superseded (invalid_at in the past).\"\"\"\n        if self.invalid_at is None:\n            return False\n        return _utc_now_iso() >= self.invalid_at\n\n\n# ---------------------------------------------------------------------------\n# Auto-recall models (Epic 003)\n# ---------------------------------------------------------------------------\n\n\nclass RecallResult(BaseModel):\n    \"\"\"Result of an auto-recall operation.\n\n    Returned by ``RecallOrchestrator.recall()`` and the ``RecallHookLike``\n    protocol. Contains the formatted memory section ready for injection,\n    metadata about which memories were selected, and timing information.\n    \"\"\"\n\n    memory_section: str = Field(\n        default=\"\",\n        description=\"Formatted markdown section for injection into the prompt.\",\n    )\n    memories: list[dict[str, Any]] = Field(\n        default_factory=list,\n        description=\"List of injected memory summaries (key, confidence, tier, score, stale).\",\n    )\n    token_count: int = Field(\n        default=0,\n        ge=0,\n        description=\"Estimated token count of the injected memory section.\",\n    )\n    recall_time_ms: float = Field(\n        default=0.0,\n        ge=0.0,\n        description=\"Time taken for the recall operation in milliseconds.\",\n    )\n    truncated: bool = Field(\n        default=False,\n        description=\"Whether the results were truncated due to token budget.\",\n    )\n    memory_count: int = Field(\n        default=0,\n        ge=0,\n        description=\"Number of memories injected.\",\n    )\n    hive_memory_count: int = Field(\n        default=0,\n        ge=0,\n        description=\"Number of memories from the Hive (EPIC-011).\",\n    )\n\n\nclass MemorySnapshot(BaseModel):\n    \"\"\"Full-state snapshot of the memory store for export/serialization.\"\"\"\n\n    project_root: str = Field(description=\"Project root path.\")\n    entries: list[MemoryEntry] = Field(default_factory=list, description=\"All memory entries.\")\n    total_count: int = Field(default=0, ge=0, description=\"Total entry count.\")\n    tier_counts: dict[str, int] = Field(default_factory=dict, description=\"Count per tier.\")\n    exported_at: str = Field(default_factory=_utc_now_iso, description=\"ISO-8601 UTC export time.\")\n\n\n# ---------------------------------------------------------------------------\n# Consolidation models (Epic 58)\n# ---------------------------------------------------------------------------\n\n\nclass ConsolidationReason(StrEnum):\n    \"\"\"Why entries were consolidated.\"\"\"\n\n    similarity = \"similarity\"  # Jaccard + TF-IDF similarity above threshold\n    same_topic = \"same_topic\"  # Same tier + overlapping tags\n    supersession = \"supersession\"  # Newer entry references older entry\n    manual = \"manual\"  # User-triggered consolidation\n\n\nclass ConsolidatedEntry(MemoryEntry):\n    \"\"\"A memory entry that consolidates multiple source entries.\n\n    Inherits all MemoryEntry fields and adds provenance tracking.\n    Source entries are marked as `consolidated: true` but retained.\n    \"\"\"\n\n    source_ids: list[str] = Field(\n        default_factory=list,\n        description=\"Keys of entries that were consolidated into this one.\",\n    )\n    consolidated_at: str = Field(\n        default_factory=_utc_now_iso,\n        description=\"ISO-8601 UTC timestamp when consolidation occurred.\",\n    )\n    consolidation_reason: ConsolidationReason = Field(\n        default=ConsolidationReason.similarity,\n        description=\"Why the entries were consolidated.\",\n    )\n    is_consolidated: bool = Field(\n        default=True,\n        description=\"Always True for ConsolidatedEntry.\",\n    )\n","numLines":328,"startLine":1,"totalLines":328}}}
