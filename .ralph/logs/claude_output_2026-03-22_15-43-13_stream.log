{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01L8r9rM5Z79ezV5Gca5E6Ga","type":"tool_result","content":"     1→\"\"\"Ranked memory retrieval with composite scoring.\n     2→\n     3→Upgrades memory search from simple keyword matching to scored,\n     4→ranked retrieval combining text relevance with memory-specific\n     5→signals (confidence, recency, access frequency).\n     6→\n     7→Uses BM25 (Okapi) for text relevance scoring with automatic\n     8→index building and invalidation. Epic 65.8: hybrid BM25 + vector\n     9→search with RRF when semantic_search.enabled.\n    10→\"\"\"\n    11→\n    12→from __future__ import annotations\n    13→\n    14→from concurrent.futures import ThreadPoolExecutor, as_completed\n    15→from datetime import UTC, datetime\n    16→from typing import TYPE_CHECKING\n    17→\n    18→import structlog\n    19→from pydantic import BaseModel, Field\n    20→\n    21→from tapps_brain.bm25 import BM25Scorer\n    22→from tapps_brain.decay import DecayConfig, calculate_decayed_confidence, is_stale\n    23→from tapps_brain.models import MemoryEntry  # noqa: TC001\n    24→from tapps_brain.reranker import RERANKER_TOP_CANDIDATES, Reranker\n    25→\n    26→if TYPE_CHECKING:\n    27→    from tapps_brain.store import MemoryStore\n    28→\n    29→logger = structlog.get_logger(__name__)\n    30→\n    31→# ---------------------------------------------------------------------------\n    32→# Models\n    33→# ---------------------------------------------------------------------------\n    34→\n    35→_MAX_RESULTS = 50\n    36→_DEFAULT_RESULTS = 10\n    37→_MIN_CONFIDENCE_FLOOR = 0.1\n    38→\n    39→# BM25 relevance normalization constant: score / (score + K)\n    40→# Chosen so that a BM25 score of 5.0 maps to ~0.5 normalized.\n    41→_BM25_NORM_K = 5.0\n    42→\n    43→\n    44→class ScoredMemory(BaseModel):\n    45→    \"\"\"A memory entry with retrieval scoring metadata.\"\"\"\n    46→\n    47→    entry: MemoryEntry\n    48→    score: float = Field(ge=0.0, description=\"Composite retrieval score.\")\n    49→    effective_confidence: float = Field(ge=0.0, le=1.0, description=\"Time-decayed confidence.\")\n    50→    bm25_relevance: float = Field(ge=0.0, description=\"Normalized text relevance.\")\n    51→    stale: bool = Field(default=False, description=\"Whether the memory is stale.\")\n    52→\n    53→\n    54→# ---------------------------------------------------------------------------\n    55→# Scoring weights\n    56→# ---------------------------------------------------------------------------\n    57→\n    58→_W_RELEVANCE = 0.40\n    59→_W_CONFIDENCE = 0.30\n    60→_W_RECENCY = 0.15\n    61→_W_FREQUENCY = 0.15\n    62→\n    63→_FREQUENCY_CAP = 20.0\n    64→\n    65→# Marker text for consolidated source entries\n    66→_CONSOLIDATED_MARKER = \"consolidated into\"\n    67→\n    68→\n    69→def _is_consolidated_source(entry: MemoryEntry) -> bool:\n    70→    \"\"\"Check if an entry is a source of a consolidated entry.\n    71→\n    72→    Source entries are marked with contradicted=True and a\n    73→    contradiction_reason containing \"consolidated into\".\n    74→\n    75→    Args:\n    76→        entry: The memory entry to check.\n    77→\n    78→    Returns:\n    79→        True if this entry was consolidated into another entry.\n    80→    \"\"\"\n    81→    if not entry.contradicted:\n    82→        return False\n    83→    reason = entry.contradiction_reason or \"\"\n    84→    return _CONSOLIDATED_MARKER in reason.lower()\n    85→\n    86→\n    87→# ---------------------------------------------------------------------------\n    88→# MemoryRetriever\n    89→# ---------------------------------------------------------------------------\n    90→\n    91→\n    92→class MemoryRetriever:\n    93→    \"\"\"Ranked retrieval engine for memory entries.\"\"\"\n    94→\n    95→    def __init__(\n    96→        self,\n    97→        config: DecayConfig | None = None,\n    98→        *,\n    99→        scoring_config: object | None = None,  # ScoringConfig from profile (EPIC-010)\n   100→        semantic_enabled: bool = False,\n   101→        hybrid_config: object = None,\n   102→        reranker: Reranker | None = None,\n   103→        reranker_enabled: bool = False,\n   104→        retrieval_policy: object | None = None,\n   105→        relations_enabled: bool = False,\n   106→        expand_queries: bool = True,\n   107→    ) -> None:\n   108→        self._config = config or DecayConfig()\n   109→        self._bm25 = BM25Scorer()\n   110→        self._bm25_entries: list[MemoryEntry] = []\n   111→        self._bm25_corpus_size: int = 0\n   112→        self._bm25_fingerprint: int = 0\n   113→        self._semantic_enabled = semantic_enabled\n   114→        self._hybrid_config = hybrid_config\n   115→        self._reranker = reranker\n   116→        self._reranker_enabled = reranker_enabled\n   117→        self._retrieval_policy = retrieval_policy\n   118→        self._relations_enabled = relations_enabled\n   119→        self._expand_queries = expand_queries\n   120→\n   121→        # EPIC-010: use configurable scoring weights if provided\n   122→        self._scoring_config = scoring_config\n   123→        if scoring_config is not None:\n   124→            self._w_relevance = getattr(scoring_config, \"relevance\", _W_RELEVANCE)\n   125→            self._w_confidence = getattr(scoring_config, \"confidence\", _W_CONFIDENCE)\n   126→            self._w_recency = getattr(scoring_config, \"recency\", _W_RECENCY)\n   127→            self._w_frequency = getattr(scoring_config, \"frequency\", _W_FREQUENCY)\n   128→            self._frequency_cap = float(getattr(scoring_config, \"frequency_cap\", _FREQUENCY_CAP))\n   129→            self._bm25_norm_k = float(getattr(scoring_config, \"bm25_norm_k\", _BM25_NORM_K))\n   130→        else:\n   131→            self._w_relevance = _W_RELEVANCE\n   132→            self._w_confidence = _W_CONFIDENCE\n   133→            self._w_recency = _W_RECENCY\n   134→            self._w_frequency = _W_FREQUENCY\n   135→            self._frequency_cap = _FREQUENCY_CAP\n   136→            self._bm25_norm_k = _BM25_NORM_K\n   137→\n   138→    def search(\n   139→        self,\n   140→        query: str,\n   141→        store: MemoryStore,\n   142→        *,\n   143→        limit: int = _DEFAULT_RESULTS,\n   144→        include_contradicted: bool = False,\n   145→        include_sources: bool = False,\n   146→        min_confidence: float = _MIN_CONFIDENCE_FLOOR,\n   147→        as_of: str | None = None,\n   148→        include_superseded: bool = False,\n   149→    ) -> list[ScoredMemory]:\n   150→        \"\"\"Search memories with ranked scoring.\n   151→\n   152→        Uses the store's FTS5-backed search for candidate retrieval,\n   153→        then applies composite scoring with confidence, recency, and\n   154→        frequency signals.\n   155→\n   156→        Args:\n   157→            query: Search query string.\n   158→            store: Memory store to search.\n   159→            limit: Max results (default 10, max 50).\n   160→            include_contradicted: Include contradicted memories.\n   161→            include_sources: Include source entries of consolidated memories\n   162→                (Epic 58, Story 58.5). When False (default), entries that were\n   163→                consolidated into other entries are filtered out. When True,\n   164→                source entries are included alongside consolidated entries.\n   165→            min_confidence: Minimum confidence filter.\n   166→            as_of: ISO-8601 timestamp for point-in-time queries. When set,\n   167→                only entries valid at that time are returned.\n   168→            include_superseded: When True, include temporally invalid entries\n   169→                (marked with ``stale=True`` and a 0.5x relevance penalty).\n   170→\n   171→        Returns:\n   172→            Scored memories sorted by composite score (descending).\n   173→        \"\"\"\n   174→        if not query or not query.strip():\n   175→            return []\n   176→\n   177→        limit = max(1, min(limit, _MAX_RESULTS))\n   178→        now = datetime.now(tz=UTC)\n   179→\n   180→        # Epic 65.13: expand query via relations when enabled\n   181→        effective_query = query\n   182→        if self._relations_enabled and self._expand_queries:\n   183→            effective_query = self._expand_query_via_relations(query, store)\n   184→\n   185→        # Epic 65.8: hybrid path when semantic enabled\n   186→        if self._semantic_enabled:\n   187→            candidates = self._get_hybrid_candidates(effective_query, store)\n   188→        else:\n   189→            candidates = self._get_candidates(effective_query, store)\n   190→\n   191→        # Score and filter\n   192→        scored: list[ScoredMemory] = []\n   193→        for entry, relevance_raw in candidates:\n   194→            # Filter source entries of consolidated memories (Epic 58.5)\n   195→            if not include_sources and _is_consolidated_source(entry):\n   196→                continue\n   197→\n   198→            # Filter contradicted entries (sources already handled above)\n   199→            is_included_source = include_sources and _is_consolidated_source(entry)\n   200→            if entry.contradicted and not include_contradicted and not is_included_source:\n   201→                continue\n   202→\n   203→            # Temporal filtering (EPIC-004)\n   204→            temporally_valid = entry.is_temporally_valid(as_of)\n   205→            if not temporally_valid and not include_superseded:\n   206→                continue\n   207→\n   208→            # Calculate effective confidence\n   209→            eff_conf = calculate_decayed_confidence(entry, self._config, now=now)\n   210→\n   211→            # Filter low confidence\n   212→            if eff_conf < min_confidence:\n   213→                continue\n   214→\n   215→            stale_flag = is_stale(entry, self._config, now=now)\n   216→            # Mark temporally invalid entries as stale (EPIC-004)\n   217→            if not temporally_valid:\n   218→                stale_flag = True\n   219→\n   220→            # Compute composite score\n   221→            relevance_norm = self._normalize_relevance(relevance_raw)\n   222→            recency = self._recency_score(entry, now)\n   223→            frequency = self._frequency_score(entry)\n   224→\n   225→            composite = (\n   226→                self._w_relevance * relevance_norm\n   227→                + self._w_confidence * eff_conf\n   228→                + self._w_recency * recency\n   229→                + self._w_frequency * frequency\n   230→            )\n   231→\n   232→            # Penalty for superseded entries included via include_superseded\n   233→            if not temporally_valid:\n   234→                composite *= 0.5\n   235→\n   236→            # Bonus for exact key match\n   237→            if entry.key == query.lower().replace(\" \", \"-\"):\n   238→                composite += 0.1\n   239→\n   240→            scored.append(\n   241→                ScoredMemory(\n   242→                    entry=entry,\n   243→                    score=round(composite, 4),\n   244→                    effective_confidence=round(eff_conf, 4),\n   245→                    bm25_relevance=round(relevance_norm, 4),\n   246→                    stale=stale_flag,\n   247→                )\n   248→            )\n   249→\n   250→        # Epic 65.14: Apply retrieval policy tag filtering\n   251→        if self._retrieval_policy is not None:\n   252→            blocked_tags = set(getattr(self._retrieval_policy, \"block_sensitive_tags\", []))\n   253→            if blocked_tags:\n   254→                scored = [s for s in scored if not blocked_tags.intersection(s.entry.tags)]\n   255→\n   256→        # Sort by score descending\n   257→        scored.sort(key=lambda s: s.score, reverse=True)\n   258→\n   259→        # Epic 65.9: optional reranking of top-20 -> top_k\n   260→        if self._reranker_enabled and self._reranker is not None and scored:\n   261→            scored = self._apply_reranker(query, scored, limit)\n   262→\n   263→        return scored[:limit]\n   264→\n   265→    def _apply_reranker(\n   266→        self,\n   267→        query: str,\n   268→        scored: list[ScoredMemory],\n   269→        limit: int,\n   270→    ) -> list[ScoredMemory]:\n   271→        \"\"\"Apply reranker to top candidates; fallback to original order on failure.\"\"\"\n   272→        assert self._reranker is not None  # caller checks before calling\n   273→        top_candidates = scored[:RERANKER_TOP_CANDIDATES]\n   274→        candidates = [(sm.entry.key, sm.entry.value) for sm in top_candidates]\n   275→        effective_top_k = min(limit, len(candidates))\n   276→\n   277→        try:\n   278→            reranked = self._reranker.rerank(query, candidates, top_k=effective_top_k)\n   279→        except Exception as e:\n   280→            logger.warning(\n   281→                \"reranker_failed_fallback_to_original\",\n   282→                reason=str(e),\n   283→            )\n   284→            return scored\n   285→\n   286→        if not reranked:\n   287→            return scored\n   288→\n   289→        key_to_scored = {sm.entry.key: sm for sm in scored}\n   290→        result: list[ScoredMemory] = []\n   291→        for key, rerank_score in reranked:\n   292→            sm = key_to_scored.get(key)\n   293→            if sm is not None:\n   294→                # Use reranker score as primary relevance; preserve other fields\n   295→                result.append(\n   296→                    ScoredMemory(\n   297→                        entry=sm.entry,\n   298→                        score=round(rerank_score, 4),\n   299→                        effective_confidence=sm.effective_confidence,\n   300→                        bm25_relevance=sm.bm25_relevance,\n   301→                        stale=sm.stale,\n   302→                    )\n   303→                )\n   304→        # Append any from original not in reranker result (e.g. API dropped some)\n   305→        seen = {sm.entry.key for sm in result}\n   306→        for sm in scored:\n   307→            if sm.entry.key not in seen:\n   308→                result.append(sm)\n   309→                if len(result) >= limit:\n   310→                    break\n   311→        return result[:limit]\n   312→\n   313→    # -----------------------------------------------------------------------\n   314→    # Relation expansion (Epic 65.13)\n   315→    # -----------------------------------------------------------------------\n   316→\n   317→    def _expand_query_via_relations(\n   318→        self,\n   319→        query: str,\n   320→        store: MemoryStore,\n   321→    ) -> str:\n   322→        \"\"\"Expand a query using entity/relationship graph traversal.\n   323→\n   324→        If the query matches a relationship pattern (e.g. \"who handles API\"),\n   325→        load relations from the persistence layer and expand with connected\n   326→        entities. Falls back to the original query on any error.\n   327→        \"\"\"\n   328→        try:\n   329→            from tapps_brain.relations import (\n   330→                RelationEntry,\n   331→                expand_via_relations,\n   332→            )\n   333→        except ImportError:\n   334→            return query\n   335→\n   336→        # Load relations from persistence if available\n   337→        try:\n   338→            persistence = getattr(store, \"_persistence\", None)\n   339→            if persistence is None:\n   340→                return query\n   341→            raw_relations = persistence.list_relations()\n   342→            if not raw_relations:\n   343→                return query\n   344→\n   345→            relations = [\n   346→                RelationEntry(\n   347→                    subject=r[\"subject\"],\n   348→                    predicate=r[\"predicate\"],\n   349→                    object_entity=r[\"object_entity\"],\n   350→                    source_entry_keys=r.get(\"source_entry_keys\", []),\n   351→                    confidence=r.get(\"confidence\", 0.8),\n   352→                )\n   353→                for r in raw_relations\n   354→            ]\n   355→\n   356→            expanded_terms = expand_via_relations(query, relations)\n   357→            if expanded_terms:\n   358→                expanded_query = f\"{query} {' '.join(expanded_terms)}\"\n   359→                logger.debug(\n   360→                    \"query_expanded_via_relations\",\n   361→                    original=query,\n   362→                    expanded=expanded_query,\n   363→                    terms_added=len(expanded_terms),\n   364→                )\n   365→                return expanded_query\n   366→        except Exception:\n   367→            logger.debug(\"relation_expansion_failed\", query=query)\n   368→\n   369→        return query\n   370→\n   371→    # -----------------------------------------------------------------------\n   372→    # BM25 index management\n   373→    # -----------------------------------------------------------------------\n   374→\n   375→    @staticmethod\n   376→    def _entry_to_document(entry: MemoryEntry) -> str:\n   377→        \"\"\"Convert a memory entry to a BM25-indexable document string.\"\"\"\n   378→        return f\"{entry.key} {entry.value} {' '.join(entry.tags)}\"\n   379→\n   380→    @staticmethod\n   381→    def _corpus_fingerprint(entries: list[MemoryEntry]) -> int:\n   382→        \"\"\"Compute a fingerprint that changes when any entry is added, removed, or updated.\"\"\"\n   383→        return hash(tuple((e.key, e.updated_at if e.updated_at else \"\") for e in entries))\n   384→\n   385→    def _ensure_bm25_index(self, entries: list[MemoryEntry]) -> None:\n   386→        \"\"\"Build or rebuild the BM25 index when the corpus changes.\"\"\"\n   387→        fingerprint = self._corpus_fingerprint(entries)\n   388→        if len(entries) == self._bm25_corpus_size and fingerprint == self._bm25_fingerprint:\n   389→            return\n   390→        documents = [self._entry_to_document(e) for e in entries]\n   391→        self._bm25.build_index(documents)\n   392→        self._bm25_entries = list(entries)\n   393→        self._bm25_corpus_size = len(entries)\n   394→        self._bm25_fingerprint = fingerprint\n   395→        logger.debug(\"bm25_index_rebuilt\", corpus_size=self._bm25_corpus_size)\n   396→\n   397→    # -----------------------------------------------------------------------\n   398→    # Candidate retrieval\n   399→    # -----------------------------------------------------------------------\n   400→\n   401→    def _get_candidates(\n   402→        self,\n   403→        query: str,\n   404→        store: MemoryStore,\n   405→    ) -> list[tuple[MemoryEntry, float]]:\n   406→        \"\"\"Retrieve candidate entries and compute BM25 relevance scores.\n   407→\n   408→        Tries the store's FTS5-backed search first for candidate\n   409→        filtering, then scores them using BM25. Falls back to full\n   410→        in-memory BM25 scan if FTS5 returns no results, and to word\n   411→        overlap if BM25 scoring fails entirely.\n   412→        \"\"\"\n   413→        # Try FTS5 via store.search() for candidate filtering\n   414→        try:\n   415→            fts_results = store.search(query)\n   416→            if fts_results:\n   417→                return self._bm25_score_entries(query, fts_results, store)\n   418→        except Exception:\n   419→            logger.debug(\"fts5_search_failed\", query=query)\n   420→\n   421→        # Fallback: full corpus BM25 scan\n   422→        return self._bm25_full_scan(query, store)\n   423→\n   424→    def _get_hybrid_candidates(\n   425→        self,\n   426→        query: str,\n   427→        store: MemoryStore,\n   428→    ) -> list[tuple[MemoryEntry, float]]:\n   429→        \"\"\"Epic 65.8: Run BM25 + vector search in parallel, merge with RRF.\"\"\"\n   430→        top_bm25 = 20\n   431→        top_vector = 20\n   432→        rrf_k = 60\n   433→        if self._hybrid_config is not None:\n   434→            top_bm25 = getattr(self._hybrid_config, \"top_bm25\", 20)\n   435→            top_vector = getattr(self._hybrid_config, \"top_vector\", 20)\n   436→            rrf_k = getattr(self._hybrid_config, \"rrf_k\", 60)\n   437→\n   438→        bm25_keys: list[str] = []\n   439→        vector_keys: list[str] = []\n   440→\n   441→        def run_bm25() -> None:\n   442→            nonlocal bm25_keys\n   443→            candidates = self._get_candidates(query, store)\n   444→            # Take top top_bm25 by score\n   445→            sorted_cands = sorted(\n   446→                candidates,\n   447→                key=lambda x: x[1],\n   448→                reverse=True,\n   449→            )[:top_bm25]\n   450→            bm25_keys = [e.key for e, _ in sorted_cands]\n   451→\n   452→        def run_vector() -> None:\n   453→            nonlocal vector_keys\n   454→            vector_results = self._vector_search(query, store, limit=top_vector)\n   455→            vector_keys = [k for k, _ in vector_results]\n   456→\n   457→        with ThreadPoolExecutor(max_workers=2) as ex:\n   458→            f1 = ex.submit(run_bm25)\n   459→            f2 = ex.submit(run_vector)\n   460→            for f in as_completed([f1, f2]):\n   461→                f.result()\n   462→\n   463→        from tapps_brain.fusion import reciprocal_rank_fusion\n   464→\n   465→        fused = reciprocal_rank_fusion(bm25_keys, vector_keys, k=rrf_k)\n   466→\n   467→        if not fused:\n   468→            return self._get_candidates(query, store)\n   469→\n   470→        entry_by_key = {e.key: e for e in store.list_all()}\n   471→        max_rrf = fused[0][1] if fused else 1.0\n   472→\n   473→        results: list[tuple[MemoryEntry, float]] = []\n   474→        for key, rrf_score in fused:\n   475→            entry = entry_by_key.get(key)\n   476→            if entry is None:\n   477→                continue\n   478→            relevance_raw = rrf_score / max_rrf if max_rrf > 0 else 0.0\n   479→            results.append((entry, relevance_raw))\n   480→\n   481→        return results\n   482→\n   483→    def _vector_search(\n   484→        self,\n   485→        query: str,\n   486→        store: MemoryStore,\n   487→        limit: int = 20,\n   488→    ) -> list[tuple[str, float]]:\n   489→        \"\"\"Epic 65.8: Embed query, cosine similarity with entry embeddings.\n   490→\n   491→        Uses on-the-fly embedding when stored embeddings are unavailable.\n   492→        Returns [(entry_key, score), ...] sorted by score descending.\n   493→        \"\"\"\n   494→        empty: list[tuple[str, float]] = []\n   495→\n   496→        try:\n   497→            from tapps_brain.embeddings import get_embedding_provider\n   498→\n   499→            embedder = get_embedding_provider(semantic_search_enabled=True)\n   500→        except ImportError:\n   501→            logger.debug(\"vector_search_embedder_unavailable\")\n   502→            return empty\n   503→        if embedder is None or not (all_entries := store.list_all()):\n   504→            return empty\n   505→\n   506→        texts = [self._entry_to_document(e) for e in all_entries]\n   507→        try:\n   508→            q = embedder.embed(query)\n   509→            entry_embs = embedder.embed_batch(texts)\n   510→        except Exception as e:\n   511→            logger.debug(\"vector_search_embed_failed\", error=str(e))\n   512→            return empty\n   513→\n   514→        if not q or len(entry_embs) != len(all_entries):\n   515→            return empty\n   516→        scored: list[tuple[str, float]] = []\n   517→        for i, entry in enumerate(all_entries):\n   518→            if i >= len(entry_embs):\n   519→                break\n   520→            emb = entry_embs[i]\n   521→            if len(emb) == len(q):\n   522→                sim = sum(a * b for a, b in zip(q, emb, strict=True))\n   523→                scored.append((entry.key, max(0.0, sim)))\n   524→        scored.sort(key=lambda x: x[1], reverse=True)\n   525→        return scored[:limit]\n   526→\n   527→    def _bm25_score_entries(\n   528→        self,\n   529→        query: str,\n   530→        entries: list[MemoryEntry],\n   531→        store: MemoryStore,\n   532→    ) -> list[tuple[MemoryEntry, float]]:\n   533→        \"\"\"Score a set of entries using BM25.\n   534→\n   535→        Builds the BM25 index over the full corpus (for proper IDF),\n   536→        then looks up scores for the given entries.\n   537→        \"\"\"\n   538→        try:\n   539→            all_entries = store.list_all()\n   540→            self._ensure_bm25_index(all_entries)\n   541→\n   542→            # Build a lookup: entry key -> index in corpus\n   543→            key_to_idx = {e.key: i for i, e in enumerate(self._bm25_entries)}\n   544→            all_scores = self._bm25.score(query)\n   545→\n   546→            results: list[tuple[MemoryEntry, float]] = []\n   547→            for entry in entries:\n   548→                idx = key_to_idx.get(entry.key)\n   549→                if idx is not None and idx < len(all_scores):\n   550→                    results.append((entry, all_scores[idx]))\n   551→                else:\n   552→                    # Entry not in index (new entry?), use word overlap\n   553→                    results.append((entry, self._word_overlap_score(query, entry)))\n   554→            return results\n   555→        except Exception:\n   556→            logger.debug(\"bm25_scoring_failed_using_word_overlap\", query=query)\n   557→            return [(entry, self._word_overlap_score(query, entry)) for entry in entries]\n   558→\n   559→    def _bm25_full_scan(\n   560→        self,\n   561→        query: str,\n   562→        store: MemoryStore,\n   563→    ) -> list[tuple[MemoryEntry, float]]:\n   564→        \"\"\"Full corpus BM25 scan as fallback.\n   565→\n   566→        Falls back to word overlap if BM25 fails.\n   567→        \"\"\"\n   568→        all_entries = store.list_all()\n   569→        if not all_entries:\n   570→            return []\n   571→\n   572→        try:\n   573→            self._ensure_bm25_index(all_entries)\n   574→            scores = self._bm25.score(query)\n   575→            return [\n   576→                (entry, score)\n   577→                for entry, score in zip(all_entries, scores, strict=True)\n   578→                if score > 0\n   579→            ]\n   580→        except Exception:\n   581→            logger.debug(\"bm25_full_scan_failed_using_word_overlap\", query=query)\n   582→            return self._like_search(query, store)\n   583→\n   584→    def _like_search(\n   585→        self,\n   586→        query: str,\n   587→        store: MemoryStore,\n   588→    ) -> list[tuple[MemoryEntry, float]]:\n   589→        \"\"\"Fallback LIKE-based search with simple word overlap scoring.\"\"\"\n   590→        query_words = set(query.lower().split())\n   591→        if not query_words:\n   592→            return []\n   593→\n   594→        all_entries = store.list_all()\n   595→        results: list[tuple[MemoryEntry, float]] = []\n   596→\n   597→        for entry in all_entries:\n   598→            relevance = self._word_overlap_score(query, entry)\n   599→            if relevance > 0:\n   600→                results.append((entry, relevance))\n   601→\n   602→        return results\n   603→\n   604→    # -----------------------------------------------------------------------\n   605→    # Scoring helpers\n   606→    # -----------------------------------------------------------------------\n   607→\n   608→    @staticmethod\n   609→    def _word_overlap_score(query: str, entry: MemoryEntry) -> float:\n   610→        \"\"\"Compute word overlap between query and entry text.\"\"\"\n   611→        query_words = set(query.lower().split())\n   612→        if not query_words:\n   613→            return 0.0\n   614→        entry_text = f\"{entry.key} {entry.value} {' '.join(entry.tags)}\".lower()\n   615→        entry_words = set(entry_text.split())\n   616→        overlap = len(query_words & entry_words)\n   617→        return overlap / len(query_words)\n   618→\n   619→    def _normalize_relevance(self, raw_score: float) -> float:\n   620→        \"\"\"Normalize relevance score to 0.0-1.0 range.\n   621→\n   622→        Uses sigmoid normalization: ``score / (score + K)`` where\n   623→        K defaults to 5.0, tuned for BM25 scores (typical range 0-15+).\n   624→        A BM25 score of K maps to 0.5 normalized. K is configurable\n   625→        via ``scoring_config.bm25_norm_k`` (EPIC-010).\n   626→        \"\"\"\n   627→        if raw_score <= 0:\n   628→            return 0.0\n   629→        return raw_score / (raw_score + self._bm25_norm_k)\n   630→\n   631→    @staticmethod\n   632→    def _recency_score(entry: MemoryEntry, now: datetime) -> float:\n   633→        \"\"\"Compute recency score: ``1.0 / (1.0 + days_since_updated)``.\"\"\"\n   634→        try:\n   635→            updated = datetime.fromisoformat(entry.updated_at)\n   636→            if updated.tzinfo is None:\n   637→                updated = updated.replace(tzinfo=UTC)\n   638→        except (ValueError, TypeError):\n   639→            return 0.5\n   640→        days = max((now - updated).total_seconds() / 86400.0, 0.0)\n   641→        return 1.0 / (1.0 + days)\n   642→\n   643→    def _frequency_score(self, entry: MemoryEntry) -> float:\n   644→        \"\"\"Compute access frequency score: ``min(1.0, access_count / cap)``.\n   645→\n   646→        The frequency cap defaults to 20.0 and is configurable via\n   647→        ``scoring_config.frequency_cap`` (EPIC-010).\n   648→        \"\"\"\n   649→        return min(1.0, entry.access_count / self._frequency_cap)\n   650→"}]},"parent_tool_use_id":null,"session_id":"1dfeb66a-ec06-46ac-b5f4-422c4dae48e2","uuid":"2887a453-5d49-4b21-a85a-33f3d2b9ed2f","timestamp":"2026-03-22T22:44:58.067Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\cursor\\tapps-brain\\src\\tapps_brain\\retrieval.py","content":"\"\"\"Ranked memory retrieval with composite scoring.\n\nUpgrades memory search from simple keyword matching to scored,\nranked retrieval combining text relevance with memory-specific\nsignals (confidence, recency, access frequency).\n\nUses BM25 (Okapi) for text relevance scoring with automatic\nindex building and invalidation. Epic 65.8: hybrid BM25 + vector\nsearch with RRF when semantic_search.enabled.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom concurrent.futures import ThreadPoolExecutor, as_completed\nfrom datetime import UTC, datetime\nfrom typing import TYPE_CHECKING\n\nimport structlog\nfrom pydantic import BaseModel, Field\n\nfrom tapps_brain.bm25 import BM25Scorer\nfrom tapps_brain.decay import DecayConfig, calculate_decayed_confidence, is_stale\nfrom tapps_brain.models import MemoryEntry  # noqa: TC001\nfrom tapps_brain.reranker import RERANKER_TOP_CANDIDATES, Reranker\n\nif TYPE_CHECKING:\n    from tapps_brain.store import MemoryStore\n\nlogger = structlog.get_logger(__name__)\n\n# ---------------------------------------------------------------------------\n# Models\n# ---------------------------------------------------------------------------\n\n_MAX_RESULTS = 50\n_DEFAULT_RESULTS = 10\n_MIN_CONFIDENCE_FLOOR = 0.1\n\n# BM25 relevance normalization constant: score / (score + K)\n# Chosen so that a BM25 score of 5.0 maps to ~0.5 normalized.\n_BM25_NORM_K = 5.0\n\n\nclass ScoredMemory(BaseModel):\n    \"\"\"A memory entry with retrieval scoring metadata.\"\"\"\n\n    entry: MemoryEntry\n    score: float = Field(ge=0.0, description=\"Composite retrieval score.\")\n    effective_confidence: float = Field(ge=0.0, le=1.0, description=\"Time-decayed confidence.\")\n    bm25_relevance: float = Field(ge=0.0, description=\"Normalized text relevance.\")\n    stale: bool = Field(default=False, description=\"Whether the memory is stale.\")\n\n\n# ---------------------------------------------------------------------------\n# Scoring weights\n# ---------------------------------------------------------------------------\n\n_W_RELEVANCE = 0.40\n_W_CONFIDENCE = 0.30\n_W_RECENCY = 0.15\n_W_FREQUENCY = 0.15\n\n_FREQUENCY_CAP = 20.0\n\n# Marker text for consolidated source entries\n_CONSOLIDATED_MARKER = \"consolidated into\"\n\n\ndef _is_consolidated_source(entry: MemoryEntry) -> bool:\n    \"\"\"Check if an entry is a source of a consolidated entry.\n\n    Source entries are marked with contradicted=True and a\n    contradiction_reason containing \"consolidated into\".\n\n    Args:\n        entry: The memory entry to check.\n\n    Returns:\n        True if this entry was consolidated into another entry.\n    \"\"\"\n    if not entry.contradicted:\n        return False\n    reason = entry.contradiction_reason or \"\"\n    return _CONSOLIDATED_MARKER in reason.lower()\n\n\n# ---------------------------------------------------------------------------\n# MemoryRetriever\n# ---------------------------------------------------------------------------\n\n\nclass MemoryRetriever:\n    \"\"\"Ranked retrieval engine for memory entries.\"\"\"\n\n    def __init__(\n        self,\n        config: DecayConfig | None = None,\n        *,\n        scoring_config: object | None = None,  # ScoringConfig from profile (EPIC-010)\n        semantic_enabled: bool = False,\n        hybrid_config: object = None,\n        reranker: Reranker | None = None,\n        reranker_enabled: bool = False,\n        retrieval_policy: object | None = None,\n        relations_enabled: bool = False,\n        expand_queries: bool = True,\n    ) -> None:\n        self._config = config or DecayConfig()\n        self._bm25 = BM25Scorer()\n        self._bm25_entries: list[MemoryEntry] = []\n        self._bm25_corpus_size: int = 0\n        self._bm25_fingerprint: int = 0\n        self._semantic_enabled = semantic_enabled\n        self._hybrid_config = hybrid_config\n        self._reranker = reranker\n        self._reranker_enabled = reranker_enabled\n        self._retrieval_policy = retrieval_policy\n        self._relations_enabled = relations_enabled\n        self._expand_queries = expand_queries\n\n        # EPIC-010: use configurable scoring weights if provided\n        self._scoring_config = scoring_config\n        if scoring_config is not None:\n            self._w_relevance = getattr(scoring_config, \"relevance\", _W_RELEVANCE)\n            self._w_confidence = getattr(scoring_config, \"confidence\", _W_CONFIDENCE)\n            self._w_recency = getattr(scoring_config, \"recency\", _W_RECENCY)\n            self._w_frequency = getattr(scoring_config, \"frequency\", _W_FREQUENCY)\n            self._frequency_cap = float(getattr(scoring_config, \"frequency_cap\", _FREQUENCY_CAP))\n            self._bm25_norm_k = float(getattr(scoring_config, \"bm25_norm_k\", _BM25_NORM_K))\n        else:\n            self._w_relevance = _W_RELEVANCE\n            self._w_confidence = _W_CONFIDENCE\n            self._w_recency = _W_RECENCY\n            self._w_frequency = _W_FREQUENCY\n            self._frequency_cap = _FREQUENCY_CAP\n            self._bm25_norm_k = _BM25_NORM_K\n\n    def search(\n        self,\n        query: str,\n        store: MemoryStore,\n        *,\n        limit: int = _DEFAULT_RESULTS,\n        include_contradicted: bool = False,\n        include_sources: bool = False,\n        min_confidence: float = _MIN_CONFIDENCE_FLOOR,\n        as_of: str | None = None,\n        include_superseded: bool = False,\n    ) -> list[ScoredMemory]:\n        \"\"\"Search memories with ranked scoring.\n\n        Uses the store's FTS5-backed search for candidate retrieval,\n        then applies composite scoring with confidence, recency, and\n        frequency signals.\n\n        Args:\n            query: Search query string.\n            store: Memory store to search.\n            limit: Max results (default 10, max 50).\n            include_contradicted: Include contradicted memories.\n            include_sources: Include source entries of consolidated memories\n                (Epic 58, Story 58.5). When False (default), entries that were\n                consolidated into other entries are filtered out. When True,\n                source entries are included alongside consolidated entries.\n            min_confidence: Minimum confidence filter.\n            as_of: ISO-8601 timestamp for point-in-time queries. When set,\n                only entries valid at that time are returned.\n            include_superseded: When True, include temporally invalid entries\n                (marked with ``stale=True`` and a 0.5x relevance penalty).\n\n        Returns:\n            Scored memories sorted by composite score (descending).\n        \"\"\"\n        if not query or not query.strip():\n            return []\n\n        limit = max(1, min(limit, _MAX_RESULTS))\n        now = datetime.now(tz=UTC)\n\n        # Epic 65.13: expand query via relations when enabled\n        effective_query = query\n        if self._relations_enabled and self._expand_queries:\n            effective_query = self._expand_query_via_relations(query, store)\n\n        # Epic 65.8: hybrid path when semantic enabled\n        if self._semantic_enabled:\n            candidates = self._get_hybrid_candidates(effective_query, store)\n        else:\n            candidates = self._get_candidates(effective_query, store)\n\n        # Score and filter\n        scored: list[ScoredMemory] = []\n        for entry, relevance_raw in candidates:\n            # Filter source entries of consolidated memories (Epic 58.5)\n            if not include_sources and _is_consolidated_source(entry):\n                continue\n\n            # Filter contradicted entries (sources already handled above)\n            is_included_source = include_sources and _is_consolidated_source(entry)\n            if entry.contradicted and not include_contradicted and not is_included_source:\n                continue\n\n            # Temporal filtering (EPIC-004)\n            temporally_valid = entry.is_temporally_valid(as_of)\n            if not temporally_valid and not include_superseded:\n                continue\n\n            # Calculate effective confidence\n            eff_conf = calculate_decayed_confidence(entry, self._config, now=now)\n\n            # Filter low confidence\n            if eff_conf < min_confidence:\n                continue\n\n            stale_flag = is_stale(entry, self._config, now=now)\n            # Mark temporally invalid entries as stale (EPIC-004)\n            if not temporally_valid:\n                stale_flag = True\n\n            # Compute composite score\n            relevance_norm = self._normalize_relevance(relevance_raw)\n            recency = self._recency_score(entry, now)\n            frequency = self._frequency_score(entry)\n\n            composite = (\n                self._w_relevance * relevance_norm\n                + self._w_confidence * eff_conf\n                + self._w_recency * recency\n                + self._w_frequency * frequency\n            )\n\n            # Penalty for superseded entries included via include_superseded\n            if not temporally_valid:\n                composite *= 0.5\n\n            # Bonus for exact key match\n            if entry.key == query.lower().replace(\" \", \"-\"):\n                composite += 0.1\n\n            scored.append(\n                ScoredMemory(\n                    entry=entry,\n                    score=round(composite, 4),\n                    effective_confidence=round(eff_conf, 4),\n                    bm25_relevance=round(relevance_norm, 4),\n                    stale=stale_flag,\n                )\n            )\n\n        # Epic 65.14: Apply retrieval policy tag filtering\n        if self._retrieval_policy is not None:\n            blocked_tags = set(getattr(self._retrieval_policy, \"block_sensitive_tags\", []))\n            if blocked_tags:\n                scored = [s for s in scored if not blocked_tags.intersection(s.entry.tags)]\n\n        # Sort by score descending\n        scored.sort(key=lambda s: s.score, reverse=True)\n\n        # Epic 65.9: optional reranking of top-20 -> top_k\n        if self._reranker_enabled and self._reranker is not None and scored:\n            scored = self._apply_reranker(query, scored, limit)\n\n        return scored[:limit]\n\n    def _apply_reranker(\n        self,\n        query: str,\n        scored: list[ScoredMemory],\n        limit: int,\n    ) -> list[ScoredMemory]:\n        \"\"\"Apply reranker to top candidates; fallback to original order on failure.\"\"\"\n        assert self._reranker is not None  # caller checks before calling\n        top_candidates = scored[:RERANKER_TOP_CANDIDATES]\n        candidates = [(sm.entry.key, sm.entry.value) for sm in top_candidates]\n        effective_top_k = min(limit, len(candidates))\n\n        try:\n            reranked = self._reranker.rerank(query, candidates, top_k=effective_top_k)\n        except Exception as e:\n            logger.warning(\n                \"reranker_failed_fallback_to_original\",\n                reason=str(e),\n            )\n            return scored\n\n        if not reranked:\n            return scored\n\n        key_to_scored = {sm.entry.key: sm for sm in scored}\n        result: list[ScoredMemory] = []\n        for key, rerank_score in reranked:\n            sm = key_to_scored.get(key)\n            if sm is not None:\n                # Use reranker score as primary relevance; preserve other fields\n                result.append(\n                    ScoredMemory(\n                        entry=sm.entry,\n                        score=round(rerank_score, 4),\n                        effective_confidence=sm.effective_confidence,\n                        bm25_relevance=sm.bm25_relevance,\n                        stale=sm.stale,\n                    )\n                )\n        # Append any from original not in reranker result (e.g. API dropped some)\n        seen = {sm.entry.key for sm in result}\n        for sm in scored:\n            if sm.entry.key not in seen:\n                result.append(sm)\n                if len(result) >= limit:\n                    break\n        return result[:limit]\n\n    # -----------------------------------------------------------------------\n    # Relation expansion (Epic 65.13)\n    # -----------------------------------------------------------------------\n\n    def _expand_query_via_relations(\n        self,\n        query: str,\n        store: MemoryStore,\n    ) -> str:\n        \"\"\"Expand a query using entity/relationship graph traversal.\n\n        If the query matches a relationship pattern (e.g. \"who handles API\"),\n        load relations from the persistence layer and expand with connected\n        entities. Falls back to the original query on any error.\n        \"\"\"\n        try:\n            from tapps_brain.relations import (\n                RelationEntry,\n                expand_via_relations,\n            )\n        except ImportError:\n            return query\n\n        # Load relations from persistence if available\n        try:\n            persistence = getattr(store, \"_persistence\", None)\n            if persistence is None:\n                return query\n            raw_relations = persistence.list_relations()\n            if not raw_relations:\n                return query\n\n            relations = [\n                RelationEntry(\n                    subject=r[\"subject\"],\n                    predicate=r[\"predicate\"],\n                    object_entity=r[\"object_entity\"],\n                    source_entry_keys=r.get(\"source_entry_keys\", []),\n                    confidence=r.get(\"confidence\", 0.8),\n                )\n                for r in raw_relations\n            ]\n\n            expanded_terms = expand_via_relations(query, relations)\n            if expanded_terms:\n                expanded_query = f\"{query} {' '.join(expanded_terms)}\"\n                logger.debug(\n                    \"query_expanded_via_relations\",\n                    original=query,\n                    expanded=expanded_query,\n                    terms_added=len(expanded_terms),\n                )\n                return expanded_query\n        except Exception:\n            logger.debug(\"relation_expansion_failed\", query=query)\n\n        return query\n\n    # -----------------------------------------------------------------------\n    # BM25 index management\n    # -----------------------------------------------------------------------\n\n    @staticmethod\n    def _entry_to_document(entry: MemoryEntry) -> str:\n        \"\"\"Convert a memory entry to a BM25-indexable document string.\"\"\"\n        return f\"{entry.key} {entry.value} {' '.join(entry.tags)}\"\n\n    @staticmethod\n    def _corpus_fingerprint(entries: list[MemoryEntry]) -> int:\n        \"\"\"Compute a fingerprint that changes when any entry is added, removed, or updated.\"\"\"\n        return hash(tuple((e.key, e.updated_at if e.updated_at else \"\") for e in entries))\n\n    def _ensure_bm25_index(self, entries: list[MemoryEntry]) -> None:\n        \"\"\"Build or rebuild the BM25 index when the corpus changes.\"\"\"\n        fingerprint = self._corpus_fingerprint(entries)\n        if len(entries) == self._bm25_corpus_size and fingerprint == self._bm25_fingerprint:\n            return\n        documents = [self._entry_to_document(e) for e in entries]\n        self._bm25.build_index(documents)\n        self._bm25_entries = list(entries)\n        self._bm25_corpus_size = len(entries)\n        self._bm25_fingerprint = fingerprint\n        logger.debug(\"bm25_index_rebuilt\", corpus_size=self._bm25_corpus_size)\n\n    # -----------------------------------------------------------------------\n    # Candidate retrieval\n    # -----------------------------------------------------------------------\n\n    def _get_candidates(\n        self,\n        query: str,\n        store: MemoryStore,\n    ) -> list[tuple[MemoryEntry, float]]:\n        \"\"\"Retrieve candidate entries and compute BM25 relevance scores.\n\n        Tries the store's FTS5-backed search first for candidate\n        filtering, then scores them using BM25. Falls back to full\n        in-memory BM25 scan if FTS5 returns no results, and to word\n        overlap if BM25 scoring fails entirely.\n        \"\"\"\n        # Try FTS5 via store.search() for candidate filtering\n        try:\n            fts_results = store.search(query)\n            if fts_results:\n                return self._bm25_score_entries(query, fts_results, store)\n        except Exception:\n            logger.debug(\"fts5_search_failed\", query=query)\n\n        # Fallback: full corpus BM25 scan\n        return self._bm25_full_scan(query, store)\n\n    def _get_hybrid_candidates(\n        self,\n        query: str,\n        store: MemoryStore,\n    ) -> list[tuple[MemoryEntry, float]]:\n        \"\"\"Epic 65.8: Run BM25 + vector search in parallel, merge with RRF.\"\"\"\n        top_bm25 = 20\n        top_vector = 20\n        rrf_k = 60\n        if self._hybrid_config is not None:\n            top_bm25 = getattr(self._hybrid_config, \"top_bm25\", 20)\n            top_vector = getattr(self._hybrid_config, \"top_vector\", 20)\n            rrf_k = getattr(self._hybrid_config, \"rrf_k\", 60)\n\n        bm25_keys: list[str] = []\n        vector_keys: list[str] = []\n\n        def run_bm25() -> None:\n            nonlocal bm25_keys\n            candidates = self._get_candidates(query, store)\n            # Take top top_bm25 by score\n            sorted_cands = sorted(\n                candidates,\n                key=lambda x: x[1],\n                reverse=True,\n            )[:top_bm25]\n            bm25_keys = [e.key for e, _ in sorted_cands]\n\n        def run_vector() -> None:\n            nonlocal vector_keys\n            vector_results = self._vector_search(query, store, limit=top_vector)\n            vector_keys = [k for k, _ in vector_results]\n\n        with ThreadPoolExecutor(max_workers=2) as ex:\n            f1 = ex.submit(run_bm25)\n            f2 = ex.submit(run_vector)\n            for f in as_completed([f1, f2]):\n                f.result()\n\n        from tapps_brain.fusion import reciprocal_rank_fusion\n\n        fused = reciprocal_rank_fusion(bm25_keys, vector_keys, k=rrf_k)\n\n        if not fused:\n            return self._get_candidates(query, store)\n\n        entry_by_key = {e.key: e for e in store.list_all()}\n        max_rrf = fused[0][1] if fused else 1.0\n\n        results: list[tuple[MemoryEntry, float]] = []\n        for key, rrf_score in fused:\n            entry = entry_by_key.get(key)\n            if entry is None:\n                continue\n            relevance_raw = rrf_score / max_rrf if max_rrf > 0 else 0.0\n            results.append((entry, relevance_raw))\n\n        return results\n\n    def _vector_search(\n        self,\n        query: str,\n        store: MemoryStore,\n        limit: int = 20,\n    ) -> list[tuple[str, float]]:\n        \"\"\"Epic 65.8: Embed query, cosine similarity with entry embeddings.\n\n        Uses on-the-fly embedding when stored embeddings are unavailable.\n        Returns [(entry_key, score), ...] sorted by score descending.\n        \"\"\"\n        empty: list[tuple[str, float]] = []\n\n        try:\n            from tapps_brain.embeddings import get_embedding_provider\n\n            embedder = get_embedding_provider(semantic_search_enabled=True)\n        except ImportError:\n            logger.debug(\"vector_search_embedder_unavailable\")\n            return empty\n        if embedder is None or not (all_entries := store.list_all()):\n            return empty\n\n        texts = [self._entry_to_document(e) for e in all_entries]\n        try:\n            q = embedder.embed(query)\n            entry_embs = embedder.embed_batch(texts)\n        except Exception as e:\n            logger.debug(\"vector_search_embed_failed\", error=str(e))\n            return empty\n\n        if not q or len(entry_embs) != len(all_entries):\n            return empty\n        scored: list[tuple[str, float]] = []\n        for i, entry in enumerate(all_entries):\n            if i >= len(entry_embs):\n                break\n            emb = entry_embs[i]\n            if len(emb) == len(q):\n                sim = sum(a * b for a, b in zip(q, emb, strict=True))\n                scored.append((entry.key, max(0.0, sim)))\n        scored.sort(key=lambda x: x[1], reverse=True)\n        return scored[:limit]\n\n    def _bm25_score_entries(\n        self,\n        query: str,\n        entries: list[MemoryEntry],\n        store: MemoryStore,\n    ) -> list[tuple[MemoryEntry, float]]:\n        \"\"\"Score a set of entries using BM25.\n\n        Builds the BM25 index over the full corpus (for proper IDF),\n        then looks up scores for the given entries.\n        \"\"\"\n        try:\n            all_entries = store.list_all()\n            self._ensure_bm25_index(all_entries)\n\n            # Build a lookup: entry key -> index in corpus\n            key_to_idx = {e.key: i for i, e in enumerate(self._bm25_entries)}\n            all_scores = self._bm25.score(query)\n\n            results: list[tuple[MemoryEntry, float]] = []\n            for entry in entries:\n                idx = key_to_idx.get(entry.key)\n                if idx is not None and idx < len(all_scores):\n                    results.append((entry, all_scores[idx]))\n                else:\n                    # Entry not in index (new entry?), use word overlap\n                    results.append((entry, self._word_overlap_score(query, entry)))\n            return results\n        except Exception:\n            logger.debug(\"bm25_scoring_failed_using_word_overlap\", query=query)\n            return [(entry, self._word_overlap_score(query, entry)) for entry in entries]\n\n    def _bm25_full_scan(\n        self,\n        query: str,\n        store: MemoryStore,\n    ) -> list[tuple[MemoryEntry, float]]:\n        \"\"\"Full corpus BM25 scan as fallback.\n\n        Falls back to word overlap if BM25 fails.\n        \"\"\"\n        all_entries = store.list_all()\n        if not all_entries:\n            return []\n\n        try:\n            self._ensure_bm25_index(all_entries)\n            scores = self._bm25.score(query)\n            return [\n                (entry, score)\n                for entry, score in zip(all_entries, scores, strict=True)\n                if score > 0\n            ]\n        except Exception:\n            logger.debug(\"bm25_full_scan_failed_using_word_overlap\", query=query)\n            return self._like_search(query, store)\n\n    def _like_search(\n        self,\n        query: str,\n        store: MemoryStore,\n    ) -> list[tuple[MemoryEntry, float]]:\n        \"\"\"Fallback LIKE-based search with simple word overlap scoring.\"\"\"\n        query_words = set(query.lower().split())\n        if not query_words:\n            return []\n\n        all_entries = store.list_all()\n        results: list[tuple[MemoryEntry, float]] = []\n\n        for entry in all_entries:\n            relevance = self._word_overlap_score(query, entry)\n            if relevance > 0:\n                results.append((entry, relevance))\n\n        return results\n\n    # -----------------------------------------------------------------------\n    # Scoring helpers\n    # -----------------------------------------------------------------------\n\n    @staticmethod\n    def _word_overlap_score(query: str, entry: MemoryEntry) -> float:\n        \"\"\"Compute word overlap between query and entry text.\"\"\"\n        query_words = set(query.lower().split())\n        if not query_words:\n            return 0.0\n        entry_text = f\"{entry.key} {entry.value} {' '.join(entry.tags)}\".lower()\n        entry_words = set(entry_text.split())\n        overlap = len(query_words & entry_words)\n        return overlap / len(query_words)\n\n    def _normalize_relevance(self, raw_score: float) -> float:\n        \"\"\"Normalize relevance score to 0.0-1.0 range.\n\n        Uses sigmoid normalization: ``score / (score + K)`` where\n        K defaults to 5.0, tuned for BM25 scores (typical range 0-15+).\n        A BM25 score of K maps to 0.5 normalized. K is configurable\n        via ``scoring_config.bm25_norm_k`` (EPIC-010).\n        \"\"\"\n        if raw_score <= 0:\n            return 0.0\n        return raw_score / (raw_score + self._bm25_norm_k)\n\n    @staticmethod\n    def _recency_score(entry: MemoryEntry, now: datetime) -> float:\n        \"\"\"Compute recency score: ``1.0 / (1.0 + days_since_updated)``.\"\"\"\n        try:\n            updated = datetime.fromisoformat(entry.updated_at)\n            if updated.tzinfo is None:\n                updated = updated.replace(tzinfo=UTC)\n        except (ValueError, TypeError):\n            return 0.5\n        days = max((now - updated).total_seconds() / 86400.0, 0.0)\n        return 1.0 / (1.0 + days)\n\n    def _frequency_score(self, entry: MemoryEntry) -> float:\n        \"\"\"Compute access frequency score: ``min(1.0, access_count / cap)``.\n\n        The frequency cap defaults to 20.0 and is configurable via\n        ``scoring_config.frequency_cap`` (EPIC-010).\n        \"\"\"\n        return min(1.0, entry.access_count / self._frequency_cap)\n","numLines":650,"startLine":1,"totalLines":650}}}
