{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01URnJTVSgtgywTsv64RLg25","type":"tool_result","content":"     1→\"\"\"Tests for ranked memory retrieval (Epic 25, Story 25.1 + Epic 34.2 BM25).\"\"\"\n     2→\n     3→from __future__ import annotations\n     4→\n     5→from datetime import UTC, datetime, timedelta\n     6→from unittest.mock import MagicMock, patch\n     7→\n     8→import pytest\n     9→\n    10→from tapps_brain.decay import DecayConfig\n    11→from tapps_brain.models import (\n    12→    MemoryEntry,\n    13→    MemorySource,\n    14→    MemoryTier,\n    15→)\n    16→from tapps_brain.reranker import NoopReranker\n    17→from tapps_brain.retrieval import MemoryRetriever, ScoredMemory\n    18→from tests.factories import make_entry\n    19→\n    20→# ---------------------------------------------------------------------------\n    21→# Helpers\n    22→# ---------------------------------------------------------------------------\n    23→\n    24→_NOW = datetime(2026, 2, 27, 12, 0, 0, tzinfo=UTC)\n    25→_RECENT = (_NOW - timedelta(days=1)).isoformat()\n    26→_OLD = (_NOW - timedelta(days=90)).isoformat()\n    27→_VERY_OLD = (_NOW - timedelta(days=365)).isoformat()\n    28→\n    29→\n    30→def _make_entry(\n    31→    key: str = \"test-key\",\n    32→    value: str = \"test value\",\n    33→    *,\n    34→    tier: MemoryTier = MemoryTier.pattern,\n    35→    confidence: float = 0.8,\n    36→    source: MemorySource = MemorySource.agent,\n    37→    updated_at: str = \"\",\n    38→    access_count: int = 0,\n    39→    contradicted: bool = False,\n    40→    tags: list[str] | None = None,\n    41→) -> MemoryEntry:\n    42→    return make_entry(\n    43→        key=key,\n    44→        value=value,\n    45→        tier=tier,\n    46→        confidence=confidence,\n    47→        source=source,\n    48→        updated_at=updated_at or _RECENT,\n    49→        created_at=updated_at or _RECENT,\n    50→        last_accessed=updated_at or _RECENT,\n    51→        access_count=access_count,\n    52→        contradicted=contradicted,\n    53→        tags=tags,\n    54→    )\n    55→\n    56→\n    57→def _make_store(entries: list[MemoryEntry] | None = None) -> MagicMock:\n    58→    \"\"\"Create a mock MemoryStore with search and list_all.\"\"\"\n    59→    store = MagicMock()\n    60→    entries = entries or []\n    61→\n    62→    store.list_all.return_value = entries\n    63→    # store.search returns the same entries (simulating FTS match)\n    64→    store.search.return_value = entries\n    65→\n    66→    entry_map = {e.key: e for e in entries}\n    67→    store.get.side_effect = lambda k, **kwargs: entry_map.get(k)\n    68→\n    69→    return store\n    70→\n    71→\n    72→# ---------------------------------------------------------------------------\n    73→# ScoredMemory model tests\n    74→# ---------------------------------------------------------------------------\n    75→\n    76→\n    77→class TestScoredMemory:\n    78→    def test_scored_memory_creation(self) -> None:\n    79→        entry = _make_entry()\n    80→        scored = ScoredMemory(\n    81→            entry=entry,\n    82→            score=0.75,\n    83→            effective_confidence=0.8,\n    84→            bm25_relevance=0.5,\n    85→            stale=False,\n    86→        )\n    87→        assert scored.score == 0.75\n    88→        assert scored.entry.key == \"test-key\"\n    89→\n    90→\n    91→# ---------------------------------------------------------------------------\n    92→# MemoryRetriever tests\n    93→# ---------------------------------------------------------------------------\n    94→\n    95→\n    96→class TestMemoryRetriever:\n    97→    def test_empty_query_returns_empty(self) -> None:\n    98→        retriever = MemoryRetriever()\n    99→        store = _make_store([_make_entry()])\n   100→        assert retriever.search(\"\", store) == []\n   101→        assert retriever.search(\"   \", store) == []\n   102→\n   103→    def test_no_matching_entries(self) -> None:\n   104→        retriever = MemoryRetriever()\n   105→        entries = [_make_entry(\"unrelated-key\", \"no match here\")]\n   106→        store = _make_store(entries)\n   107→        # store.search returns empty for non-matching query\n   108→        store.search.return_value = []\n   109→\n   110→        results = retriever.search(\"completely different query\", store)\n   111→        assert len(results) == 0\n   112→\n   113→    def test_exact_key_match_ranks_highest(self) -> None:\n   114→        entries = [\n   115→            _make_entry(\"jwt-auth\", \"JWT authentication config\", confidence=0.7),\n   116→            _make_entry(\"auth-setup\", \"Authentication setup details\", confidence=0.7),\n   117→        ]\n   118→        retriever = MemoryRetriever()\n   119→        store = _make_store(entries)\n   120→\n   121→        results = retriever.search(\"jwt-auth\", store)\n   122→        assert len(results) >= 1\n   123→        assert results[0].entry.key == \"jwt-auth\"\n   124→\n   125→    def test_high_confidence_outranks_low(self) -> None:\n   126→        entries = [\n   127→            _make_entry(\n   128→                \"low-conf\",\n   129→                \"test framework value\",\n   130→                confidence=0.3,\n   131→                updated_at=_RECENT,\n   132→            ),\n   133→            _make_entry(\n   134→                \"high-conf\",\n   135→                \"test framework value\",\n   136→                confidence=0.9,\n   137→                updated_at=_RECENT,\n   138→            ),\n   139→        ]\n   140→        retriever = MemoryRetriever()\n   141→        store = _make_store(entries)\n   142→\n   143→        results = retriever.search(\"test framework\", store)\n   144→        assert len(results) == 2\n   145→        assert results[0].entry.key == \"high-conf\"\n   146→\n   147→    def test_recent_memory_outranks_old(self) -> None:\n   148→        entries = [\n   149→            _make_entry(\n   150→                \"old-memory\",\n   151→                \"database config setup\",\n   152→                confidence=0.8,\n   153→                updated_at=_OLD,\n   154→            ),\n   155→            _make_entry(\n   156→                \"new-memory\",\n   157→                \"database config setup\",\n   158→                confidence=0.8,\n   159→                updated_at=_RECENT,\n   160→            ),\n   161→        ]\n   162→        retriever = MemoryRetriever()\n   163→        store = _make_store(entries)\n   164→\n   165→        results = retriever.search(\"database config\", store)\n   166→        assert len(results) == 2\n   167→        assert results[0].entry.key == \"new-memory\"\n   168→\n   169→    def test_contradicted_excluded_by_default(self) -> None:\n   170→        entries = [\n   171→            _make_entry(\"good-key\", \"valid memory\", contradicted=False),\n   172→            _make_entry(\"bad-key\", \"contradicted memory\", contradicted=True),\n   173→        ]\n   174→        retriever = MemoryRetriever()\n   175→        store = _make_store(entries)\n   176→\n   177→        results = retriever.search(\"memory\", store)\n   178→        keys = [r.entry.key for r in results]\n   179→        assert \"bad-key\" not in keys\n   180→\n   181→    def test_contradicted_included_when_requested(self) -> None:\n   182→        entries = [\n   183→            _make_entry(\"bad-key\", \"contradicted memory\", contradicted=True),\n   184→        ]\n   185→        retriever = MemoryRetriever()\n   186→        store = _make_store(entries)\n   187→\n   188→        results = retriever.search(\"contradicted memory\", store, include_contradicted=True)\n   189→        assert len(results) == 1\n   190→        assert results[0].entry.key == \"bad-key\"\n   191→\n   192→    def test_result_limit_respected(self) -> None:\n   193→        entries = [_make_entry(f\"key-{i}\", f\"matching value {i}\") for i in range(20)]\n   194→        retriever = MemoryRetriever()\n   195→        store = _make_store(entries)\n   196→\n   197→        results = retriever.search(\"matching value\", store, limit=5)\n   198→        assert len(results) <= 5\n   199→\n   200→    def test_max_limit_capped(self) -> None:\n   201→        entries = [_make_entry(f\"key-{i}\", f\"value {i}\") for i in range(60)]\n   202→        retriever = MemoryRetriever()\n   203→        store = _make_store(entries)\n   204→\n   205→        results = retriever.search(\"value\", store, limit=100)\n   206→        assert len(results) <= 50\n   207→\n   208→    def test_low_confidence_filtered(self) -> None:\n   209→        entries = [\n   210→            _make_entry(\n   211→                \"very-low\",\n   212→                \"matching text\",\n   213→                confidence=0.05,\n   214→                updated_at=_VERY_OLD,\n   215→            ),\n   216→        ]\n   217→        retriever = MemoryRetriever(config=DecayConfig())\n   218→        store = _make_store(entries)\n   219→\n   220→        # Confidence floor is 0.1, so entry decays to 0.1.\n   221→        # Use min_confidence > 0.1 to filter it out.\n   222→        results = retriever.search(\"matching text\", store, min_confidence=0.2)\n   223→        assert len(results) == 0\n   224→\n   225→    def test_frequency_affects_ranking(self) -> None:\n   226→        entries = [\n   227→            _make_entry(\n   228→                \"rarely-accessed\",\n   229→                \"shared pattern data\",\n   230→                access_count=1,\n   231→                confidence=0.8,\n   232→            ),\n   233→            _make_entry(\n   234→                \"often-accessed\",\n   235→                \"shared pattern data\",\n   236→                access_count=20,\n   237→                confidence=0.8,\n   238→            ),\n   239→        ]\n   240→        retriever = MemoryRetriever()\n   241→        store = _make_store(entries)\n   242→\n   243→        results = retriever.search(\"shared pattern\", store)\n   244→        assert len(results) == 2\n   245→        assert results[0].entry.key == \"often-accessed\"\n   246→\n   247→    def test_fallback_to_like_search(self) -> None:\n   248→        \"\"\"When FTS5 search returns no results, fallback to LIKE.\"\"\"\n   249→        entries = [_make_entry(\"my-key\", \"some matching content\")]\n   250→        retriever = MemoryRetriever()\n   251→        store = _make_store(entries)\n   252→        # store.search raises exception = FTS5 unavailable\n   253→        store.search.side_effect = Exception(\"FTS5 not available\")\n   254→\n   255→        results = retriever.search(\"matching content\", store)\n   256→        assert len(results) == 1\n   257→\n   258→    def test_word_overlap_scoring(self) -> None:\n   259→        entry = _make_entry(\"test-key\", \"python fastapi web framework\")\n   260→        score = MemoryRetriever._word_overlap_score(\"python fastapi\", entry)\n   261→        assert score > 0.0\n   262→\n   263→\n   264→# ---------------------------------------------------------------------------\n   265→# Scoring helpers\n   266→# ---------------------------------------------------------------------------\n   267→\n   268→\n   269→class TestScoringHelpers:\n   270→    def test_normalize_relevance_zero(self) -> None:\n   271→        retriever = MemoryRetriever()\n   272→        assert retriever._normalize_relevance(0.0) == 0.0\n   273→\n   274→    def test_normalize_relevance_positive(self) -> None:\n   275→        # BM25 normalization: score / (score + 5.0)\n   276→        retriever = MemoryRetriever()\n   277→        score = retriever._normalize_relevance(5.0)\n   278→        assert 0.0 < score < 1.0\n   279→        assert score == pytest.approx(0.5)\n   280→\n   281→    def test_normalize_relevance_large(self) -> None:\n   282→        retriever = MemoryRetriever()\n   283→        score = retriever._normalize_relevance(100.0)\n   284→        assert score > 0.9\n   285→\n   286→    def test_recency_score_recent(self) -> None:\n   287→        entry = _make_entry(updated_at=_NOW.isoformat())\n   288→        score = MemoryRetriever._recency_score(entry, _NOW)\n   289→        assert score == pytest.approx(1.0, abs=0.01)\n   290→\n   291→    def test_recency_score_old(self) -> None:\n   292→        entry = _make_entry(updated_at=_OLD)\n   293→        score = MemoryRetriever._recency_score(entry, _NOW)\n   294→        assert score < 0.1\n   295→\n   296→    def test_frequency_score_zero(self) -> None:\n   297→        retriever = MemoryRetriever()\n   298→        entry = _make_entry(access_count=0)\n   299→        assert retriever._frequency_score(entry) == 0.0\n   300→\n   301→    def test_frequency_score_capped(self) -> None:\n   302→        retriever = MemoryRetriever()\n   303→        entry = _make_entry(access_count=100)\n   304→        assert retriever._frequency_score(entry) == 1.0\n   305→\n   306→\n   307→# ---------------------------------------------------------------------------\n   308→# BM25 integration tests (Epic 34.2)\n   309→# ---------------------------------------------------------------------------\n   310→\n   311→\n   312→class TestBM25Integration:\n   313→    \"\"\"Tests for BM25-based relevance scoring in MemoryRetriever.\"\"\"\n   314→\n   315→    def test_stemming_matches_related_words(self) -> None:\n   316→        \"\"\"'testing' query should match a memory about 'test' via stemming.\"\"\"\n   317→        entries = [\n   318→            _make_entry(\"test-framework\", \"test framework configuration\"),\n   319→            _make_entry(\"unrelated\", \"database connection pooling\"),\n   320→        ]\n   321→        retriever = MemoryRetriever()\n   322→        store = _make_store(entries)\n   323→\n   324→        results = retriever.search(\"testing\", store)\n   325→        assert len(results) >= 1\n   326→        assert results[0].entry.key == \"test-framework\"\n   327→\n   328→    def test_idf_rare_term_scores_higher(self) -> None:\n   329→        \"\"\"A rare term should produce higher BM25 relevance than a common one.\"\"\"\n   330→        entries = [\n   331→            _make_entry(\"python-setup\", \"python setup guide\", confidence=0.8),\n   332→            _make_entry(\"python-web\", \"python web framework\", confidence=0.8),\n   333→            _make_entry(\"python-data\", \"python data science\", confidence=0.8),\n   334→            _make_entry(\"rust-setup\", \"rust setup guide\", confidence=0.8),\n   335→        ]\n   336→        retriever = MemoryRetriever()\n   337→        store = _make_store(entries)\n   338→\n   339→        # \"rust\" is rare (1 doc), \"python\" is common (3 docs)\n   340→        rust_results = retriever.search(\"rust\", store)\n   341→        python_results = retriever.search(\"python\", store)\n   342→\n   343→        # The rust match should have higher BM25 relevance\n   344→        assert len(rust_results) >= 1\n   345→        assert len(python_results) >= 1\n   346→        assert rust_results[0].bm25_relevance > python_results[0].bm25_relevance\n   347→\n   348→    def test_composite_scoring_still_works(self) -> None:\n   349→        \"\"\"BM25 integration preserves composite scoring formula.\"\"\"\n   350→        entries = [\n   351→            _make_entry(\n   352→                \"high-conf\",\n   353→                \"python framework config\",\n   354→                confidence=0.9,\n   355→                updated_at=_RECENT,\n   356→                access_count=10,\n   357→            ),\n   358→            _make_entry(\n   359→                \"low-conf\",\n   360→                \"python framework config\",\n   361→                confidence=0.3,\n   362→                updated_at=_RECENT,\n   363→                access_count=1,\n   364→            ),\n   365→        ]\n   366→        retriever = MemoryRetriever()\n   367→        store = _make_store(entries)\n   368→\n   369→        results = retriever.search(\"python framework\", store)\n   370→        assert len(results) == 2\n   371→        # High confidence + high frequency should outrank\n   372→        assert results[0].entry.key == \"high-conf\"\n   373→        # Both should have positive composite scores\n   374→        assert all(r.score > 0 for r in results)\n   375→        # bm25_relevance should be populated\n   376→        assert all(r.bm25_relevance >= 0 for r in results)\n   377→\n   378→    def test_fallback_to_word_overlap_on_bm25_error(self) -> None:\n   379→        \"\"\"If BM25 scoring fails, fall back to word overlap.\"\"\"\n   380→        entries = [_make_entry(\"my-key\", \"python framework setup\")]\n   381→        retriever = MemoryRetriever()\n   382→        store = _make_store(entries)\n   383→\n   384→        # Force BM25 to fail by corrupting internal state\n   385→        with patch.object(retriever._bm25, \"score\", side_effect=RuntimeError(\"BM25 broken\")):\n   386→            results = retriever.search(\"python framework\", store)\n   387→            # Should still get results via word overlap fallback\n   388→            assert len(results) >= 1\n   389→\n   390→    def test_index_invalidation_on_store_size_change(self) -> None:\n   391→        \"\"\"BM25 index should rebuild when store size changes.\"\"\"\n   392→        entries_v1 = [\n   393→            _make_entry(\"key-a\", \"alpha content\"),\n   394→        ]\n   395→        entries_v2 = [\n   396→            _make_entry(\"key-a\", \"alpha content\"),\n   397→            _make_entry(\"key-b\", \"beta content\"),\n   398→        ]\n   399→        retriever = MemoryRetriever()\n   400→\n   401→        # First search builds index for 1 entry\n   402→        store_v1 = _make_store(entries_v1)\n   403→        retriever.search(\"alpha\", store_v1)\n   404→        assert retriever._bm25_corpus_size == 1\n   405→\n   406→        # Second search with 2 entries should rebuild\n   407→        store_v2 = _make_store(entries_v2)\n   408→        retriever.search(\"beta\", store_v2)\n   409→        assert retriever._bm25_corpus_size == 2\n   410→\n   411→    def test_empty_store_returns_no_results(self) -> None:\n   412→        \"\"\"An empty store should return no results.\"\"\"\n   413→        retriever = MemoryRetriever()\n   414→        store = _make_store([])\n   415→        store.search.return_value = []\n   416→\n   417→        results = retriever.search(\"anything\", store)\n   418→        assert results == []\n   419→\n   420→    def test_bm25_relevance_field_populated(self) -> None:\n   421→        \"\"\"The bm25_relevance field should be populated with BM25 score.\"\"\"\n   422→        entries = [_make_entry(\"pytest-config\", \"pytest configuration details\")]\n   423→        retriever = MemoryRetriever()\n   424→        store = _make_store(entries)\n   425→\n   426→        results = retriever.search(\"pytest config\", store)\n   427→        assert len(results) == 1\n   428→        assert results[0].bm25_relevance > 0.0\n   429→        assert results[0].bm25_relevance <= 1.0\n   430→\n   431→    def test_word_overlap_still_available_as_method(self) -> None:\n   432→        \"\"\"_word_overlap_score should still be available as a fallback.\"\"\"\n   433→        entry = _make_entry(\"test-key\", \"python web framework\")\n   434→        score = MemoryRetriever._word_overlap_score(\"python web\", entry)\n   435→        assert score > 0.0\n   436→\n   437→    def test_entry_to_document_includes_tags(self) -> None:\n   438→        \"\"\"Document text should include key, value, and tags.\"\"\"\n   439→        entry = _make_entry(\"my-key\", \"my value\", tags=[\"tag1\", \"tag2\"])\n   440→        doc = MemoryRetriever._entry_to_document(entry)\n   441→        assert \"my-key\" in doc\n   442→        assert \"my value\" in doc\n   443→        assert \"tag1\" in doc\n   444→        assert \"tag2\" in doc\n   445→\n   446→    def test_semantic_disabled_uses_bm25_only(self) -> None:\n   447→        \"\"\"Epic 65.8: When semantic_enabled=False, BM25-only (no regression).\"\"\"\n   448→        entries = [\n   449→            _make_entry(\"key-a\", \"python testing framework\"),\n   450→            _make_entry(\"key-b\", \"python web server\"),\n   451→        ]\n   452→        retriever = MemoryRetriever(semantic_enabled=False)\n   453→        store = _make_store(entries)\n   454→\n   455→        results = retriever.search(\"python testing\", store)\n   456→        assert len(results) >= 1\n   457→        assert results[0].entry.key == \"key-a\"\n   458→\n   459→    def test_hybrid_falls_back_to_bm25_when_vector_empty(self) -> None:\n   460→        \"\"\"Epic 65.8: When embedder unavailable, hybrid falls back to BM25.\"\"\"\n   461→        entries = [_make_entry(\"my-key\", \"matching content\")]\n   462→        retriever = MemoryRetriever(semantic_enabled=True)\n   463→        store = _make_store(entries)\n   464→\n   465→        with patch(\n   466→            \"tapps_brain.retrieval.MemoryRetriever._vector_search\",\n   467→            return_value=[],\n   468→        ):\n   469→            results = retriever.search(\"matching content\", store)\n   470→        assert len(results) >= 1\n   471→        assert results[0].entry.key == \"my-key\"\n   472→\n   473→    def test_hybrid_merges_rrf_when_both_return_results(self) -> None:\n   474→        \"\"\"Epic 65.8: Hybrid merges BM25 + vector via RRF.\"\"\"\n   475→        entries = [\n   476→            _make_entry(\"a\", \"python framework\"),\n   477→            _make_entry(\"b\", \"testing library\"),\n   478→            _make_entry(\"c\", \"database config\"),\n   479→        ]\n   480→        retriever = MemoryRetriever(semantic_enabled=True)\n   481→        store = _make_store(entries)\n   482→\n   483→        def mock_vector_search(\n   484→            query: str, store: object, limit: int = 20\n   485→        ) -> list[tuple[str, float]]:\n   486→            return [(\"b\", 0.9), (\"a\", 0.7), (\"c\", 0.5)][:limit]\n   487→\n   488→        with patch.object(retriever, \"_vector_search\", side_effect=mock_vector_search):\n   489→            results = retriever.search(\"python\", store, limit=5)\n   490→        assert len(results) >= 1\n   491→        keys = [r.entry.key for r in results]\n   492→        assert \"a\" in keys or \"b\" in keys or \"c\" in keys\n   493→\n   494→    def test_bm25_multi_term_query(self) -> None:\n   495→        \"\"\"Multi-term queries should match entries with multiple terms.\"\"\"\n   496→        entries = [\n   497→            _make_entry(\"full-match\", \"python testing framework config\"),\n   498→            _make_entry(\"partial-match\", \"python web server\"),\n   499→            _make_entry(\"no-match\", \"database connection pooling\"),\n   500→        ]\n   501→        retriever = MemoryRetriever()\n   502→        store = _make_store(entries)\n   503→\n   504→        results = retriever.search(\"python testing framework\", store)\n   505→        # full-match should rank first (matches more query terms)\n   506→        assert len(results) >= 1\n   507→        assert results[0].entry.key == \"full-match\"\n   508→\n   509→\n   510→# ---------------------------------------------------------------------------\n   511→# Reranker integration (Epic 65.9)\n   512→# ---------------------------------------------------------------------------\n   513→\n   514→\n   515→class TestRerankerIntegration:\n   516→    \"\"\"Tests for optional reranking in MemoryRetriever.\"\"\"\n   517→\n   518→    def test_reranker_reorders_results(self) -> None:\n   519→        \"\"\"When reranker reverses order, final order follows reranker.\"\"\"\n   520→        entries = [\n   521→            _make_entry(\"key-a\", \"python framework\"),\n   522→            _make_entry(\"key-b\", \"testing library\"),\n   523→            _make_entry(\"key-c\", \"database config\"),\n   524→        ]\n   525→\n   526→        # NoopReranker preserves order, so use a custom reranker that reverses\n   527→        class ReverseReranker:\n   528→            def rerank(\n   529→                self,\n   530→                query: str,\n   531→                candidates: list[tuple[str, str]],\n   532→                top_k: int,\n   533→            ) -> list[tuple[str, float]]:\n   534→                reversed_cands = list(reversed(candidates[:top_k]))\n   535→                return [(k, 1.0 - i / 10) for i, (k, _) in enumerate(reversed_cands)]\n   536→\n   537→        retriever = MemoryRetriever(\n   538→            reranker=ReverseReranker(),\n   539→            reranker_enabled=True,\n   540→        )\n   541→        store = _make_store(entries)\n   542→\n   543→        results = retriever.search(\"python testing database\", store, limit=3)\n   544→        assert len(results) >= 1\n   545→        # ReverseReranker puts last candidate first\n   546→        assert results[0].entry.key == \"key-c\"\n   547→\n   548→    def test_reranker_disabled_uses_composite_order(self) -> None:\n   549→        \"\"\"When reranker disabled, original composite order is used.\"\"\"\n   550→        entries = [\n   551→            _make_entry(\"high-conf\", \"matching content\", confidence=0.9),\n   552→            _make_entry(\"low-conf\", \"matching content\", confidence=0.3),\n   553→        ]\n   554→        retriever = MemoryRetriever(reranker=NoopReranker(), reranker_enabled=False)\n   555→        store = _make_store(entries)\n   556→\n   557→        results = retriever.search(\"matching content\", store)\n   558→        assert len(results) == 2\n   559→        assert results[0].entry.key == \"high-conf\"\n   560→\n   561→    def test_reranker_failure_fallback(self) -> None:\n   562→        \"\"\"When reranker raises, fall back to original order.\"\"\"\n   563→        entries = [\n   564→            _make_entry(\"key-a\", \"content a\"),\n   565→            _make_entry(\"key-b\", \"content b\"),\n   566→        ]\n   567→        fail_reranker = MagicMock()\n   568→        fail_reranker.rerank.side_effect = RuntimeError(\"API down\")\n   569→\n   570→        retriever = MemoryRetriever(\n   571→            reranker=fail_reranker,\n   572→            reranker_enabled=True,\n   573→        )\n   574→        store = _make_store(entries)\n   575→\n   576→        results = retriever.search(\"content\", store)\n   577→        assert len(results) == 2\n   578→        # Original composite order preserved on failure\n   579→        assert results[0].entry.key in (\"key-a\", \"key-b\")\n   580→\n   581→\n   582→class TestTemporalFiltering:\n   583→    \"\"\"Tests for temporal filtering in retriever (EPIC-004, STORY-004.3).\"\"\"\n   584→\n   585→    def test_superseded_excluded_by_default(self) -> None:\n   586→        \"\"\"Entries with invalid_at in the past are excluded by default.\"\"\"\n   587→        entries = [\n   588→            _make_entry(\"v1\", \"old pricing plan\", updated_at=_RECENT),\n   589→            _make_entry(\"v2\", \"new pricing plan\", updated_at=_RECENT),\n   590→        ]\n   591→        # Manually set v1 as superseded\n   592→        entries[0] = entries[0].model_copy(\n   593→            update={\"invalid_at\": \"2020-01-01T00:00:00+00:00\", \"superseded_by\": \"v2\"}\n   594→        )\n   595→        entries[1] = entries[1].model_copy(update={\"valid_at\": _RECENT})\n   596→\n   597→        retriever = MemoryRetriever()\n   598→        store = _make_store(entries)\n   599→        results = retriever.search(\"pricing plan\", store)\n   600→        keys = [r.entry.key for r in results]\n   601→        assert \"v1\" not in keys\n   602→        assert \"v2\" in keys\n   603→\n   604→    def test_superseded_included_with_flag(self) -> None:\n   605→        \"\"\"include_superseded=True returns temporally invalid entries marked stale.\"\"\"\n   606→        entries = [\n   607→            _make_entry(\"old-fact\", \"old technology stack\", updated_at=_RECENT),\n   608→            _make_entry(\"new-fact\", \"new technology stack\", updated_at=_RECENT),\n   609→        ]\n   610→        entries[0] = entries[0].model_copy(\n   611→            update={\"invalid_at\": \"2020-01-01T00:00:00+00:00\", \"superseded_by\": \"new-fact\"}\n   612→        )\n   613→\n   614→        retriever = MemoryRetriever()\n   615→        store = _make_store(entries)\n   616→        results = retriever.search(\"technology stack\", store, include_superseded=True)\n   617→        keys = [r.entry.key for r in results]\n   618→        assert \"old-fact\" in keys\n   619→\n   620→        old = next(r for r in results if r.entry.key == \"old-fact\")\n   621→        assert old.stale is True\n   622→\n   623→    def test_as_of_point_in_time(self) -> None:\n   624→        \"\"\"as_of parameter returns entries valid at that timestamp.\"\"\"\n   625→        entries = [\n   626→            _make_entry(\"versioned\", \"database version info\", updated_at=_RECENT),\n   627→        ]\n   628→        entries[0] = entries[0].model_copy(\n   629→            update={\n   630→                \"valid_at\": \"2026-01-01T00:00:00+00:00\",\n   631→                \"invalid_at\": \"2026-06-01T00:00:00+00:00\",\n   632→            }\n   633→        )\n   634→\n   635→        retriever = MemoryRetriever()\n   636→        store = _make_store(entries)\n   637→\n   638→        # Within window\n   639→        results_in = retriever.search(\"database version\", store, as_of=\"2026-03-01T00:00:00+00:00\")\n   640→        assert any(r.entry.key == \"versioned\" for r in results_in)\n   641→\n   642→        # Outside window\n   643→        results_out = retriever.search(\"database version\", store, as_of=\"2026-07-01T00:00:00+00:00\")\n   644→        assert not any(r.entry.key == \"versioned\" for r in results_out)\n   645→\n   646→    def test_superseded_penalty(self) -> None:\n   647→        \"\"\"Superseded entries included via flag get a score penalty.\"\"\"\n   648→        entries = [\n   649→            _make_entry(\"active\", \"current active data\", confidence=0.8, updated_at=_RECENT),\n   650→            _make_entry(\"superseded\", \"old superseded data\", confidence=0.8, updated_at=_RECENT),\n   651→        ]\n   652→        entries[1] = entries[1].model_copy(update={\"invalid_at\": \"2020-01-01T00:00:00+00:00\"})\n   653→\n   654→        retriever = MemoryRetriever()\n   655→        store = _make_store(entries)\n   656→        results = retriever.search(\"data\", store, include_superseded=True)\n   657→\n   658→        active = next((r for r in results if r.entry.key == \"active\"), None)\n   659→        superseded = next((r for r in results if r.entry.key == \"superseded\"), None)\n   660→        assert active is not None\n   661→        assert superseded is not None\n   662→        assert active.score > superseded.score\n   663→"}]},"parent_tool_use_id":null,"session_id":"1dfeb66a-ec06-46ac-b5f4-422c4dae48e2","uuid":"c7c9ae8d-eedf-4524-ac4f-f1cd5e19124d","timestamp":"2026-03-22T22:45:08.857Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\cursor\\tapps-brain\\tests\\unit\\test_memory_retrieval.py","content":"\"\"\"Tests for ranked memory retrieval (Epic 25, Story 25.1 + Epic 34.2 BM25).\"\"\"\n\nfrom __future__ import annotations\n\nfrom datetime import UTC, datetime, timedelta\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\n\nfrom tapps_brain.decay import DecayConfig\nfrom tapps_brain.models import (\n    MemoryEntry,\n    MemorySource,\n    MemoryTier,\n)\nfrom tapps_brain.reranker import NoopReranker\nfrom tapps_brain.retrieval import MemoryRetriever, ScoredMemory\nfrom tests.factories import make_entry\n\n# ---------------------------------------------------------------------------\n# Helpers\n# ---------------------------------------------------------------------------\n\n_NOW = datetime(2026, 2, 27, 12, 0, 0, tzinfo=UTC)\n_RECENT = (_NOW - timedelta(days=1)).isoformat()\n_OLD = (_NOW - timedelta(days=90)).isoformat()\n_VERY_OLD = (_NOW - timedelta(days=365)).isoformat()\n\n\ndef _make_entry(\n    key: str = \"test-key\",\n    value: str = \"test value\",\n    *,\n    tier: MemoryTier = MemoryTier.pattern,\n    confidence: float = 0.8,\n    source: MemorySource = MemorySource.agent,\n    updated_at: str = \"\",\n    access_count: int = 0,\n    contradicted: bool = False,\n    tags: list[str] | None = None,\n) -> MemoryEntry:\n    return make_entry(\n        key=key,\n        value=value,\n        tier=tier,\n        confidence=confidence,\n        source=source,\n        updated_at=updated_at or _RECENT,\n        created_at=updated_at or _RECENT,\n        last_accessed=updated_at or _RECENT,\n        access_count=access_count,\n        contradicted=contradicted,\n        tags=tags,\n    )\n\n\ndef _make_store(entries: list[MemoryEntry] | None = None) -> MagicMock:\n    \"\"\"Create a mock MemoryStore with search and list_all.\"\"\"\n    store = MagicMock()\n    entries = entries or []\n\n    store.list_all.return_value = entries\n    # store.search returns the same entries (simulating FTS match)\n    store.search.return_value = entries\n\n    entry_map = {e.key: e for e in entries}\n    store.get.side_effect = lambda k, **kwargs: entry_map.get(k)\n\n    return store\n\n\n# ---------------------------------------------------------------------------\n# ScoredMemory model tests\n# ---------------------------------------------------------------------------\n\n\nclass TestScoredMemory:\n    def test_scored_memory_creation(self) -> None:\n        entry = _make_entry()\n        scored = ScoredMemory(\n            entry=entry,\n            score=0.75,\n            effective_confidence=0.8,\n            bm25_relevance=0.5,\n            stale=False,\n        )\n        assert scored.score == 0.75\n        assert scored.entry.key == \"test-key\"\n\n\n# ---------------------------------------------------------------------------\n# MemoryRetriever tests\n# ---------------------------------------------------------------------------\n\n\nclass TestMemoryRetriever:\n    def test_empty_query_returns_empty(self) -> None:\n        retriever = MemoryRetriever()\n        store = _make_store([_make_entry()])\n        assert retriever.search(\"\", store) == []\n        assert retriever.search(\"   \", store) == []\n\n    def test_no_matching_entries(self) -> None:\n        retriever = MemoryRetriever()\n        entries = [_make_entry(\"unrelated-key\", \"no match here\")]\n        store = _make_store(entries)\n        # store.search returns empty for non-matching query\n        store.search.return_value = []\n\n        results = retriever.search(\"completely different query\", store)\n        assert len(results) == 0\n\n    def test_exact_key_match_ranks_highest(self) -> None:\n        entries = [\n            _make_entry(\"jwt-auth\", \"JWT authentication config\", confidence=0.7),\n            _make_entry(\"auth-setup\", \"Authentication setup details\", confidence=0.7),\n        ]\n        retriever = MemoryRetriever()\n        store = _make_store(entries)\n\n        results = retriever.search(\"jwt-auth\", store)\n        assert len(results) >= 1\n        assert results[0].entry.key == \"jwt-auth\"\n\n    def test_high_confidence_outranks_low(self) -> None:\n        entries = [\n            _make_entry(\n                \"low-conf\",\n                \"test framework value\",\n                confidence=0.3,\n                updated_at=_RECENT,\n            ),\n            _make_entry(\n                \"high-conf\",\n                \"test framework value\",\n                confidence=0.9,\n                updated_at=_RECENT,\n            ),\n        ]\n        retriever = MemoryRetriever()\n        store = _make_store(entries)\n\n        results = retriever.search(\"test framework\", store)\n        assert len(results) == 2\n        assert results[0].entry.key == \"high-conf\"\n\n    def test_recent_memory_outranks_old(self) -> None:\n        entries = [\n            _make_entry(\n                \"old-memory\",\n                \"database config setup\",\n                confidence=0.8,\n                updated_at=_OLD,\n            ),\n            _make_entry(\n                \"new-memory\",\n                \"database config setup\",\n                confidence=0.8,\n                updated_at=_RECENT,\n            ),\n        ]\n        retriever = MemoryRetriever()\n        store = _make_store(entries)\n\n        results = retriever.search(\"database config\", store)\n        assert len(results) == 2\n        assert results[0].entry.key == \"new-memory\"\n\n    def test_contradicted_excluded_by_default(self) -> None:\n        entries = [\n            _make_entry(\"good-key\", \"valid memory\", contradicted=False),\n            _make_entry(\"bad-key\", \"contradicted memory\", contradicted=True),\n        ]\n        retriever = MemoryRetriever()\n        store = _make_store(entries)\n\n        results = retriever.search(\"memory\", store)\n        keys = [r.entry.key for r in results]\n        assert \"bad-key\" not in keys\n\n    def test_contradicted_included_when_requested(self) -> None:\n        entries = [\n            _make_entry(\"bad-key\", \"contradicted memory\", contradicted=True),\n        ]\n        retriever = MemoryRetriever()\n        store = _make_store(entries)\n\n        results = retriever.search(\"contradicted memory\", store, include_contradicted=True)\n        assert len(results) == 1\n        assert results[0].entry.key == \"bad-key\"\n\n    def test_result_limit_respected(self) -> None:\n        entries = [_make_entry(f\"key-{i}\", f\"matching value {i}\") for i in range(20)]\n        retriever = MemoryRetriever()\n        store = _make_store(entries)\n\n        results = retriever.search(\"matching value\", store, limit=5)\n        assert len(results) <= 5\n\n    def test_max_limit_capped(self) -> None:\n        entries = [_make_entry(f\"key-{i}\", f\"value {i}\") for i in range(60)]\n        retriever = MemoryRetriever()\n        store = _make_store(entries)\n\n        results = retriever.search(\"value\", store, limit=100)\n        assert len(results) <= 50\n\n    def test_low_confidence_filtered(self) -> None:\n        entries = [\n            _make_entry(\n                \"very-low\",\n                \"matching text\",\n                confidence=0.05,\n                updated_at=_VERY_OLD,\n            ),\n        ]\n        retriever = MemoryRetriever(config=DecayConfig())\n        store = _make_store(entries)\n\n        # Confidence floor is 0.1, so entry decays to 0.1.\n        # Use min_confidence > 0.1 to filter it out.\n        results = retriever.search(\"matching text\", store, min_confidence=0.2)\n        assert len(results) == 0\n\n    def test_frequency_affects_ranking(self) -> None:\n        entries = [\n            _make_entry(\n                \"rarely-accessed\",\n                \"shared pattern data\",\n                access_count=1,\n                confidence=0.8,\n            ),\n            _make_entry(\n                \"often-accessed\",\n                \"shared pattern data\",\n                access_count=20,\n                confidence=0.8,\n            ),\n        ]\n        retriever = MemoryRetriever()\n        store = _make_store(entries)\n\n        results = retriever.search(\"shared pattern\", store)\n        assert len(results) == 2\n        assert results[0].entry.key == \"often-accessed\"\n\n    def test_fallback_to_like_search(self) -> None:\n        \"\"\"When FTS5 search returns no results, fallback to LIKE.\"\"\"\n        entries = [_make_entry(\"my-key\", \"some matching content\")]\n        retriever = MemoryRetriever()\n        store = _make_store(entries)\n        # store.search raises exception = FTS5 unavailable\n        store.search.side_effect = Exception(\"FTS5 not available\")\n\n        results = retriever.search(\"matching content\", store)\n        assert len(results) == 1\n\n    def test_word_overlap_scoring(self) -> None:\n        entry = _make_entry(\"test-key\", \"python fastapi web framework\")\n        score = MemoryRetriever._word_overlap_score(\"python fastapi\", entry)\n        assert score > 0.0\n\n\n# ---------------------------------------------------------------------------\n# Scoring helpers\n# ---------------------------------------------------------------------------\n\n\nclass TestScoringHelpers:\n    def test_normalize_relevance_zero(self) -> None:\n        retriever = MemoryRetriever()\n        assert retriever._normalize_relevance(0.0) == 0.0\n\n    def test_normalize_relevance_positive(self) -> None:\n        # BM25 normalization: score / (score + 5.0)\n        retriever = MemoryRetriever()\n        score = retriever._normalize_relevance(5.0)\n        assert 0.0 < score < 1.0\n        assert score == pytest.approx(0.5)\n\n    def test_normalize_relevance_large(self) -> None:\n        retriever = MemoryRetriever()\n        score = retriever._normalize_relevance(100.0)\n        assert score > 0.9\n\n    def test_recency_score_recent(self) -> None:\n        entry = _make_entry(updated_at=_NOW.isoformat())\n        score = MemoryRetriever._recency_score(entry, _NOW)\n        assert score == pytest.approx(1.0, abs=0.01)\n\n    def test_recency_score_old(self) -> None:\n        entry = _make_entry(updated_at=_OLD)\n        score = MemoryRetriever._recency_score(entry, _NOW)\n        assert score < 0.1\n\n    def test_frequency_score_zero(self) -> None:\n        retriever = MemoryRetriever()\n        entry = _make_entry(access_count=0)\n        assert retriever._frequency_score(entry) == 0.0\n\n    def test_frequency_score_capped(self) -> None:\n        retriever = MemoryRetriever()\n        entry = _make_entry(access_count=100)\n        assert retriever._frequency_score(entry) == 1.0\n\n\n# ---------------------------------------------------------------------------\n# BM25 integration tests (Epic 34.2)\n# ---------------------------------------------------------------------------\n\n\nclass TestBM25Integration:\n    \"\"\"Tests for BM25-based relevance scoring in MemoryRetriever.\"\"\"\n\n    def test_stemming_matches_related_words(self) -> None:\n        \"\"\"'testing' query should match a memory about 'test' via stemming.\"\"\"\n        entries = [\n            _make_entry(\"test-framework\", \"test framework configuration\"),\n            _make_entry(\"unrelated\", \"database connection pooling\"),\n        ]\n        retriever = MemoryRetriever()\n        store = _make_store(entries)\n\n        results = retriever.search(\"testing\", store)\n        assert len(results) >= 1\n        assert results[0].entry.key == \"test-framework\"\n\n    def test_idf_rare_term_scores_higher(self) -> None:\n        \"\"\"A rare term should produce higher BM25 relevance than a common one.\"\"\"\n        entries = [\n            _make_entry(\"python-setup\", \"python setup guide\", confidence=0.8),\n            _make_entry(\"python-web\", \"python web framework\", confidence=0.8),\n            _make_entry(\"python-data\", \"python data science\", confidence=0.8),\n            _make_entry(\"rust-setup\", \"rust setup guide\", confidence=0.8),\n        ]\n        retriever = MemoryRetriever()\n        store = _make_store(entries)\n\n        # \"rust\" is rare (1 doc), \"python\" is common (3 docs)\n        rust_results = retriever.search(\"rust\", store)\n        python_results = retriever.search(\"python\", store)\n\n        # The rust match should have higher BM25 relevance\n        assert len(rust_results) >= 1\n        assert len(python_results) >= 1\n        assert rust_results[0].bm25_relevance > python_results[0].bm25_relevance\n\n    def test_composite_scoring_still_works(self) -> None:\n        \"\"\"BM25 integration preserves composite scoring formula.\"\"\"\n        entries = [\n            _make_entry(\n                \"high-conf\",\n                \"python framework config\",\n                confidence=0.9,\n                updated_at=_RECENT,\n                access_count=10,\n            ),\n            _make_entry(\n                \"low-conf\",\n                \"python framework config\",\n                confidence=0.3,\n                updated_at=_RECENT,\n                access_count=1,\n            ),\n        ]\n        retriever = MemoryRetriever()\n        store = _make_store(entries)\n\n        results = retriever.search(\"python framework\", store)\n        assert len(results) == 2\n        # High confidence + high frequency should outrank\n        assert results[0].entry.key == \"high-conf\"\n        # Both should have positive composite scores\n        assert all(r.score > 0 for r in results)\n        # bm25_relevance should be populated\n        assert all(r.bm25_relevance >= 0 for r in results)\n\n    def test_fallback_to_word_overlap_on_bm25_error(self) -> None:\n        \"\"\"If BM25 scoring fails, fall back to word overlap.\"\"\"\n        entries = [_make_entry(\"my-key\", \"python framework setup\")]\n        retriever = MemoryRetriever()\n        store = _make_store(entries)\n\n        # Force BM25 to fail by corrupting internal state\n        with patch.object(retriever._bm25, \"score\", side_effect=RuntimeError(\"BM25 broken\")):\n            results = retriever.search(\"python framework\", store)\n            # Should still get results via word overlap fallback\n            assert len(results) >= 1\n\n    def test_index_invalidation_on_store_size_change(self) -> None:\n        \"\"\"BM25 index should rebuild when store size changes.\"\"\"\n        entries_v1 = [\n            _make_entry(\"key-a\", \"alpha content\"),\n        ]\n        entries_v2 = [\n            _make_entry(\"key-a\", \"alpha content\"),\n            _make_entry(\"key-b\", \"beta content\"),\n        ]\n        retriever = MemoryRetriever()\n\n        # First search builds index for 1 entry\n        store_v1 = _make_store(entries_v1)\n        retriever.search(\"alpha\", store_v1)\n        assert retriever._bm25_corpus_size == 1\n\n        # Second search with 2 entries should rebuild\n        store_v2 = _make_store(entries_v2)\n        retriever.search(\"beta\", store_v2)\n        assert retriever._bm25_corpus_size == 2\n\n    def test_empty_store_returns_no_results(self) -> None:\n        \"\"\"An empty store should return no results.\"\"\"\n        retriever = MemoryRetriever()\n        store = _make_store([])\n        store.search.return_value = []\n\n        results = retriever.search(\"anything\", store)\n        assert results == []\n\n    def test_bm25_relevance_field_populated(self) -> None:\n        \"\"\"The bm25_relevance field should be populated with BM25 score.\"\"\"\n        entries = [_make_entry(\"pytest-config\", \"pytest configuration details\")]\n        retriever = MemoryRetriever()\n        store = _make_store(entries)\n\n        results = retriever.search(\"pytest config\", store)\n        assert len(results) == 1\n        assert results[0].bm25_relevance > 0.0\n        assert results[0].bm25_relevance <= 1.0\n\n    def test_word_overlap_still_available_as_method(self) -> None:\n        \"\"\"_word_overlap_score should still be available as a fallback.\"\"\"\n        entry = _make_entry(\"test-key\", \"python web framework\")\n        score = MemoryRetriever._word_overlap_score(\"python web\", entry)\n        assert score > 0.0\n\n    def test_entry_to_document_includes_tags(self) -> None:\n        \"\"\"Document text should include key, value, and tags.\"\"\"\n        entry = _make_entry(\"my-key\", \"my value\", tags=[\"tag1\", \"tag2\"])\n        doc = MemoryRetriever._entry_to_document(entry)\n        assert \"my-key\" in doc\n        assert \"my value\" in doc\n        assert \"tag1\" in doc\n        assert \"tag2\" in doc\n\n    def test_semantic_disabled_uses_bm25_only(self) -> None:\n        \"\"\"Epic 65.8: When semantic_enabled=False, BM25-only (no regression).\"\"\"\n        entries = [\n            _make_entry(\"key-a\", \"python testing framework\"),\n            _make_entry(\"key-b\", \"python web server\"),\n        ]\n        retriever = MemoryRetriever(semantic_enabled=False)\n        store = _make_store(entries)\n\n        results = retriever.search(\"python testing\", store)\n        assert len(results) >= 1\n        assert results[0].entry.key == \"key-a\"\n\n    def test_hybrid_falls_back_to_bm25_when_vector_empty(self) -> None:\n        \"\"\"Epic 65.8: When embedder unavailable, hybrid falls back to BM25.\"\"\"\n        entries = [_make_entry(\"my-key\", \"matching content\")]\n        retriever = MemoryRetriever(semantic_enabled=True)\n        store = _make_store(entries)\n\n        with patch(\n            \"tapps_brain.retrieval.MemoryRetriever._vector_search\",\n            return_value=[],\n        ):\n            results = retriever.search(\"matching content\", store)\n        assert len(results) >= 1\n        assert results[0].entry.key == \"my-key\"\n\n    def test_hybrid_merges_rrf_when_both_return_results(self) -> None:\n        \"\"\"Epic 65.8: Hybrid merges BM25 + vector via RRF.\"\"\"\n        entries = [\n            _make_entry(\"a\", \"python framework\"),\n            _make_entry(\"b\", \"testing library\"),\n            _make_entry(\"c\", \"database config\"),\n        ]\n        retriever = MemoryRetriever(semantic_enabled=True)\n        store = _make_store(entries)\n\n        def mock_vector_search(\n            query: str, store: object, limit: int = 20\n        ) -> list[tuple[str, float]]:\n            return [(\"b\", 0.9), (\"a\", 0.7), (\"c\", 0.5)][:limit]\n\n        with patch.object(retriever, \"_vector_search\", side_effect=mock_vector_search):\n            results = retriever.search(\"python\", store, limit=5)\n        assert len(results) >= 1\n        keys = [r.entry.key for r in results]\n        assert \"a\" in keys or \"b\" in keys or \"c\" in keys\n\n    def test_bm25_multi_term_query(self) -> None:\n        \"\"\"Multi-term queries should match entries with multiple terms.\"\"\"\n        entries = [\n            _make_entry(\"full-match\", \"python testing framework config\"),\n            _make_entry(\"partial-match\", \"python web server\"),\n            _make_entry(\"no-match\", \"database connection pooling\"),\n        ]\n        retriever = MemoryRetriever()\n        store = _make_store(entries)\n\n        results = retriever.search(\"python testing framework\", store)\n        # full-match should rank first (matches more query terms)\n        assert len(results) >= 1\n        assert results[0].entry.key == \"full-match\"\n\n\n# ---------------------------------------------------------------------------\n# Reranker integration (Epic 65.9)\n# ---------------------------------------------------------------------------\n\n\nclass TestRerankerIntegration:\n    \"\"\"Tests for optional reranking in MemoryRetriever.\"\"\"\n\n    def test_reranker_reorders_results(self) -> None:\n        \"\"\"When reranker reverses order, final order follows reranker.\"\"\"\n        entries = [\n            _make_entry(\"key-a\", \"python framework\"),\n            _make_entry(\"key-b\", \"testing library\"),\n            _make_entry(\"key-c\", \"database config\"),\n        ]\n\n        # NoopReranker preserves order, so use a custom reranker that reverses\n        class ReverseReranker:\n            def rerank(\n                self,\n                query: str,\n                candidates: list[tuple[str, str]],\n                top_k: int,\n            ) -> list[tuple[str, float]]:\n                reversed_cands = list(reversed(candidates[:top_k]))\n                return [(k, 1.0 - i / 10) for i, (k, _) in enumerate(reversed_cands)]\n\n        retriever = MemoryRetriever(\n            reranker=ReverseReranker(),\n            reranker_enabled=True,\n        )\n        store = _make_store(entries)\n\n        results = retriever.search(\"python testing database\", store, limit=3)\n        assert len(results) >= 1\n        # ReverseReranker puts last candidate first\n        assert results[0].entry.key == \"key-c\"\n\n    def test_reranker_disabled_uses_composite_order(self) -> None:\n        \"\"\"When reranker disabled, original composite order is used.\"\"\"\n        entries = [\n            _make_entry(\"high-conf\", \"matching content\", confidence=0.9),\n            _make_entry(\"low-conf\", \"matching content\", confidence=0.3),\n        ]\n        retriever = MemoryRetriever(reranker=NoopReranker(), reranker_enabled=False)\n        store = _make_store(entries)\n\n        results = retriever.search(\"matching content\", store)\n        assert len(results) == 2\n        assert results[0].entry.key == \"high-conf\"\n\n    def test_reranker_failure_fallback(self) -> None:\n        \"\"\"When reranker raises, fall back to original order.\"\"\"\n        entries = [\n            _make_entry(\"key-a\", \"content a\"),\n            _make_entry(\"key-b\", \"content b\"),\n        ]\n        fail_reranker = MagicMock()\n        fail_reranker.rerank.side_effect = RuntimeError(\"API down\")\n\n        retriever = MemoryRetriever(\n            reranker=fail_reranker,\n            reranker_enabled=True,\n        )\n        store = _make_store(entries)\n\n        results = retriever.search(\"content\", store)\n        assert len(results) == 2\n        # Original composite order preserved on failure\n        assert results[0].entry.key in (\"key-a\", \"key-b\")\n\n\nclass TestTemporalFiltering:\n    \"\"\"Tests for temporal filtering in retriever (EPIC-004, STORY-004.3).\"\"\"\n\n    def test_superseded_excluded_by_default(self) -> None:\n        \"\"\"Entries with invalid_at in the past are excluded by default.\"\"\"\n        entries = [\n            _make_entry(\"v1\", \"old pricing plan\", updated_at=_RECENT),\n            _make_entry(\"v2\", \"new pricing plan\", updated_at=_RECENT),\n        ]\n        # Manually set v1 as superseded\n        entries[0] = entries[0].model_copy(\n            update={\"invalid_at\": \"2020-01-01T00:00:00+00:00\", \"superseded_by\": \"v2\"}\n        )\n        entries[1] = entries[1].model_copy(update={\"valid_at\": _RECENT})\n\n        retriever = MemoryRetriever()\n        store = _make_store(entries)\n        results = retriever.search(\"pricing plan\", store)\n        keys = [r.entry.key for r in results]\n        assert \"v1\" not in keys\n        assert \"v2\" in keys\n\n    def test_superseded_included_with_flag(self) -> None:\n        \"\"\"include_superseded=True returns temporally invalid entries marked stale.\"\"\"\n        entries = [\n            _make_entry(\"old-fact\", \"old technology stack\", updated_at=_RECENT),\n            _make_entry(\"new-fact\", \"new technology stack\", updated_at=_RECENT),\n        ]\n        entries[0] = entries[0].model_copy(\n            update={\"invalid_at\": \"2020-01-01T00:00:00+00:00\", \"superseded_by\": \"new-fact\"}\n        )\n\n        retriever = MemoryRetriever()\n        store = _make_store(entries)\n        results = retriever.search(\"technology stack\", store, include_superseded=True)\n        keys = [r.entry.key for r in results]\n        assert \"old-fact\" in keys\n\n        old = next(r for r in results if r.entry.key == \"old-fact\")\n        assert old.stale is True\n\n    def test_as_of_point_in_time(self) -> None:\n        \"\"\"as_of parameter returns entries valid at that timestamp.\"\"\"\n        entries = [\n            _make_entry(\"versioned\", \"database version info\", updated_at=_RECENT),\n        ]\n        entries[0] = entries[0].model_copy(\n            update={\n                \"valid_at\": \"2026-01-01T00:00:00+00:00\",\n                \"invalid_at\": \"2026-06-01T00:00:00+00:00\",\n            }\n        )\n\n        retriever = MemoryRetriever()\n        store = _make_store(entries)\n\n        # Within window\n        results_in = retriever.search(\"database version\", store, as_of=\"2026-03-01T00:00:00+00:00\")\n        assert any(r.entry.key == \"versioned\" for r in results_in)\n\n        # Outside window\n        results_out = retriever.search(\"database version\", store, as_of=\"2026-07-01T00:00:00+00:00\")\n        assert not any(r.entry.key == \"versioned\" for r in results_out)\n\n    def test_superseded_penalty(self) -> None:\n        \"\"\"Superseded entries included via flag get a score penalty.\"\"\"\n        entries = [\n            _make_entry(\"active\", \"current active data\", confidence=0.8, updated_at=_RECENT),\n            _make_entry(\"superseded\", \"old superseded data\", confidence=0.8, updated_at=_RECENT),\n        ]\n        entries[1] = entries[1].model_copy(update={\"invalid_at\": \"2020-01-01T00:00:00+00:00\"})\n\n        retriever = MemoryRetriever()\n        store = _make_store(entries)\n        results = retriever.search(\"data\", store, include_superseded=True)\n\n        active = next((r for r in results if r.entry.key == \"active\"), None)\n        superseded = next((r for r in results if r.entry.key == \"superseded\"), None)\n        assert active is not None\n        assert superseded is not None\n        assert active.score > superseded.score\n","numLines":663,"startLine":1,"totalLines":663}}}
