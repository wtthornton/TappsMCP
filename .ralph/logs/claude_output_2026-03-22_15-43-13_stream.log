{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013cC4NPgRJdCHmkmoRpBMeT","type":"tool_result","content":"     1→\"\"\"Tests for ranked memory retrieval (Epic 25, Story 25.1 + Epic 34.2 BM25).\"\"\"\n     2→\n     3→from __future__ import annotations\n     4→\n     5→from datetime import UTC, datetime, timedelta\n     6→from unittest.mock import MagicMock, patch\n     7→\n     8→import pytest\n     9→\n    10→from tapps_brain.decay import DecayConfig\n    11→from tapps_brain.models import (\n    12→    MemoryEntry,\n    13→    MemorySource,\n    14→    MemoryTier,\n    15→)\n    16→from tapps_brain.reranker import NoopReranker\n    17→from tapps_brain.retrieval import MemoryRetriever, ScoredMemory\n    18→from tests.factories import make_entry\n    19→\n    20→# ---------------------------------------------------------------------------\n    21→# Helpers\n    22→# ---------------------------------------------------------------------------\n    23→\n    24→_NOW = datetime(2026, 2, 27, 12, 0, 0, tzinfo=UTC)\n    25→_RECENT = (_NOW - timedelta(days=1)).isoformat()\n    26→_OLD = (_NOW - timedelta(days=90)).isoformat()\n    27→_VERY_OLD = (_NOW - timedelta(days=365)).isoformat()\n    28→\n    29→\n    30→def _make_entry(\n    31→    key: str = \"test-key\",\n    32→    value: str = \"test value\",\n    33→    *,\n    34→    tier: MemoryTier = MemoryTier.pattern,\n    35→    confidence: float = 0.8,\n    36→    source: MemorySource = MemorySource.agent,\n    37→    updated_at: str = \"\",\n    38→    access_count: int = 0,\n    39→    contradicted: bool = False,\n    40→    tags: list[str] | None = None,\n    41→) -> MemoryEntry:\n    42→    return make_entry(\n    43→        key=key,\n    44→        value=value,\n    45→        tier=tier,\n    46→        confidence=confidence,\n    47→        source=source,\n    48→        updated_at=updated_at or _RECENT,\n    49→        created_at=updated_at or _RECENT,\n    50→        last_accessed=updated_at or _RECENT,\n    51→        access_count=access_count,\n    52→        contradicted=contradicted,\n    53→        tags=tags,\n    54→    )\n    55→\n    56→\n    57→def _make_store(entries: list[MemoryEntry] | None = None) -> MagicMock:\n    58→    \"\"\"Create a mock MemoryStore with search and list_all.\"\"\"\n    59→    store = MagicMock()\n    60→    entries = entries or []\n    61→\n    62→    store.list_all.return_value = entries\n    63→    # store.search returns the same entries (simulating FTS match)\n    64→    store.search.return_value = entries\n    65→\n    66→    entry_map = {e.key: e for e in entries}\n    67→    store.get.side_effect = lambda k, **kwargs: entry_map.get(k)\n    68→\n    69→    return store\n    70→\n    71→\n    72→# ---------------------------------------------------------------------------\n    73→# ScoredMemory model tests\n    74→# ---------------------------------------------------------------------------\n    75→\n    76→\n    77→class TestScoredMemory:\n    78→    def test_scored_memory_creation(self) -> None:\n    79→        entry = _make_entry()\n    80→        scored = ScoredMemory(\n    81→            entry=entry,\n    82→            score=0.75,\n    83→            effective_confidence=0.8,\n    84→            bm25_relevance=0.5,\n    85→            stale=False,\n    86→        )\n    87→        assert scored.score == 0.75\n    88→        assert scored.entry.key == \"test-key\"\n    89→\n    90→\n    91→# ---------------------------------------------------------------------------\n    92→# MemoryRetriever tests\n    93→# ---------------------------------------------------------------------------\n    94→\n    95→\n    96→class TestMemoryRetriever:\n    97→    def test_empty_query_returns_empty(self) -> None:\n    98→        retriever = MemoryRetriever()\n    99→        store = _make_store([_make_entry()])\n   100→        assert retriever.search(\"\", store) == []\n   101→        assert retriever.search(\"   \", store) == []\n   102→\n   103→    def test_no_matching_entries(self) -> None:\n   104→        retriever = MemoryRetriever()\n   105→        entries = [_make_entry(\"unrelated-key\", \"no match here\")]\n   106→        store = _make_store(entries)\n   107→        # store.search returns empty for non-matching query\n   108→        store.search.return_value = []\n   109→\n   110→        results = retriever.search(\"completely different query\", store)\n   111→        assert len(results) == 0\n   112→\n   113→    def test_exact_key_match_ranks_highest(self) -> None:\n   114→        entries = [\n   115→            _make_entry(\"jwt-auth\", \"JWT authentication config\", confidence=0.7),\n   116→            _make_entry(\"auth-setup\", \"Authentication setup details\", confidence=0.7),\n   117→        ]\n   118→        retriever = MemoryRetriever()\n   119→        store = _make_store(entries)\n   120→\n   121→        results = retriever.search(\"jwt-auth\", store)\n   122→        assert len(results) >= 1\n   123→        assert results[0].entry.key == \"jwt-auth\"\n   124→\n   125→    def test_high_confidence_outranks_low(self) -> None:\n   126→        entries = [\n   127→            _make_entry(\n   128→                \"low-conf\",\n   129→                \"test framework value\",\n   130→                confidence=0.3,\n   131→                updated_at=_RECENT,\n   132→            ),\n   133→            _make_entry(\n   134→                \"high-conf\",\n   135→                \"test framework value\",\n   136→                confidence=0.9,\n   137→                updated_at=_RECENT,\n   138→            ),\n   139→        ]\n   140→        retriever = MemoryRetriever()\n   141→        store = _make_store(entries)\n   142→\n   143→        results = retriever.search(\"test framework\", store)\n   144→        assert len(results) == 2\n   145→        assert results[0].entry.key == \"high-conf\"\n   146→\n   147→    def test_recent_memory_outranks_old(self) -> None:\n   148→        entries = [\n   149→            _make_entry(\n   150→                \"old-memory\",\n   151→                \"database config setup\",\n   152→                confidence=0.8,\n   153→                updated_at=_OLD,\n   154→            ),\n   155→            _make_entry(\n   156→                \"new-memory\",\n   157→                \"database config setup\",\n   158→                confidence=0.8,\n   159→                updated_at=_RECENT,\n   160→            ),\n   161→        ]\n   162→        retriever = MemoryRetriever()\n   163→        store = _make_store(entries)\n   164→\n   165→        results = retriever.search(\"database config\", store)\n   166→        assert len(results) == 2\n   167→        assert results[0].entry.key == \"new-memory\"\n   168→\n   169→    def test_contradicted_excluded_by_default(self) -> None:\n   170→        entries = [\n   171→            _make_entry(\"good-key\", \"valid memory\", contradicted=False),\n   172→            _make_entry(\"bad-key\", \"contradicted memory\", contradicted=True),\n   173→        ]\n   174→        retriever = MemoryRetriever()\n   175→        store = _make_store(entries)\n   176→\n   177→        results = retriever.search(\"memory\", store)\n   178→        keys = [r.entry.key for r in results]\n   179→        assert \"bad-key\" not in keys\n   180→\n   181→    def test_contradicted_included_when_requested(self) -> None:\n   182→        entries = [\n   183→            _make_entry(\"bad-key\", \"contradicted memory\", contradicted=True),\n   184→        ]\n   185→        retriever = MemoryRetriever()\n   186→        store = _make_store(entries)\n   187→\n   188→        results = retriever.search(\"contradicted memory\", store, include_contradicted=True)\n   189→        assert len(results) == 1\n   190→        assert results[0].entry.key == \"bad-key\"\n   191→\n   192→    def test_result_limit_respected(self) -> None:\n   193→        entries = [_make_entry(f\"key-{i}\", f\"matching value {i}\") for i in range(20)]\n   194→        retriever = MemoryRetriever()\n   195→        store = _make_store(entries)\n   196→\n   197→        results = retriever.search(\"matching value\", store, limit=5)\n   198→        assert len(results) <= 5\n   199→\n   200→    def test_max_limit_capped(self) -> None:"}]},"parent_tool_use_id":"toolu_018L5tqxjjasB32i2EQmYvDy","session_id":"1dfeb66a-ec06-46ac-b5f4-422c4dae48e2","uuid":"f62e6729-15dd-4a54-b797-4203adb9199d","timestamp":"2026-03-22T22:44:10.057Z"}
