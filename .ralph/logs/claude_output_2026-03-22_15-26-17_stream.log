{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JZsAW6gBL2Kz8xTLvpuPkC","type":"tool_result","content":"     1→\"\"\"Markdown import for migrating MEMORY.md files into tapps-brain.\n     2→\n     3→Parses markdown headings into memory keys (slugified) and body text into\n     4→values. Heading level determines tier:\n     5→  H1/H2 → architectural, H3 → pattern, H4+ → procedural.\n     6→\n     7→Daily notes (``memory/YYYY-MM-DD.md``) are imported as context-tier entries\n     8→with date extracted from the filename.\n     9→\n    10→Part of EPIC-012 (OpenClaw integration).\n    11→\"\"\"\n    12→\n    13→from __future__ import annotations\n    14→\n    15→import re\n    16→from typing import TYPE_CHECKING, Any\n    17→\n    18→import structlog\n    19→\n    20→from tapps_brain.models import MAX_KEY_LENGTH, MAX_VALUE_LENGTH, MemorySource, MemoryTier\n    21→\n    22→if TYPE_CHECKING:\n    23→    from pathlib import Path\n    24→\n    25→    from tapps_brain.store import MemoryStore\n    26→\n    27→logger = structlog.get_logger(__name__)\n    28→\n    29→# Matches markdown headings: group(1)=hashes, group(2)=text\n    30→_HEADING_RE = re.compile(r\"^(#{1,6})\\s+(.+?)\\s*$\")\n    31→\n    32→# Tier boundary heading levels\n    33→_H_ARCHITECTURAL_MAX = 2  # H1/H2 → architectural\n    34→_H_PATTERN = 3  # H3 → pattern; H4+ → procedural\n    35→\n    36→# Daily note filename pattern: YYYY-MM-DD.md\n    37→_DAILY_NOTE_RE = re.compile(r\"^(\\d{4}-\\d{2}-\\d{2})\\.md$\")\n    38→\n    39→# Characters allowed in slugified keys\n    40→_SLUG_CLEAN_RE = re.compile(r\"[^a-z0-9._-]+\")\n    41→_MULTI_SEP_RE = re.compile(r\"[-_.]{2,}\")\n    42→\n    43→\n    44→def _slugify(text: str) -> str:\n    45→    \"\"\"Convert heading text to a valid memory key slug.\n    46→\n    47→    Lowercase, replace non-alphanumeric with hyphens, collapse runs,\n    48→    strip leading/trailing separators, truncate to MAX_KEY_LENGTH.\n    49→    \"\"\"\n    50→    slug = text.lower().strip()\n    51→    slug = _SLUG_CLEAN_RE.sub(\"-\", slug)\n    52→    slug = _MULTI_SEP_RE.sub(\"-\", slug)\n    53→    slug = slug.strip(\"-._\")\n    54→    # Ensure starts with alphanumeric\n    55→    slug = slug.lstrip(\"-._\")\n    56→    if not slug or not slug[0].isalnum():\n    57→        slug = \"m-\" + slug\n    58→    return slug[:MAX_KEY_LENGTH]\n    59→\n    60→\n    61→def _tier_from_level(level: int) -> MemoryTier:\n    62→    \"\"\"Map heading level (1-6) to a memory tier.\"\"\"\n    63→    if level <= _H_ARCHITECTURAL_MAX:\n    64→        return MemoryTier.architectural\n    65→    if level == _H_PATTERN:\n    66→        return MemoryTier.pattern\n    67→    return MemoryTier.procedural\n    68→\n    69→\n    70→def import_memory_md(path: Path, store: MemoryStore) -> int:\n    71→    \"\"\"Parse a MEMORY.md file and import entries into the store.\n    72→\n    73→    Each heading becomes a key (slugified). The body text under that heading\n    74→    becomes the value. Entries whose keys already exist are skipped.\n    75→\n    76→    Args:\n    77→        path: Path to the markdown file.\n    78→        store: MemoryStore instance to import into.\n    79→\n    80→    Returns:\n    81→        Number of new entries imported.\n    82→    \"\"\"\n    83→    if not path.is_file():\n    84→        logger.warning(\"markdown_import.file_not_found\", path=str(path))\n    85→        return 0\n    86→\n    87→    text = path.read_text(encoding=\"utf-8\")\n    88→    return _parse_and_import(text, store)\n    89→\n    90→\n    91→def _parse_and_import(text: str, store: MemoryStore) -> int:\n    92→    \"\"\"Parse markdown text into sections and import them.\n    93→\n    94→    Returns the number of new entries imported.\n    95→    \"\"\"\n    96→    sections = _parse_sections(text)\n    97→    imported = 0\n    98→\n    99→    for key, value, tier in sections:\n   100→        # Skip if key already exists (deduplication)"}]},"parent_tool_use_id":"toolu_01ETxuMXE5rZCE6YhLTRE2TH","session_id":"432b4479-d665-4641-add7-8ce0bc4cd0e0","uuid":"3595c166-1c8e-47bc-a2b3-80529cf4c843","timestamp":"2026-03-22T22:27:00.399Z"}
