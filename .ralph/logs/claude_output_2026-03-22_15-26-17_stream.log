{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01D4JFbcW5dmfsPtr49n9jRY","type":"tool_result","content":"   150→\n   151→    source_keys = [e.key for e in entries_to_consolidate]\n   152→\n   153→    _persist_consolidated_entry(store, consolidated, source_keys)\n   154→\n   155→    logger.info(\n   156→        \"auto_consolidation_triggered\",\n   157→        new_key=consolidated.key,\n   158→        source_keys=source_keys,\n   159→        reason=reason.value,\n   160→        threshold=threshold,\n   161→    )\n   162→\n   163→    return ConsolidationResult(\n   164→        triggered=True,\n   165→        consolidated_entry=consolidated,\n   166→        source_keys=source_keys,\n   167→        reason=reason.value,\n   168→    )\n   169→\n   170→\n   171→def _get_enum_value(obj: object) -> str:\n   172→    \"\"\"Extract string value from an enum or return str() for non-enums.\"\"\"\n   173→    return obj.value if hasattr(obj, \"value\") else str(obj)\n   174→\n   175→\n   176→def _persist_consolidated_entry(\n   177→    store: MemoryStore,\n   178→    consolidated: ConsolidatedEntry,\n   179→    source_keys: list[str],\n   180→) -> None:\n   181→    \"\"\"Persist the consolidated entry and mark sources as consolidated.\n   182→\n   183→    Saves the new consolidated entry and marks source entries by updating\n   184→    their metadata. Source entries are NOT deleted (retained for provenance).\n   185→    \"\"\"\n   186→    store.save(\n   187→        key=consolidated.key,\n   188→        value=consolidated.value,\n   189→        tier=_get_enum_value(consolidated.tier),\n   190→        source=_get_enum_value(consolidated.source),\n   191→        source_agent=consolidated.source_agent,\n   192→        scope=_get_enum_value(consolidated.scope),\n   193→        tags=consolidated.tags,\n   194→        confidence=consolidated.confidence,\n   195→    )\n   196→\n   197→    # Merge relations from all source entries onto the consolidated entry\n   198→    relation_lists = [store.get_relations(k) for k in source_keys]\n   199→    merged_relations = merge_entry_relations(relation_lists, consolidated.key)\n   200→    if merged_relations:\n   201→        store._persistence.save_relations(consolidated.key, merged_relations)\n   202→        with store._lock:\n   203→            store._relations[consolidated.key] = store._persistence.load_relations(consolidated.key)\n   204→\n   205→    now = _utc_now_iso()\n   206→    for key in source_keys:\n   207→        if key != consolidated.key:\n   208→            store.update_fields(\n   209→                key,\n   210→                contradicted=True,\n   211→                contradiction_reason=f\"consolidated into {consolidated.key}\",\n   212→                # EPIC-004: set temporal fields for bi-temporal versioning\n   213→                invalid_at=now,\n   214→                superseded_by=consolidated.key,\n   215→            )\n   216→\n   217→\n   218→def run_periodic_consolidation_scan(\n   219→    store: MemoryStore,\n   220→    project_root: Path,\n   221→    *,\n   222→    threshold: float = 0.7,\n   223→    min_group_size: int = 3,\n   224→    scan_interval_days: int = 7,\n   225→    force: bool = False,\n   226→) -> PeriodicScanResult:\n   227→    \"\"\"Run periodic scan for memory consolidation.\n   228→\n   229→    Called at session start. Checks if enough time has passed since the\n   230→    last scan, finds consolidation groups, and consolidates them.\n   231→\n   232→    Args:\n   233→        store: The memory store to scan.\n   234→        project_root: Project root for state file persistence.\n   235→        threshold: Similarity threshold for grouping.\n   236→        min_group_size: Minimum entries per group to consolidate.\n   237→        scan_interval_days: Minimum days between scans.\n   238→        force: If True, run scan regardless of last scan time.\n   239→\n   240→    Returns:\n   241→        PeriodicScanResult with details of the operation.\n   242→    \"\"\"\n   243→    if not force:\n   244→        last_scan = _get_last_scan_time(project_root)\n   245→        if last_scan is not None:\n   246→            days_since = (datetime.now(tz=UTC) - last_scan).days\n   247→            if days_since < scan_interval_days:\n   248→                return PeriodicScanResult(\n   249→                    scanned=False,\n   250→                    skipped_reason=f\"last_scan_{days_since}_days_ago\",\n   251→                )\n   252→\n   253→    all_entries = store.list_all()\n   254→\n   255→    active_entries = [\n   256→        e for e in all_entries if not getattr(e, \"is_consolidated\", False) and not e.contradicted\n   257→    ]\n   258→\n   259→    if len(active_entries) < min_group_size:\n   260→        _update_last_scan_time(project_root)\n   261→        return PeriodicScanResult(\n   262→            scanned=True,\n   263→            groups_found=0,\n   264→            skipped_reason=\"not_enough_active_entries\",\n   265→        )\n   266→\n   267→    groups = find_consolidation_groups(\n   268→        active_entries,\n   269→        threshold=threshold,\n   270→        min_group_size=min_group_size,\n   271→    )\n   272→\n   273→    if not groups:\n   274→        _update_last_scan_time(project_root)\n   275→        return PeriodicScanResult(\n   276→            scanned=True,\n   277→            groups_found=0,\n   278→        )\n   279→\n   280→    consolidated_keys: list[str] = []\n   281→    total_entries_consolidated = 0\n   282→\n   283→    entry_by_key = {e.key: e for e in active_entries}\n   284→\n   285→    for group_keys in groups:\n   286→        group_entries = [entry_by_key[k] for k in group_keys if k in entry_by_key]\n   287→\n   288→        if len(group_entries) < MIN_CONSOLIDATION_ENTRIES:\n   289→            continue\n   290→\n   291→        reason = detect_consolidation_reason(group_entries[0], group_entries[1:])\n   292→\n   293→        try:\n   294→            consolidated = consolidate(group_entries, reason=reason)\n   295→        except ValueError:\n   296→            continue\n   297→\n   298→        _persist_consolidated_entry(store, consolidated, group_keys)\n   299→        consolidated_keys.append(consolidated.key)"}]},"parent_tool_use_id":"toolu_01ETxuMXE5rZCE6YhLTRE2TH","session_id":"432b4479-d665-4641-add7-8ce0bc4cd0e0","uuid":"541ad9ae-8976-4f8f-a58e-405bc3000ba3","timestamp":"2026-03-22T22:27:16.947Z"}
