{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012MRfRnSikWgDfcjSa3ZfeL","type":"tool_result","content":"     1→\"\"\"Profile-based memory seeding.\n     2→\n     3→Automatically seeds the memory store with facts detected by\n     4→``tapps_project_profile`` on first run. Seeded memories are tagged\n     5→with ``auto-seeded`` and ``source=system``.\n     6→\"\"\"\n     7→\n     8→from __future__ import annotations\n     9→\n    10→from typing import TYPE_CHECKING, Any\n    11→\n    12→import structlog\n    13→\n    14→from tapps_brain.models import MemoryScope, MemorySource, MemoryTier\n    15→\n    16→if TYPE_CHECKING:\n    17→    from tapps_brain._protocols import ProjectProfileLike\n    18→    from tapps_brain.store import MemoryStore\n    19→\n    20→logger = structlog.get_logger(__name__)\n    21→\n    22→# ---------------------------------------------------------------------------\n    23→# Constants\n    24→# ---------------------------------------------------------------------------\n    25→\n    26→_SEEDED_TAG = \"auto-seeded\"\n    27→_SOURCE_AGENT = \"tapps-brain\"\n    28→_SEEDED_FROM = \"project_profile\"\n    29→_DEFAULT_CONFIDENCE = 0.9\n    30→\n    31→\n    32→# ---------------------------------------------------------------------------\n    33→# Seeding logic\n    34→# ---------------------------------------------------------------------------\n    35→\n    36→\n    37→def _make_seed_tags(*extra: str) -> list[str]:\n    38→    \"\"\"Build a tag list that always includes the auto-seeded marker.\"\"\"\n    39→    return [_SEEDED_TAG, *extra]\n    40→\n    41→\n    42→def seed_from_profile(\n    43→    store: MemoryStore,\n    44→    profile: ProjectProfileLike,\n    45→) -> dict[str, Any]:\n    46→    \"\"\"Seed memory store with facts from a project profile.\n    47→\n    48→    Only seeds if the store is empty (first run). To re-seed, use\n    49→    :func:`reseed_from_profile` which updates only ``auto-seeded`` entries.\n    50→\n    51→    Args:\n    52→        store: The memory store to seed.\n    53→        profile: Detected project profile.\n    54→\n    55→    Returns:\n    56→        Summary dict with ``seeded_count``, ``skipped`` (bool, if non-empty).\n    57→    \"\"\"\n    58→    if store.count() > 0:\n    59→        logger.info(\"memory_seed_skipped\", reason=\"store not empty\")\n    60→        return {\"seeded_count\": 0, \"skipped\": True}\n    61→\n    62→    return _do_seed(store, profile)\n    63→\n    64→\n    65→def reseed_from_profile(\n    66→    store: MemoryStore,\n    67→    profile: ProjectProfileLike,\n    68→) -> dict[str, Any]:\n    69→    \"\"\"Re-seed memory store, updating only auto-seeded entries.\n    70→\n    71→    Never overwrites human/agent-created memories. Only updates\n    72→    entries tagged with ``auto-seeded``.\n    73→\n    74→    Args:\n    75→        store: The memory store to reseed.\n    76→        profile: Detected project profile.\n    77→\n    78→    Returns:\n    79→        Summary dict with ``seeded_count``, ``updated_count``.\n    80→    \"\"\"\n    81→    # Delete existing auto-seeded memories\n    82→    existing = store.list_all(tags=[_SEEDED_TAG])\n    83→    deleted = 0\n    84→    for entry in existing:\n    85→        if _SEEDED_TAG in entry.tags:\n    86→            store.delete(entry.key)\n    87→            deleted += 1\n    88→\n    89→    result = _do_seed(store, profile)\n    90→    result[\"deleted_old\"] = deleted\n    91→    return result\n    92→\n    93→\n    94→def _do_seed(\n    95→    store: MemoryStore,\n    96→    profile: ProjectProfileLike,\n    97→) -> dict[str, Any]:\n    98→    \"\"\"Internal: create seed memories from profile data.\"\"\"\n    99→    seeded = 0\n   100→"}]},"parent_tool_use_id":"toolu_01ETxuMXE5rZCE6YhLTRE2TH","session_id":"432b4479-d665-4641-add7-8ce0bc4cd0e0","uuid":"a744664e-d097-4137-b78d-931ce3584b72","timestamp":"2026-03-22T22:26:49.646Z"}
