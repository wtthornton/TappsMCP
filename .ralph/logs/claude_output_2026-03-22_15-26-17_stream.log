{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011hcmy6PifdGfGEJdgc9D66","type":"tool_result","content":"     1→\"\"\"Concurrency stress tests for MemoryStore — 016-C and 016-D.\n     2→\n     3→Tests cover (016-C):\n     4→- 10 threads saving 50 entries each → all 500 persisted, no corruption\n     5→- 5 threads saving while 5 threads recalling → no exceptions\n     6→- Concurrent save at max capacity (500) → eviction correct under contention\n     7→\n     8→Tests cover (016-D):\n     9→- GC running while saves happen → no exceptions, archive consistent\n    10→- Multiple agents propagating to HiveStore concurrently → all entries arrive\n    11→- Concurrent recall from Hive during propagation → no exceptions\n    12→\n    13→All tests use a 30-second timeout via pytest-timeout or threading.Event.\n    14→\"\"\"\n    15→\n    16→from __future__ import annotations\n    17→\n    18→import threading\n    19→import time\n    20→from typing import TYPE_CHECKING\n    21→\n    22→import pytest\n    23→\n    24→if TYPE_CHECKING:\n    25→    from pathlib import Path\n    26→\n    27→from tapps_brain.hive import HiveStore\n    28→from tapps_brain.store import MemoryStore\n    29→\n    30→\n    31→@pytest.fixture()\n    32→def store(tmp_path: Path) -> MemoryStore:\n    33→    s = MemoryStore(tmp_path)\n    34→    yield s\n    35→    s.close()\n    36→\n    37→\n    38→class TestConcurrentSave:\n    39→    \"\"\"10 threads each saving 50 unique entries → all 500 entries persisted.\"\"\"\n    40→\n    41→    def test_concurrent_save_all_persisted(self, store: MemoryStore) -> None:\n    42→        num_threads = 10\n    43→        entries_per_thread = 50\n    44→        errors: list[Exception] = []\n    45→\n    46→        def saver(thread_id: int) -> None:\n    47→            try:\n    48→                for i in range(entries_per_thread):\n    49→                    key = f\"thread-{thread_id}-entry-{i}\"\n    50→                    store.save(\n    51→                        key=key,\n    52→                        value=f\"value from thread {thread_id} entry {i}\",\n    53→                        tier=\"context\",\n    54→                    )\n    55→            except Exception as exc:\n    56→                errors.append(exc)\n    57→\n    58→        threads = [threading.Thread(target=saver, args=(t,)) for t in range(num_threads)]\n    59→        start = time.monotonic()\n    60→        for t in threads:\n    61→            t.start()\n    62→        for t in threads:\n    63→            t.join(timeout=30)\n    64→\n    65→        elapsed = time.monotonic() - start\n    66→        assert elapsed < 30, f\"Concurrent save test timed out after {elapsed:.1f}s\"\n    67→        assert not errors, f\"Threads raised exceptions: {errors}\"\n    68→\n    69→        # All 500 entries must be present (store enforces max 500)\n    70→        count = store.count()\n    71→        assert count == num_threads * entries_per_thread\n    72→\n    73→    def test_concurrent_save_no_data_corruption(self, store: MemoryStore) -> None:\n    74→        \"\"\"Values written by threads must be readable without corruption.\"\"\"\n    75→        num_threads = 5\n    76→        entries_per_thread = 20\n    77→        errors: list[Exception] = []\n    78→\n    79→        def saver(thread_id: int) -> None:\n    80→            try:\n    81→                for i in range(entries_per_thread):\n    82→                    key = f\"corruption-thread-{thread_id}-{i}\"\n    83→                    val = f\"thread={thread_id} i={i}\"\n    84→                    store.save(key=key, value=val, tier=\"context\")\n    85→            except Exception as exc:\n    86→                errors.append(exc)\n    87→\n    88→        threads = [threading.Thread(target=saver, args=(t,)) for t in range(num_threads)]\n    89→        for t in threads:\n    90→            t.start()\n    91→        for t in threads:\n    92→            t.join(timeout=30)\n    93→\n    94→        assert not errors, f\"Threads raised exceptions: {errors}\"\n    95→\n    96→        # Spot-check: all keys should be retrievable with correct values\n    97→        for thread_id in range(num_threads):\n    98→            for i in range(entries_per_thread):\n    99→                key = f\"corruption-thread-{thread_id}-{i}\"\n   100→                entry = store.get(key)\n   101→                assert entry is not None, f\"Missing entry for {key}\"\n   102→                assert f\"thread={thread_id}\" in entry.value, (\n   103→                    f\"Value corrupted for {key}: {entry.value!r}\"\n   104→                )\n   105→\n   106→\n   107→class TestConcurrentSaveAndRecall:\n   108→    \"\"\"5 threads saving while 5 threads recalling — no exceptions.\"\"\"\n   109→\n   110→    def test_concurrent_save_and_recall(self, store: MemoryStore) -> None:\n   111→        # Pre-populate a few entries so recall has something to return\n   112→        for i in range(10):\n   113→            store.save(key=f\"seed-{i}\", value=f\"seed value {i}\", tier=\"pattern\")\n   114→\n   115→        errors: list[Exception] = []\n   116→        stop_event = threading.Event()\n   117→\n   118→        def saver(thread_id: int) -> None:\n   119→            try:\n   120→                idx = 0\n   121→                while not stop_event.is_set():\n   122→                    key = f\"concurrent-save-{thread_id}-{idx}\"\n   123→                    store.save(key=key, value=f\"value {idx}\", tier=\"context\")\n   124→                    idx += 1\n   125→            except Exception as exc:\n   126→                errors.append(exc)\n   127→\n   128→        def recaller(thread_id: int) -> None:\n   129→            try:\n   130→                while not stop_event.is_set():\n   131→                    store.search(\"seed value\")\n   132→                    time.sleep(0.005)\n   133→            except Exception as exc:\n   134→                errors.append(exc)\n   135→\n   136→        save_threads = [threading.Thread(target=saver, args=(t,)) for t in range(5)]\n   137→        recall_threads = [threading.Thread(target=recaller, args=(t,)) for t in range(5)]\n   138→        all_threads = save_threads + recall_threads\n   139→\n   140→        for t in all_threads:\n   141→            t.start()\n   142→\n   143→        # Let threads run for 2 seconds then stop\n   144→        time.sleep(2)\n   145→        stop_event.set()\n   146→\n   147→        for t in all_threads:\n   148→            t.join(timeout=30)\n   149→\n   150→        assert not errors, f\"Threads raised exceptions: {errors}\"\n   151→\n   152→\n   153→class TestConcurrentSaveAtCapacity:\n   154→    \"\"\"Concurrent saves at max capacity (500) — eviction correct under contention.\"\"\"\n   155→\n   156→    def test_concurrent_save_at_max_capacity(self, tmp_path: Path) -> None:\n   157→        \"\"\"Saving beyond 500 entries concurrently never leaves store in corrupt state.\"\"\"\n   158→        s = MemoryStore(tmp_path)\n   159→        try:\n   160→            # Pre-fill to 490 entries\n   161→            for i in range(490):\n   162→                s.save(key=f\"pre-{i}\", value=f\"pre-value {i}\", tier=\"context\")\n   163→\n   164→            assert s.count() == 490\n   165→\n   166→            errors: list[Exception] = []\n   167→\n   168→            def saver(thread_id: int) -> None:\n   169→                try:\n   170→                    for i in range(20):\n   171→                        key = f\"cap-thread-{thread_id}-{i}\"\n   172→                        s.save(key=key, value=f\"overflow value {i}\", tier=\"context\")\n   173→                except Exception as exc:\n   174→                    errors.append(exc)\n   175→\n   176→            threads = [threading.Thread(target=saver, args=(t,)) for t in range(5)]\n   177→            for t in threads:\n   178→                t.start()\n   179→            for t in threads:\n   180→                t.join(timeout=30)\n   181→\n   182→            assert not errors, f\"Threads raised exceptions: {errors}\"\n   183→\n   184→            # Store must not exceed 500 entries\n   185→            count = s.count()\n   186→            assert count <= 500, f\"Store exceeded max capacity: {count}\"\n   187→            assert count > 0, \"Store must not be empty after concurrent saves\"\n   188→        finally:\n   189→            s.close()\n   190→\n   191→\n   192→class TestConcurrentGCAndSaves:\n   193→    \"\"\"GC running while saves happen — no exceptions, archive consistent.\"\"\"\n   194→\n   195→    def test_gc_concurrent_with_saves(self, tmp_path: Path) -> None:\n   196→        \"\"\"GC and saves running in parallel must not corrupt the store.\"\"\"\n   197→        s = MemoryStore(tmp_path)\n   198→        try:\n   199→            # Pre-populate 10 stale entries (contradicted + very low confidence)\n   200→            for i in range(10):\n   201→                s.save(key=f\"stale-{i}\", value=f\"stale value {i}\", tier=\"context\")\n   202→                # Mark as contradicted with floor confidence so GC archives them\n   203→                entry = s.get(f\"stale-{i}\")\n   204→                if entry is not None:\n   205→                    entry.contradicted = True\n   206→                    entry.confidence = 0.05  # well below 0.2 threshold\n   207→\n   208→            errors: list[Exception] = []\n   209→            stop_event = threading.Event()\n   210→\n   211→            def saver(thread_id: int) -> None:\n   212→                idx = 0\n   213→                try:\n   214→                    while not stop_event.is_set():\n   215→                        key = f\"gc-save-{thread_id}-{idx}\"\n   216→                        s.save(key=key, value=f\"fresh value {idx}\", tier=\"pattern\")\n   217→                        idx += 1\n   218→                        time.sleep(0.002)\n   219→                except Exception as exc:\n   220→                    errors.append(exc)\n   221→\n   222→            def gc_runner() -> None:\n   223→                try:\n   224→                    while not stop_event.is_set():\n   225→                        s.gc(dry_run=False)\n   226→                        time.sleep(0.01)\n   227→                except Exception as exc:\n   228→                    errors.append(exc)\n   229→\n   230→            save_threads = [threading.Thread(target=saver, args=(t,)) for t in range(3)]\n   231→            gc_thread = threading.Thread(target=gc_runner)\n   232→\n   233→            all_threads = [*save_threads, gc_thread]\n   234→            for t in all_threads:\n   235→                t.start()\n   236→\n   237→            # Run for 2 seconds\n   238→            time.sleep(2)\n   239→            stop_event.set()\n   240→\n   241→            start_join = time.monotonic()\n   242→            for t in all_threads:\n   243→                t.join(timeout=30)\n   244→            elapsed = time.monotonic() - start_join\n   245→\n   246→            assert elapsed < 30, f\"GC concurrent test join timed out after {elapsed:.1f}s\"\n   247→            assert not errors, f\"Threads raised exceptions: {errors}\"\n   248→\n   249→            # Store integrity: count must be non-negative and within bounds\n   250→            count = s.count()\n   251→            assert 0 <= count <= 500, f\"Store count out of range: {count}\"\n   252→        finally:\n   253→            s.close()\n   254→\n   255→    def test_gc_archive_consistent_under_contention(self, tmp_path: Path) -> None:\n   256→        \"\"\"Entries archived by GC must not remain in the live store.\"\"\"\n   257→        s = MemoryStore(tmp_path)\n   258→        try:\n   259→            # Save 5 entries and mark as stale (contradicted + floor confidence)\n   260→            stale_keys = [f\"archive-stale-{i}\" for i in range(5)]\n   261→            for key in stale_keys:\n   262→                s.save(key=key, value=\"old data\", tier=\"context\")\n   263→                entry = s.get(key)\n   264→                if entry is not None:\n   265→                    entry.contradicted = True\n   266→                    entry.confidence = 0.05\n   267→\n   268→            errors: list[Exception] = []\n   269→\n   270→            def saver(thread_id: int) -> None:\n   271→                try:\n   272→                    for i in range(10):\n   273→                        s.save(\n   274→                            key=f\"archive-new-{thread_id}-{i}\",\n   275→                            value=f\"new value {i}\",\n   276→                            tier=\"pattern\",\n   277→                        )\n   278→                except Exception as exc:\n   279→                    errors.append(exc)\n   280→\n   281→            # Launch saves and GC simultaneously\n   282→            save_threads = [threading.Thread(target=saver, args=(t,)) for t in range(3)]\n   283→            gc_thread = threading.Thread(target=lambda: s.gc(dry_run=False))\n   284→\n   285→            all_threads = [*save_threads, gc_thread]\n   286→            for t in all_threads:\n   287→                t.start()\n   288→            for t in all_threads:\n   289→                t.join(timeout=30)\n   290→\n   291→            assert not errors, f\"Threads raised exceptions: {errors}\"\n   292→\n   293→            # Any stale key that was archived must not appear in the live store\n   294→            live_keys = {e.key for e in s.list_all()}\n   295→            for key in stale_keys:\n   296→                # If GC ran and found it stale, it should have been removed\n   297→                entry = s.get(key)\n   298→                if entry is not None:\n   299→                    # If still present it means it was re-saved or GC lost the race — OK\n   300→                    assert key in live_keys\n   301→        finally:\n   302→            s.close()\n   303→\n   304→\n   305→@pytest.fixture()\n   306→def hive_store(tmp_path: Path) -> HiveStore:  # type: ignore[misc]\n   307→    \"\"\"Isolated HiveStore backed by a temp SQLite file.\"\"\"\n   308→    hs = HiveStore(db_path=tmp_path / \"hive.db\")\n   309→    yield hs\n   310→    hs.close()\n   311→\n   312→\n   313→class TestConcurrentHivePropagation:\n   314→    \"\"\"Multiple agents propagating to HiveStore concurrently — all entries arrive.\"\"\"\n   315→\n   316→    def test_concurrent_hive_saves_all_arrive(self, hive_store: HiveStore) -> None:\n   317→        \"\"\"5 agents each saving 20 unique entries → all 100 entries in HiveStore.\"\"\"\n   318→        num_agents = 5\n   319→        entries_per_agent = 20\n   320→        errors: list[Exception] = []\n   321→\n   322→        def propagate(agent_id: int) -> None:\n   323→            try:\n   324→                for i in range(entries_per_agent):\n   325→                    hive_store.save(\n   326→                        key=f\"agent-{agent_id}-entry-{i}\",\n   327→                        value=f\"from agent {agent_id}, item {i}\",\n   328→                        namespace=\"universal\",\n   329→                        source_agent=f\"agent-{agent_id}\",\n   330→                        tier=\"pattern\",\n   331→                        conflict_policy=\"last_write_wins\",\n   332→                    )\n   333→            except Exception as exc:\n   334→                errors.append(exc)\n   335→\n   336→        threads = [threading.Thread(target=propagate, args=(a,)) for a in range(num_agents)]\n   337→        start = time.monotonic()\n   338→        for t in threads:\n   339→            t.start()\n   340→        for t in threads:\n   341→            t.join(timeout=30)\n   342→        elapsed = time.monotonic() - start\n   343→\n   344→        assert elapsed < 30, f\"Concurrent Hive save timed out after {elapsed:.1f}s\"\n   345→        assert not errors, f\"Threads raised exceptions: {errors}\"\n   346→\n   347→        # All unique keys must be present\n   348→        results = hive_store.search(\"agent\", namespaces=[\"universal\"], limit=200)\n   349→        saved_keys = {r[\"key\"] for r in results}\n   350→        expected_count = num_agents * entries_per_agent\n   351→        assert len(saved_keys) == expected_count, (\n   352→            f\"Expected {expected_count} entries, found {len(saved_keys)}\"\n   353→        )\n   354→\n   355→    def test_concurrent_hive_multi_namespace(self, hive_store: HiveStore) -> None:\n   356→        \"\"\"Agents writing to different namespaces should not collide.\"\"\"\n   357→        namespaces = [\"domain-a\", \"domain-b\", \"domain-c\"]\n   358→        entries_per_ns = 10\n   359→        errors: list[Exception] = []\n   360→\n   361→        def ns_writer(ns: str) -> None:\n   362→            try:\n   363→                for i in range(entries_per_ns):\n   364→                    hive_store.save(\n   365→                        key=f\"ns-entry-{i}\",\n   366→                        value=f\"value for {ns} item {i}\",\n   367→                        namespace=ns,\n   368→                        source_agent=f\"agent-{ns}\",\n   369→                        tier=\"pattern\",\n   370→                        conflict_policy=\"last_write_wins\",\n   371→                    )\n   372→            except Exception as exc:\n   373→                errors.append(exc)\n   374→\n   375→        threads = [threading.Thread(target=ns_writer, args=(ns,)) for ns in namespaces]\n   376→        for t in threads:\n   377→            t.start()\n   378→        for t in threads:\n   379→            t.join(timeout=30)\n   380→\n   381→        assert not errors, f\"Threads raised exceptions: {errors}\"\n   382→\n   383→        # Each namespace should have exactly entries_per_ns entries\n   384→        for ns in namespaces:\n   385→            results = hive_store.search(\"value for\", namespaces=[ns], limit=50)\n   386→            assert len(results) == entries_per_ns, (\n   387→                f\"Namespace {ns!r}: expected {entries_per_ns}, got {len(results)}\"\n   388→            )\n   389→\n   390→\n   391→class TestConcurrentHiveRecallDuringPropagation:\n   392→    \"\"\"Concurrent recall from Hive during propagation — no exceptions.\"\"\"\n   393→\n   394→    def test_recall_during_propagation(self, hive_store: HiveStore) -> None:\n   395→        \"\"\"Searches must not raise even when concurrent saves are in progress.\"\"\"\n   396→        # Seed with some entries so searches return results from the start\n   397→        for i in range(20):\n   398→            hive_store.save(\n   399→                key=f\"seed-{i}\",\n   400→                value=f\"seed content item {i}\",\n   401→                namespace=\"universal\",\n   402→                source_agent=\"seeder\",\n   403→                conflict_policy=\"last_write_wins\",\n   404→            )\n   405→\n   406→        errors: list[Exception] = []\n   407→        stop_event = threading.Event()\n   408→\n   409→        def writer(thread_id: int) -> None:\n   410→            idx = 0\n   411→            try:\n   412→                while not stop_event.is_set():\n   413→                    hive_store.save(\n   414→                        key=f\"live-{thread_id}-{idx}\",\n   415→                        value=f\"live content from {thread_id} idx {idx}\",\n   416→                        namespace=\"universal\",\n   417→                        source_agent=f\"writer-{thread_id}\",\n   418→                        conflict_policy=\"last_write_wins\",\n   419→                    )\n   420→                    idx += 1\n   421→                    time.sleep(0.003)\n   422→            except Exception as exc:\n   423→                errors.append(exc)\n   424→\n   425→        def reader(thread_id: int) -> None:\n   426→            try:\n   427→                while not stop_event.is_set():\n   428→                    hive_store.search(\"content\", namespaces=[\"universal\"], limit=20)\n   429→                    time.sleep(0.005)\n   430→            except Exception as exc:\n   431→                errors.append(exc)\n   432→\n   433→        write_threads = [threading.Thread(target=writer, args=(t,)) for t in range(3)]\n   434→        read_threads = [threading.Thread(target=reader, args=(t,)) for t in range(3)]\n   435→        all_threads = write_threads + read_threads\n   436→\n   437→        for t in all_threads:\n   438→            t.start()\n   439→\n   440→        time.sleep(2)\n   441→        stop_event.set()\n   442→\n   443→        for t in all_threads:\n   444→            t.join(timeout=30)\n   445→\n   446→        assert not errors, f\"Threads raised exceptions: {errors}\"\n   447→"}]},"parent_tool_use_id":"toolu_01ETxuMXE5rZCE6YhLTRE2TH","session_id":"432b4479-d665-4641-add7-8ce0bc4cd0e0","uuid":"cfd9e500-47ee-4240-bd06-9d61a17a14de","timestamp":"2026-03-22T22:27:26.719Z"}
