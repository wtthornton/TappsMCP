{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016qbSUsA7Vd5dntQs4D4RN1","type":"tool_result","content":"     1→\"\"\"Profile-based memory seeding.\n     2→\n     3→Automatically seeds the memory store with facts detected by\n     4→``tapps_project_profile`` on first run. Seeded memories are tagged\n     5→with ``auto-seeded`` and ``source=system``.\n     6→\"\"\"\n     7→\n     8→from __future__ import annotations\n     9→\n    10→from typing import TYPE_CHECKING, Any\n    11→\n    12→import structlog\n    13→\n    14→from tapps_brain.models import MemoryScope, MemorySource, MemoryTier\n    15→\n    16→if TYPE_CHECKING:\n    17→    from tapps_brain._protocols import ProjectProfileLike\n    18→    from tapps_brain.store import MemoryStore\n    19→\n    20→logger = structlog.get_logger(__name__)\n    21→\n    22→# ---------------------------------------------------------------------------\n    23→# Constants\n    24→# ---------------------------------------------------------------------------\n    25→\n    26→_SEEDED_TAG = \"auto-seeded\"\n    27→_SOURCE_AGENT = \"tapps-brain\"\n    28→_SEEDED_FROM = \"project_profile\"\n    29→_DEFAULT_CONFIDENCE = 0.9\n    30→\n    31→\n    32→# ---------------------------------------------------------------------------\n    33→# Seeding logic\n    34→# ---------------------------------------------------------------------------\n    35→\n    36→\n    37→def _make_seed_tags(*extra: str) -> list[str]:\n    38→    \"\"\"Build a tag list that always includes the auto-seeded marker.\"\"\"\n    39→    return [_SEEDED_TAG, *extra]\n    40→\n    41→\n    42→def seed_from_profile(\n    43→    store: MemoryStore,\n    44→    profile: ProjectProfileLike,\n    45→) -> dict[str, Any]:\n    46→    \"\"\"Seed memory store with facts from a project profile.\n    47→\n    48→    Only seeds if the store is empty (first run). To re-seed, use\n    49→    :func:`reseed_from_profile` which updates only ``auto-seeded`` entries.\n    50→\n    51→    Args:\n    52→        store: The memory store to seed.\n    53→        profile: Detected project profile.\n    54→\n    55→    Returns:\n    56→        Summary dict with ``seeded_count``, ``skipped`` (bool, if non-empty).\n    57→    \"\"\"\n    58→    if store.count() > 0:\n    59→        logger.info(\"memory_seed_skipped\", reason=\"store not empty\")\n    60→        return {\"seeded_count\": 0, \"skipped\": True}\n    61→\n    62→    return _do_seed(store, profile)\n    63→\n    64→\n    65→def reseed_from_profile(\n    66→    store: MemoryStore,\n    67→    profile: ProjectProfileLike,\n    68→) -> dict[str, Any]:\n    69→    \"\"\"Re-seed memory store, updating only auto-seeded entries.\n    70→\n    71→    Never overwrites human/agent-created memories. Only updates\n    72→    entries tagged with ``auto-seeded``.\n    73→\n    74→    Args:\n    75→        store: The memory store to reseed.\n    76→        profile: Detected project profile.\n    77→\n    78→    Returns:\n    79→        Summary dict with ``seeded_count``, ``updated_count``.\n    80→    \"\"\"\n    81→    # Delete existing auto-seeded memories\n    82→    existing = store.list_all(tags=[_SEEDED_TAG])\n    83→    deleted = 0\n    84→    for entry in existing:\n    85→        if _SEEDED_TAG in entry.tags:\n    86→            store.delete(entry.key)\n    87→            deleted += 1\n    88→\n    89→    result = _do_seed(store, profile)\n    90→    result[\"deleted_old\"] = deleted\n    91→    return result\n    92→\n    93→\n    94→def _do_seed(\n    95→    store: MemoryStore,\n    96→    profile: ProjectProfileLike,\n    97→) -> dict[str, Any]:\n    98→    \"\"\"Internal: create seed memories from profile data.\"\"\"\n    99→    seeded = 0\n   100→\n   101→    # Project type\n   102→    if profile.project_type:\n   103→        confidence = max(_DEFAULT_CONFIDENCE, profile.project_type_confidence)\n   104→        store.save(\n   105→            key=\"project-type\",\n   106→            value=f\"Project type is {profile.project_type}\",\n   107→            tier=MemoryTier.architectural.value,\n   108→            source=MemorySource.system.value,\n   109→            source_agent=_SOURCE_AGENT,\n   110→            scope=MemoryScope.project.value,\n   111→            tags=_make_seed_tags(\"project-type\"),\n   112→            confidence=confidence,\n   113→        )\n   114→        _set_seeded_from(store, \"project-type\")\n   115→        seeded += 1\n   116→\n   117→    # Languages\n   118→    for lang in profile.tech_stack.languages:\n   119→        key = f\"language-{_slugify(lang)}\"\n   120→        store.save(\n   121→            key=key,\n   122→            value=f\"Project uses {lang}\",\n   123→            tier=MemoryTier.architectural.value,\n   124→            source=MemorySource.system.value,\n   125→            source_agent=_SOURCE_AGENT,\n   126→            scope=MemoryScope.project.value,\n   127→            tags=_make_seed_tags(\"language\"),\n   128→            confidence=_DEFAULT_CONFIDENCE,\n   129→        )\n   130→        _set_seeded_from(store, key)\n   131→        seeded += 1\n   132→\n   133→    # Frameworks\n   134→    for fw in profile.tech_stack.frameworks:\n   135→        key = f\"framework-{_slugify(fw)}\"\n   136→        store.save(\n   137→            key=key,\n   138→            value=f\"Project uses {fw} framework\",\n   139→            tier=MemoryTier.architectural.value,\n   140→            source=MemorySource.system.value,\n   141→            source_agent=_SOURCE_AGENT,\n   142→            scope=MemoryScope.project.value,\n   143→            tags=_make_seed_tags(\"framework\"),\n   144→            confidence=_DEFAULT_CONFIDENCE,\n   145→        )\n   146→        _set_seeded_from(store, key)\n   147→        seeded += 1\n   148→\n   149→    # Test frameworks\n   150→    for tf in profile.test_frameworks:\n   151→        key = f\"test-framework-{_slugify(tf)}\"\n   152→        store.save(\n   153→            key=key,\n   154→            value=f\"Project uses {tf} for testing\",\n   155→            tier=MemoryTier.pattern.value,\n   156→            source=MemorySource.system.value,\n   157→            source_agent=_SOURCE_AGENT,\n   158→            scope=MemoryScope.project.value,\n   159→            tags=_make_seed_tags(\"test-framework\"),\n   160→            confidence=_DEFAULT_CONFIDENCE,\n   161→        )\n   162→        _set_seeded_from(store, key)\n   163→        seeded += 1\n   164→\n   165→    # Package managers\n   166→    for pm in profile.package_managers:\n   167→        key = f\"package-manager-{_slugify(pm)}\"\n   168→        store.save(\n   169→            key=key,\n   170→            value=f\"Package manager is {pm}\",\n   171→            tier=MemoryTier.pattern.value,\n   172→            source=MemorySource.system.value,\n   173→            source_agent=_SOURCE_AGENT,\n   174→            scope=MemoryScope.project.value,\n   175→            tags=_make_seed_tags(\"package-manager\"),\n   176→            confidence=_DEFAULT_CONFIDENCE,\n   177→        )\n   178→        _set_seeded_from(store, key)\n   179→        seeded += 1\n   180→\n   181→    # CI systems\n   182→    for ci in profile.ci_systems:\n   183→        key = f\"ci-system-{_slugify(ci)}\"\n   184→        store.save(\n   185→            key=key,\n   186→            value=f\"Project uses {ci} for CI/CD\",\n   187→            tier=MemoryTier.architectural.value,\n   188→            source=MemorySource.system.value,\n   189→            source_agent=_SOURCE_AGENT,\n   190→            scope=MemoryScope.project.value,\n   191→            tags=_make_seed_tags(\"ci-system\"),\n   192→            confidence=_DEFAULT_CONFIDENCE,\n   193→        )\n   194→        _set_seeded_from(store, key)\n   195→        seeded += 1\n   196→\n   197→    # Docker\n   198→    if profile.has_docker:\n   199→        store.save(\n   200→            key=\"has-docker\",\n   201→            value=\"Project uses Docker\",\n   202→            tier=MemoryTier.architectural.value,\n   203→            source=MemorySource.system.value,\n   204→            source_agent=_SOURCE_AGENT,\n   205→            scope=MemoryScope.project.value,\n   206→            tags=_make_seed_tags(\"docker\"),\n   207→            confidence=_DEFAULT_CONFIDENCE,\n   208→        )\n   209→        _set_seeded_from(store, \"has-docker\")\n   210→        seeded += 1\n   211→\n   212→    logger.info(\"memory_seeded\", count=seeded)\n   213→    return {\"seeded_count\": seeded, \"skipped\": False}\n   214→\n   215→\n   216→# ---------------------------------------------------------------------------\n   217→# Helpers\n   218→# ---------------------------------------------------------------------------\n   219→\n   220→\n   221→def _slugify(text: str) -> str:\n   222→    \"\"\"Convert text to a simple slug for use as a memory key suffix.\"\"\"\n   223→    return text.lower().replace(\" \", \"-\").replace(\"_\", \"-\")\n   224→\n   225→\n   226→def _set_seeded_from(store: MemoryStore, key: str) -> None:\n   227→    \"\"\"Set the ``seeded_from`` field on a freshly seeded memory.\"\"\"\n   228→    store.update_fields(key, seeded_from=_SEEDED_FROM)\n   229→"}]},"parent_tool_use_id":null,"session_id":"432b4479-d665-4641-add7-8ce0bc4cd0e0","uuid":"f76dae09-76f7-403c-8a26-c5a6cf1f9d18","timestamp":"2026-03-22T22:28:01.911Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\cursor\\tapps-brain\\src\\tapps_brain\\seeding.py","content":"\"\"\"Profile-based memory seeding.\n\nAutomatically seeds the memory store with facts detected by\n``tapps_project_profile`` on first run. Seeded memories are tagged\nwith ``auto-seeded`` and ``source=system``.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom typing import TYPE_CHECKING, Any\n\nimport structlog\n\nfrom tapps_brain.models import MemoryScope, MemorySource, MemoryTier\n\nif TYPE_CHECKING:\n    from tapps_brain._protocols import ProjectProfileLike\n    from tapps_brain.store import MemoryStore\n\nlogger = structlog.get_logger(__name__)\n\n# ---------------------------------------------------------------------------\n# Constants\n# ---------------------------------------------------------------------------\n\n_SEEDED_TAG = \"auto-seeded\"\n_SOURCE_AGENT = \"tapps-brain\"\n_SEEDED_FROM = \"project_profile\"\n_DEFAULT_CONFIDENCE = 0.9\n\n\n# ---------------------------------------------------------------------------\n# Seeding logic\n# ---------------------------------------------------------------------------\n\n\ndef _make_seed_tags(*extra: str) -> list[str]:\n    \"\"\"Build a tag list that always includes the auto-seeded marker.\"\"\"\n    return [_SEEDED_TAG, *extra]\n\n\ndef seed_from_profile(\n    store: MemoryStore,\n    profile: ProjectProfileLike,\n) -> dict[str, Any]:\n    \"\"\"Seed memory store with facts from a project profile.\n\n    Only seeds if the store is empty (first run). To re-seed, use\n    :func:`reseed_from_profile` which updates only ``auto-seeded`` entries.\n\n    Args:\n        store: The memory store to seed.\n        profile: Detected project profile.\n\n    Returns:\n        Summary dict with ``seeded_count``, ``skipped`` (bool, if non-empty).\n    \"\"\"\n    if store.count() > 0:\n        logger.info(\"memory_seed_skipped\", reason=\"store not empty\")\n        return {\"seeded_count\": 0, \"skipped\": True}\n\n    return _do_seed(store, profile)\n\n\ndef reseed_from_profile(\n    store: MemoryStore,\n    profile: ProjectProfileLike,\n) -> dict[str, Any]:\n    \"\"\"Re-seed memory store, updating only auto-seeded entries.\n\n    Never overwrites human/agent-created memories. Only updates\n    entries tagged with ``auto-seeded``.\n\n    Args:\n        store: The memory store to reseed.\n        profile: Detected project profile.\n\n    Returns:\n        Summary dict with ``seeded_count``, ``updated_count``.\n    \"\"\"\n    # Delete existing auto-seeded memories\n    existing = store.list_all(tags=[_SEEDED_TAG])\n    deleted = 0\n    for entry in existing:\n        if _SEEDED_TAG in entry.tags:\n            store.delete(entry.key)\n            deleted += 1\n\n    result = _do_seed(store, profile)\n    result[\"deleted_old\"] = deleted\n    return result\n\n\ndef _do_seed(\n    store: MemoryStore,\n    profile: ProjectProfileLike,\n) -> dict[str, Any]:\n    \"\"\"Internal: create seed memories from profile data.\"\"\"\n    seeded = 0\n\n    # Project type\n    if profile.project_type:\n        confidence = max(_DEFAULT_CONFIDENCE, profile.project_type_confidence)\n        store.save(\n            key=\"project-type\",\n            value=f\"Project type is {profile.project_type}\",\n            tier=MemoryTier.architectural.value,\n            source=MemorySource.system.value,\n            source_agent=_SOURCE_AGENT,\n            scope=MemoryScope.project.value,\n            tags=_make_seed_tags(\"project-type\"),\n            confidence=confidence,\n        )\n        _set_seeded_from(store, \"project-type\")\n        seeded += 1\n\n    # Languages\n    for lang in profile.tech_stack.languages:\n        key = f\"language-{_slugify(lang)}\"\n        store.save(\n            key=key,\n            value=f\"Project uses {lang}\",\n            tier=MemoryTier.architectural.value,\n            source=MemorySource.system.value,\n            source_agent=_SOURCE_AGENT,\n            scope=MemoryScope.project.value,\n            tags=_make_seed_tags(\"language\"),\n            confidence=_DEFAULT_CONFIDENCE,\n        )\n        _set_seeded_from(store, key)\n        seeded += 1\n\n    # Frameworks\n    for fw in profile.tech_stack.frameworks:\n        key = f\"framework-{_slugify(fw)}\"\n        store.save(\n            key=key,\n            value=f\"Project uses {fw} framework\",\n            tier=MemoryTier.architectural.value,\n            source=MemorySource.system.value,\n            source_agent=_SOURCE_AGENT,\n            scope=MemoryScope.project.value,\n            tags=_make_seed_tags(\"framework\"),\n            confidence=_DEFAULT_CONFIDENCE,\n        )\n        _set_seeded_from(store, key)\n        seeded += 1\n\n    # Test frameworks\n    for tf in profile.test_frameworks:\n        key = f\"test-framework-{_slugify(tf)}\"\n        store.save(\n            key=key,\n            value=f\"Project uses {tf} for testing\",\n            tier=MemoryTier.pattern.value,\n            source=MemorySource.system.value,\n            source_agent=_SOURCE_AGENT,\n            scope=MemoryScope.project.value,\n            tags=_make_seed_tags(\"test-framework\"),\n            confidence=_DEFAULT_CONFIDENCE,\n        )\n        _set_seeded_from(store, key)\n        seeded += 1\n\n    # Package managers\n    for pm in profile.package_managers:\n        key = f\"package-manager-{_slugify(pm)}\"\n        store.save(\n            key=key,\n            value=f\"Package manager is {pm}\",\n            tier=MemoryTier.pattern.value,\n            source=MemorySource.system.value,\n            source_agent=_SOURCE_AGENT,\n            scope=MemoryScope.project.value,\n            tags=_make_seed_tags(\"package-manager\"),\n            confidence=_DEFAULT_CONFIDENCE,\n        )\n        _set_seeded_from(store, key)\n        seeded += 1\n\n    # CI systems\n    for ci in profile.ci_systems:\n        key = f\"ci-system-{_slugify(ci)}\"\n        store.save(\n            key=key,\n            value=f\"Project uses {ci} for CI/CD\",\n            tier=MemoryTier.architectural.value,\n            source=MemorySource.system.value,\n            source_agent=_SOURCE_AGENT,\n            scope=MemoryScope.project.value,\n            tags=_make_seed_tags(\"ci-system\"),\n            confidence=_DEFAULT_CONFIDENCE,\n        )\n        _set_seeded_from(store, key)\n        seeded += 1\n\n    # Docker\n    if profile.has_docker:\n        store.save(\n            key=\"has-docker\",\n            value=\"Project uses Docker\",\n            tier=MemoryTier.architectural.value,\n            source=MemorySource.system.value,\n            source_agent=_SOURCE_AGENT,\n            scope=MemoryScope.project.value,\n            tags=_make_seed_tags(\"docker\"),\n            confidence=_DEFAULT_CONFIDENCE,\n        )\n        _set_seeded_from(store, \"has-docker\")\n        seeded += 1\n\n    logger.info(\"memory_seeded\", count=seeded)\n    return {\"seeded_count\": seeded, \"skipped\": False}\n\n\n# ---------------------------------------------------------------------------\n# Helpers\n# ---------------------------------------------------------------------------\n\n\ndef _slugify(text: str) -> str:\n    \"\"\"Convert text to a simple slug for use as a memory key suffix.\"\"\"\n    return text.lower().replace(\" \", \"-\").replace(\"_\", \"-\")\n\n\ndef _set_seeded_from(store: MemoryStore, key: str) -> None:\n    \"\"\"Set the ``seeded_from`` field on a freshly seeded memory.\"\"\"\n    store.update_fields(key, seeded_from=_SEEDED_FROM)\n","numLines":229,"startLine":1,"totalLines":229}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CPb7KLw7Li1gUsKDU2vPwE","type":"tool_result","content":"     1→\"\"\"Markdown import for migrating MEMORY.md files into tapps-brain.\n     2→\n     3→Parses markdown headings into memory keys (slugified) and body text into\n     4→values. Heading level determines tier:\n     5→  H1/H2 → architectural, H3 → pattern, H4+ → procedural.\n     6→\n     7→Daily notes (``memory/YYYY-MM-DD.md``) are imported as context-tier entries\n     8→with date extracted from the filename.\n     9→\n    10→Part of EPIC-012 (OpenClaw integration).\n    11→\"\"\"\n    12→\n    13→from __future__ import annotations\n    14→\n    15→import re\n    16→from typing import TYPE_CHECKING, Any\n    17→\n    18→import structlog\n    19→\n    20→from tapps_brain.models import MAX_KEY_LENGTH, MAX_VALUE_LENGTH, MemorySource, MemoryTier\n    21→\n    22→if TYPE_CHECKING:\n    23→    from pathlib import Path\n    24→\n    25→    from tapps_brain.store import MemoryStore\n    26→\n    27→logger = structlog.get_logger(__name__)\n    28→\n    29→# Matches markdown headings: group(1)=hashes, group(2)=text\n    30→_HEADING_RE = re.compile(r\"^(#{1,6})\\s+(.+?)\\s*$\")\n    31→\n    32→# Tier boundary heading levels\n    33→_H_ARCHITECTURAL_MAX = 2  # H1/H2 → architectural\n    34→_H_PATTERN = 3  # H3 → pattern; H4+ → procedural\n    35→\n    36→# Daily note filename pattern: YYYY-MM-DD.md\n    37→_DAILY_NOTE_RE = re.compile(r\"^(\\d{4}-\\d{2}-\\d{2})\\.md$\")\n    38→\n    39→# Characters allowed in slugified keys\n    40→_SLUG_CLEAN_RE = re.compile(r\"[^a-z0-9._-]+\")\n    41→_MULTI_SEP_RE = re.compile(r\"[-_.]{2,}\")\n    42→\n    43→\n    44→def _slugify(text: str) -> str:\n    45→    \"\"\"Convert heading text to a valid memory key slug.\n    46→\n    47→    Lowercase, replace non-alphanumeric with hyphens, collapse runs,\n    48→    strip leading/trailing separators, truncate to MAX_KEY_LENGTH.\n    49→    \"\"\"\n    50→    slug = text.lower().strip()\n    51→    slug = _SLUG_CLEAN_RE.sub(\"-\", slug)\n    52→    slug = _MULTI_SEP_RE.sub(\"-\", slug)\n    53→    slug = slug.strip(\"-._\")\n    54→    # Ensure starts with alphanumeric\n    55→    slug = slug.lstrip(\"-._\")\n    56→    if not slug or not slug[0].isalnum():\n    57→        slug = \"m-\" + slug\n    58→    return slug[:MAX_KEY_LENGTH]\n    59→\n    60→\n    61→def _tier_from_level(level: int) -> MemoryTier:\n    62→    \"\"\"Map heading level (1-6) to a memory tier.\"\"\"\n    63→    if level <= _H_ARCHITECTURAL_MAX:\n    64→        return MemoryTier.architectural\n    65→    if level == _H_PATTERN:\n    66→        return MemoryTier.pattern\n    67→    return MemoryTier.procedural\n    68→\n    69→\n    70→def import_memory_md(path: Path, store: MemoryStore) -> int:\n    71→    \"\"\"Parse a MEMORY.md file and import entries into the store.\n    72→\n    73→    Each heading becomes a key (slugified). The body text under that heading\n    74→    becomes the value. Entries whose keys already exist are skipped.\n    75→\n    76→    Args:\n    77→        path: Path to the markdown file.\n    78→        store: MemoryStore instance to import into.\n    79→\n    80→    Returns:\n    81→        Number of new entries imported.\n    82→    \"\"\"\n    83→    if not path.is_file():\n    84→        logger.warning(\"markdown_import.file_not_found\", path=str(path))\n    85→        return 0\n    86→\n    87→    text = path.read_text(encoding=\"utf-8\")\n    88→    return _parse_and_import(text, store)\n    89→\n    90→\n    91→def _parse_and_import(text: str, store: MemoryStore) -> int:\n    92→    \"\"\"Parse markdown text into sections and import them.\n    93→\n    94→    Returns the number of new entries imported.\n    95→    \"\"\"\n    96→    sections = _parse_sections(text)\n    97→    imported = 0\n    98→\n    99→    for key, value, tier in sections:\n   100→        # Skip if key already exists (deduplication)\n   101→        if store.get(key) is not None:\n   102→            logger.debug(\"markdown_import.skip_duplicate\", key=key)\n   103→            continue\n   104→\n   105→        # Truncate value if too long\n   106→        if len(value) > MAX_VALUE_LENGTH:\n   107→            value = value[:MAX_VALUE_LENGTH]\n   108→\n   109→        store.save(\n   110→            key=key,\n   111→            value=value,\n   112→            tier=tier.value,\n   113→            source=MemorySource.system.value,\n   114→        )\n   115→        imported += 1\n   116→        logger.debug(\"markdown_import.imported\", key=key, tier=tier.value)\n   117→\n   118→    return imported\n   119→\n   120→\n   121→def _parse_sections(text: str) -> list[tuple[str, str, MemoryTier]]:\n   122→    \"\"\"Split markdown into (key, value, tier) tuples from headings + body.\"\"\"\n   123→    sections: list[tuple[str, str, MemoryTier]] = []\n   124→    current_key: str | None = None\n   125→    current_tier: MemoryTier = MemoryTier.pattern\n   126→    body_lines: list[str] = []\n   127→\n   128→    for line in text.splitlines():\n   129→        match = _HEADING_RE.match(line)\n   130→        if match:\n   131→            # Flush previous section\n   132→            if current_key is not None:\n   133→                body = \"\\n\".join(body_lines).strip()\n   134→                if body:\n   135→                    sections.append((current_key, body, current_tier))\n   136→\n   137→            level = len(match.group(1))\n   138→            heading_text = match.group(2)\n   139→            current_key = _slugify(heading_text)\n   140→            current_tier = _tier_from_level(level)\n   141→            body_lines = []\n   142→        else:\n   143→            body_lines.append(line)\n   144→\n   145→    # Flush last section\n   146→    if current_key is not None:\n   147→        body = \"\\n\".join(body_lines).strip()\n   148→        if body:\n   149→            sections.append((current_key, body, current_tier))\n   150→\n   151→    return sections\n   152→\n   153→\n   154→def _import_daily_note(path: Path, store: MemoryStore) -> bool:\n   155→    \"\"\"Import a single daily note file as a context-tier entry.\n   156→\n   157→    The key is derived from the date in the filename (``daily-YYYY-MM-DD``).\n   158→    If the key already exists in the store, the note is skipped.\n   159→\n   160→    Returns:\n   161→        ``True`` if the note was imported, ``False`` if skipped or empty.\n   162→    \"\"\"\n   163→    match = _DAILY_NOTE_RE.match(path.name)\n   164→    if not match:\n   165→        return False\n   166→\n   167→    date_str = match.group(1)\n   168→    key = f\"daily-{date_str}\"\n   169→\n   170→    # Deduplicate\n   171→    if store.get(key) is not None:\n   172→        logger.debug(\"markdown_import.skip_daily_duplicate\", key=key)\n   173→        return False\n   174→\n   175→    text = path.read_text(encoding=\"utf-8\").strip()\n   176→    if not text:\n   177→        logger.debug(\"markdown_import.skip_empty_daily\", path=str(path))\n   178→        return False\n   179→\n   180→    # Truncate if needed\n   181→    value = text[:MAX_VALUE_LENGTH]\n   182→\n   183→    store.save(\n   184→        key=key,\n   185→        value=value,\n   186→        tier=MemoryTier.context.value,\n   187→        source=MemorySource.system.value,\n   188→    )\n   189→    logger.debug(\"markdown_import.imported_daily\", key=key, date=date_str)\n   190→    return True\n   191→\n   192→\n   193→def import_openclaw_workspace(\n   194→    workspace_dir: Path,\n   195→    store: MemoryStore,\n   196→) -> dict[str, Any]:\n   197→    \"\"\"Import an OpenClaw workspace's markdown memories into the store.\n   198→\n   199→    Imports both the top-level ``MEMORY.md`` and any daily notes found in\n   200→    ``memory/YYYY-MM-DD.md``.\n   201→\n   202→    Args:\n   203→        workspace_dir: Root directory of the OpenClaw workspace.\n   204→        store: MemoryStore instance to import into.\n   205→\n   206→    Returns:\n   207→        Dict with keys ``memory_md`` (int), ``daily_notes`` (int),\n   208→        ``skipped`` (int) representing counts.\n   209→    \"\"\"\n   210→    memory_md_count = 0\n   211→    daily_notes_count = 0\n   212→    skipped = 0\n   213→\n   214→    # 1) Import MEMORY.md from workspace root\n   215→    memory_md_path = workspace_dir / \"MEMORY.md\"\n   216→    if memory_md_path.is_file():\n   217→        text = memory_md_path.read_text(encoding=\"utf-8\")\n   218→        sections = _parse_sections(text)\n   219→        for key, value, tier in sections:\n   220→            if store.get(key) is not None:\n   221→                logger.debug(\"markdown_import.skip_duplicate\", key=key)\n   222→                skipped += 1\n   223→                continue\n   224→            if len(value) > MAX_VALUE_LENGTH:\n   225→                value = value[:MAX_VALUE_LENGTH]\n   226→            store.save(\n   227→                key=key,\n   228→                value=value,\n   229→                tier=tier.value,\n   230→                source=MemorySource.system.value,\n   231→            )\n   232→            memory_md_count += 1\n   233→    else:\n   234→        logger.info(\"markdown_import.no_memory_md\", dir=str(workspace_dir))\n   235→\n   236→    # 2) Import daily notes from memory/ subdirectory\n   237→    memory_dir = workspace_dir / \"memory\"\n   238→    if memory_dir.is_dir():\n   239→        for note_path in sorted(memory_dir.iterdir()):\n   240→            if not note_path.is_file():\n   241→                continue\n   242→            match = _DAILY_NOTE_RE.match(note_path.name)\n   243→            if not match:\n   244→                continue\n   245→            if _import_daily_note(note_path, store):\n   246→                daily_notes_count += 1\n   247→            else:\n   248→                skipped += 1\n   249→    else:\n   250→        logger.info(\"markdown_import.no_memory_dir\", dir=str(workspace_dir))\n   251→\n   252→    logger.info(\n   253→        \"markdown_import.workspace_complete\",\n   254→        workspace=str(workspace_dir),\n   255→        memory_md=memory_md_count,\n   256→        daily_notes=daily_notes_count,\n   257→        skipped=skipped,\n   258→    )\n   259→\n   260→    return {\n   261→        \"memory_md\": memory_md_count,\n   262→        \"daily_notes\": daily_notes_count,\n   263→        \"skipped\": skipped,\n   264→    }\n   265→"}]},"parent_tool_use_id":null,"session_id":"432b4479-d665-4641-add7-8ce0bc4cd0e0","uuid":"77988374-8da1-4985-b85e-7e994557c279","timestamp":"2026-03-22T22:28:01.914Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\cursor\\tapps-brain\\src\\tapps_brain\\markdown_import.py","content":"\"\"\"Markdown import for migrating MEMORY.md files into tapps-brain.\n\nParses markdown headings into memory keys (slugified) and body text into\nvalues. Heading level determines tier:\n  H1/H2 → architectural, H3 → pattern, H4+ → procedural.\n\nDaily notes (``memory/YYYY-MM-DD.md``) are imported as context-tier entries\nwith date extracted from the filename.\n\nPart of EPIC-012 (OpenClaw integration).\n\"\"\"\n\nfrom __future__ import annotations\n\nimport re\nfrom typing import TYPE_CHECKING, Any\n\nimport structlog\n\nfrom tapps_brain.models import MAX_KEY_LENGTH, MAX_VALUE_LENGTH, MemorySource, MemoryTier\n\nif TYPE_CHECKING:\n    from pathlib import Path\n\n    from tapps_brain.store import MemoryStore\n\nlogger = structlog.get_logger(__name__)\n\n# Matches markdown headings: group(1)=hashes, group(2)=text\n_HEADING_RE = re.compile(r\"^(#{1,6})\\s+(.+?)\\s*$\")\n\n# Tier boundary heading levels\n_H_ARCHITECTURAL_MAX = 2  # H1/H2 → architectural\n_H_PATTERN = 3  # H3 → pattern; H4+ → procedural\n\n# Daily note filename pattern: YYYY-MM-DD.md\n_DAILY_NOTE_RE = re.compile(r\"^(\\d{4}-\\d{2}-\\d{2})\\.md$\")\n\n# Characters allowed in slugified keys\n_SLUG_CLEAN_RE = re.compile(r\"[^a-z0-9._-]+\")\n_MULTI_SEP_RE = re.compile(r\"[-_.]{2,}\")\n\n\ndef _slugify(text: str) -> str:\n    \"\"\"Convert heading text to a valid memory key slug.\n\n    Lowercase, replace non-alphanumeric with hyphens, collapse runs,\n    strip leading/trailing separators, truncate to MAX_KEY_LENGTH.\n    \"\"\"\n    slug = text.lower().strip()\n    slug = _SLUG_CLEAN_RE.sub(\"-\", slug)\n    slug = _MULTI_SEP_RE.sub(\"-\", slug)\n    slug = slug.strip(\"-._\")\n    # Ensure starts with alphanumeric\n    slug = slug.lstrip(\"-._\")\n    if not slug or not slug[0].isalnum():\n        slug = \"m-\" + slug\n    return slug[:MAX_KEY_LENGTH]\n\n\ndef _tier_from_level(level: int) -> MemoryTier:\n    \"\"\"Map heading level (1-6) to a memory tier.\"\"\"\n    if level <= _H_ARCHITECTURAL_MAX:\n        return MemoryTier.architectural\n    if level == _H_PATTERN:\n        return MemoryTier.pattern\n    return MemoryTier.procedural\n\n\ndef import_memory_md(path: Path, store: MemoryStore) -> int:\n    \"\"\"Parse a MEMORY.md file and import entries into the store.\n\n    Each heading becomes a key (slugified). The body text under that heading\n    becomes the value. Entries whose keys already exist are skipped.\n\n    Args:\n        path: Path to the markdown file.\n        store: MemoryStore instance to import into.\n\n    Returns:\n        Number of new entries imported.\n    \"\"\"\n    if not path.is_file():\n        logger.warning(\"markdown_import.file_not_found\", path=str(path))\n        return 0\n\n    text = path.read_text(encoding=\"utf-8\")\n    return _parse_and_import(text, store)\n\n\ndef _parse_and_import(text: str, store: MemoryStore) -> int:\n    \"\"\"Parse markdown text into sections and import them.\n\n    Returns the number of new entries imported.\n    \"\"\"\n    sections = _parse_sections(text)\n    imported = 0\n\n    for key, value, tier in sections:\n        # Skip if key already exists (deduplication)\n        if store.get(key) is not None:\n            logger.debug(\"markdown_import.skip_duplicate\", key=key)\n            continue\n\n        # Truncate value if too long\n        if len(value) > MAX_VALUE_LENGTH:\n            value = value[:MAX_VALUE_LENGTH]\n\n        store.save(\n            key=key,\n            value=value,\n            tier=tier.value,\n            source=MemorySource.system.value,\n        )\n        imported += 1\n        logger.debug(\"markdown_import.imported\", key=key, tier=tier.value)\n\n    return imported\n\n\ndef _parse_sections(text: str) -> list[tuple[str, str, MemoryTier]]:\n    \"\"\"Split markdown into (key, value, tier) tuples from headings + body.\"\"\"\n    sections: list[tuple[str, str, MemoryTier]] = []\n    current_key: str | None = None\n    current_tier: MemoryTier = MemoryTier.pattern\n    body_lines: list[str] = []\n\n    for line in text.splitlines():\n        match = _HEADING_RE.match(line)\n        if match:\n            # Flush previous section\n            if current_key is not None:\n                body = \"\\n\".join(body_lines).strip()\n                if body:\n                    sections.append((current_key, body, current_tier))\n\n            level = len(match.group(1))\n            heading_text = match.group(2)\n            current_key = _slugify(heading_text)\n            current_tier = _tier_from_level(level)\n            body_lines = []\n        else:\n            body_lines.append(line)\n\n    # Flush last section\n    if current_key is not None:\n        body = \"\\n\".join(body_lines).strip()\n        if body:\n            sections.append((current_key, body, current_tier))\n\n    return sections\n\n\ndef _import_daily_note(path: Path, store: MemoryStore) -> bool:\n    \"\"\"Import a single daily note file as a context-tier entry.\n\n    The key is derived from the date in the filename (``daily-YYYY-MM-DD``).\n    If the key already exists in the store, the note is skipped.\n\n    Returns:\n        ``True`` if the note was imported, ``False`` if skipped or empty.\n    \"\"\"\n    match = _DAILY_NOTE_RE.match(path.name)\n    if not match:\n        return False\n\n    date_str = match.group(1)\n    key = f\"daily-{date_str}\"\n\n    # Deduplicate\n    if store.get(key) is not None:\n        logger.debug(\"markdown_import.skip_daily_duplicate\", key=key)\n        return False\n\n    text = path.read_text(encoding=\"utf-8\").strip()\n    if not text:\n        logger.debug(\"markdown_import.skip_empty_daily\", path=str(path))\n        return False\n\n    # Truncate if needed\n    value = text[:MAX_VALUE_LENGTH]\n\n    store.save(\n        key=key,\n        value=value,\n        tier=MemoryTier.context.value,\n        source=MemorySource.system.value,\n    )\n    logger.debug(\"markdown_import.imported_daily\", key=key, date=date_str)\n    return True\n\n\ndef import_openclaw_workspace(\n    workspace_dir: Path,\n    store: MemoryStore,\n) -> dict[str, Any]:\n    \"\"\"Import an OpenClaw workspace's markdown memories into the store.\n\n    Imports both the top-level ``MEMORY.md`` and any daily notes found in\n    ``memory/YYYY-MM-DD.md``.\n\n    Args:\n        workspace_dir: Root directory of the OpenClaw workspace.\n        store: MemoryStore instance to import into.\n\n    Returns:\n        Dict with keys ``memory_md`` (int), ``daily_notes`` (int),\n        ``skipped`` (int) representing counts.\n    \"\"\"\n    memory_md_count = 0\n    daily_notes_count = 0\n    skipped = 0\n\n    # 1) Import MEMORY.md from workspace root\n    memory_md_path = workspace_dir / \"MEMORY.md\"\n    if memory_md_path.is_file():\n        text = memory_md_path.read_text(encoding=\"utf-8\")\n        sections = _parse_sections(text)\n        for key, value, tier in sections:\n            if store.get(key) is not None:\n                logger.debug(\"markdown_import.skip_duplicate\", key=key)\n                skipped += 1\n                continue\n            if len(value) > MAX_VALUE_LENGTH:\n                value = value[:MAX_VALUE_LENGTH]\n            store.save(\n                key=key,\n                value=value,\n                tier=tier.value,\n                source=MemorySource.system.value,\n            )\n            memory_md_count += 1\n    else:\n        logger.info(\"markdown_import.no_memory_md\", dir=str(workspace_dir))\n\n    # 2) Import daily notes from memory/ subdirectory\n    memory_dir = workspace_dir / \"memory\"\n    if memory_dir.is_dir():\n        for note_path in sorted(memory_dir.iterdir()):\n            if not note_path.is_file():\n                continue\n            match = _DAILY_NOTE_RE.match(note_path.name)\n            if not match:\n                continue\n            if _import_daily_note(note_path, store):\n                daily_notes_count += 1\n            else:\n                skipped += 1\n    else:\n        logger.info(\"markdown_import.no_memory_dir\", dir=str(workspace_dir))\n\n    logger.info(\n        \"markdown_import.workspace_complete\",\n        workspace=str(workspace_dir),\n        memory_md=memory_md_count,\n        daily_notes=daily_notes_count,\n        skipped=skipped,\n    )\n\n    return {\n        \"memory_md\": memory_md_count,\n        \"daily_notes\": daily_notes_count,\n        \"skipped\": skipped,\n    }\n","numLines":265,"startLine":1,"totalLines":265}}}
