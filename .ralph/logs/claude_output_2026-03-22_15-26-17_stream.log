{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RkgyBhA1zPui6ncHt1UDF3","type":"tool_result","content":"741-    # ------------------------------------------------------------------\n742-    # Maintenance tools (STORY-008.5)\n743-    # ------------------------------------------------------------------\n744-\n745-    @mcp.tool()  # type: ignore[untyped-decorator]\n746:    def maintenance_consolidate(\n747-        threshold: float = 0.7,\n748-        min_group_size: int = 3,\n749-        force: bool = True,\n750-    ) -> str:\n751-        \"\"\"Trigger memory consolidation to merge similar entries.\n752-\n753-        Scans the store for groups of similar memories and merges them\n754:        into consolidated entries.\n755-\n756-        Args:\n757-            threshold: Similarity threshold for grouping (0.0-1.0, default 0.7).\n758:            min_group_size: Minimum entries per group to consolidate (default 3).\n759-            force: If True, run regardless of last scan time (default True).\n760-        \"\"\"\n761-        from tapps_brain.auto_consolidation import run_periodic_consolidation_scan\n762-\n763-        result = run_periodic_consolidation_scan("}]},"parent_tool_use_id":"toolu_01ETxuMXE5rZCE6YhLTRE2TH","session_id":"432b4479-d665-4641-add7-8ce0bc4cd0e0","uuid":"acab0948-9784-4eed-a505-1e479d878db4","timestamp":"2026-03-22T22:27:12.669Z"}
