{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HYhedAEMQz9LyJsNNnCFBX","type":"tool_result","content":"   100→        # Skip if key already exists (deduplication)\n   101→        if store.get(key) is not None:\n   102→            logger.debug(\"markdown_import.skip_duplicate\", key=key)\n   103→            continue\n   104→\n   105→        # Truncate value if too long\n   106→        if len(value) > MAX_VALUE_LENGTH:\n   107→            value = value[:MAX_VALUE_LENGTH]\n   108→\n   109→        store.save(\n   110→            key=key,\n   111→            value=value,\n   112→            tier=tier.value,\n   113→            source=MemorySource.system.value,\n   114→        )\n   115→        imported += 1\n   116→        logger.debug(\"markdown_import.imported\", key=key, tier=tier.value)\n   117→\n   118→    return imported\n   119→\n   120→\n   121→def _parse_sections(text: str) -> list[tuple[str, str, MemoryTier]]:\n   122→    \"\"\"Split markdown into (key, value, tier) tuples from headings + body.\"\"\"\n   123→    sections: list[tuple[str, str, MemoryTier]] = []\n   124→    current_key: str | None = None\n   125→    current_tier: MemoryTier = MemoryTier.pattern\n   126→    body_lines: list[str] = []\n   127→\n   128→    for line in text.splitlines():\n   129→        match = _HEADING_RE.match(line)\n   130→        if match:\n   131→            # Flush previous section\n   132→            if current_key is not None:\n   133→                body = \"\\n\".join(body_lines).strip()\n   134→                if body:\n   135→                    sections.append((current_key, body, current_tier))\n   136→\n   137→            level = len(match.group(1))\n   138→            heading_text = match.group(2)\n   139→            current_key = _slugify(heading_text)\n   140→            current_tier = _tier_from_level(level)\n   141→            body_lines = []\n   142→        else:\n   143→            body_lines.append(line)\n   144→\n   145→    # Flush last section\n   146→    if current_key is not None:\n   147→        body = \"\\n\".join(body_lines).strip()\n   148→        if body:\n   149→            sections.append((current_key, body, current_tier))\n   150→\n   151→    return sections\n   152→\n   153→\n   154→def _import_daily_note(path: Path, store: MemoryStore) -> bool:\n   155→    \"\"\"Import a single daily note file as a context-tier entry.\n   156→\n   157→    The key is derived from the date in the filename (``daily-YYYY-MM-DD``).\n   158→    If the key already exists in the store, the note is skipped.\n   159→\n   160→    Returns:\n   161→        ``True`` if the note was imported, ``False`` if skipped or empty.\n   162→    \"\"\"\n   163→    match = _DAILY_NOTE_RE.match(path.name)\n   164→    if not match:\n   165→        return False\n   166→\n   167→    date_str = match.group(1)\n   168→    key = f\"daily-{date_str}\"\n   169→\n   170→    # Deduplicate\n   171→    if store.get(key) is not None:\n   172→        logger.debug(\"markdown_import.skip_daily_duplicate\", key=key)\n   173→        return False\n   174→\n   175→    text = path.read_text(encoding=\"utf-8\").strip()\n   176→    if not text:\n   177→        logger.debug(\"markdown_import.skip_empty_daily\", path=str(path))\n   178→        return False\n   179→\n   180→    # Truncate if needed\n   181→    value = text[:MAX_VALUE_LENGTH]\n   182→\n   183→    store.save(\n   184→        key=key,\n   185→        value=value,\n   186→        tier=MemoryTier.context.value,\n   187→        source=MemorySource.system.value,\n   188→    )\n   189→    logger.debug(\"markdown_import.imported_daily\", key=key, date=date_str)\n   190→    return True\n   191→\n   192→\n   193→def import_openclaw_workspace(\n   194→    workspace_dir: Path,\n   195→    store: MemoryStore,\n   196→) -> dict[str, Any]:\n   197→    \"\"\"Import an OpenClaw workspace's markdown memories into the store.\n   198→\n   199→    Imports both the top-level ``MEMORY.md`` and any daily notes found in"}]},"parent_tool_use_id":"toolu_01ETxuMXE5rZCE6YhLTRE2TH","session_id":"432b4479-d665-4641-add7-8ce0bc4cd0e0","uuid":"370eb498-df5b-4563-a276-1bae27ba64e4","timestamp":"2026-03-22T22:27:02.601Z"}
