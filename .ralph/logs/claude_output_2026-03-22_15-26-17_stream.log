{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01C1JxWYLFeC8xvdvTaVRuQv","type":"tool_result","content":"   200→        \"\"\"Return the rate limiter instance for stats/config access.\"\"\"\n   201→        return self._rate_limiter\n   202→\n   203→    @staticmethod\n   204→    def _resolve_profile(project_root: Path, profile: Any) -> Any:  # noqa: ANN401\n   205→        \"\"\"Resolve the active memory profile (EPIC-010).\n   206→\n   207→        When *profile* is an explicit ``MemoryProfile``, use it directly.\n   208→        Otherwise, attempt resolution from project/user/built-in defaults.\n   209→        Falls back gracefully to ``None`` if the profile module isn't\n   210→        available or no profile files exist.\n   211→        \"\"\"\n   212→        if profile is not None:\n   213→            return profile\n   214→        try:\n   215→            from tapps_brain.profile import resolve_profile as _resolve\n   216→\n   217→            return _resolve(project_root)\n   218→        except Exception:\n   219→            return None\n   220→\n   221→    @property\n   222→    def profile(self) -> Any:  # noqa: ANN401\n   223→        \"\"\"Return the active ``MemoryProfile``, or ``None``.\"\"\"\n   224→        return self._profile\n   225→\n   226→    def _get_decay_config(self) -> Any:  # noqa: ANN401\n   227→        \"\"\"Return a ``DecayConfig`` derived from the active profile (EPIC-010).\"\"\"\n   228→        if self._profile is not None:\n   229→            try:\n   230→                from tapps_brain.decay import decay_config_from_profile\n   231→\n   232→                return decay_config_from_profile(self._profile)\n   233→            except Exception:\n   234→                pass\n   235→        from tapps_brain.decay import DecayConfig\n   236→\n   237→        return DecayConfig()\n   238→\n   239→    # ------------------------------------------------------------------\n   240→    # CRUD operations\n   241→    # ------------------------------------------------------------------\n   242→\n   243→    def save(\n   244→        self,\n   245→        key: str,\n   246→        value: str,\n   247→        tier: str = \"pattern\",\n   248→        source: str = \"agent\",\n   249→        source_agent: str = \"unknown\",\n   250→        scope: str = \"project\",\n   251→        tags: list[str] | None = None,\n   252→        branch: str | None = None,\n   253→        confidence: float = -1.0,\n   254→        agent_scope: str = \"private\",\n   255→        *,\n   256→        skip_consolidation: bool = False,\n   257→        batch_context: str | None = None,\n   258→    ) -> MemoryEntry | dict[str, Any]:\n   259→        \"\"\"Save or update a memory entry.\n   260→\n   261→        Returns the saved ``MemoryEntry``, or an error dict if RAG safety\n   262→        blocks the content.\n   263→\n   264→        Args:\n   265→            key: Unique identifier for the memory.\n   266→            value: Memory content.\n   267→            tier: Memory tier (architectural, pattern, context).\n   268→            source: Source of the memory (human, agent, inferred, system).\n   269→            source_agent: Identifier of the agent saving the memory.\n   270→            scope: Visibility scope (project, branch, session).\n   271→            agent_scope: Hive propagation scope (private, domain, hive).\n   272→            tags: Tags for categorization.\n   273→            branch: Git branch name (required when scope=branch).\n   274→            confidence: Confidence score (-1.0 for auto from source).\n   275→            skip_consolidation: If True, skip auto-consolidation check.\n   276→            batch_context: Operation context for rate limit exemption\n   277→                (e.g. \"import_markdown\", \"seed\", \"federation_sync\", \"consolidate\").\n   278→        \"\"\"\n   279→        # agent_scope enum validation\n   280→        if agent_scope not in VALID_AGENT_SCOPES:\n   281→            return {\n   282→                \"error\": \"invalid_agent_scope\",\n   283→                \"message\": (\n   284→                    f\"Invalid agent_scope {agent_scope!r}. Valid values: {list(VALID_AGENT_SCOPES)}\"\n   285→                ),\n   286→                \"valid_values\": list(VALID_AGENT_SCOPES),\n   287→            }\n   288→\n   289→        # Write rules validation (Epic 65.17)\n   290→        wr_error = _validate_write_rules(key, value, self._write_rules)\n   291→        if wr_error is not None:\n   292→            return {\n   293→                \"error\": \"write_rules_violation\",\n   294→                \"message\": wr_error,\n   295→            }\n   296→\n   297→        # Rate limit check (H6a) — warn-only, never blocks\n   298→        rate_result = self._rate_limiter.check(batch_context=batch_context)\n   299→        if rate_result.minute_exceeded or rate_result.session_exceeded:\n   300→            logger.warning(\n   301→                \"memory_save_rate_warning\",\n   302→                key=key,\n   303→                minute_count=rate_result.current_minute_count,\n   304→                session_count=rate_result.current_session_count,\n   305→            )\n   306→\n   307→        # RAG safety check on value\n   308→        safety = check_content_safety(value)\n   309→        if not safety.safe and safety.match_count >= _RAG_BLOCK_THRESHOLD:\n   310→            logger.warning(\n   311→                \"memory_save_blocked\",\n   312→                key=key,\n   313→                match_count=safety.match_count,\n   314→                patterns=safety.flagged_patterns,\n   315→            )\n   316→            return {\n   317→                \"error\": \"content_blocked\",\n   318→                \"message\": \"Memory value blocked by RAG safety filter.\",\n   319→                \"flagged_patterns\": safety.flagged_patterns,\n   320→            }\n   321→\n   322→        # Sanitise if flagged but not blocked\n   323→        if not safety.safe and safety.sanitised_content:\n   324→            value = safety.sanitised_content\n   325→\n   326→        self._metrics.increment(\"store.save\")\n   327→        _timer = MetricsTimer(self._metrics, \"store.save_ms\")\n   328→        _timer.__enter__()\n   329→\n   330→        now = _utc_now_iso()\n   331→        with self._lock:\n   332→            existing = self._entries.get(key)\n   333→\n   334→            # EPIC-010: Accept profile layer names as tier values.\n   335→            # Try MemoryTier enum first; if it fails, accept the raw\n   336→            # string when the active profile defines a layer with that name.\n   337→            try:\n   338→                tier_val: MemoryTier | str = MemoryTier(tier)\n   339→            except ValueError:\n   340→                if self._profile is not None and tier in self._profile.layer_names:\n   341→                    tier_val = tier\n   342→                else:\n   343→                    tier_val = MemoryTier(tier)  # Raise original error\n   344→\n   345→            entry = MemoryEntry(\n   346→                key=key,\n   347→                value=value,\n   348→                tier=tier_val,\n   349→                confidence=confidence,\n   350→                source=MemorySource(source),\n   351→                source_agent=source_agent,\n   352→                scope=MemoryScope(scope),\n   353→                agent_scope=agent_scope,\n   354→                tags=tags or [],\n   355→                created_at=existing.created_at if existing else now,\n   356→                updated_at=now,\n   357→                last_accessed=now,\n   358→                access_count=existing.access_count if existing else 1,\n   359→                branch=branch,\n   360→                # Preserve reserved fields on update\n   361→                last_reinforced=existing.last_reinforced if existing else None,\n   362→                reinforce_count=existing.reinforce_count if existing else 0,\n   363→                contradicted=existing.contradicted if existing else False,\n   364→                contradiction_reason=(existing.contradiction_reason if existing else None),\n   365→                seeded_from=existing.seeded_from if existing else None,\n   366→                # Preserve temporal fields on update (EPIC-004)\n   367→                valid_at=existing.valid_at if existing else None,\n   368→                invalid_at=existing.invalid_at if existing else None,\n   369→                superseded_by=existing.superseded_by if existing else None,\n   370→            )\n   371→\n   372→            # Max entries enforcement: evict lowest-confidence entry\n   373→            if key not in self._entries and len(self._entries) >= _MAX_ENTRIES:\n   374→                self._evict_lowest_confidence()\n   375→\n   376→            self._entries[key] = entry\n   377→\n   378→        # Compute embedding when semantic search is enabled (Epic 65.7)\n   379→        if self._embedding_provider is not None:\n   380→            try:\n   381→                emb = self._embedding_provider.embed(value)\n   382→                entry = entry.model_copy(update={\"embedding\": emb})\n   383→                with self._lock:\n   384→                    self._entries[key] = entry\n   385→            except Exception:\n   386→                logger.debug(\"embedding_compute_failed\", key=key, exc_info=True)\n   387→\n   388→        self._persistence.save(entry)\n   389→\n   390→        # Hive propagation (EPIC-011)\n   391→        if self._hive_store is not None:\n   392→            self._propagate_to_hive(entry)\n   393→\n   394→        # Extract and persist relations (EPIC-006)\n   395→        relations = extract_relations(key, value)\n   396→        if relations:\n   397→            self._persistence.save_relations(key, relations)\n   398→            # Reload from persistence to keep timestamps consistent\n   399→            self._relations[key] = self._persistence.load_relations(key)\n   400→\n   401→        # Auto-consolidation check (Epic 58)\n   402→        if (\n   403→            self._consolidation_config.enabled\n   404→            and not skip_consolidation\n   405→            and not self._consolidation_in_progress\n   406→        ):\n   407→            self._maybe_consolidate(entry)\n   408→\n   409→        _timer.__exit__(None, None, None)\n   410→        return entry\n   411→\n   412→    def _maybe_consolidate(self, entry: MemoryEntry) -> None:\n   413→        \"\"\"Check if the saved entry should trigger consolidation.\n   414→\n   415→        Runs consolidation in a non-reentrant manner to prevent infinite\n   416→        loops when consolidation saves new entries.\n   417→        \"\"\"\n   418→        if self._consolidation_in_progress:\n   419→            return\n   420→\n   421→        self._consolidation_in_progress = True\n   422→        try:\n   423→            from tapps_brain.auto_consolidation import check_consolidation_on_save\n   424→\n   425→            result = check_consolidation_on_save(\n   426→                entry,\n   427→                self,\n   428→                threshold=self._consolidation_config.threshold,\n   429→                min_entries=self._consolidation_config.min_entries,\n   430→            )\n   431→\n   432→            if result.triggered:\n   433→                self._metrics.increment(\"store.consolidate\")\n   434→                self._metrics.increment(\"store.consolidate.merged\", len(result.source_keys))\n   435→                logger.info(\n   436→                    \"auto_consolidation_on_save\",\n   437→                    entry_key=entry.key,\n   438→                    consolidated_key=result.consolidated_entry.key\n   439→                    if result.consolidated_entry\n   440→                    else None,\n   441→                    source_keys=result.source_keys,\n   442→                )\n   443→        except Exception:\n   444→            logger.debug(\"auto_consolidation_check_failed\", exc_info=True)\n   445→        finally:\n   446→            self._consolidation_in_progress = False\n   447→\n   448→    def _propagate_to_hive(self, entry: MemoryEntry) -> None:\n   449→        \"\"\"Propagate a saved entry to the Hive if appropriate (EPIC-011).\"\"\"\n   450→        if self._hive_store is None:\n   451→            return\n   452→        try:\n   453→            from tapps_brain.hive import PropagationEngine\n   454→\n   455→            # Read Hive config from profile if available\n   456→            auto_propagate: list[str] | None = None\n   457→            private: list[str] | None = None\n   458→            agent_profile = \"repo-brain\"\n   459→            if self._profile is not None:\n   460→                hive_cfg = getattr(self._profile, \"hive\", None)\n   461→                if hive_cfg is not None:\n   462→                    auto_propagate = hive_cfg.auto_propagate_tiers\n   463→                    private = hive_cfg.private_tiers\n   464→                agent_profile = getattr(self._profile, \"name\", \"repo-brain\")\n   465→\n   466→            tier_str = entry.tier.value if hasattr(entry.tier, \"value\") else str(entry.tier)\n   467→\n   468→            PropagationEngine.propagate(\n   469→                key=entry.key,\n   470→                value=entry.value,\n   471→                agent_scope=entry.agent_scope,\n   472→                agent_id=self._hive_agent_id,\n   473→                agent_profile=agent_profile,\n   474→                tier=tier_str,\n   475→                confidence=entry.confidence,\n   476→                source=entry.source.value if hasattr(entry.source, \"value\") else str(entry.source),\n   477→                tags=entry.tags,\n   478→                hive_store=self._hive_store,\n   479→                auto_propagate_tiers=auto_propagate,\n   480→                private_tiers=private,\n   481→            )\n   482→        except Exception:\n   483→            logger.debug(\"hive_propagation_failed\", key=entry.key, exc_info=True)\n   484→\n   485→    def get(\n   486→        self,\n   487→        key: str,\n   488→        scope: str | None = None,\n   489→        branch: str | None = None,\n   490→    ) -> MemoryEntry | None:\n   491→        \"\"\"Retrieve a memory entry by key.\n   492→\n   493→        When *scope* and *branch* are provided, applies scope resolution:\n   494→        session > branch > project (most specific wins).\n   495→\n   496→        Updates ``last_accessed`` and ``access_count`` on read.\n   497→        \"\"\"\n   498→        self._metrics.increment(\"store.get\")\n   499→        with MetricsTimer(self._metrics, \"store.get_ms\"):"}]},"parent_tool_use_id":"toolu_01ETxuMXE5rZCE6YhLTRE2TH","session_id":"432b4479-d665-4641-add7-8ce0bc4cd0e0","uuid":"b7682c0e-b9c6-4344-bafd-8192db0cf890","timestamp":"2026-03-22T22:26:46.987Z"}
