{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UUnHrLwubKPkorHvM7Xw4H","type":"tool_result","content":"     1→\"\"\"Cross-project memory federation.\n     2→\n     3→Enables memory sharing across projects via a central hub store\n     4→at ``~/.tapps-mcp/memory/federated.db``.  Projects explicitly publish\n     5→shared-scope memories to the hub and subscribe to memories from\n     6→other projects.\n     7→\n     8→Epic 64 — all operations are explicit (no automatic sharing).\n     9→\"\"\"\n    10→\n    11→from __future__ import annotations\n    12→\n    13→import contextlib\n    14→import json\n    15→import sqlite3\n    16→import threading\n    17→from dataclasses import dataclass, field\n    18→from datetime import UTC, datetime\n    19→from pathlib import Path\n    20→from typing import TYPE_CHECKING, Any\n    21→\n    22→import structlog\n    23→import yaml\n    24→from pydantic import BaseModel, ConfigDict, Field\n    25→\n    26→if TYPE_CHECKING:\n    27→    from tapps_brain.models import MemoryEntry\n    28→    from tapps_brain.store import MemoryStore\n    29→\n    30→logger: structlog.stdlib.BoundLogger = structlog.get_logger(__name__)\n    31→\n    32→_DEFAULT_HUB_DIR = Path.home() / \".tapps-brain\" / \"memory\"\n    33→_MAX_PROJECTS = 50\n    34→_MAX_SUBSCRIPTIONS = 50\n    35→\n    36→\n    37→# ---------------------------------------------------------------------------\n    38→# Configuration models\n    39→# ---------------------------------------------------------------------------\n    40→\n    41→\n    42→class FederationProject(BaseModel):\n    43→    \"\"\"A registered project in the federation hub.\"\"\"\n    44→\n    45→    model_config = ConfigDict(extra=\"forbid\")\n    46→\n    47→    project_id: str = Field(description=\"Unique project identifier (slug).\")\n    48→    project_root: str = Field(description=\"Absolute path to project root.\")\n    49→    registered_at: str = Field(default=\"\", description=\"ISO-8601 UTC registration time.\")\n    50→    tags: list[str] = Field(default_factory=list, description=\"Project tags for filtering.\")\n    51→\n    52→\n    53→class FederationSubscription(BaseModel):\n    54→    \"\"\"Subscription from one project to others.\"\"\"\n    55→\n    56→    model_config = ConfigDict(extra=\"forbid\")\n    57→\n    58→    subscriber: str = Field(description=\"Subscribing project ID.\")\n    59→    sources: list[str] = Field(\n    60→        default_factory=list,\n    61→        description=\"Source project IDs to subscribe to (empty = all).\",\n    62→    )\n    63→    tag_filter: list[str] = Field(\n    64→        default_factory=list,\n    65→        description=\"Only import memories with these tags.\",\n    66→    )\n    67→    min_confidence: float = Field(\n    68→        default=0.5,\n    69→        ge=0.0,\n    70→        le=1.0,\n    71→        description=\"Minimum confidence threshold for imported memories.\",\n    72→    )\n    73→\n    74→\n    75→class FederationConfig(BaseModel):\n    76→    \"\"\"Root config for federation stored at ~/.tapps-mcp/memory/federation.yaml.\"\"\"\n    77→\n    78→    model_config = ConfigDict(extra=\"forbid\")\n    79→\n    80→    hub_path: str = Field(\n    81→        default=\"\",\n    82→        description=\"Path to federated.db (default: ~/.tapps-mcp/memory/federated.db).\",\n    83→    )\n    84→    projects: list[FederationProject] = Field(default_factory=list)\n    85→    subscriptions: list[FederationSubscription] = Field(default_factory=list)\n    86→\n    87→\n    88→# ---------------------------------------------------------------------------\n    89→# Config file management\n    90→# ---------------------------------------------------------------------------\n    91→\n    92→\n    93→def _config_path() -> Path:\n    94→    \"\"\"Return the path to federation.yaml.\"\"\"\n    95→    return _DEFAULT_HUB_DIR / \"federation.yaml\"\n    96→\n    97→\n    98→def load_federation_config() -> FederationConfig:\n    99→    \"\"\"Load federation config from disk, creating defaults if absent.\"\"\"\n   100→    path = _config_path()\n   101→    if not path.exists():\n   102→        return FederationConfig()\n   103→    raw = yaml.safe_load(path.read_text(encoding=\"utf-8\"))\n   104→    if raw is None or not isinstance(raw, dict):\n   105→        return FederationConfig()\n   106→    return FederationConfig(**raw)\n   107→\n   108→\n   109→def save_federation_config(config: FederationConfig) -> None:\n   110→    \"\"\"Persist federation config to disk.\"\"\"\n   111→    path = _config_path()\n   112→    path.parent.mkdir(parents=True, exist_ok=True)\n   113→    data = config.model_dump(mode=\"json\")\n   114→    path.write_text(\n   115→        yaml.safe_dump(data, default_flow_style=False, sort_keys=False),\n   116→        encoding=\"utf-8\",\n   117→    )\n   118→    logger.info(\"federation_config.saved\", path=str(path))\n   119→\n   120→\n   121→def register_project(\n   122→    project_id: str,\n   123→    project_root: str,\n   124→    tags: list[str] | None = None,\n   125→) -> FederationConfig:\n   126→    \"\"\"Register a project in the federation hub.\n   127→\n   128→    Returns the updated config.\n   129→    \"\"\"\n   130→    config = load_federation_config()\n   131→\n   132→    # Check for duplicates\n   133→    existing_ids = {p.project_id for p in config.projects}\n   134→    if project_id in existing_ids:\n   135→        logger.info(\"federation.project_already_registered\", project_id=project_id)\n   136→        # Update tags if provided\n   137→        for proj in config.projects:\n   138→            if proj.project_id == project_id:\n   139→                if tags is not None:\n   140→                    proj.tags = tags\n   141→                proj.project_root = project_root\n   142→                break\n   143→        save_federation_config(config)\n   144→        return config\n   145→\n   146→    if len(config.projects) >= _MAX_PROJECTS:\n   147→        msg = f\"Federation hub has reached max projects ({_MAX_PROJECTS})\"\n   148→        raise ValueError(msg)\n   149→\n   150→    config.projects.append(\n   151→        FederationProject(\n   152→            project_id=project_id,\n   153→            project_root=project_root,\n   154→            registered_at=datetime.now(tz=UTC).isoformat(),\n   155→            tags=tags or [],\n   156→        )\n   157→    )\n   158→    save_federation_config(config)\n   159→    logger.info(\"federation.project_registered\", project_id=project_id)\n   160→    return config\n   161→\n   162→\n   163→def unregister_project(project_id: str) -> FederationConfig:\n   164→    \"\"\"Remove a project from the federation hub.\"\"\"\n   165→    config = load_federation_config()\n   166→    config.projects = [p for p in config.projects if p.project_id != project_id]\n   167→    config.subscriptions = [s for s in config.subscriptions if s.subscriber != project_id]\n   168→    save_federation_config(config)\n   169→    logger.info(\"federation.project_unregistered\", project_id=project_id)\n   170→    return config\n   171→\n   172→\n   173→def add_subscription(\n   174→    subscriber: str,\n   175→    sources: list[str] | None = None,\n   176→    tag_filter: list[str] | None = None,\n   177→    min_confidence: float = 0.5,\n   178→) -> FederationConfig:\n   179→    \"\"\"Add or update a subscription for a project.\"\"\"\n   180→    config = load_federation_config()\n   181→\n   182→    # Validate subscriber exists\n   183→    project_ids = {p.project_id for p in config.projects}\n   184→    if subscriber not in project_ids:\n   185→        msg = f\"Subscriber '{subscriber}' is not registered in the federation hub\"\n   186→        raise ValueError(msg)\n   187→\n   188→    # Validate sources exist\n   189→    if sources:\n   190→        unknown = set(sources) - project_ids\n   191→        if unknown:\n   192→            msg = f\"Unknown source project(s): {sorted(unknown)}\"\n   193→            raise ValueError(msg)\n   194→\n   195→    # Remove existing subscription for this subscriber (replace)\n   196→    config.subscriptions = [s for s in config.subscriptions if s.subscriber != subscriber]\n   197→\n   198→    if len(config.subscriptions) >= _MAX_SUBSCRIPTIONS:\n   199→        msg = f\"Federation hub has reached max subscriptions ({_MAX_SUBSCRIPTIONS})\"\n   200→        raise ValueError(msg)\n   201→\n   202→    config.subscriptions.append(\n   203→        FederationSubscription(\n   204→            subscriber=subscriber,\n   205→            sources=sources or [],\n   206→            tag_filter=tag_filter or [],\n   207→            min_confidence=min_confidence,\n   208→        )\n   209→    )\n   210→    save_federation_config(config)\n   211→    logger.info(\n   212→        \"federation.subscription_added\",\n   213→        subscriber=subscriber,\n   214→        sources=sources or [\"all\"],\n   215→    )\n   216→    return config\n   217→\n   218→\n   219→# ---------------------------------------------------------------------------\n   220→# Federated Hub Store (SQLite)\n   221→# ---------------------------------------------------------------------------\n   222→\n   223→\n   224→class FederatedStore:\n   225→    \"\"\"Central hub for cross-project memory federation.\n   226→\n   227→    Uses a SQLite database at ``~/.tapps-mcp/memory/federated.db`` with\n   228→    composite primary key ``(project_id, key)`` and FTS5 for search.\n   229→    \"\"\"\n   230→\n   231→    def __init__(self, db_path: Path | None = None) -> None:\n   232→        self._db_path = db_path or (_DEFAULT_HUB_DIR / \"federated.db\")\n   233→        self._db_path.parent.mkdir(parents=True, exist_ok=True)\n   234→        self._lock = threading.Lock()\n   235→        self._conn = self._connect()\n   236→        self._ensure_schema()\n   237→\n   238→    def _connect(self) -> sqlite3.Connection:\n   239→        conn = sqlite3.connect(\n   240→            str(self._db_path),\n   241→            check_same_thread=False,\n   242→        )\n   243→        conn.row_factory = sqlite3.Row\n   244→        conn.execute(\"PRAGMA journal_mode=WAL\")\n   245→        conn.execute(\"PRAGMA busy_timeout=5000\")\n   246→        conn.execute(\"PRAGMA foreign_keys=ON\")\n   247→        return conn\n   248→\n   249→    def _ensure_schema(self) -> None:\n   250→        with self._lock:\n   251→            self._conn.executescript(\"\"\"\n   252→                CREATE TABLE IF NOT EXISTS federated_memories (\n   253→                    project_id TEXT NOT NULL,\n   254→                    key TEXT NOT NULL,\n   255→                    value TEXT NOT NULL,\n   256→                    tier TEXT NOT NULL DEFAULT 'pattern',\n   257→                    confidence REAL NOT NULL DEFAULT 0.6,\n   258→                    source TEXT NOT NULL DEFAULT 'agent',\n   259→                    source_agent TEXT NOT NULL DEFAULT 'unknown',\n   260→                    tags TEXT NOT NULL DEFAULT '[]',\n   261→                    created_at TEXT NOT NULL,\n   262→                    updated_at TEXT NOT NULL,\n   263→                    published_at TEXT NOT NULL,\n   264→                    origin_project_root TEXT NOT NULL DEFAULT '',\n   265→                    PRIMARY KEY (project_id, key)\n   266→                );\n   267→\n   268→                CREATE INDEX IF NOT EXISTS idx_fed_project\n   269→                    ON federated_memories(project_id);\n   270→                CREATE INDEX IF NOT EXISTS idx_fed_confidence\n   271→                    ON federated_memories(confidence);\n   272→                CREATE INDEX IF NOT EXISTS idx_fed_tier\n   273→                    ON federated_memories(tier);\n   274→\n   275→                CREATE TABLE IF NOT EXISTS federation_meta (\n   276→                    project_id TEXT PRIMARY KEY,\n   277→                    last_sync TEXT NOT NULL,\n   278→                    entry_count INTEGER NOT NULL DEFAULT 0\n   279→                );\n   280→            \"\"\")\n   281→\n   282→            # FTS5 table -- created separately (can't use executescript reliably)\n   283→            with contextlib.suppress(sqlite3.OperationalError):\n   284→                self._conn.execute(\"\"\"\n   285→                    CREATE VIRTUAL TABLE IF NOT EXISTS federated_fts\n   286→                    USING fts5(key, value, tags, content=federated_memories, content_rowid=rowid)\n   287→                \"\"\")\n   288→\n   289→            self._conn.commit()\n   290→\n   291→    def close(self) -> None:\n   292→        \"\"\"Close the database connection.\"\"\"\n   293→        with self._lock:\n   294→            self._conn.close()\n   295→\n   296→    # ------------------------------------------------------------------\n   297→    # Publish / Unpublish\n   298→    # ------------------------------------------------------------------\n   299→\n   300→    def publish(\n   301→        self,\n   302→        project_id: str,\n   303→        entries: list[MemoryEntry],\n   304→        project_root: str = \"\",\n   305→    ) -> int:\n   306→        \"\"\"Publish memories to the federation hub.\n   307→\n   308→        Args:\n   309→            project_id: Source project identifier.\n   310→            entries: Memory entries to publish.\n   311→            project_root: Source project root path for traceability.\n   312→\n   313→        Returns:\n   314→            Number of entries published.\n   315→        \"\"\"\n   316→        now = datetime.now(tz=UTC).isoformat()\n   317→        published = 0\n   318→\n   319→        with self._lock:\n   320→            for entry in entries:\n   321→                tags_json = json.dumps(entry.tags)\n   322→                self._conn.execute(\n   323→                    \"\"\"\n   324→                    INSERT OR REPLACE INTO federated_memories\n   325→                    (project_id, key, value, tier, confidence, source,\n   326→                     source_agent, tags, created_at, updated_at,\n   327→                     published_at, origin_project_root)\n   328→                    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n   329→                    \"\"\",\n   330→                    (\n   331→                        project_id,\n   332→                        entry.key,\n   333→                        entry.value,\n   334→                        entry.tier.value if hasattr(entry.tier, \"value\") else str(entry.tier),\n   335→                        entry.confidence,\n   336→                        entry.source.value if hasattr(entry.source, \"value\") else str(entry.source),\n   337→                        entry.source_agent,\n   338→                        tags_json,\n   339→                        entry.created_at,\n   340→                        entry.updated_at,\n   341→                        now,\n   342→                        project_root,\n   343→                    ),\n   344→                )\n   345→                published += 1\n   346→\n   347→            # Update FTS index\n   348→            with contextlib.suppress(sqlite3.OperationalError):\n   349→                self._conn.execute(\"INSERT INTO federated_fts(federated_fts) VALUES('rebuild')\")\n   350→\n   351→            # Update meta\n   352→            self._conn.execute(\n   353→                \"\"\"\n   354→                INSERT OR REPLACE INTO federation_meta\n   355→                (project_id, last_sync, entry_count)\n   356→                VALUES (?, ?, (SELECT COUNT(*) FROM federated_memories WHERE project_id = ?))\n   357→                \"\"\",\n   358→                (project_id, now, project_id),\n   359→            )\n   360→            self._conn.commit()\n   361→\n   362→        logger.info(\n   363→            \"federation.published\",\n   364→            project_id=project_id,\n   365→            count=published,\n   366→        )\n   367→        return published\n   368→\n   369→    def unpublish(self, project_id: str, keys: list[str] | None = None) -> int:\n   370→        \"\"\"Remove memories from the hub.\n   371→\n   372→        Args:\n   373→            project_id: Source project identifier.\n   374→            keys: Specific keys to remove. If None, removes all for this project.\n   375→\n   376→        Returns:\n   377→            Number of entries removed.\n   378→        \"\"\"\n   379→        with self._lock:\n   380→            if keys:\n   381→                placeholders = \",\".join(\"?\" for _ in keys)\n   382→                cursor = self._conn.execute(\n   383→                    \"DELETE FROM federated_memories\"\n   384→                    f\" WHERE project_id = ? AND key IN ({placeholders})\",\n   385→                    [project_id, *keys],\n   386→                )\n   387→            else:\n   388→                cursor = self._conn.execute(\n   389→                    \"DELETE FROM federated_memories WHERE project_id = ?\",\n   390→                    (project_id,),\n   391→                )\n   392→            removed = cursor.rowcount\n   393→            self._conn.commit()\n   394→\n   395→        logger.info(\n   396→            \"federation.unpublished\",\n   397→            project_id=project_id,\n   398→            count=removed,\n   399→        )\n   400→        return removed\n   401→\n   402→    # ------------------------------------------------------------------\n   403→    # Search & Query\n   404→    # ------------------------------------------------------------------\n   405→\n   406→    def search(\n   407→        self,\n   408→        query: str,\n   409→        project_ids: list[str] | None = None,\n   410→        tags: list[str] | None = None,\n   411→        min_confidence: float = 0.0,\n   412→        limit: int = 50,\n   413→    ) -> list[dict[str, Any]]:\n   414→        \"\"\"Search federated memories with optional filtering.\n   415→\n   416→        Args:\n   417→            query: Full-text search query.\n   418→            project_ids: Limit to specific projects.\n   419→            tags: Require entries to have at least one of these tags.\n   420→            min_confidence: Minimum confidence threshold.\n   421→            limit: Maximum results.\n   422→\n   423→        Returns:\n   424→            List of matching entries as dicts with project attribution.\n   425→        \"\"\"\n   426→        with self._lock:\n   427→            # Try FTS5 first\n   428→            try:\n   429→                rows = self._conn.execute(\n   430→                    \"\"\"\n   431→                    SELECT fm.*, rank\n   432→                    FROM federated_fts fts\n   433→                    JOIN federated_memories fm ON fts.rowid = fm.rowid\n   434→                    WHERE fts MATCH ?\n   435→                    AND fm.confidence >= ?\n   436→                    ORDER BY rank\n   437→                    LIMIT ?\n   438→                    \"\"\",\n   439→                    (query, min_confidence, limit),\n   440→                ).fetchall()\n   441→            except sqlite3.OperationalError:\n   442→                # FTS5 fallback: simple LIKE search\n   443→                rows = self._conn.execute(\n   444→                    \"\"\"\n   445→                    SELECT *, 0.0 as rank\n   446→                    FROM federated_memories\n   447→                    WHERE (key LIKE ? OR value LIKE ?)\n   448→                    AND confidence >= ?\n   449→                    LIMIT ?\n   450→                    \"\"\",\n   451→                    (f\"%{query}%\", f\"%{query}%\", min_confidence, limit),\n   452→                ).fetchall()\n   453→\n   454→        results: list[dict[str, Any]] = []\n   455→        for row in rows:\n   456→            row_dict = dict(row)\n   457→            row_tags = json.loads(row_dict.get(\"tags\", \"[]\"))\n   458→\n   459→            # Filter by project_ids\n   460→            if project_ids and row_dict[\"project_id\"] not in project_ids:\n   461→                continue\n   462→\n   463→            # Filter by tags\n   464→            if tags and not set(tags) & set(row_tags):\n   465→                continue\n   466→\n   467→            row_dict[\"tags\"] = row_tags\n   468→            results.append(row_dict)\n   469→\n   470→        return results[:limit]\n   471→\n   472→    def get_project_entries(\n   473→        self,\n   474→        project_id: str,\n   475→        limit: int = 100,\n   476→    ) -> list[dict[str, Any]]:\n   477→        \"\"\"Get all entries for a specific project.\"\"\"\n   478→        with self._lock:\n   479→            rows = self._conn.execute(\n   480→                \"\"\"\n   481→                SELECT * FROM federated_memories\n   482→                WHERE project_id = ?\n   483→                ORDER BY updated_at DESC\n   484→                LIMIT ?\n   485→                \"\"\",\n   486→                (project_id, limit),\n   487→            ).fetchall()\n   488→\n   489→        results: list[dict[str, Any]] = []\n   490→        for row in rows:\n   491→            row_dict = dict(row)\n   492→            row_dict[\"tags\"] = json.loads(row_dict.get(\"tags\", \"[]\"))\n   493→            results.append(row_dict)\n   494→        return results\n   495→\n   496→    def get_stats(self) -> dict[str, Any]:\n   497→        \"\"\"Return federation hub statistics.\"\"\"\n   498→        with self._lock:\n   499→            total = self._conn.execute(\"SELECT COUNT(*) FROM federated_memories\").fetchone()[0]\n   500→\n   501→            project_counts = self._conn.execute(\n   502→                \"\"\"\n   503→                SELECT project_id, COUNT(*) as cnt\n   504→                FROM federated_memories\n   505→                GROUP BY project_id\n   506→                \"\"\",\n   507→            ).fetchall()\n   508→\n   509→            meta_rows = self._conn.execute(\"SELECT * FROM federation_meta\").fetchall()\n   510→\n   511→        return {\n   512→            \"total_entries\": total,\n   513→            \"projects\": {row[0]: row[1] for row in project_counts},\n   514→            \"meta\": [dict(row) for row in meta_rows],\n   515→        }\n   516→\n   517→\n   518→# ---------------------------------------------------------------------------\n   519→# Sync operations\n   520→# ---------------------------------------------------------------------------\n   521→\n   522→\n   523→def sync_to_hub(\n   524→    store: MemoryStore,\n   525→    federated_store: FederatedStore,\n   526→    project_id: str,\n   527→    project_root: str = \"\",\n   528→    keys: list[str] | None = None,\n   529→) -> dict[str, int]:\n   530→    \"\"\"Publish shared-scope memories from local store to federation hub.\n   531→\n   532→    Args:\n   533→        store: Local MemoryStore instance.\n   534→        federated_store: Federation hub store.\n   535→        project_id: This project's federation ID.\n   536→        project_root: This project's root path.\n   537→        keys: Specific keys to publish. If None, publishes all shared-scope.\n   538→\n   539→    Returns:\n   540→        Dict with published and skipped counts.\n   541→    \"\"\"\n   542→    all_entries = store.list_all(scope=\"shared\")\n   543→\n   544→    entries = [e for e in all_entries if e.key in set(keys)] if keys else all_entries\n   545→\n   546→    if not entries:\n   547→        return {\"published\": 0, \"skipped\": 0}\n   548→\n   549→    published = federated_store.publish(\n   550→        project_id=project_id,\n   551→        entries=entries,\n   552→        project_root=project_root,\n   553→    )\n   554→\n   555→    return {\n   556→        \"published\": published,\n   557→        \"skipped\": len(all_entries) - published,\n   558→    }\n   559→\n   560→\n   561→def sync_from_hub(\n   562→    store: MemoryStore,\n   563→    federated_store: FederatedStore,\n   564→    project_id: str,\n   565→    config: FederationConfig | None = None,\n   566→) -> dict[str, int]:\n   567→    \"\"\"Pull subscribed memories from federation hub into local store.\n   568→\n   569→    Args:\n   570→        store: Local MemoryStore instance.\n   571→        federated_store: Federation hub store.\n   572→        project_id: This project's federation ID.\n   573→        config: Federation config (loaded if None).\n   574→\n   575→    Returns:\n   576→        Dict with imported, skipped, and conflict counts.\n   577→    \"\"\"\n   578→    if config is None:\n   579→        config = load_federation_config()\n   580→\n   581→    # Find subscription for this project\n   582→    subscription = None\n   583→    for sub in config.subscriptions:\n   584→        if sub.subscriber == project_id:\n   585→            subscription = sub\n   586→            break\n   587→\n   588→    if subscription is None:\n   589→        return {\"imported\": 0, \"skipped\": 0, \"conflicts\": 0}\n   590→\n   591→    # Query hub for matching entries\n   592→    source_ids = subscription.sources or [\n   593→        p.project_id for p in config.projects if p.project_id != project_id\n   594→    ]\n   595→\n   596→    imported = 0\n   597→    skipped = 0\n   598→    conflicts = 0\n   599→\n   600→    for source_id in source_ids:\n   601→        entries = federated_store.get_project_entries(source_id)\n   602→\n   603→        for entry_dict in entries:\n   604→            # Apply confidence filter\n   605→            if entry_dict.get(\"confidence\", 0) < subscription.min_confidence:\n   606→                skipped += 1\n   607→                continue\n   608→\n   609→            # Apply tag filter\n   610→            entry_tags = entry_dict.get(\"tags\", [])\n   611→            if subscription.tag_filter and not set(subscription.tag_filter) & set(entry_tags):\n   612→                skipped += 1\n   613→                continue\n   614→\n   615→            key = entry_dict[\"key\"]\n   616→\n   617→            # Check for local conflict\n   618→            local = store.get(key)\n   619→            if local is not None:\n   620→                # Local always wins\n   621→                conflicts += 1\n   622→                continue\n   623→\n   624→            # Import into local store\n   625→            store.save(\n   626→                key=key,\n   627→                value=entry_dict[\"value\"],\n   628→                tier=entry_dict.get(\"tier\", \"pattern\"),\n   629→                source=\"system\",\n   630→                source_agent=f\"federated:{source_id}\",\n   631→                scope=\"project\",\n   632→                tags=[*entry_tags, \"federated\", f\"from:{source_id}\"],\n   633→            )\n   634→            imported += 1\n   635→\n   636→    logger.info(\n   637→        \"federation.synced_from_hub\",\n   638→        project_id=project_id,\n   639→        imported=imported,\n   640→        skipped=skipped,\n   641→        conflicts=conflicts,\n   642→    )\n   643→\n   644→    return {\n   645→        \"imported\": imported,\n   646→        \"skipped\": skipped,\n   647→        \"conflicts\": conflicts,\n   648→    }\n   649→\n   650→\n   651→# ---------------------------------------------------------------------------\n   652→# Federated search\n   653→# ---------------------------------------------------------------------------\n   654→\n   655→\n   656→@dataclass\n   657→class FederatedSearchResult:\n   658→    \"\"\"A search result with project attribution.\"\"\"\n   659→\n   660→    key: str\n   661→    value: str\n   662→    source: str  # \"local\" or \"federated\"\n   663→    project_id: str\n   664→    confidence: float = 0.0\n   665→    tier: str = \"pattern\"\n   666→    tags: list[str] = field(default_factory=list)\n   667→    relevance_score: float = 0.0\n   668→\n   669→\n   670→def federated_search(\n   671→    query: str,\n   672→    local_store: MemoryStore,\n   673→    federated_store: FederatedStore,\n   674→    project_id: str,\n   675→    include_local: bool = True,\n   676→    include_hub: bool = True,\n   677→    max_results: int = 20,\n   678→) -> list[FederatedSearchResult]:\n   679→    \"\"\"Search across local and federated memory stores.\n   680→\n   681→    Local results get a 1.2x relevance boost. Results are deduplicated\n   682→    by key (local wins on collision).\n   683→\n   684→    Args:\n   685→        query: Search query string.\n   686→        local_store: Local MemoryStore instance.\n   687→        federated_store: Federation hub store.\n   688→        project_id: This project's federation ID.\n   689→        include_local: Include local store results.\n   690→        include_hub: Include hub results.\n   691→        max_results: Maximum results to return.\n   692→\n   693→    Returns:\n   694→        Sorted list of FederatedSearchResult.\n   695→    \"\"\"\n   696→    results: list[FederatedSearchResult] = []\n   697→    seen_keys: set[str] = set()\n   698→\n   699→    # Local results first (with boost)\n   700→    if include_local:\n   701→        local_results = local_store.search(query)\n   702→        for entry in local_results:\n   703→            if entry.key in seen_keys:\n   704→                continue\n   705→            seen_keys.add(entry.key)\n   706→            results.append(\n   707→                FederatedSearchResult(\n   708→                    key=entry.key,\n   709→                    value=entry.value,\n   710→                    source=\"local\",\n   711→                    project_id=project_id,\n   712→                    confidence=entry.confidence,\n   713→                    tier=entry.tier.value if hasattr(entry.tier, \"value\") else str(entry.tier),\n   714→                    tags=entry.tags,\n   715→                    relevance_score=entry.confidence * 1.2,  # local boost\n   716→                )\n   717→            )\n   718→\n   719→    # Hub results\n   720→    if include_hub:\n   721→        hub_results = federated_store.search(\n   722→            query=query,\n   723→            limit=max_results * 2,  # fetch more, filter after dedup\n   724→        )\n   725→        for row in hub_results:\n   726→            key = row[\"key\"]\n   727→            if key in seen_keys:\n   728→                continue\n   729→            seen_keys.add(key)\n   730→            results.append(\n   731→                FederatedSearchResult(\n   732→                    key=key,\n   733→                    value=row[\"value\"],\n   734→                    source=\"federated\",\n   735→                    project_id=row[\"project_id\"],\n   736→                    confidence=row.get(\"confidence\", 0.0),\n   737→                    tier=row.get(\"tier\", \"pattern\"),\n   738→                    tags=row.get(\"tags\", []),\n   739→                    relevance_score=row.get(\"confidence\", 0.0),\n   740→                )\n   741→            )\n   742→\n   743→    # Sort by relevance (descending)\n   744→    results.sort(key=lambda r: r.relevance_score, reverse=True)\n   745→\n   746→    return results[:max_results]\n   747→"}]},"parent_tool_use_id":null,"session_id":"432b4479-d665-4641-add7-8ce0bc4cd0e0","uuid":"69db3f7e-ae7a-4033-b4b0-726041069dec","timestamp":"2026-03-22T22:28:12.694Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\cursor\\tapps-brain\\src\\tapps_brain\\federation.py","content":"\"\"\"Cross-project memory federation.\n\nEnables memory sharing across projects via a central hub store\nat ``~/.tapps-mcp/memory/federated.db``.  Projects explicitly publish\nshared-scope memories to the hub and subscribe to memories from\nother projects.\n\nEpic 64 — all operations are explicit (no automatic sharing).\n\"\"\"\n\nfrom __future__ import annotations\n\nimport contextlib\nimport json\nimport sqlite3\nimport threading\nfrom dataclasses import dataclass, field\nfrom datetime import UTC, datetime\nfrom pathlib import Path\nfrom typing import TYPE_CHECKING, Any\n\nimport structlog\nimport yaml\nfrom pydantic import BaseModel, ConfigDict, Field\n\nif TYPE_CHECKING:\n    from tapps_brain.models import MemoryEntry\n    from tapps_brain.store import MemoryStore\n\nlogger: structlog.stdlib.BoundLogger = structlog.get_logger(__name__)\n\n_DEFAULT_HUB_DIR = Path.home() / \".tapps-brain\" / \"memory\"\n_MAX_PROJECTS = 50\n_MAX_SUBSCRIPTIONS = 50\n\n\n# ---------------------------------------------------------------------------\n# Configuration models\n# ---------------------------------------------------------------------------\n\n\nclass FederationProject(BaseModel):\n    \"\"\"A registered project in the federation hub.\"\"\"\n\n    model_config = ConfigDict(extra=\"forbid\")\n\n    project_id: str = Field(description=\"Unique project identifier (slug).\")\n    project_root: str = Field(description=\"Absolute path to project root.\")\n    registered_at: str = Field(default=\"\", description=\"ISO-8601 UTC registration time.\")\n    tags: list[str] = Field(default_factory=list, description=\"Project tags for filtering.\")\n\n\nclass FederationSubscription(BaseModel):\n    \"\"\"Subscription from one project to others.\"\"\"\n\n    model_config = ConfigDict(extra=\"forbid\")\n\n    subscriber: str = Field(description=\"Subscribing project ID.\")\n    sources: list[str] = Field(\n        default_factory=list,\n        description=\"Source project IDs to subscribe to (empty = all).\",\n    )\n    tag_filter: list[str] = Field(\n        default_factory=list,\n        description=\"Only import memories with these tags.\",\n    )\n    min_confidence: float = Field(\n        default=0.5,\n        ge=0.0,\n        le=1.0,\n        description=\"Minimum confidence threshold for imported memories.\",\n    )\n\n\nclass FederationConfig(BaseModel):\n    \"\"\"Root config for federation stored at ~/.tapps-mcp/memory/federation.yaml.\"\"\"\n\n    model_config = ConfigDict(extra=\"forbid\")\n\n    hub_path: str = Field(\n        default=\"\",\n        description=\"Path to federated.db (default: ~/.tapps-mcp/memory/federated.db).\",\n    )\n    projects: list[FederationProject] = Field(default_factory=list)\n    subscriptions: list[FederationSubscription] = Field(default_factory=list)\n\n\n# ---------------------------------------------------------------------------\n# Config file management\n# ---------------------------------------------------------------------------\n\n\ndef _config_path() -> Path:\n    \"\"\"Return the path to federation.yaml.\"\"\"\n    return _DEFAULT_HUB_DIR / \"federation.yaml\"\n\n\ndef load_federation_config() -> FederationConfig:\n    \"\"\"Load federation config from disk, creating defaults if absent.\"\"\"\n    path = _config_path()\n    if not path.exists():\n        return FederationConfig()\n    raw = yaml.safe_load(path.read_text(encoding=\"utf-8\"))\n    if raw is None or not isinstance(raw, dict):\n        return FederationConfig()\n    return FederationConfig(**raw)\n\n\ndef save_federation_config(config: FederationConfig) -> None:\n    \"\"\"Persist federation config to disk.\"\"\"\n    path = _config_path()\n    path.parent.mkdir(parents=True, exist_ok=True)\n    data = config.model_dump(mode=\"json\")\n    path.write_text(\n        yaml.safe_dump(data, default_flow_style=False, sort_keys=False),\n        encoding=\"utf-8\",\n    )\n    logger.info(\"federation_config.saved\", path=str(path))\n\n\ndef register_project(\n    project_id: str,\n    project_root: str,\n    tags: list[str] | None = None,\n) -> FederationConfig:\n    \"\"\"Register a project in the federation hub.\n\n    Returns the updated config.\n    \"\"\"\n    config = load_federation_config()\n\n    # Check for duplicates\n    existing_ids = {p.project_id for p in config.projects}\n    if project_id in existing_ids:\n        logger.info(\"federation.project_already_registered\", project_id=project_id)\n        # Update tags if provided\n        for proj in config.projects:\n            if proj.project_id == project_id:\n                if tags is not None:\n                    proj.tags = tags\n                proj.project_root = project_root\n                break\n        save_federation_config(config)\n        return config\n\n    if len(config.projects) >= _MAX_PROJECTS:\n        msg = f\"Federation hub has reached max projects ({_MAX_PROJECTS})\"\n        raise ValueError(msg)\n\n    config.projects.append(\n        FederationProject(\n            project_id=project_id,\n            project_root=project_root,\n            registered_at=datetime.now(tz=UTC).isoformat(),\n            tags=tags or [],\n        )\n    )\n    save_federation_config(config)\n    logger.info(\"federation.project_registered\", project_id=project_id)\n    return config\n\n\ndef unregister_project(project_id: str) -> FederationConfig:\n    \"\"\"Remove a project from the federation hub.\"\"\"\n    config = load_federation_config()\n    config.projects = [p for p in config.projects if p.project_id != project_id]\n    config.subscriptions = [s for s in config.subscriptions if s.subscriber != project_id]\n    save_federation_config(config)\n    logger.info(\"federation.project_unregistered\", project_id=project_id)\n    return config\n\n\ndef add_subscription(\n    subscriber: str,\n    sources: list[str] | None = None,\n    tag_filter: list[str] | None = None,\n    min_confidence: float = 0.5,\n) -> FederationConfig:\n    \"\"\"Add or update a subscription for a project.\"\"\"\n    config = load_federation_config()\n\n    # Validate subscriber exists\n    project_ids = {p.project_id for p in config.projects}\n    if subscriber not in project_ids:\n        msg = f\"Subscriber '{subscriber}' is not registered in the federation hub\"\n        raise ValueError(msg)\n\n    # Validate sources exist\n    if sources:\n        unknown = set(sources) - project_ids\n        if unknown:\n            msg = f\"Unknown source project(s): {sorted(unknown)}\"\n            raise ValueError(msg)\n\n    # Remove existing subscription for this subscriber (replace)\n    config.subscriptions = [s for s in config.subscriptions if s.subscriber != subscriber]\n\n    if len(config.subscriptions) >= _MAX_SUBSCRIPTIONS:\n        msg = f\"Federation hub has reached max subscriptions ({_MAX_SUBSCRIPTIONS})\"\n        raise ValueError(msg)\n\n    config.subscriptions.append(\n        FederationSubscription(\n            subscriber=subscriber,\n            sources=sources or [],\n            tag_filter=tag_filter or [],\n            min_confidence=min_confidence,\n        )\n    )\n    save_federation_config(config)\n    logger.info(\n        \"federation.subscription_added\",\n        subscriber=subscriber,\n        sources=sources or [\"all\"],\n    )\n    return config\n\n\n# ---------------------------------------------------------------------------\n# Federated Hub Store (SQLite)\n# ---------------------------------------------------------------------------\n\n\nclass FederatedStore:\n    \"\"\"Central hub for cross-project memory federation.\n\n    Uses a SQLite database at ``~/.tapps-mcp/memory/federated.db`` with\n    composite primary key ``(project_id, key)`` and FTS5 for search.\n    \"\"\"\n\n    def __init__(self, db_path: Path | None = None) -> None:\n        self._db_path = db_path or (_DEFAULT_HUB_DIR / \"federated.db\")\n        self._db_path.parent.mkdir(parents=True, exist_ok=True)\n        self._lock = threading.Lock()\n        self._conn = self._connect()\n        self._ensure_schema()\n\n    def _connect(self) -> sqlite3.Connection:\n        conn = sqlite3.connect(\n            str(self._db_path),\n            check_same_thread=False,\n        )\n        conn.row_factory = sqlite3.Row\n        conn.execute(\"PRAGMA journal_mode=WAL\")\n        conn.execute(\"PRAGMA busy_timeout=5000\")\n        conn.execute(\"PRAGMA foreign_keys=ON\")\n        return conn\n\n    def _ensure_schema(self) -> None:\n        with self._lock:\n            self._conn.executescript(\"\"\"\n                CREATE TABLE IF NOT EXISTS federated_memories (\n                    project_id TEXT NOT NULL,\n                    key TEXT NOT NULL,\n                    value TEXT NOT NULL,\n                    tier TEXT NOT NULL DEFAULT 'pattern',\n                    confidence REAL NOT NULL DEFAULT 0.6,\n                    source TEXT NOT NULL DEFAULT 'agent',\n                    source_agent TEXT NOT NULL DEFAULT 'unknown',\n                    tags TEXT NOT NULL DEFAULT '[]',\n                    created_at TEXT NOT NULL,\n                    updated_at TEXT NOT NULL,\n                    published_at TEXT NOT NULL,\n                    origin_project_root TEXT NOT NULL DEFAULT '',\n                    PRIMARY KEY (project_id, key)\n                );\n\n                CREATE INDEX IF NOT EXISTS idx_fed_project\n                    ON federated_memories(project_id);\n                CREATE INDEX IF NOT EXISTS idx_fed_confidence\n                    ON federated_memories(confidence);\n                CREATE INDEX IF NOT EXISTS idx_fed_tier\n                    ON federated_memories(tier);\n\n                CREATE TABLE IF NOT EXISTS federation_meta (\n                    project_id TEXT PRIMARY KEY,\n                    last_sync TEXT NOT NULL,\n                    entry_count INTEGER NOT NULL DEFAULT 0\n                );\n            \"\"\")\n\n            # FTS5 table -- created separately (can't use executescript reliably)\n            with contextlib.suppress(sqlite3.OperationalError):\n                self._conn.execute(\"\"\"\n                    CREATE VIRTUAL TABLE IF NOT EXISTS federated_fts\n                    USING fts5(key, value, tags, content=federated_memories, content_rowid=rowid)\n                \"\"\")\n\n            self._conn.commit()\n\n    def close(self) -> None:\n        \"\"\"Close the database connection.\"\"\"\n        with self._lock:\n            self._conn.close()\n\n    # ------------------------------------------------------------------\n    # Publish / Unpublish\n    # ------------------------------------------------------------------\n\n    def publish(\n        self,\n        project_id: str,\n        entries: list[MemoryEntry],\n        project_root: str = \"\",\n    ) -> int:\n        \"\"\"Publish memories to the federation hub.\n\n        Args:\n            project_id: Source project identifier.\n            entries: Memory entries to publish.\n            project_root: Source project root path for traceability.\n\n        Returns:\n            Number of entries published.\n        \"\"\"\n        now = datetime.now(tz=UTC).isoformat()\n        published = 0\n\n        with self._lock:\n            for entry in entries:\n                tags_json = json.dumps(entry.tags)\n                self._conn.execute(\n                    \"\"\"\n                    INSERT OR REPLACE INTO federated_memories\n                    (project_id, key, value, tier, confidence, source,\n                     source_agent, tags, created_at, updated_at,\n                     published_at, origin_project_root)\n                    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n                    \"\"\",\n                    (\n                        project_id,\n                        entry.key,\n                        entry.value,\n                        entry.tier.value if hasattr(entry.tier, \"value\") else str(entry.tier),\n                        entry.confidence,\n                        entry.source.value if hasattr(entry.source, \"value\") else str(entry.source),\n                        entry.source_agent,\n                        tags_json,\n                        entry.created_at,\n                        entry.updated_at,\n                        now,\n                        project_root,\n                    ),\n                )\n                published += 1\n\n            # Update FTS index\n            with contextlib.suppress(sqlite3.OperationalError):\n                self._conn.execute(\"INSERT INTO federated_fts(federated_fts) VALUES('rebuild')\")\n\n            # Update meta\n            self._conn.execute(\n                \"\"\"\n                INSERT OR REPLACE INTO federation_meta\n                (project_id, last_sync, entry_count)\n                VALUES (?, ?, (SELECT COUNT(*) FROM federated_memories WHERE project_id = ?))\n                \"\"\",\n                (project_id, now, project_id),\n            )\n            self._conn.commit()\n\n        logger.info(\n            \"federation.published\",\n            project_id=project_id,\n            count=published,\n        )\n        return published\n\n    def unpublish(self, project_id: str, keys: list[str] | None = None) -> int:\n        \"\"\"Remove memories from the hub.\n\n        Args:\n            project_id: Source project identifier.\n            keys: Specific keys to remove. If None, removes all for this project.\n\n        Returns:\n            Number of entries removed.\n        \"\"\"\n        with self._lock:\n            if keys:\n                placeholders = \",\".join(\"?\" for _ in keys)\n                cursor = self._conn.execute(\n                    \"DELETE FROM federated_memories\"\n                    f\" WHERE project_id = ? AND key IN ({placeholders})\",\n                    [project_id, *keys],\n                )\n            else:\n                cursor = self._conn.execute(\n                    \"DELETE FROM federated_memories WHERE project_id = ?\",\n                    (project_id,),\n                )\n            removed = cursor.rowcount\n            self._conn.commit()\n\n        logger.info(\n            \"federation.unpublished\",\n            project_id=project_id,\n            count=removed,\n        )\n        return removed\n\n    # ------------------------------------------------------------------\n    # Search & Query\n    # ------------------------------------------------------------------\n\n    def search(\n        self,\n        query: str,\n        project_ids: list[str] | None = None,\n        tags: list[str] | None = None,\n        min_confidence: float = 0.0,\n        limit: int = 50,\n    ) -> list[dict[str, Any]]:\n        \"\"\"Search federated memories with optional filtering.\n\n        Args:\n            query: Full-text search query.\n            project_ids: Limit to specific projects.\n            tags: Require entries to have at least one of these tags.\n            min_confidence: Minimum confidence threshold.\n            limit: Maximum results.\n\n        Returns:\n            List of matching entries as dicts with project attribution.\n        \"\"\"\n        with self._lock:\n            # Try FTS5 first\n            try:\n                rows = self._conn.execute(\n                    \"\"\"\n                    SELECT fm.*, rank\n                    FROM federated_fts fts\n                    JOIN federated_memories fm ON fts.rowid = fm.rowid\n                    WHERE fts MATCH ?\n                    AND fm.confidence >= ?\n                    ORDER BY rank\n                    LIMIT ?\n                    \"\"\",\n                    (query, min_confidence, limit),\n                ).fetchall()\n            except sqlite3.OperationalError:\n                # FTS5 fallback: simple LIKE search\n                rows = self._conn.execute(\n                    \"\"\"\n                    SELECT *, 0.0 as rank\n                    FROM federated_memories\n                    WHERE (key LIKE ? OR value LIKE ?)\n                    AND confidence >= ?\n                    LIMIT ?\n                    \"\"\",\n                    (f\"%{query}%\", f\"%{query}%\", min_confidence, limit),\n                ).fetchall()\n\n        results: list[dict[str, Any]] = []\n        for row in rows:\n            row_dict = dict(row)\n            row_tags = json.loads(row_dict.get(\"tags\", \"[]\"))\n\n            # Filter by project_ids\n            if project_ids and row_dict[\"project_id\"] not in project_ids:\n                continue\n\n            # Filter by tags\n            if tags and not set(tags) & set(row_tags):\n                continue\n\n            row_dict[\"tags\"] = row_tags\n            results.append(row_dict)\n\n        return results[:limit]\n\n    def get_project_entries(\n        self,\n        project_id: str,\n        limit: int = 100,\n    ) -> list[dict[str, Any]]:\n        \"\"\"Get all entries for a specific project.\"\"\"\n        with self._lock:\n            rows = self._conn.execute(\n                \"\"\"\n                SELECT * FROM federated_memories\n                WHERE project_id = ?\n                ORDER BY updated_at DESC\n                LIMIT ?\n                \"\"\",\n                (project_id, limit),\n            ).fetchall()\n\n        results: list[dict[str, Any]] = []\n        for row in rows:\n            row_dict = dict(row)\n            row_dict[\"tags\"] = json.loads(row_dict.get(\"tags\", \"[]\"))\n            results.append(row_dict)\n        return results\n\n    def get_stats(self) -> dict[str, Any]:\n        \"\"\"Return federation hub statistics.\"\"\"\n        with self._lock:\n            total = self._conn.execute(\"SELECT COUNT(*) FROM federated_memories\").fetchone()[0]\n\n            project_counts = self._conn.execute(\n                \"\"\"\n                SELECT project_id, COUNT(*) as cnt\n                FROM federated_memories\n                GROUP BY project_id\n                \"\"\",\n            ).fetchall()\n\n            meta_rows = self._conn.execute(\"SELECT * FROM federation_meta\").fetchall()\n\n        return {\n            \"total_entries\": total,\n            \"projects\": {row[0]: row[1] for row in project_counts},\n            \"meta\": [dict(row) for row in meta_rows],\n        }\n\n\n# ---------------------------------------------------------------------------\n# Sync operations\n# ---------------------------------------------------------------------------\n\n\ndef sync_to_hub(\n    store: MemoryStore,\n    federated_store: FederatedStore,\n    project_id: str,\n    project_root: str = \"\",\n    keys: list[str] | None = None,\n) -> dict[str, int]:\n    \"\"\"Publish shared-scope memories from local store to federation hub.\n\n    Args:\n        store: Local MemoryStore instance.\n        federated_store: Federation hub store.\n        project_id: This project's federation ID.\n        project_root: This project's root path.\n        keys: Specific keys to publish. If None, publishes all shared-scope.\n\n    Returns:\n        Dict with published and skipped counts.\n    \"\"\"\n    all_entries = store.list_all(scope=\"shared\")\n\n    entries = [e for e in all_entries if e.key in set(keys)] if keys else all_entries\n\n    if not entries:\n        return {\"published\": 0, \"skipped\": 0}\n\n    published = federated_store.publish(\n        project_id=project_id,\n        entries=entries,\n        project_root=project_root,\n    )\n\n    return {\n        \"published\": published,\n        \"skipped\": len(all_entries) - published,\n    }\n\n\ndef sync_from_hub(\n    store: MemoryStore,\n    federated_store: FederatedStore,\n    project_id: str,\n    config: FederationConfig | None = None,\n) -> dict[str, int]:\n    \"\"\"Pull subscribed memories from federation hub into local store.\n\n    Args:\n        store: Local MemoryStore instance.\n        federated_store: Federation hub store.\n        project_id: This project's federation ID.\n        config: Federation config (loaded if None).\n\n    Returns:\n        Dict with imported, skipped, and conflict counts.\n    \"\"\"\n    if config is None:\n        config = load_federation_config()\n\n    # Find subscription for this project\n    subscription = None\n    for sub in config.subscriptions:\n        if sub.subscriber == project_id:\n            subscription = sub\n            break\n\n    if subscription is None:\n        return {\"imported\": 0, \"skipped\": 0, \"conflicts\": 0}\n\n    # Query hub for matching entries\n    source_ids = subscription.sources or [\n        p.project_id for p in config.projects if p.project_id != project_id\n    ]\n\n    imported = 0\n    skipped = 0\n    conflicts = 0\n\n    for source_id in source_ids:\n        entries = federated_store.get_project_entries(source_id)\n\n        for entry_dict in entries:\n            # Apply confidence filter\n            if entry_dict.get(\"confidence\", 0) < subscription.min_confidence:\n                skipped += 1\n                continue\n\n            # Apply tag filter\n            entry_tags = entry_dict.get(\"tags\", [])\n            if subscription.tag_filter and not set(subscription.tag_filter) & set(entry_tags):\n                skipped += 1\n                continue\n\n            key = entry_dict[\"key\"]\n\n            # Check for local conflict\n            local = store.get(key)\n            if local is not None:\n                # Local always wins\n                conflicts += 1\n                continue\n\n            # Import into local store\n            store.save(\n                key=key,\n                value=entry_dict[\"value\"],\n                tier=entry_dict.get(\"tier\", \"pattern\"),\n                source=\"system\",\n                source_agent=f\"federated:{source_id}\",\n                scope=\"project\",\n                tags=[*entry_tags, \"federated\", f\"from:{source_id}\"],\n            )\n            imported += 1\n\n    logger.info(\n        \"federation.synced_from_hub\",\n        project_id=project_id,\n        imported=imported,\n        skipped=skipped,\n        conflicts=conflicts,\n    )\n\n    return {\n        \"imported\": imported,\n        \"skipped\": skipped,\n        \"conflicts\": conflicts,\n    }\n\n\n# ---------------------------------------------------------------------------\n# Federated search\n# ---------------------------------------------------------------------------\n\n\n@dataclass\nclass FederatedSearchResult:\n    \"\"\"A search result with project attribution.\"\"\"\n\n    key: str\n    value: str\n    source: str  # \"local\" or \"federated\"\n    project_id: str\n    confidence: float = 0.0\n    tier: str = \"pattern\"\n    tags: list[str] = field(default_factory=list)\n    relevance_score: float = 0.0\n\n\ndef federated_search(\n    query: str,\n    local_store: MemoryStore,\n    federated_store: FederatedStore,\n    project_id: str,\n    include_local: bool = True,\n    include_hub: bool = True,\n    max_results: int = 20,\n) -> list[FederatedSearchResult]:\n    \"\"\"Search across local and federated memory stores.\n\n    Local results get a 1.2x relevance boost. Results are deduplicated\n    by key (local wins on collision).\n\n    Args:\n        query: Search query string.\n        local_store: Local MemoryStore instance.\n        federated_store: Federation hub store.\n        project_id: This project's federation ID.\n        include_local: Include local store results.\n        include_hub: Include hub results.\n        max_results: Maximum results to return.\n\n    Returns:\n        Sorted list of FederatedSearchResult.\n    \"\"\"\n    results: list[FederatedSearchResult] = []\n    seen_keys: set[str] = set()\n\n    # Local results first (with boost)\n    if include_local:\n        local_results = local_store.search(query)\n        for entry in local_results:\n            if entry.key in seen_keys:\n                continue\n            seen_keys.add(entry.key)\n            results.append(\n                FederatedSearchResult(\n                    key=entry.key,\n                    value=entry.value,\n                    source=\"local\",\n                    project_id=project_id,\n                    confidence=entry.confidence,\n                    tier=entry.tier.value if hasattr(entry.tier, \"value\") else str(entry.tier),\n                    tags=entry.tags,\n                    relevance_score=entry.confidence * 1.2,  # local boost\n                )\n            )\n\n    # Hub results\n    if include_hub:\n        hub_results = federated_store.search(\n            query=query,\n            limit=max_results * 2,  # fetch more, filter after dedup\n        )\n        for row in hub_results:\n            key = row[\"key\"]\n            if key in seen_keys:\n                continue\n            seen_keys.add(key)\n            results.append(\n                FederatedSearchResult(\n                    key=key,\n                    value=row[\"value\"],\n                    source=\"federated\",\n                    project_id=row[\"project_id\"],\n                    confidence=row.get(\"confidence\", 0.0),\n                    tier=row.get(\"tier\", \"pattern\"),\n                    tags=row.get(\"tags\", []),\n                    relevance_score=row.get(\"confidence\", 0.0),\n                )\n            )\n\n    # Sort by relevance (descending)\n    results.sort(key=lambda r: r.relevance_score, reverse=True)\n\n    return results[:max_results]\n","numLines":747,"startLine":1,"totalLines":747}}}
