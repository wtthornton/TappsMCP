{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013tqzGk4fEFKJsg6aff6c69","type":"tool_result","content":"     1→\"\"\"Auto-consolidation triggers for memory subsystem (Epic 58, Story 58.3).\n     2→\n     3→Provides automatic consolidation of similar memory entries:\n     4→- On save: Check if new entry should be consolidated with existing entries\n     5→- On session start: Periodic scan to find and consolidate related entries\n     6→\"\"\"\n     7→\n     8→from __future__ import annotations\n     9→\n    10→import contextlib\n    11→import json\n    12→from datetime import UTC, datetime\n    13→from pathlib import Path  # noqa: TC003 - Used at runtime for Path operations\n    14→from typing import TYPE_CHECKING, Any\n    15→\n    16→import structlog\n    17→\n    18→from tapps_brain.consolidation import (\n    19→    consolidate,\n    20→    detect_consolidation_reason,\n    21→    merge_entry_relations,\n    22→    should_consolidate,\n    23→)\n    24→from tapps_brain.models import (\n    25→    ConsolidatedEntry,\n    26→    MemoryEntry,\n    27→    _utc_now_iso,\n    28→)\n    29→from tapps_brain.similarity import find_consolidation_groups\n    30→\n    31→if TYPE_CHECKING:\n    32→    from tapps_brain.store import MemoryStore\n    33→\n    34→logger = structlog.get_logger(__name__)\n    35→\n    36→CONSOLIDATION_STATE_FILE = \".tapps-brain/memory/consolidation-state.json\"\n    37→MIN_CONSOLIDATION_ENTRIES = 2\n    38→\n    39→\n    40→class ConsolidationResult:\n    41→    \"\"\"Result of a consolidation operation.\"\"\"\n    42→\n    43→    def __init__(\n    44→        self,\n    45→        *,\n    46→        triggered: bool = False,\n    47→        consolidated_entry: ConsolidatedEntry | None = None,\n    48→        source_keys: list[str] | None = None,\n    49→        reason: str = \"\",\n    50→    ) -> None:\n    51→        self.triggered = triggered\n    52→        self.consolidated_entry = consolidated_entry\n    53→        self.source_keys = source_keys or []\n    54→        self.reason = reason\n    55→\n    56→    def to_dict(self) -> dict[str, Any]:\n    57→        \"\"\"Convert to dictionary for serialization.\"\"\"\n    58→        return {\n    59→            \"triggered\": self.triggered,\n    60→            \"consolidated_key\": (self.consolidated_entry.key if self.consolidated_entry else None),\n    61→            \"source_keys\": self.source_keys,\n    62→            \"reason\": self.reason,\n    63→        }\n    64→\n    65→\n    66→class PeriodicScanResult:\n    67→    \"\"\"Result of a periodic consolidation scan.\"\"\"\n    68→\n    69→    def __init__(\n    70→        self,\n    71→        *,\n    72→        scanned: bool = False,\n    73→        groups_found: int = 0,\n    74→        entries_consolidated: int = 0,\n    75→        consolidated_entries: list[str] | None = None,\n    76→        skipped_reason: str = \"\",\n    77→    ) -> None:\n    78→        self.scanned = scanned\n    79→        self.groups_found = groups_found\n    80→        self.entries_consolidated = entries_consolidated\n    81→        self.consolidated_entries = consolidated_entries or []\n    82→        self.skipped_reason = skipped_reason\n    83→\n    84→    def to_dict(self) -> dict[str, Any]:\n    85→        \"\"\"Convert to dictionary for serialization.\"\"\"\n    86→        return {\n    87→            \"scanned\": self.scanned,\n    88→            \"groups_found\": self.groups_found,\n    89→            \"entries_consolidated\": self.entries_consolidated,\n    90→            \"consolidated_entries\": self.consolidated_entries,\n    91→            \"skipped_reason\": self.skipped_reason,\n    92→        }\n    93→\n    94→\n    95→def check_consolidation_on_save(\n    96→    entry: MemoryEntry,\n    97→    store: MemoryStore,\n    98→    *,\n    99→    threshold: float = 0.7,\n   100→    min_entries: int = 3,\n   101→) -> ConsolidationResult:\n   102→    \"\"\"Check if a newly saved entry should trigger consolidation.\n   103→\n   104→    Called after saving a new entry. If the entry is similar to existing\n   105→    entries (above threshold), consolidates them into a single entry.\n   106→\n   107→    Args:\n   108→        entry: The newly saved/updated entry.\n   109→        store: The memory store to check against.\n   110→        threshold: Similarity threshold for consolidation.\n   111→        min_entries: Minimum entries (including new one) to trigger consolidation.\n   112→\n   113→    Returns:\n   114→        ConsolidationResult with details of the operation.\n   115→    \"\"\"\n   116→    min_entries = max(min_entries, MIN_CONSOLIDATION_ENTRIES)\n   117→\n   118→    all_entries = store.list_all()\n   119→    candidates = [e for e in all_entries if e.key != entry.key]\n   120→\n   121→    if len(candidates) < min_entries - 1:\n   122→        return ConsolidationResult(\n   123→            triggered=False,\n   124→            reason=\"not_enough_candidates\",\n   125→        )\n   126→\n   127→    matches = should_consolidate(entry, candidates, threshold=threshold)\n   128→\n   129→    if len(matches) < min_entries - 1:\n   130→        return ConsolidationResult(\n   131→            triggered=False,\n   132→            reason=\"no_similar_entries\",\n   133→        )\n   134→\n   135→    entries_to_consolidate = [entry, *matches[: min_entries - 1]]\n   136→    reason = detect_consolidation_reason(entry, matches)\n   137→\n   138→    try:\n   139→        consolidated = consolidate(entries_to_consolidate, reason=reason)\n   140→    except ValueError as exc:\n   141→        logger.debug(\n   142→            \"consolidation_failed\",\n   143→            error=str(exc),\n   144→            entry_key=entry.key,\n   145→        )\n   146→        return ConsolidationResult(\n   147→            triggered=False,\n   148→            reason=f\"consolidation_error: {exc}\",\n   149→        )\n   150→"}]},"parent_tool_use_id":"toolu_01ETxuMXE5rZCE6YhLTRE2TH","session_id":"432b4479-d665-4641-add7-8ce0bc4cd0e0","uuid":"376665be-d6e9-4a23-98d2-d999f6105baa","timestamp":"2026-03-22T22:27:14.477Z"}
