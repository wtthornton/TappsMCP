{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JXXkri9qnZX5ZP1RTbgYCE","type":"tool_result","content":"     1\t\"\"\"Sliding window rate limiter for memory write operations.\n     2\t\n     3\tProvides warn-only rate limiting to detect anomalous write bursts\n     4\twithout blocking legitimate operations. Configurable per-minute and\n     5\tper-session limits with batch context exemptions.\n     6\t\"\"\"\n     7\t\n     8\tfrom __future__ import annotations\n     9\t\n    10\timport threading\n    11\timport time\n    12\tfrom dataclasses import dataclass, field\n    13\t\n    14\timport structlog\n    15\t\n    16\tlogger = structlog.get_logger(__name__)\n    17\t\n    18\t# Default limits\n    19\t_DEFAULT_WRITES_PER_MINUTE = 20\n    20\t_DEFAULT_WRITES_PER_SESSION = 100\n    21\t\n    22\t# Batch contexts exempt from rate limiting (H6b)\n    23\tBATCH_EXEMPT_CONTEXTS: frozenset[str] = frozenset({\n    24\t    \"import_markdown\",\n    25\t    \"seed\",\n    26\t    \"federation_sync\",\n    27\t    \"consolidate\",\n    28\t})\n    29\t\n    30\t\n    31\t@dataclass\n    32\tclass RateLimiterConfig:\n    33\t    \"\"\"Configuration for the sliding window rate limiter.\"\"\"\n    34\t\n    35\t    writes_per_minute: int = _DEFAULT_WRITES_PER_MINUTE\n    36\t    writes_per_session: int = _DEFAULT_WRITES_PER_SESSION\n    37\t    enabled: bool = True\n    38\t\n    39\t\n    40\t@dataclass\n... 142 more lines (182 total - use Read tool for full file)","is_error":false}]},"parent_tool_use_id":null,"session_id":"2e34ce78-cb66-445c-866e-bb03bec88fd3","uuid":"0b4fba9f-e838-4e41-b387-ff94e2d50f2c","timestamp":"2026-03-22T22:26:25.888Z","tool_use_result":{"stdout":"     1\t\"\"\"Sliding window rate limiter for memory write operations.\n     2\t\n     3\tProvides warn-only rate limiting to detect anomalous write bursts\n     4\twithout blocking legitimate operations. Configurable per-minute and\n     5\tper-session limits with batch context exemptions.\n     6\t\"\"\"\n     7\t\n     8\tfrom __future__ import annotations\n     9\t\n    10\timport threading\n    11\timport time\n    12\tfrom dataclasses import dataclass, field\n    13\t\n    14\timport structlog\n    15\t\n    16\tlogger = structlog.get_logger(__name__)\n    17\t\n    18\t# Default limits\n    19\t_DEFAULT_WRITES_PER_MINUTE = 20\n    20\t_DEFAULT_WRITES_PER_SESSION = 100\n    21\t\n    22\t# Batch contexts exempt from rate limiting (H6b)\n    23\tBATCH_EXEMPT_CONTEXTS: frozenset[str] = frozenset({\n    24\t    \"import_markdown\",\n    25\t    \"seed\",\n    26\t    \"federation_sync\",\n    27\t    \"consolidate\",\n    28\t})\n    29\t\n    30\t\n    31\t@dataclass\n    32\tclass RateLimiterConfig:\n    33\t    \"\"\"Configuration for the sliding window rate limiter.\"\"\"\n    34\t\n    35\t    writes_per_minute: int = _DEFAULT_WRITES_PER_MINUTE\n    36\t    writes_per_session: int = _DEFAULT_WRITES_PER_SESSION\n    37\t    enabled: bool = True\n    38\t\n    39\t\n    40\t@dataclass\n    41\tclass RateLimitResult:\n    42\t    \"\"\"Result of a rate limit check.\"\"\"\n    43\t\n    44\t    allowed: bool = True\n    45\t    minute_exceeded: bool = False\n    46\t    session_exceeded: bool = False\n    47\t    current_minute_count: int = 0\n    48\t    current_session_count: int = 0\n    49\t    message: str = \"\"\n    50\t\n    51\t\n    52\t@dataclass\n    53\tclass RateLimiterStats:\n    54\t    \"\"\"Accumulated anomaly statistics for health reporting.\"\"\"\n    55\t\n    56\t    minute_anomalies: int = 0\n    57\t    session_anomalies: int = 0\n    58\t    total_writes: int = 0\n    59\t    exempt_writes: int = 0\n    60\t\n    61\t\n    62\tclass SlidingWindowRateLimiter:\n    63\t    \"\"\"Sliding window rate limiter for memory writes.\n    64\t\n    65\t    Uses a deque-like list of timestamps for the per-minute window.\n    66\t    Thread-safe via ``threading.Lock``.\n    67\t\n    68\t    In warn-only mode (default), writes are never blocked — the limiter\n    69\t    logs warnings and tracks anomaly counts for ``memory_health()``.\n    70\t    \"\"\"\n    71\t\n    72\t    def __init__(self, config: RateLimiterConfig | None = None) -> None:\n    73\t        self._config = config or RateLimiterConfig()\n    74\t        self._lock = threading.Lock()\n    75\t        self._timestamps: list[float] = []\n    76\t        self._session_count: int = 0\n    77\t        self._stats = RateLimiterStats()\n    78\t\n    79\t    @property\n    80\t    def config(self) -> RateLimiterConfig:\n    81\t        \"\"\"Return the active configuration.\"\"\"\n    82\t        return self._config\n    83\t\n    84\t    @property\n    85\t    def stats(self) -> RateLimiterStats:\n    86\t        \"\"\"Return accumulated anomaly statistics.\"\"\"\n    87\t        with self._lock:\n    88\t            return RateLimiterStats(\n    89\t                minute_anomalies=self._stats.minute_anomalies,\n    90\t                session_anomalies=self._stats.session_anomalies,\n    91\t                total_writes=self._stats.total_writes,\n    92\t                exempt_writes=self._stats.exempt_writes,\n    93\t            )\n    94\t\n    95\t    def check(self, *, batch_context: str | None = None) -> RateLimitResult:\n    96\t        \"\"\"Check rate limits and record the write.\n    97\t\n    98\t        Args:\n    99\t            batch_context: If provided and in ``BATCH_EXEMPT_CONTEXTS``,\n   100\t                the write is exempt from rate limiting.\n   101\t\n   102\t        Returns:\n   103\t            ``RateLimitResult`` indicating whether limits were exceeded.\n   104\t            In warn-only mode, ``allowed`` is always ``True``.\n   105\t        \"\"\"\n   106\t        if not self._config.enabled:\n   107\t            return RateLimitResult()\n   108\t\n   109\t        # Batch context exemption (H6b)\n   110\t        if batch_context is not None and batch_context in BATCH_EXEMPT_CONTEXTS:\n   111\t            with self._lock:\n   112\t                self._stats.exempt_writes += 1\n   113\t                self._stats.total_writes += 1\n   114\t            return RateLimitResult()\n   115\t\n   116\t        now = time.monotonic()\n   117\t        window_start = now - 60.0\n   118\t\n   119\t        with self._lock:\n   120\t            # Prune timestamps older than 1 minute\n   121\t            self._timestamps = [t for t in self._timestamps if t > window_start]\n   122\t\n   123\t            # Record this write\n   124\t            self._timestamps.append(now)\n   125\t            self._session_count += 1\n   126\t            self._stats.total_writes += 1\n   127\t\n   128\t            minute_count = len(self._timestamps)\n   129\t            session_count = self._session_count\n   130\t\n   131\t            minute_exceeded = minute_count > self._config.writes_per_minute\n   132\t            session_exceeded = session_count > self._config.writes_per_session\n   133\t\n   134\t            if minute_exceeded:\n   135\t                self._stats.minute_anomalies += 1\n   136\t            if session_exceeded:\n   137\t                self._stats.session_anomalies += 1\n   138\t\n   139\t        # Build result\n   140\t        result = RateLimitResult(\n   141\t            allowed=True,  # Warn-only: never block\n   142\t            minute_exceeded=minute_exceeded,\n   143\t            session_exceeded=session_exceeded,\n   144\t            current_minute_count=minute_count,\n   145\t            current_session_count=session_count,\n   146\t        )\n   147\t\n   148\t        # Log warnings for exceeded limits\n   149\t        if minute_exceeded:\n   150\t            result.message = (\n   151\t                f\"Rate limit warning: {minute_count} writes in last minute \"\n   152\t                f\"(limit: {self._config.writes_per_minute})\"\n   153\t            )\n   154\t            logger.warning(\n   155\t                \"rate_limit_minute_exceeded\",\n   156\t                current=minute_count,\n   157\t                limit=self._config.writes_per_minute,\n   158\t            )\n   159\t\n   160\t        if session_exceeded:\n   161\t            msg = (\n   162\t                f\"Rate limit warning: {session_count} writes this session \"\n   163\t                f\"(limit: {self._config.writes_per_session})\"\n   164\t            )\n   165\t            if result.message:\n   166\t                result.message += f\"; {msg}\"\n   167\t            else:\n   168\t                result.message = msg\n   169\t            logger.warning(\n   170\t                \"rate_limit_session_exceeded\",\n   171\t                current=session_count,\n   172\t                limit=self._config.writes_per_session,\n   173\t            )\n   174\t\n   175\t        return result\n   176\t\n   177\t    def reset(self) -> None:\n   178\t        \"\"\"Reset all counters and timestamps (useful for testing).\"\"\"\n   179\t        with self._lock:\n   180\t            self._timestamps.clear()\n   181\t            self._session_count = 0\n   182\t            self._stats = RateLimiterStats()","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false,"tokenSaverOutput":"     1\t\"\"\"Sliding window rate limiter for memory write operations.\n     2\t\n     3\tProvides warn-only rate limiting to detect anomalous write bursts\n     4\twithout blocking legitimate operations. Configurable per-minute and\n     5\tper-session limits with batch context exemptions.\n     6\t\"\"\"\n     7\t\n     8\tfrom __future__ import annotations\n     9\t\n    10\timport threading\n    11\timport time\n    12\tfrom dataclasses import dataclass, field\n    13\t\n    14\timport structlog\n    15\t\n    16\tlogger = structlog.get_logger(__name__)\n    17\t\n    18\t# Default limits\n    19\t_DEFAULT_WRITES_PER_MINUTE = 20\n    20\t_DEFAULT_WRITES_PER_SESSION = 100\n    21\t\n    22\t# Batch contexts exempt from rate limiting (H6b)\n    23\tBATCH_EXEMPT_CONTEXTS: frozenset[str] = frozenset({\n    24\t    \"import_markdown\",\n    25\t    \"seed\",\n    26\t    \"federation_sync\",\n    27\t    \"consolidate\",\n    28\t})\n    29\t\n    30\t\n    31\t@dataclass\n    32\tclass RateLimiterConfig:\n    33\t    \"\"\"Configuration for the sliding window rate limiter.\"\"\"\n    34\t\n    35\t    writes_per_minute: int = _DEFAULT_WRITES_PER_MINUTE\n    36\t    writes_per_session: int = _DEFAULT_WRITES_PER_SESSION\n    37\t    enabled: bool = True\n    38\t\n    39\t\n    40\t@dataclass\n... 142 more lines (182 total - use Read tool for full file)"}}
