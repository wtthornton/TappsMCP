# TappsMCP environment variable reference
# Copy relevant vars to your shell profile, .env, or MCP server env block.

# ── Brain HTTP connection ─────────────────────────────────────────────────────
# URL of the tapps-brain HTTP service. Required when tapps-brain runs as a
# separate Docker service (recommended for production).
# TAPPS_MCP_MEMORY_BRAIN_HTTP_URL=http://localhost:8080

# Bearer token for authenticated brain calls. Must match the token configured
# in the brain container (TAPPS_MCP_AUTH_TOKEN).
# TAPPS_MCP_MEMORY_BRAIN_AUTH_TOKEN=your-secret-token

# ── Brain async-native writes (set on the BRAIN CONTAINER, not tapps-mcp) ────
# Setting either var in the brain container environment activates the async
# write backend in brain's http_adapter.py. There is no client-side toggle —
# DSN presence is the gate.
#
# TAPPS_BRAIN_DATABASE_URL=postgresql+asyncpg://brain:brain@localhost:5432/brain
# TAPPS_BRAIN_HIVE_DSN=postgresql+asyncpg://brain:brain@localhost:5432/hive
#
# Verify async-native is active: call tapps_session_start and check
# brain_bridge_health.async_native == true.
# See docs/operations/brain-deployment.md for the full deployment guide.

# ── tapps-mcp server ──────────────────────────────────────────────────────────
# TAPPS_MCP_PROJECT_ROOT=/path/to/your/project
# TAPPS_MCP_QUALITY_PRESET=standard
# TAPPS_MCP_LOG_LEVEL=INFO

# ── Brain pool tuning (optional) ─────────────────────────────────────────────
# TAPPS_BRAIN_PG_POOL_MAX_WAITING=10
# TAPPS_BRAIN_PG_POOL_MAX_LIFETIME_SECONDS=300
