# Operator-wide TappsMCP secrets — copy to ~/.tapps-operator.env (chmod 600).
# Same values for every consumer repo on this machine. Project .env holds repo-owned
# keys only (AgentForge, Reddit, etc.). See docs/operations/OPERATOR-SECRETS.md.

# Context7 — live library docs (tapps_lookup_docs). Get a key: https://context7.com
TAPPS_MCP_CONTEXT7_API_KEY=

# tapps-brain HTTP bearer (same token as brain docker/.env or tapps-brain token create)
TAPPS_BRAIN_AUTH_TOKEN=

# Brain endpoint (usually local shared brain)
TAPPS_MCP_MEMORY_BRAIN_HTTP_URL=http://localhost:8080
