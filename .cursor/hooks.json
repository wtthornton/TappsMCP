{
  "hooks": {
    "beforeMCPExecution": [
      {
        "command": ".cursor/hooks/tapps-before-mcp.sh"
      }
    ],
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/tapps-after-edit.sh"
      }
    ],
    "sessionStart": [
      {
        "command": ".cursor/hooks/tapps-mcp-zombie-cleanup.sh"
      },
      {
        "command": ".cursor/hooks/tapps-memory-auto-recall.sh"
      }
    ],
    "preCompact": [
      {
        "command": ".cursor/hooks/tapps-memory-auto-recall.sh"
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/tapps-stop.sh"
      }
    ]
  },
  "version": 1
}
