{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(uv *)",
      "Bash(git diff *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git commit *)",
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(sort *)",
      "Bash(ls *)",
      "Bash(python *)",
      "Bash(gh *)",
      "mcp__tapps-mcp__*",
      "mcp__docs-mcp__*",
      "mcp__tapps-mcp",
      "Bash(uv run ruff *)",
      "Bash(uv run mypy *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/__pycache__/**)",
      "Read(.venv/**)",
      "Read(**/*.egg-info/**)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "BASH_MAX_OUTPUT_LENGTH": "150000"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tapps-session-start.sh"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tapps-session-compact.sh"
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash .ralph/hooks/on-session-start.sh",
            "statusMessage": "Injecting Ralph loop context..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tapps-pre-tooluse.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .ralph/hooks/validate-command.sh",
            "statusMessage": "Validating command..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .ralph/hooks/protect-ralph-files.sh",
            "statusMessage": "Checking file protection..."
          }
        ]
      },
      {
        "matcher": "Edit\\",
        "hooks": [
          {
            "type": "command",
            "command": "Write",
            "statusMessage": "bash .ralph/hooks/protect-ralph-files.sh|Checking file protection..."
          }
        ]
      },
      {
        "matcher": "mcp__plugin_linear_linear__save_issue",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/tapps-pre-linear-write.sh"
          }
        ]
      },
      {
        "matcher": "mcp__plugin_linear_linear__list_issues",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/tapps-pre-linear-list.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tapps-post-edit.sh"
          }
        ]
      },
      {
        "matcher": "mcp__tapps-mcp__tapps_validate_changed|mcp__tapps-mcp__tapps_report",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tapps-stop.sh"
          }
        ]
      },
      {
        "matcher": "mcp__tapps-mcp__tapps_validate_changed",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tapps-post-validate.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "mcp__tapps-mcp__tapps_report",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tapps-post-report.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "if": "Edit(**/*.py) | Write(**/*.py) | MultiEdit(**/*.py)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/tapps-post-edit.sh"
          }
        ]
      },
      {
        "matcher": "mcp__docs-mcp__docs_validate_linear_issue",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/tapps-post-docs-validate.sh"
          }
        ]
      },
      {
        "matcher": "mcp__tapps-mcp__tapps_linear_snapshot_get",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/tapps-post-linear-snapshot-get.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tapps-stop.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tapps-memory-capture.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .ralph/hooks/on-stop.sh",
            "statusMessage": "Analyzing Ralph response..."
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tapps-task-completed.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .ralph/hooks/on-task-completed.sh",
            "statusMessage": "Validating task completion..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tapps-pre-compact.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tapps-subagent-start.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tapps-subagent-stop.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .ralph/hooks/on-subagent-done.sh"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .ralph/hooks/on-teammate-idle.sh",
            "statusMessage": "Checking teammate work queue..."
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "rate_limit\\",
        "hooks": [
          {
            "type": "command",
            "command": "server_error",
            "statusMessage": "bash .ralph/hooks/on-stop-failure.sh|Handling API error..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/tapps-user-prompt-submit.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/tapps-session-end.sh"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "mcp__tapps-mcp__.*",
        "if": "mcp__tapps-mcp__*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/tapps-tool-failure.sh"
          }
        ]
      }
    ]
  }
}
