{
  "// NOTE": "Copy this file to settings.local.json and customize for your dev environment",
  "// NOTE2": "settings.local.json is gitignored and overrides settings.json locally",

  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "mcp__tapps-mcp__*",
      "mcp__docs-mcp__*"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Read(.env)"
    ],
    "additionalDirectories": [
      "/path/to/other/projects"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "tapps-mcp",
    "docs-mcp"
  ],
  "defaultMode": "acceptEdits"
}
